---
const footerSections = [
  {
    title: 'Solutions',
    links: [
      { label: 'Certification', href: '/certification' },
      { label: 'SEAM Approved', href: '/approved' },
      { label: 'AP Credential', href: '/ap-credential' },
      { label: 'The Standard', href: '/resources/standard' },
      { label: 'Membership Community', href: '/community' },
      { label: 'Individual Membership', href: '/community/individual' },
      { label: 'Organization Membership', href: '/community/organization' },
    ],
  },
  {
    title: 'Rating Systems',
    links: [
      { label: 'Buildings + Interiors', href: '/rating-system/buildings-interiors' },
      { label: 'Operations + Maintenance', href: '/rating-system/operations-maintenance' },
    ],
  },
  {
    title: 'Pillars',
    links: [
      { label: 'Social Impact', href: '/standard/social-impact' },
      { label: 'Social Responsibility', href: '/standard/social-responsibility' },
      { label: 'Social Justice', href: '/standard/social-justice' },
      { label: 'Social Accountability', href: '/standard/social-accountability' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Social Equity 101', href: '/social-equity-101' },
      { label: 'The Standard', href: '/resources/standard' },
      { label: 'ROSSI Calculator', href: '/resources/rossi' },
      { label: 'Blog & Insights', href: '/resources/blog' },
      { label: 'Courses', href: '/resources/courses' },
    ],
  },
  {
    title: 'Who We Serve',
    links: [
      { label: 'Developers & Owners', href: '/for/developers-owners' },
      { label: 'Building Professionals', href: '/for/building-professionals' },
      { label: 'Property Managers', href: '/for/operators' },
      { label: 'Capital Providers', href: '/for/capital-providers' },
      { label: 'Impact Professionals', href: '/for/impact-professionals' },
      { label: 'People & Communities', href: '/for/people' },
    ],
  },
  {
    title: 'Directory',
    links: [
      { label: 'SEAM APs', href: '/directory?tab=aps' },
      { label: 'Certified Projects', href: '/directory?tab=projects' },
      { label: 'Approved Activities', href: '/directory?tab=activities' },
      { label: 'About SEAM', href: '/about' },
      { label: 'Talk to an Advisor', href: '/get-started' },
    ],
  },
]

const year = new Date().getFullYear()
---
<footer class="bg-warm-900 text-warm-300">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-3">
        <img src="/logos/seam-wordmark.png" alt="SEAM" class="h-8 w-auto" />
        <p class="mt-6 text-[17px] leading-relaxed text-warm-400 max-w-sm">
          Real estate has a human impact. SEAM exists to make that impact positive, for everyone connected to it.
        </p>

        <!-- Newsletter -->
        <div class="mt-8 pt-8 border-t border-warm-700/50"></div>
        <form id="footer-newsletter">
          <p class="text-[13px] font-medium uppercase tracking-[0.1em] text-warm-400 mb-3">Stay in the loop</p>
          <div class="flex gap-2">
            <input
              type="email"
              name="email"
              placeholder="Your email"
              required
              class="flex-1 min-w-0 rounded-full bg-warm-800 border border-warm-700 px-4 py-2.5 text-[14px] text-white placeholder-warm-500 focus:outline-none focus:border-seam-500 transition-colors"
            />
            <button
              type="submit"
              class="shrink-0 rounded-full bg-white px-5 py-2.5 text-[14px] font-medium text-warm-900 hover:bg-warm-100 transition-colors"
            >
              Subscribe
            </button>
          </div>
        </form>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/company/seam-inc/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-6 text-[14px] text-warm-400 hover:text-white transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Follow on LinkedIn
        </a>
      </div>

      <div class="lg:col-span-9 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 md:gap-8 lg:gap-10">
        {footerSections.map((section) => (
          <div>
            <h3 class="text-[13px] font-medium uppercase tracking-[0.1em] text-warm-400 mb-6">
              {section.title}
            </h3>
            <ul class="space-y-4">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-[15px] text-warm-400 hover:text-white transition-colors duration-300"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-20 pt-10 border-t border-warm-700/50 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[14px] text-warm-400">
        &copy; {year} SEAM, Inc. All rights reserved.
      </p>
      <div class="flex gap-8">
        <a href="/privacy" class="text-[14px] text-warm-400 hover:text-warm-300 transition-colors">
          Privacy
        </a>
        <a href="/terms" class="text-[14px] text-warm-400 hover:text-warm-300 transition-colors">
          Terms
        </a>
      </div>
    </div>
  </div>
</footer>
