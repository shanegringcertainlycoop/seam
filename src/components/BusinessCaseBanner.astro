---
interface Props {
  tag?: string
  title?: string
  summary?: string
  dark?: boolean
}

const {
  tag = 'The business case',
  title = 'Social equity drives financial performance.',
  summary = 'A decade of research from McKinsey, Gallup, CBRE, and GRESB confirms it — equitable organizations and certified buildings outperform their peers across every metric that matters.',
  dark = false,
} = Astro.props

const stats = [
  { value: '39%', label: 'more likely to outperform', detail: 'Diverse executive teams', source: 'McKinsey, 2023', logo: '/logos/mckinsey.svg' },
  { value: '4–8%', label: 'rent premium', detail: 'Certified buildings', source: 'CBRE, 2024', logo: '/logos/cbre.svg' },
  { value: '51%', label: 'lower turnover', detail: 'Inclusive workplaces', source: 'Gallup Q12', logo: '/logos/gallup.svg' },
  { value: '23%', label: 'risk reduction', detail: 'Certified asset portfolios', source: 'ROSSI Modeling', logo: '/logos/seam-wordmark.png' },
]
---

<section class={`py-24 lg:py-32 ${dark ? 'bg-warm-900' : ''}`}>
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">

    <div class="reveal-slide-left max-w-2xl mb-14 lg:mb-16">
      <p class={`text-[13px] font-medium uppercase tracking-[0.15em] mb-6 ${dark ? 'text-seam-400' : 'text-gold-600'}`}>
        {tag}
      </p>
      <h2 class={`font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] ${dark ? 'text-white' : 'text-warm-900'}`}>
        {title}
      </h2>
      <p class={`mt-6 text-[17px] leading-relaxed max-w-xl ${dark ? 'text-warm-400' : 'text-warm-600'}`}>
        {summary}
      </p>
    </div>

    <div class="reveal-stagger grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {stats.map((s) => (
        <div class={`reveal-child rounded-2xl p-8 ${dark ? 'bg-warm-800/50 border border-warm-700/40' : 'border border-warm-100'}`}>
          <img src={s.logo} alt="" class={`h-4 object-contain mb-3 ${dark ? 'opacity-40 brightness-200' : 'opacity-40 grayscale'}`} />
          <p class={`text-[13px] mb-1 ${dark ? 'text-warm-400' : 'text-warm-500'}`}>{s.detail}</p>
          <span class={`block font-display text-[clamp(2rem,4vw,3rem)] tracking-[-0.04em] leading-none ${dark ? 'text-seam-400' : 'text-seam-700'}`}>
            {s.value}
          </span>
          <p class={`mt-2 text-[15px] font-medium ${dark ? 'text-warm-200' : 'text-warm-800'}`}>{s.label}</p>
          <p class={`mt-3 text-[11px] uppercase tracking-[0.08em] ${dark ? 'text-warm-500' : 'text-warm-400'}`}>{s.source}</p>
        </div>
      ))}
    </div>

    <div class="reveal-fade-up">
      <a
        href="/resources/roi"
        class={`inline-flex items-center gap-2 rounded-full px-8 py-4 text-[16px] font-medium transition-colors duration-300 ${dark ? 'bg-white text-warm-900 hover:bg-warm-100' : 'bg-warm-900 text-white hover:bg-warm-800'}`}
      >
        See the full evidence
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
