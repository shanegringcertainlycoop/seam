---
/**
 * AP Credential Bundle limited-time offer popup.
 * Appears once per session after 20 seconds of browsing.
 * Dismissable — won't reappear after close (sessionStorage).
 */
---

<!-- Popup backdrop + modal -->
<div
  id="bundle-offer-popup"
  class="fixed inset-0 z-[9999] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
  role="dialog"
  aria-label="AP Credential Bundle limited-time offer"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-warm-900/60 backdrop-blur-sm" data-popup-backdrop></div>

  <!-- Modal -->
  <div class="relative w-full max-w-md rounded-2xl bg-white shadow-2xl shadow-warm-900/20 overflow-hidden transform scale-95 transition-transform duration-300" id="bundle-offer-modal">

    <!-- Close button -->
    <button
      data-popup-close
      class="absolute top-4 right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-warm-100 text-warm-500 hover:bg-warm-200 hover:text-warm-700 transition-colors"
      aria-label="Close offer"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Top accent bar -->
    <div class="h-1.5 bg-gradient-to-r from-seam-500 via-seam-600 to-gold-500"></div>

    <div class="p-8 lg:p-10">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full bg-amber-50 border border-amber-200 px-3 py-1.5 mb-6">
        <svg class="w-4 h-4 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="text-[13px] font-semibold text-amber-800">Code SITELAUNCH25 · ends May 31, 2026</span>
      </div>

      <!-- Heading -->
      <h3 class="font-display text-[clamp(1.5rem,3vw,1.75rem)] leading-[1.15] tracking-[-0.02em] text-warm-900 mb-3">
        AP Credential Bundle — <span class="text-seam-600">$389</span>
      </h3>

      <!-- Strike price -->
      <p class="text-[15px] text-warm-500 mb-6">
        <span class="line-through">$519</span> — use code <strong class="text-seam-700">SITELAUNCH25</strong> · ends May 31
      </p>

      <!-- What's included -->
      <ul class="space-y-3 mb-8">
        <li class="flex items-start gap-2.5 text-[14px] text-warm-600">
          <svg class="w-4 h-4 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Foundations course ($129 value)
        </li>
        <li class="flex items-start gap-2.5 text-[14px] text-warm-600">
          <svg class="w-4 h-4 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Proctored online examination
        </li>
        <li class="flex items-start gap-2.5 text-[14px] text-warm-600">
          <svg class="w-4 h-4 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Digital credential & seal
        </li>
        <li class="flex items-start gap-2.5 text-[14px] text-warm-600">
          <svg class="w-4 h-4 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          SEAM directory listing
        </li>
      </ul>

      <!-- CTA -->
      <a
        href="https://community.seamcertification.org/plans/1539142?bundle_token=a4239c7d9757838e8b3d7153035846d4&utm_source=manual"
        class="block w-full text-center rounded-full bg-seam-500 px-8 py-4 text-[16px] font-medium text-white hover:bg-seam-600 transition-colors duration-300"
      >
        Claim your bundle
      </a>

      <p class="mt-4 text-center text-[13px] text-warm-400">
        Or <a href="/ap-credential#pricing" class="underline hover:text-warm-600 transition-colors" data-popup-close>view full pricing details</a>
      </p>
    </div>
  </div>
</div>

<script>
  ;(function () {
    const STORAGE_KEY = 'seam_bundle_popup_dismissed'
    const DELAY_MS = 20000
    const popup = document.getElementById('bundle-offer-popup')
    const modal = document.getElementById('bundle-offer-modal')
    if (!popup || !modal) return

    // Don't show if already dismissed this session
    if (sessionStorage.getItem(STORAGE_KEY)) return

    // Don't show if already past the deadline
    const deadline = new Date('2026-06-01T00:00:00')
    if (new Date() >= deadline) return

    // Don't show on the AP credential page itself (user is already looking at it)
    if (window.location.pathname === '/ap-credential') return

    function open() {
      popup.classList.remove('opacity-0', 'pointer-events-none')
      popup.classList.add('opacity-100', 'pointer-events-auto')
      modal.classList.remove('scale-95')
      modal.classList.add('scale-100')
      popup.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    function close() {
      popup.classList.add('opacity-0', 'pointer-events-none')
      popup.classList.remove('opacity-100', 'pointer-events-auto')
      modal.classList.add('scale-95')
      modal.classList.remove('scale-100')
      popup.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
      sessionStorage.setItem(STORAGE_KEY, '1')
    }

    // Close handlers
    popup.querySelectorAll('[data-popup-close]').forEach(function (el) {
      el.addEventListener('click', close)
    })
    popup.querySelector('[data-popup-backdrop]')?.addEventListener('click', close)
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && popup.getAttribute('aria-hidden') === 'false') {
        close()
      }
    })

    // Trigger after delay
    setTimeout(open, DELAY_MS)
  })()
</script>
