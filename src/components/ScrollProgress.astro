---
// Thin progress bar pinned to the top of the viewport.
---
<div class="fixed top-0 left-0 right-0 z-[60] h-[3px] pointer-events-none">
  <div
    id="scroll-progress-bar"
    class="h-full bg-gradient-to-r from-gold-500 to-gold-400 transition-[width] duration-75 ease-linear"
    style="width: 0%"
  />
</div>

<script>
  function initScrollProgress() {
    const bar = document.getElementById('scroll-progress-bar')
    if (!bar) return

    function handleScroll() {
      const scrollTop = window.scrollY
      const docHeight = document.documentElement.scrollHeight - window.innerHeight
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0
      bar!.style.width = `${progress}%`
    }

    window.addEventListener('scroll', handleScroll, { passive: true })
  }

  document.addEventListener('astro:page-load', initScrollProgress)
  if (document.readyState !== 'loading') {
    initScrollProgress()
  } else {
    document.addEventListener('DOMContentLoaded', initScrollProgress)
  }
</script>
