---
import { accent } from './_accent'
const { eyebrow, heading, subheading, image, imagePath, sideLogos = [], pulse = false, ctas = [] } = Astro.props
// imagePath (a /public path) wins over an uploaded asset URL.
const bg = imagePath ?? image
const hasSide = Array.isArray(sideLogos) && sideLogos.length > 0
---
<section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
  {bg && (
    <div class="absolute inset-0">
      <img src={bg} alt="" class="h-full w-full object-cover object-center" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-br from-warm-900/85 via-warm-900/60 to-seam-900/70"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>
  )}
  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
    {hasSide ? (
      <div class="hero-enter grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-16 items-center">
        <div class="max-w-2xl">
          {eyebrow && (
            <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">{eyebrow}</span>
          )}
          <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.25rem)] leading-[1.05] tracking-[-0.04em] text-white" set:html={accent(heading, 'seam-300')} />
          {subheading && (
            <p class="hero-subtitle mt-8 max-w-2xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">{subheading}</p>
          )}
          {ctas.length > 0 && (
            <div class="hero-cta mt-10 flex flex-wrap gap-4">
              {ctas.map((c: any, i: number) => (
                c.style === 'primary' || (i === 0 && !c.style) ? (
                  <a href={c.href} class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">{c.label}</a>
                ) : (
                  <a href={c.href} class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">{c.label}</a>
                )
              ))}
            </div>
          )}
        </div>
        <div class="flex items-end justify-center mx-auto lg:mx-0 -space-x-10 sm:-space-x-14 lg:-space-x-16">
          {sideLogos.map((src: string, i: number) => (
            pulse && i === 0 ? (
              <div class="relative flex items-center justify-center">
                <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/40" style="animation-delay: 0s;"></div>
                <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/25" style="animation-delay: 1s;"></div>
                <div class="approved-ripple absolute inset-[-8px] rounded-full border border-seam-300/15" style="animation-delay: 0.5s;"></div>
                <div class="absolute inset-[-20px] rounded-full bg-gold-400/[0.06] approved-glow"></div>
                <img src={src} alt="" class="relative w-44 h-44 sm:w-52 sm:h-52 object-contain drop-shadow-2xl" loading="eager" decoding="async" />
              </div>
            ) : (
              <img src={src} alt="" class="w-36 h-36 sm:w-44 sm:h-44 lg:w-52 lg:h-52 object-contain drop-shadow-2xl" loading="eager" decoding="async" />
            )
          ))}
        </div>
      </div>
    ) : (
      <div class="max-w-4xl mx-auto text-center">
        {eyebrow && (
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">{eyebrow}</span>
        )}
        <h1 class="font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white" set:html={accent(heading, 'seam-300')} />
        {subheading && (
          <p class="mt-8 max-w-xl mx-auto text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">{subheading}</p>
        )}
        {ctas.length > 0 && (
          <div class="mt-10 flex flex-wrap gap-4 justify-center">
            {ctas.map((c: any, i: number) => (
              c.style === 'primary' || (i === 0 && !c.style) ? (
                <a href={c.href} class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">{c.label}</a>
              ) : (
                <a href={c.href} class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">{c.label}</a>
              )
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</section>
