---
import Hero from './Hero.astro'
import FeatureGrid from './FeatureGrid.astro'
import RichText from './RichText.astro'
import Faq from './Faq.astro'
import Cta from './Cta.astro'
import PainSolutionGrid from './PainSolutionGrid.astro'
import Testimonial from './Testimonial.astro'
import BusinessCaseBannerSection from './BusinessCaseBannerSection.astro'
import CertLevels from './CertLevels.astro'
import FocusAreas from './FocusAreas.astro'
import StandardActivities from './StandardActivities.astro'
import ComparisonTable from './ComparisonTable.astro'
import Embed from './Embed.astro'
import TeamGrid from './TeamGrid.astro'
import SealSteps from './SealSteps.astro'
import ImageText from './ImageText.astro'
import MarkActivities from './MarkActivities.astro'
import Steps from './Steps.astro'
import ImageBreak from './ImageBreak.astro'
import Pricing from './Pricing.astro'
import Pathway from './Pathway.astro'
import LogoWall from './LogoWall.astro'

const COMPONENTS: Record<string, any> = {
  heroSection: Hero,
  featureGridSection: FeatureGrid,
  richTextSection: RichText,
  faqSection: Faq,
  ctaSection: Cta,
  painSolutionGrid: PainSolutionGrid,
  testimonialSection: Testimonial,
  businessCaseBanner: BusinessCaseBannerSection,
  certLevelsSection: CertLevels,
  focusAreasSection: FocusAreas,
  standardActivitiesSection: StandardActivities,
  comparisonTableSection: ComparisonTable,
  embedSection: Embed,
  teamSection: TeamGrid,
  sealStepsSection: SealSteps,
  imageTextSection: ImageText,
  markActivitiesSection: MarkActivities,
  stepsSection: Steps,
  imageBreakSection: ImageBreak,
  pricingSection: Pricing,
  pathwaySection: Pathway,
  logoWallSection: LogoWall,
}

const { sections = [] } = Astro.props
---
{sections.map((section: any) => {
  const Component = COMPONENTS[section?._type]
  return Component ? <Component {...section} /> : null
})}
