---
import { toHTML } from '@portabletext/to-html'
import { accent } from './_accent'
const { heading, body } = Astro.props
const html = body
  ? toHTML(body, {
      components: {
        block: {
          normal: ({ children }: any) => `<p class="text-[17px] leading-[1.8] text-warm-600 mb-6">${children}</p>`,
          h2: ({ children }: any) => `<h2 class="font-display text-[28px] lg:text-[32px] tracking-[-0.02em] text-warm-900 mt-14 mb-6">${children}</h2>`,
          h3: ({ children }: any) => `<h3 class="font-display text-[22px] tracking-[-0.02em] text-warm-900 mt-10 mb-4">${children}</h3>`,
          blockquote: ({ children }: any) => `<blockquote class="border-l-2 border-seam-300 pl-6 my-8 text-[19px] italic text-warm-700">${children}</blockquote>`,
        },
        marks: {
          link: ({ children, value }: any) => `<a href="${value?.href}" class="text-seam-600 underline hover:text-seam-700"${value?.newTab ? ' target="_blank" rel="noopener noreferrer"' : ''}>${children}</a>`,
          strong: ({ children }: any) => `<strong class="font-medium text-warm-900">${children}</strong>`,
        },
        list: {
          bullet: ({ children }: any) => `<ul class="list-disc pl-6 mb-6 space-y-2 text-[17px] leading-relaxed text-warm-600">${children}</ul>`,
          number: ({ children }: any) => `<ol class="list-decimal pl-6 mb-6 space-y-2 text-[17px] leading-relaxed text-warm-600">${children}</ol>`,
        },
      },
    })
  : ''
---
<section class="py-20 lg:py-28">
  <div class="mx-auto max-w-3xl px-6 lg:px-10">
    {heading && <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-10" set:html={accent(heading, 'seam-600')} />}
    <div set:html={html} />
  </div>
</section>
