---
// Three-tier "where this fits" ladder (Marks → Seal → Certification). The
// `current` tier is highlighted with the seam border and a "You are here"
// badge; the others are links to their pages.
import { accent } from './_accent'
const { eyebrow, heading, intro, tiers = [] } = Astro.props
---
<section class="py-24 lg:py-32 bg-white">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    {(eyebrow || heading) && (
      <div class="max-w-2xl mb-16">
        {eyebrow && <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">{eyebrow}</p>}
        {heading && <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900" set:html={accent(heading, 'seam-600')} />}
        {intro && <p class="mt-6 text-[17px] leading-relaxed text-warm-600">{intro}</p>}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {tiers.map((t: any) => (
        t.current ? (
          <div class="rounded-2xl border-2 border-seam-500 bg-seam-50/40 p-8 lg:p-10 flex flex-col relative">
            <span class="absolute -top-3.5 left-8 inline-block rounded-full bg-seam-600 px-4 py-1 text-[12px] font-medium text-white tracking-wide uppercase">{t.badge ?? 'You are here'}</span>
            {t.step && <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-700 mb-4">{t.step}</p>}
            <h3 class="font-display text-[28px] tracking-[-0.02em] text-warm-900">{t.title}</h3>
            <p class="mt-3 text-[15px] leading-relaxed text-warm-700 flex-1">{t.body}</p>
            <span class="mt-6 inline-flex items-center text-[14px] font-medium text-seam-700">{t.linkLabel ?? t.badge ?? 'You are here'}</span>
          </div>
        ) : (
          <a href={t.href} class="group rounded-2xl border border-warm-200/60 bg-white p-8 lg:p-10 flex flex-col transition-all duration-300 hover:border-warm-300 hover:shadow-lg">
            {t.step && <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 mb-4">{t.step}</p>}
            <h3 class="font-display text-[28px] tracking-[-0.02em] text-warm-900">{t.title}</h3>
            <p class="mt-3 text-[15px] leading-relaxed text-warm-600 flex-1">{t.body}</p>
            <span class="mt-6 inline-flex items-center text-[14px] font-medium text-seam-600 group-hover:text-seam-700 transition-colors">{t.linkLabel ?? 'Learn more'} &rarr;</span>
          </a>
        )
      ))}
    </div>
  </div>
</section>
