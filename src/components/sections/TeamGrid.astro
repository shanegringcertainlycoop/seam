---
import { accent } from './_accent'
import { getTeam } from '../../lib/sanity'
const { eyebrow, heading, filter = 'all' } = Astro.props
const all = await getTeam()
const isBoard = (m: any) => m.role === 'Board Member' || (m.role ?? '').includes('Board')
const members = filter === 'board' ? all.filter(isBoard) : filter === 'staff' ? all.filter((m) => !isBoard(m)) : all
const blurb = (bio: string) => {
  const first = (bio ?? '').split('\n\n')[0] ?? ''
  return first.length > 180 ? first.slice(0, 177) + '…' : first
}
---
<section class="py-24 lg:py-32">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    {(eyebrow || heading) && (
      <div class="max-w-2xl mb-16 lg:mb-20">
        {eyebrow && <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">{eyebrow}</p>}
        {heading && <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900" set:html={accent(heading, 'seam-600')} />}
      </div>
    )}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {members.map((m: any) => (
        <a href={`/directory/team/${m.slug}`} class="group block">
          {m.image && (
            <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-warm-100 mb-5">
              <img src={m.image} alt={m.name} style={`object-position:${m.imagePosition ?? 'top'}`} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" decoding="async" />
            </div>
          )}
          <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 group-hover:text-seam-700 transition-colors">{m.name}</h3>
          <p class="text-[14px] font-medium text-gold-600 mt-1">{m.role}</p>
          <p class="text-[15px] leading-relaxed text-warm-600 mt-3">{blurb(m.bio)}</p>
        </a>
      ))}
    </div>
  </div>
</section>
