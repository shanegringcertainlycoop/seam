---
import { getSeamAPs, getCertifiedProjects, getMemberOrgs } from '../lib/sanity'

const [seamAPs, certifiedProjects, memberOrgs] = await Promise.all([
  getSeamAPs(),
  getCertifiedProjects(),
  getMemberOrgs(),
])

interface NavLink {
  label: string
  href: string
  description: string
  logo?: string
  logos?: string[]
  external?: boolean
  children?: Array<{ label: string; href: string; external?: boolean; code?: string }>
}

/* Stroke-based pillar glyphs sourced from the digital standard's
 * PillarGlyph component. Keyed by pillar slug. */
const PILLAR_GLYPHS: Record<string, string> = {
  'social-impact': '<path d="M3 18h18M5 18V9a7 7 0 0 1 14 0v9M9 18v-6M15 18v-6"/>',
  'social-responsibility': '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  'social-justice': '<path d="M12 4v17M8 21h8M5 7h14M6 7l-3 5h6L6 7zM18 7l-3 5h6l-3-5z"/>',
  'social-accountability': '<path d="M9 18h6M10 21h4M8.5 14a5 5 0 1 1 7 0c-.7.6-1.5 1.5-1.5 3v1h-4v-1c0-1.5-.8-2.4-1.5-3z"/>',
}

/* Concept badge background colors, matching the digital standard's
 * ConceptBadge component. */
const CONCEPT_COLORS: Record<string, string> = {
  IA: 'bg-seam-700',
  TG: 'bg-gold-500',
  CI: 'bg-warm-700',
  SI: 'bg-black',
  SJ: 'bg-amber-600',
  IN: 'bg-emerald-700',
  HR: 'bg-rose-700',
  HS: 'bg-sky-700',
}

function pillarSlug(href: string): string {
  // e.g. '/standard/social-impact' → 'social-impact'
  const parts = href.split('/').filter(Boolean)
  return parts[parts.length - 1]
}

interface NavSection {
  heading: string
  href?: string
  links: NavLink[]
}

interface ProgressionStep {
  step: string
  label: string
  href: string
  tagline: string
  description: string
  accent: 'soft' | 'core' | 'deep'
}

interface NavGroup {
  label: string
  links: NavLink[]
  featured?: { label: string; href: string; description: string }
  progression?: ProgressionStep[]
  sections?: NavSection[]
  quickLinks?: Array<{ label: string; href: string; external?: boolean }>
}

const takeAction: NavGroup = {
  label: 'Take Action',
  links: [],
  progression: [
    {
      step: '',
      label: 'SEAM Marks',
      href: '/marks',
      tagline: 'Verify one practice',
      description: 'The simplest way to show a single human-impact practice is independently verified.',
      accent: 'soft',
    },
    {
      step: '',
      label: 'SEAM Seal',
      href: '/seals',
      tagline: 'Lead a full focus area',
      description: 'Bundle related verified practices into one recognizable badge of leadership.',
      accent: 'core',
    },
    {
      step: '',
      label: 'SEAM Certification',
      href: '/certification',
      tagline: 'Recognize the whole project',
      description: "Project-wide recognition across all four pillars, awarded at four levels based on how far the project goes.",
      accent: 'deep',
    },
  ],
  quickLinks: [
    { label: 'Compare actions', href: '/compare' },
    { label: 'Pricing', href: '/pricing' },
    { label: 'Talk to an Advisor', href: '/get-started' },
  ],
}

const network: NavGroup = {
  label: 'Network',
  links: [],
  quickLinks: [
    { label: 'Membership Overview', href: '/membership' },
    { label: 'Directory', href: '/directory' },
    { label: 'Talk to an Advisor', href: '/get-started' },
  ],
  sections: [
    {
      heading: 'For Professionals',
      links: [
        {
          label: 'AP Credential',
          href: '/ap-credential',
          description: 'Become the expert organizations call to get this right.',
          logo: '/logos/ap-seal.png',
        },
        {
          label: 'Individual Membership',
          href: '/membership/individual',
          description: 'Your career in social equity starts here. Free and paid tiers.',
          logos: ['/logos/member-individual.png', '/logos/member-changemaker.png'],
        },
      ],
    },
    {
      heading: 'For Organizations',
      links: [
        {
          label: 'Organization Membership',
          href: '/membership/organization',
          description: 'Give your team the tools, network, and recognition to lead.',
          logos: ['/logos/member-standing.png', '/logos/member-ladder.png', '/logos/member-arc.png'],
        },
      ],
    },
  ],
}

const STANDARD_BASE = 'https://standard.seamcertification.org'

const theStandard: NavGroup = {
  label: 'The Standard',
  links: [],
  featured: {
    label: 'SEAM Standard v.1',
    href: '/resources/standard',
    description: 'The playbook for social equity in buildings. Free to download.',
  },
  sections: [
    {
      heading: 'Pillars + Concepts',
      links: [
        {
          label: 'Social Impact',
          href: '/standard/social-impact',
          description: 'Know who your project affects — and whether it is working.',
          children: [
            { label: 'Impact Assessment', href: `${STANDARD_BASE}/social-impact/impact-assessment`, external: true, code: 'IA' },
          ],
        },
        {
          label: 'Social Responsibility',
          href: '/standard/social-responsibility',
          description: 'Walk the talk on governance, community, and investment.',
          children: [
            { label: 'Transformational Governance', href: `${STANDARD_BASE}/social-responsibility/transformational-governance`, external: true, code: 'TG' },
            { label: 'Community Involvement', href: `${STANDARD_BASE}/social-responsibility/community-involvement`, external: true, code: 'CI' },
            { label: 'Social Investment', href: `${STANDARD_BASE}/social-responsibility/social-investment`, external: true, code: 'SI' },
          ],
        },
        {
          label: 'Social Justice',
          href: '/standard/social-justice',
          description: 'Equity across procurement, the workplace, and capital access.',
          children: [
            { label: 'Social Equity + Justice', href: `${STANDARD_BASE}/social-justice/social-equity-justice`, external: true, code: 'SJ' },
            { label: 'Social Justice Innovation', href: `${STANDARD_BASE}/social-justice/social-justice-innovation`, external: true, code: 'IN' },
          ],
        },
        {
          label: 'Social Accountability',
          href: '/standard/social-accountability',
          description: 'Human rights, ethical sourcing, and worker well-being.',
          children: [
            { label: 'Human Rights', href: `${STANDARD_BASE}/social-accountability/human-rights`, external: true, code: 'HR' },
            { label: 'Health + Safety', href: `${STANDARD_BASE}/social-accountability/health-safety`, external: true, code: 'HS' },
          ],
        },
      ],
    },
  ],
  quickLinks: [
    { label: 'Browse the digital Standard', href: STANDARD_BASE, external: true },
    { label: 'Glossary', href: `${STANDARD_BASE}/glossary`, external: true },
    { label: 'Bibliography', href: `${STANDARD_BASE}/bibliography`, external: true },
    { label: 'Appendices', href: `${STANDARD_BASE}/appendix`, external: true },
  ],
}

const latestArticle = {
  title: 'What Is AP Certification? And Why Does Social Equity in Real Estate Need One?',
  href: '/resources/blog/seam-ap-credential-built-for-social-equity',
  image: '/images/blog/seam-ap-credential.webp',
  category: 'The Standard',
}

const resources: NavGroup = {
  label: 'Resources',
  links: [],
  sections: [
    {
      heading: 'Learn',
      links: [
        { label: 'Social Equity 101', href: '/social-equity-101', description: 'What buildings owe the people they touch.' },
        { label: 'ROI of Social Equity', href: '/resources/roi', description: 'The financial case, backed by research.' },
        { label: 'Courses & Webinars', href: '/resources/courses', description: 'Self-paced learning and live sessions.' },
        { label: 'Blog & Insights', href: '/resources/blog', description: 'Stories from the field.' },
        // { label: 'Integrations', href: '/resources/integrations', description: 'LEED, WELL, Fitwel, and the UN SDGs.' },
        { label: 'FAQ', href: '/faq', description: 'Common questions, answered.' },
      ],
    },
    {
      heading: 'Tools & More',
      links: [
        { label: 'ROSSI Calculator', href: '/resources/rossi', description: 'Quantify your social equity ROI.' },
        { label: 'LEED Crosswalk', href: '/resources/leed-crosswalk', description: 'Map SEAM activities to LEED credits.' },
        { label: 'Pathways', href: '/pathways', description: 'Seven ways to engage — find your entry point.' },
        { label: 'About SEAM', href: '/about', description: 'Our mission and team.' },
        { label: 'Shop', href: 'https://seamstore.org/', description: 'Gear and merch.', external: true },
      ],
    },
  ],
}

const audiences: NavGroup = {
  label: 'Who SEAM Is For',
  links: [
    { label: 'Developers & Owners', href: '/for/developers-owners', description: 'Reduce turnover, attract mission-aligned capital, and differentiate your asset in the market.' },
    { label: 'Building Professionals', href: '/for/building-professionals', description: 'Architects, interior designers, contractors, and engineers shaping equitable spaces.' },
    { label: 'Property Managers & Facility Teams', href: '/for/operators', description: 'Turn the equity work you already do into a verified credential that strengthens renewals.' },
    { label: 'Capital Providers & Compliance', href: '/for/capital-providers', description: 'A diligence signal for social risk. GRESB-aligned data, international compliance-ready.' },
    { label: 'Social Impact Professionals', href: '/for/impact-professionals', description: 'Earn the AP credential, join a practitioner network, and build a practice around the Standard.' },
    { label: 'People & Communities', href: '/for/people', description: 'Choose buildings that reflect your values — health, equity, and inclusion verified.' },
  ],
}

// Directory images for nav
const apPhotos = seamAPs.filter((a) => a.photo).map((a) => a.photo)
const projectImages = certifiedProjects.filter((p) => p.image).map((p) => ({ image: p.image, name: p.name }))
const orgLogos = memberOrgs.filter((o) => o.logo).map((o) => ({ src: o.logo, name: o.name }))

const directory: NavGroup = {
  label: 'Directory',
  links: [],
  quickLinks: [
    { label: 'SEAM APs', href: '/directory?tab=professionals' },
    { label: 'Projects', href: '/directory?tab=projects' },
    { label: 'Members', href: '/directory?tab=members' },
  ],
}

const dropdowns = [takeAction, network, theStandard, directory, resources]

function logoClass(_logo: string) {
  return 'w-11 h-11'
}
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-warm-900/10 backdrop-blur-[2px]"
>
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <div class="flex h-[88px] items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img
          id="nav-logo"
          src="/logos/seam-wordmark-white.svg"
          data-src-light="/logos/seam-wordmark.svg"
          data-src-dark="/logos/seam-wordmark-white.svg"
          alt="SEAM"
          decoding="async"
          class="h-8 w-auto transition-all duration-300"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-10">
        {dropdowns.map((group, idx) => (
          <div class="relative" data-dropdown={idx}>
            <button
              class="nav-text-link inline-flex items-center text-[15px] transition-colors duration-300 text-white/80 hover:text-white"
              aria-expanded="false"
              data-dropdown-trigger={idx}
            >
              {group.label}
              <svg
                class="ml-1 h-3.5 w-3.5 transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={2}
                stroke="currentColor"
                data-dropdown-chevron={idx}
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>

            <!-- Dropdown panel -->
            <div
              class={`absolute top-full pt-4 hidden ${group.label === 'Resources' ? 'right-0' : 'left-1/2 -translate-x-1/2'}`}
              data-dropdown-panel={idx}
            >
              {group.label === 'Directory' ? (
                <div class="rounded-2xl border border-warm-100 bg-white shadow-[0_24px_60px_rgba(0,0,0,0.08)] w-[680px] overflow-hidden">
                  {/* Visual hero */}
                  <div class="relative bg-gradient-to-br from-warm-900 via-warm-900 to-seam-900 px-8 py-7 overflow-hidden">
                    <div class="flex items-center justify-between gap-6">
                      <div>
                        <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-gold-400 mb-3">Directory</p>
                        <p class="font-display text-[22px] leading-[1.1] tracking-[-0.02em] text-white">The SEAM ecosystem</p>
                        <p class="mt-2 text-[13px] leading-relaxed text-warm-300 max-w-[280px]">
                          Professionals, certified projects, and organizations advancing social equity.
                        </p>
                        <a href="/directory" class="inline-flex items-center mt-4 rounded-full bg-white px-4 py-2 text-[13px] font-medium text-warm-900 hover:bg-warm-100 transition-colors">
                          Browse the directory
                        </a>
                      </div>
                      <div class="flex flex-col items-end gap-3 shrink-0">
                        <div class="flex -space-x-2.5">
                          {apPhotos.slice(0, 8).map((src) => (
                            <div class="w-9 h-9 rounded-full bg-warm-700 border-2 border-warm-900 overflow-hidden">
                              <img src={src} alt="" loading="lazy" decoding="async" width="36" height="36" class="w-full h-full object-cover object-top" />
                            </div>
                          ))}
                          {apPhotos.length > 8 && (
                            <div class="w-9 h-9 rounded-full bg-warm-700/60 border-2 border-warm-900 flex items-center justify-center text-[10px] font-medium text-white">
                              +{apPhotos.length - 8}
                            </div>
                          )}
                        </div>
                        <div class="flex gap-2">
                          {projectImages.slice(0, 3).map((p) => (
                            <div class="w-[72px] h-12 rounded-lg overflow-hidden bg-warm-700">
                              <img src={p.image} alt={p.name} loading="lazy" decoding="async" width="72" height="48" class="w-full h-full object-cover opacity-90" />
                            </div>
                          ))}
                        </div>
                        <div class="flex items-center gap-3">
                          {orgLogos.slice(0, 6).map((o) => (
                            <img src={o.src} alt={o.name} loading="lazy" decoding="async" class="h-5 w-auto object-contain grayscale invert mix-blend-screen opacity-60" />
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                  {/* Category links */}
                  <div class="grid grid-cols-3 divide-x divide-warm-100">
                    <a href="/directory?tab=professionals" class="group/item p-5 hover:bg-warm-50 transition-colors">
                      <p class="text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600 transition-colors">Find SEAM APs</p>
                    </a>
                    <a href="/directory?tab=projects" class="group/item p-5 hover:bg-warm-50 transition-colors">
                      <p class="text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600 transition-colors">Find SEAM projects</p>
                    </a>
                    <a href="/directory?tab=members" class="group/item p-5 hover:bg-warm-50 transition-colors">
                      <p class="text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600 transition-colors">Find SEAM members</p>
                    </a>
                  </div>
                </div>
              ) : group.label === 'Take Action' && group.progression ? (
                <div class="rounded-2xl border border-warm-100 bg-white shadow-[0_24px_60px_rgba(0,0,0,0.08)] w-[960px] overflow-hidden">
                  {/* Progression hero */}
                  <div class="relative bg-gradient-to-br from-warm-900 via-warm-900 to-seam-900 px-8 py-7">
                    <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-gold-400 mb-2">Take Action</p>
                    <p class="font-display text-[22px] leading-[1.15] tracking-[-0.02em] text-white mb-6">
                      Verify your human-impact progress.
                    </p>
                    <div class="flex items-stretch gap-3">
                      {group.progression.map((step, i) => (
                        <>
                          <a
                            href={step.href}
                            class={`group/step relative flex-1 rounded-xl p-5 transition-all duration-200 border ${
                              step.accent === 'deep'
                                ? 'bg-gold-400/10 border-gold-400/40 hover:bg-gold-400/15'
                                : step.accent === 'core'
                                ? 'bg-seam-500/15 border-seam-400/40 hover:bg-seam-500/20'
                                : 'bg-white/[0.06] border-white/15 hover:bg-white/[0.1]'
                            }`}
                          >
                            <div class="flex items-start justify-end gap-2 mb-3">
                              {step.label === 'SEAM Marks' && (
                                <img src="/logos/mark-activity.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" class="h-8 w-auto object-contain opacity-90" />
                              )}
                              {step.label === 'SEAM Seal' && (
                                <div class="flex items-center -space-x-2">
                                  <img src="/logos/seal-ethical-procurement.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" class="w-8 h-auto drop-shadow" />
                                  <img src="/logos/seal-community-development.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" class="w-8 h-auto drop-shadow" />
                                </div>
                              )}
                              {step.label === 'SEAM Certification' && (
                                <div class="flex items-center -space-x-2">
                                  <img src="/logos/cert-bronze.png" alt="" aria-hidden="true" loading="lazy" decoding="async" class="w-7 h-7 object-contain" />
                                  <img src="/logos/cert-silver.png" alt="" aria-hidden="true" loading="lazy" decoding="async" class="w-7 h-7 object-contain" />
                                  <img src="/logos/cert-gold.png" alt="" aria-hidden="true" loading="lazy" decoding="async" class="w-7 h-7 object-contain" />
                                  <img src="/logos/cert-platinum.png" alt="" aria-hidden="true" loading="lazy" decoding="async" class="w-7 h-7 object-contain" />
                                </div>
                              )}
                            </div>
                            <p class="font-display text-[18px] leading-[1.15] tracking-[-0.02em] text-white mb-1">{step.label}</p>
                            <p class={`text-[11px] ${step.description ? 'mb-3' : ''} ${
                              step.accent === 'deep' ? 'text-gold-200' : step.accent === 'core' ? 'text-seam-200' : 'text-warm-300'
                            }`}>{step.tagline}</p>
                            {step.description && (
                              <p class="text-[12px] leading-snug text-warm-300">{step.description}</p>
                            )}
                            <span class="mt-3 inline-flex items-center text-[12px] font-medium text-white/80 group-hover/step:text-white transition-colors">
                              Learn more &rarr;
                            </span>
                          </a>
                          {i < group.progression!.length - 1 && (
                            <div class="flex items-center text-warm-500 shrink-0" aria-hidden="true">
                              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                              </svg>
                            </div>
                          )}
                        </>
                      ))}
                    </div>
                  </div>
                  {/* Quicklinks bar */}
                  {group.quickLinks && (
                    <div class="flex items-center gap-4 px-6 py-3 bg-warm-900 border-t border-warm-800">
                      {group.quickLinks.map((ql, i) => (
                        <>
                          {i > 0 && <span class="text-warm-600">·</span>}
                          <a
                            href={ql.href}
                            class="text-[13px] font-medium text-warm-400 hover:text-white transition-colors"
                          >
                            {ql.label}
                          </a>
                        </>
                      ))}
                    </div>
                  )}
                </div>
              ) : group.sections?.length ? (
                <div class={`rounded-2xl border border-warm-100 bg-white shadow-[0_24px_60px_rgba(0,0,0,0.08)] ${group.label === 'The Standard' ? 'w-[720px]' : group.label === 'Network' ? 'w-[760px]' : group.label === 'Resources' ? 'w-[1060px]' : 'w-[760px]'} overflow-hidden`}>
                  {/* Standard featured hero at top */}
                  {group.label === 'The Standard' && group.featured && (
                    <div class="relative grid grid-cols-[1fr_300px] items-stretch bg-gradient-to-br from-warm-900 via-warm-900 to-seam-900 px-8 py-7 border-b border-warm-100 overflow-hidden">
                      <div class="flex flex-col justify-between py-1">
                        <div>
                          <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-gold-400 mb-3">
                            Featured
                          </p>
                          <p class="font-display text-[28px] leading-[1.1] tracking-[-0.02em] text-white">
                            {group.featured.label}
                          </p>
                          <p class="mt-3 text-[13px] leading-relaxed text-warm-300 max-w-[320px]">
                            The complete social equity framework for the built environment. Free and open.
                          </p>
                        </div>
                        <div class="mt-5 flex flex-wrap items-center gap-2">
                          <a
                            href={group.featured.href}
                            class="inline-flex items-center rounded-full bg-white px-4 py-2 text-[13px] font-medium text-warm-900 hover:bg-warm-100 transition-colors"
                          >
                            Learn more
                          </a>
                          <a
                            href="/resources/standard#download"
                            class="inline-flex items-center rounded-full border border-white/30 px-4 py-2 text-[13px] font-medium text-white hover:border-white/60 hover:bg-white/[0.06] transition-colors"
                          >
                            Download
                          </a>
                        </div>
                      </div>
                      {/* Standard book cover */}
                      <div class="absolute -right-8 -top-4 -bottom-4 w-[320px] overflow-hidden">
                        <img
                          src="/images/seam-standard-book.webp"
                          alt="The SEAM Standard book cover"
                          width="280"
                          height="303"
                          loading="lazy"
                          decoding="async"
                          class="absolute right-2 top-1/2 -translate-y-[45%] h-[280px] w-auto drop-shadow-[0_16px_32px_rgba(0,0,0,0.4)] rotate-[12deg]"
                        />
                      </div>
                    </div>
                  )}
                  {group.label === 'The Standard' ? (
                    <div class="grid grid-cols-2 gap-x-4 p-4">
                      {group.sections[0].links.map((p) => (
                        <div class="py-2">
                          <a
                            href={p.href}
                            class="group/pillar flex items-start gap-3 rounded-xl px-3 py-2.5 transition-colors duration-150 hover:bg-warm-50"
                          >
                            <span class="shrink-0 mt-0.5 text-seam-700 group-hover/pillar:text-gold-600 transition-colors">
                              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={PILLAR_GLYPHS[pillarSlug(p.href)] ?? ''} />
                            </span>
                            <span>
                              <span class="block text-[15px] font-medium text-warm-900 group-hover/pillar:text-gold-600 transition-colors">
                                {p.label}
                              </span>
                              <span class="block mt-0.5 text-[12.5px] leading-snug text-warm-400">
                                {p.description}
                              </span>
                            </span>
                          </a>
                          {(p.children ?? []).length > 0 && (
                            <ul class="ml-[40px] mt-1 mb-1 space-y-0.5">
                              {(p.children ?? []).map((c) => (
                                <li>
                                  <a
                                    href={c.href}
                                    {...(c.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                                    class="group/concept flex items-center gap-2.5 rounded-lg px-3 py-1.5 transition-colors duration-150 hover:bg-warm-50"
                                  >
                                    {c.code && (
                                      <span class={`inline-flex shrink-0 items-center justify-center rounded-full font-mono font-semibold uppercase text-white h-5 w-5 text-[9px] ${CONCEPT_COLORS[c.code] ?? 'bg-warm-500'}`}>
                                        {c.code}
                                      </span>
                                    )}
                                    <span class="flex-1 text-[13.5px] text-warm-700 group-hover/concept:text-warm-900 transition-colors">
                                      {c.label}
                                    </span>
                                  </a>
                                </li>
                              ))}
                            </ul>
                          )}
                        </div>
                      ))}
                    </div>
                  ) : (
                  <div class={`grid ${group.label === 'Resources' ? 'grid-cols-[300px_1fr_1fr]' : 'grid-cols-2'} divide-x divide-warm-100`}>
                    {/* Resources: latest article in first column */}
                    {group.label === 'Resources' && (
                      <a href={latestArticle.href} class="group/article bg-warm-50 p-6 flex flex-col">
                        <p class="px-0 pb-3 text-[11px] font-medium uppercase tracking-[0.15em] text-gold-600">Latest article</p>
                        <div class="rounded-lg overflow-hidden mb-4">
                          <img src={latestArticle.image} alt={latestArticle.title} loading="lazy" decoding="async" width="300" height="188" class="w-full aspect-[16/10] object-cover transition-transform duration-500 group-hover/article:scale-105" />
                        </div>
                        <p class="text-[14px] font-medium leading-snug text-warm-900 group-hover/article:text-gold-600 transition-colors line-clamp-3">{latestArticle.title}</p>
                        <span class="inline-flex items-center mt-auto pt-3 text-[12px] font-medium text-seam-600">Read article &rarr;</span>
                      </a>
                    )}
                    {group.sections.map((section) => (
                      <div class="p-6 space-y-1">
                        {section.href ? (
                          <a
                            href={section.href}
                            class="block px-3 pb-2 text-[11px] font-medium uppercase tracking-[0.15em] text-warm-400 hover:text-gold-600 transition-colors"
                          >
                            {section.heading} &rarr;
                          </a>
                        ) : (
                          <p class="px-3 pb-2 text-[11px] font-medium uppercase tracking-[0.15em] text-warm-400">
                            {section.heading}
                          </p>
                        )}
                        {section.links.map((link) => (
                          <div>
                            <a
                              href={link.href}
                              class="group/item flex items-center gap-4 rounded-xl px-3 py-3 transition-colors duration-150 hover:bg-warm-50"
                            >
                              {link.logos ? (
                                <div class="flex items-center shrink-0 -space-x-3">
                                  {link.logos.map((src) => (
                                    <img
                                      src={src}
                                      alt={link.label}
                                      loading="lazy"
                                      decoding="async"
                                      width="40"
                                      height="40"
                                      class="w-10 h-10 object-contain drop-shadow-sm"
                                    />
                                  ))}
                                </div>
                              ) : link.logo ? (
                                <img
                                  src={link.logo}
                                  alt={link.label}
                                  width="44"
                                  height="44"
                                  loading="lazy"
                                  decoding="async"
                                  class={`object-contain shrink-0 ${logoClass(link.logo)}`}
                                />
                              ) : null}
                              <div>
                                <span class="block text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600">
                                  {link.label}
                                </span>
                                <span class="block mt-0.5 text-[13px] leading-snug text-warm-400">
                                  {link.description}
                                </span>
                              </div>
                            </a>
                            {link.children && link.children.length > 0 && (
                              <ul class="ml-[64px] mt-0.5 mb-1 space-y-0.5">
                                {link.children.map((child) => (
                                  <li>
                                    <a
                                      href={child.href}
                                      {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                                      class="inline-flex items-center gap-1 rounded px-3 py-1 text-[12.5px] text-warm-500 hover:text-gold-600 transition-colors"
                                    >
                                      {child.label}
                                      {child.external && (
                                        <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                        </svg>
                                      )}
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </div>
                        ))}
                      </div>
                    ))}
                  </div>
                  )}
                  {/* Bottom quick-links bar */}
                  {group.quickLinks && (
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 px-6 py-3 bg-warm-900 rounded-b-2xl">
                      {group.quickLinks.map((ql, i) => (
                        <>
                          {i > 0 && <span class="text-warm-600" aria-hidden="true">·</span>}
                          <a
                            href={ql.href}
                            {...(ql.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                            class="inline-flex items-center gap-1 text-[13px] font-medium text-warm-400 hover:text-white transition-colors"
                          >
                            {ql.label}
                            {ql.external && (
                              <svg class="w-3 h-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                              </svg>
                            )}
                          </a>
                        </>
                      ))}
                    </div>
                  )}
                </div>
              ) : (
                <div class={`rounded-2xl border border-warm-100 bg-white shadow-[0_24px_60px_rgba(0,0,0,0.08)] ${group.featured ? 'w-[640px]' : 'w-[480px]'}`}>
                  <div class={group.featured ? 'grid grid-cols-5' : ''}>
                    <div class={`p-6 space-y-1 ${group.featured ? 'col-span-3' : ''}`}>
                      <p class="px-3 pb-2 text-[11px] font-medium uppercase tracking-[0.15em] text-warm-400">
                        {group.label}
                      </p>
                      {group.links.map((link) => (
                        <a
                          href={link.href}
                          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                          class="group/item flex items-center gap-4 rounded-xl px-3 py-3 transition-colors duration-150 hover:bg-warm-50"
                        >
                          {link.logo && (
                            <img
                              src={link.logo}
                              alt={link.label}
                              loading="lazy"
                              decoding="async"
                              width="40"
                              height="40"
                              class="w-10 h-10 object-contain shrink-0"
                            />
                          )}
                          <div>
                            <span class="block text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600">
                              {link.label}
                              {link.external && (
                                <svg class="inline-block w-3 h-3 ml-1 text-warm-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                </svg>
                              )}
                            </span>
                            <span class="block mt-0.5 text-[13px] leading-snug text-warm-400">
                              {link.description}
                            </span>
                          </div>
                        </a>
                      ))}
                    </div>
                    {group.featured && (
                      <div class="col-span-2 rounded-r-2xl bg-warm-50 p-6 flex flex-col justify-end">
                        <a href={group.featured.href} class="group/feat block">
                          <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-2">Featured</p>
                          <p class="text-[15px] font-medium text-warm-900 group-hover/feat:text-gold-600 transition-colors">
                            {group.featured.label}
                          </p>
                          <p class="mt-1 text-[13px] leading-snug text-warm-400">
                            {group.featured.description}
                          </p>
                          <span class="inline-block mt-3 text-[13px] font-medium text-gold-600">Learn more &rarr;</span>
                        </a>
                      </div>
                    )}
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}

        <a
          href="/get-started"
          id="nav-cta"
          class="ml-4 inline-flex items-center rounded-full px-6 py-3 text-[15px] font-medium transition-colors duration-300 bg-white text-warm-900 hover:bg-white/90"
        >
          Talk to an Advisor
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-toggle"
        class="lg:hidden p-2 transition-colors duration-300 text-white"
        aria-label="Toggle menu"
      >
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width={1.5} stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke-width={1.5} stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden bg-white border-t border-warm-100 hidden">
    <div class="px-6 py-4">
      {dropdowns.map((group, idx) => (
        <div class="border-b border-warm-100 last:border-b-0" data-mobile-accordion={idx}>
          <button
            class="flex w-full items-center justify-between py-4 text-[17px] font-medium text-warm-700"
            data-mobile-trigger={idx}
          >
            {group.label}
            <svg
              class="ml-1 h-3.5 w-3.5 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width={2}
              stroke="currentColor"
              data-mobile-chevron={idx}
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div class="pb-4 pl-2 space-y-1 hidden" data-mobile-content={idx}>
            {group.label === 'Directory' ? (
              <>
                <a href="/directory?tab=professionals" class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900">SEAM APs</a>
                <a href="/directory?tab=projects" class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900">Projects</a>
                <a href="/directory?tab=members" class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900">Members</a>
              </>
            ) : group.progression?.length ? (
              <>
                <p class="pt-2 pb-1 text-[12px] font-medium uppercase tracking-[0.12em] text-warm-400">Take Action</p>
                {group.progression.map((step) => (
                  <a href={step.href} class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900">
                    <span class="block">{step.label}</span>
                    <span class="block text-[13px] text-warm-400">{step.tagline}</span>
                  </a>
                ))}
                {group.quickLinks && (
                  <div class="pt-2 mt-2 border-t border-warm-100">
                    {group.quickLinks.map((ql) => (
                      <a href={ql.href} class="block py-2 text-[14px] text-warm-500 hover:text-warm-900">{ql.label}</a>
                    ))}
                  </div>
                )}
              </>
            ) : group.sections?.length ? (
              group.sections.map((section) => (
                <div>
                  {section.href ? (
                    <a
                      href={section.href}
                      class="block pt-2 pb-1 text-[12px] font-medium uppercase tracking-[0.12em] text-warm-400 hover:text-gold-600 transition-colors"
                    >
                      {section.heading} &rarr;
                    </a>
                  ) : (
                    <p class="pt-2 pb-1 text-[12px] font-medium uppercase tracking-[0.12em] text-warm-400">
                      {section.heading}
                    </p>
                  )}
                  {section.links.map((link) => (
                    <div>
                      <a
                        href={link.href}
                        class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900"
                      >
                        {link.label}
                      </a>
                      {link.children && link.children.length > 0 && (
                        <ul class="ml-4 -mt-1 mb-1 space-y-0.5 border-l border-warm-100 pl-3">
                          {link.children.map((child) => (
                            <li>
                              <a
                                href={child.href}
                                {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                                class="block py-1 text-[13.5px] text-warm-500 hover:text-warm-900"
                              >
                                {child.label}
                                {child.external && (
                                  <svg class="inline-block w-3 h-3 ml-1 opacity-60" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                  </svg>
                                )}
                              </a>
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  ))}
                </div>
              ))
            ) : (
              group.links.map((link) => (
                <a
                  href={link.href}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900"
                >
                  {link.label}
                  {link.external && (
                    <svg class="inline-block w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                  )}
                </a>
              ))
            )}
            {group.featured && (
              <a
                href={group.featured.href}
                class="block py-2.5 text-[16px] text-gold-600"
              >
                {group.featured.label}
              </a>
            )}
          </div>
        </div>
      ))}

      <a
        href="/get-started"
        class="mt-6 block w-full text-center rounded-full bg-warm-900 px-6 py-3.5 text-[17px] font-medium text-white"
      >
        Talk to an Advisor
      </a>
    </div>
  </div>
</nav>

<script>
  function initNavbar() {
    const nav = document.getElementById('main-nav')
    const logo = document.getElementById('nav-logo')
    const cta = document.getElementById('nav-cta')
    const mobileToggle = document.getElementById('mobile-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const hamburgerIcon = document.getElementById('hamburger-icon')
    const closeIcon = document.getElementById('close-icon')

    if (!nav) return

    const alwaysSolid = !!document.querySelector('[data-solid-nav]')
    let scrolled = false
    let mobileOpen = false
    let activeDropdown: string | null = null
    let closeTimeout: ReturnType<typeof setTimeout> | null = null

    function updateNavStyle() {
      const solid = alwaysSolid || scrolled || mobileOpen || activeDropdown !== null
      if (solid) {
        nav!.classList.remove('bg-warm-900/10', 'backdrop-blur-[2px]')
        nav!.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm')
      } else {
        nav!.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm')
        nav!.classList.add('bg-warm-900/10', 'backdrop-blur-[2px]')
      }

      // Logo swap
      if (logo) {
        logo.setAttribute('src', solid ? logo.dataset.srcLight! : logo.dataset.srcDark!)
      }

      // CTA button style
      if (cta) {
        if (solid) {
          cta.classList.remove('bg-white', 'text-warm-900', 'hover:bg-white/90')
          cta.classList.add('bg-warm-900', 'text-white', 'hover:bg-warm-800')
        } else {
          cta.classList.remove('bg-warm-900', 'text-white', 'hover:bg-warm-800')
          cta.classList.add('bg-white', 'text-warm-900', 'hover:bg-white/90')
        }
      }

      // Desktop nav link colors
      const textLinks = nav!.querySelectorAll<HTMLElement>('.nav-text-link')
      textLinks.forEach((link) => {
        if (solid) {
          link.classList.remove('text-white/80', 'hover:text-white')
          link.classList.add('text-warm-600', 'hover:text-warm-900')
        } else {
          link.classList.remove('text-warm-600', 'hover:text-warm-900')
          link.classList.add('text-white/80', 'hover:text-white')
        }
      })

      // Mobile toggle color
      if (mobileToggle) {
        if (solid) {
          mobileToggle.classList.remove('text-white')
          mobileToggle.classList.add('text-warm-600')
        } else {
          mobileToggle.classList.remove('text-warm-600')
          mobileToggle.classList.add('text-white')
        }
      }
    }

    // Scroll tracking
    window.addEventListener('scroll', () => {
      scrolled = window.scrollY > 50
      updateNavStyle()
    }, { passive: true })

    // Desktop dropdowns
    const dropdownContainers = nav!.querySelectorAll<HTMLElement>('[data-dropdown]')
    dropdownContainers.forEach((container) => {
      const idx = container.dataset.dropdown!
      const trigger = container.querySelector(`[data-dropdown-trigger="${idx}"]`) as HTMLButtonElement
      const panel = container.querySelector(`[data-dropdown-panel="${idx}"]`) as HTMLElement
      const chevron = container.querySelector(`[data-dropdown-chevron="${idx}"]`) as SVGElement

      function open() {
        if (closeTimeout) clearTimeout(closeTimeout)
        // Close other panels
        dropdownContainers.forEach((c) => {
          const cIdx = c.dataset.dropdown!
          if (cIdx !== idx) {
            const p = c.querySelector(`[data-dropdown-panel="${cIdx}"]`) as HTMLElement
            const ch = c.querySelector(`[data-dropdown-chevron="${cIdx}"]`) as SVGElement
            const t = c.querySelector(`[data-dropdown-trigger="${cIdx}"]`) as HTMLButtonElement
            p?.classList.add('hidden')
            ch?.classList.remove('rotate-180')
            t?.setAttribute('aria-expanded', 'false')
          }
        })
        panel.classList.remove('hidden')
        chevron?.classList.add('rotate-180')
        trigger.setAttribute('aria-expanded', 'true')
        activeDropdown = idx
        updateNavStyle()
      }

      function close() {
        closeTimeout = setTimeout(() => {
          panel.classList.add('hidden')
          chevron?.classList.remove('rotate-180')
          trigger.setAttribute('aria-expanded', 'false')
          activeDropdown = null
          updateNavStyle()
        }, 150)
      }

      container.addEventListener('mouseenter', open)
      container.addEventListener('mouseleave', close)
      trigger.addEventListener('click', () => {
        if (panel.classList.contains('hidden')) {
          open()
        } else {
          panel.classList.add('hidden')
          chevron?.classList.remove('rotate-180')
          trigger.setAttribute('aria-expanded', 'false')
          activeDropdown = null
          updateNavStyle()
        }
      })
    })

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (nav && !nav.contains(e.target as Node)) {
        dropdownContainers.forEach((c) => {
          const idx = c.dataset.dropdown!
          const p = c.querySelector(`[data-dropdown-panel="${idx}"]`) as HTMLElement
          const ch = c.querySelector(`[data-dropdown-chevron="${idx}"]`) as SVGElement
          const t = c.querySelector(`[data-dropdown-trigger="${idx}"]`) as HTMLButtonElement
          p?.classList.add('hidden')
          ch?.classList.remove('rotate-180')
          t?.setAttribute('aria-expanded', 'false')
        })
        activeDropdown = null
        updateNavStyle()
      }
    })

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownContainers.forEach((c) => {
          const idx = c.dataset.dropdown!
          const p = c.querySelector(`[data-dropdown-panel="${idx}"]`) as HTMLElement
          const ch = c.querySelector(`[data-dropdown-chevron="${idx}"]`) as SVGElement
          const t = c.querySelector(`[data-dropdown-trigger="${idx}"]`) as HTMLButtonElement
          p?.classList.add('hidden')
          ch?.classList.remove('rotate-180')
          t?.setAttribute('aria-expanded', 'false')
        })
        activeDropdown = null
        mobileOpen = false
        mobileMenu?.classList.add('hidden')
        hamburgerIcon?.classList.remove('hidden')
        closeIcon?.classList.add('hidden')
        updateNavStyle()
      }
    })

    // Mobile menu toggle
    mobileToggle?.addEventListener('click', () => {
      mobileOpen = !mobileOpen
      mobileMenu?.classList.toggle('hidden', !mobileOpen)
      hamburgerIcon?.classList.toggle('hidden', mobileOpen)
      closeIcon?.classList.toggle('hidden', !mobileOpen)
      updateNavStyle()
    })

    // Mobile accordions
    const mobileAccordions = nav!.querySelectorAll<HTMLElement>('[data-mobile-accordion]')
    mobileAccordions.forEach((accordion) => {
      const idx = accordion.dataset.mobileAccordion!
      const trigger = accordion.querySelector(`[data-mobile-trigger="${idx}"]`) as HTMLButtonElement
      const content = accordion.querySelector(`[data-mobile-content="${idx}"]`) as HTMLElement
      const chevron = accordion.querySelector(`[data-mobile-chevron="${idx}"]`) as SVGElement

      trigger?.addEventListener('click', () => {
        const isOpen = !content.classList.contains('hidden')
        content.classList.toggle('hidden', isOpen)
        chevron?.classList.toggle('rotate-180', !isOpen)
      })
    })

    updateNavStyle()
  }

  document.addEventListener('astro:page-load', initNavbar)
  if (document.readyState !== 'loading') {
    initNavbar()
  } else {
    document.addEventListener('DOMContentLoaded', initNavbar)
  }
</script>
