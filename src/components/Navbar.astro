---
interface NavLink {
  label: string
  href: string
  description: string
  logo?: string
  logos?: string[]
}

interface NavSection {
  heading: string
  href?: string
  links: NavLink[]
}

interface NavGroup {
  label: string
  links: NavLink[]
  featured?: { label: string; href: string; description: string }
  sections?: NavSection[]
}

const solutions: NavGroup = {
  label: 'Solutions',
  links: [],
  sections: [
    {
      heading: 'Products',
      links: [
        {
          label: 'Certification',
          href: '/certification',
          description: 'Full building certification across three tracks, Bronze through Platinum.',
          logos: ['/logos/cert-bronze.png', '/logos/cert-silver.png', '/logos/cert-gold.png', '/logos/cert-platinum.png'],
        },
        {
          label: 'SEAM Approved',
          href: '/approved',
          description: 'Standalone activity verification. An on-ramp or a parallel track.',
          logo: '/logos/approved-wordmark.png',
        },
        {
          label: 'AP Credential',
          href: '/ap-credential',
          description: 'The professional qualification for practitioners leading certification.',
          logo: '/logos/ap-seal.png',
        },
      ],
    },
    {
      heading: 'Community',
      links: [
        {
          label: 'Community Overview',
          href: '/community',
          description: 'The membership community for organizations and individuals.',
        },
        {
          label: 'Individual Membership',
          href: '/community/individual',
          description: 'A la carte commitments at multiple price points. Pick what you need.',
          logos: ['/logos/member-individual.png', '/logos/member-changemaker.png'],
        },
        {
          label: 'Organization Membership',
          href: '/community/organization',
          description: 'Contributor, Builder, and Steward tiers for teams and institutions.',
          logos: ['/logos/member-standing.png', '/logos/member-ladder.png', '/logos/member-arc.png'],
        },
      ],
    },
  ],
}

const theStandard: NavGroup = {
  label: 'The Standard',
  links: [],
  featured: {
    label: 'The Standard',
    href: '/resources/standard',
    description: 'The full SEAM framework, free to download.',
  },
  sections: [
    {
      heading: 'Rating Systems',
      href: '/rating-system',
      links: [
        {
          label: 'All Rating Systems',
          href: '/rating-system',
          description: 'Choose the right path for your project type and role.',
        },
        {
          label: 'Buildings + Interiors',
          href: '/rating-system/buildings-interiors',
          description: 'Design and construction of equitable indoor environments.',
        },
        {
          label: 'Operations + Maintenance',
          href: '/rating-system/operations-maintenance',
          description: 'Ongoing management, procurement, and facility stewardship.',
        },
      ],
    },
    {
      heading: 'Pillars',
      links: [
        {
          label: 'Social Impact',
          href: '/standard/social-impact',
          description: 'Measurable outcomes for people and communities.',
          logo: '/icons/pillar-social-impact.png',
        },
        {
          label: 'Social Responsibility',
          href: '/standard/social-responsibility',
          description: 'Ethical practices in procurement, labor, and governance.',
          logo: '/icons/pillar-social-responsibility.png',
        },
        {
          label: 'Social Justice',
          href: '/standard/social-justice',
          description: 'Addressing systemic inequity through the built environment.',
          logo: '/icons/pillar-social-justice.png',
        },
        {
          label: 'Social Accountability',
          href: '/standard/social-accountability',
          description: 'Transparency, reporting, and stakeholder engagement.',
          logo: '/icons/pillar-social-accountability.png',
        },
      ],
    },
  ],
}

const resources: NavGroup = {
  label: 'Resources',
  links: [
    { label: 'Directory', href: '/directory', description: 'Find accredited professionals, certified projects, and verified activities.' },
    { label: 'The Standard', href: '/resources/standard', description: 'The full SEAM framework, free to download.' },
    { label: 'ROSSI Calculator', href: '/resources/rossi', description: 'Translate social equity outcomes into financial language.' },
    { label: 'Integrations', href: '/resources/integrations', description: 'How SEAM works alongside LEED, WELL, Fitwel, and UN SDG frameworks.' },
    { label: 'Blog & Insights', href: '/resources/blog', description: 'Lessons from certified projects and practitioner perspectives.' },
    { label: 'Courses & Webinars', href: '/resources/courses', description: 'Build your understanding of social equity. Free and open.' },
    { label: 'Pricing', href: '/pricing', description: 'Transparent pricing for certification, credentials, and membership.' },
  ],
}

const audiences: NavGroup = {
  label: 'Who SEAM Is For',
  links: [
    { label: 'Developers & Owners', href: '/for/developers-owners', description: 'Reduce turnover, attract mission-aligned capital, and differentiate your asset in the market.' },
    { label: 'Building Professionals', href: '/for/building-professionals', description: 'Architects, interior designers, contractors, and engineers shaping equitable spaces.' },
    { label: 'Property Managers & Facility Teams', href: '/for/operators', description: 'Turn the equity work you already do into a verified credential that strengthens renewals.' },
    { label: 'Capital Providers & Compliance', href: '/for/capital-providers', description: 'A diligence signal for social risk. GRESB-aligned data, international compliance-ready.' },
    { label: 'Social Impact Professionals', href: '/for/impact-professionals', description: 'Earn the AP credential, join a practitioner network, and build a practice around the Standard.' },
    { label: 'People & Communities', href: '/for/people', description: 'Choose buildings that reflect your values — health, equity, and inclusion verified.' },
  ],
}

const dropdowns = [solutions, theStandard, audiences, resources]

function logoClass(_logo: string) {
  return 'w-11 h-11'
}
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-warm-900/10 backdrop-blur-[2px]"
>
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <div class="flex h-[88px] items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img
          id="nav-logo"
          src="/logos/seam-wordmark.png"
          alt="SEAM"
          class="h-8 w-auto transition-all duration-300"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-10">
        <a
          href="/about"
          class="nav-text-link text-[15px] transition-colors duration-300 text-white/80 hover:text-white"
        >
          About
        </a>

        {dropdowns.map((group, idx) => (
          <div class="relative" data-dropdown={idx}>
            <button
              class="nav-text-link inline-flex items-center text-[15px] transition-colors duration-300 text-white/80 hover:text-white"
              aria-expanded="false"
              data-dropdown-trigger={idx}
            >
              {group.label}
              <svg
                class="ml-1 h-3.5 w-3.5 transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={2}
                stroke="currentColor"
                data-dropdown-chevron={idx}
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>

            <!-- Dropdown panel -->
            <div
              class="absolute top-full left-1/2 -translate-x-1/2 pt-4 hidden"
              data-dropdown-panel={idx}
            >
              {group.sections?.length ? (
                <div class={`rounded-2xl border border-warm-100 bg-white shadow-[0_24px_60px_rgba(0,0,0,0.08)] ${group.label === 'The Standard' ? 'w-[820px]' : 'w-[760px]'} overflow-hidden`}>
                  {/* Standard featured hero at top */}
                  {group.label === 'The Standard' && group.featured && (
                    <div class="relative grid grid-cols-[1fr_300px] items-stretch bg-gradient-to-br from-warm-900 via-warm-900 to-seam-900 px-8 py-7 border-b border-warm-100 overflow-hidden">
                      <div class="flex flex-col justify-between py-1">
                        <div>
                          <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-gold-400 mb-3">
                            Featured
                          </p>
                          <p class="font-display text-[28px] leading-[1.1] tracking-[-0.02em] text-white">
                            {group.featured.label}
                          </p>
                          <p class="mt-3 text-[13px] leading-relaxed text-warm-300 max-w-[320px]">
                            The complete social equity framework for the built environment. Free and open.
                          </p>
                        </div>
                        <div class="mt-5 flex flex-wrap items-center gap-2">
                          <a
                            href={group.featured.href}
                            class="inline-flex items-center rounded-full bg-white px-4 py-2 text-[13px] font-medium text-warm-900 hover:bg-warm-100 transition-colors"
                          >
                            Learn more
                          </a>
                          <a
                            href="/community/individual"
                            class="inline-flex items-center rounded-full border border-white/30 px-4 py-2 text-[13px] font-medium text-white hover:border-white/60 hover:bg-white/5 transition-colors"
                          >
                            Access with free Open Membership
                          </a>
                        </div>
                      </div>
                      {/* Standard book cover */}
                      <div class="absolute -right-8 -top-4 -bottom-4 w-[320px] overflow-hidden">
                        <img
                          src="/images/seam-standard-book.png"
                          alt="The SEAM Standard book cover"
                          class="absolute right-2 top-1/2 -translate-y-[45%] h-[280px] w-auto drop-shadow-[0_16px_32px_rgba(0,0,0,0.4)] rotate-[12deg]"
                        />
                      </div>
                    </div>
                  )}
                  <div class="grid grid-cols-2 divide-x divide-warm-100">
                    {group.sections.map((section) => (
                      <div class="p-6 space-y-1">
                        {section.href ? (
                          <a
                            href={section.href}
                            class="block px-3 pb-2 text-[11px] font-medium uppercase tracking-[0.15em] text-warm-400 hover:text-gold-600 transition-colors"
                          >
                            {section.heading} &rarr;
                          </a>
                        ) : (
                          <p class="px-3 pb-2 text-[11px] font-medium uppercase tracking-[0.15em] text-warm-400">
                            {section.heading}
                          </p>
                        )}
                        {section.links.map((link) => (
                          <a
                            href={link.href}
                            class="group/item flex items-center gap-4 rounded-xl px-3 py-3 transition-colors duration-150 hover:bg-warm-50"
                          >
                            {link.logos ? (
                              <div class="flex items-center shrink-0 -space-x-3">
                                {link.logos.map((src) => (
                                  <img
                                    src={src}
                                    alt=""
                                    class="w-10 h-10 object-contain drop-shadow-sm"
                                  />
                                ))}
                              </div>
                            ) : link.logo ? (
                              <img
                                src={link.logo}
                                alt=""
                                class={`object-contain shrink-0 ${logoClass(link.logo)}`}
                              />
                            ) : null}
                            <div>
                              <span class="block text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600">
                                {link.label}
                              </span>
                              <span class="block mt-0.5 text-[13px] leading-snug text-warm-400">
                                {link.description}
                              </span>
                            </div>
                          </a>
                        ))}
                      </div>
                    ))}
                  </div>
                </div>
              ) : (
                <div class={`rounded-2xl border border-warm-100 bg-white shadow-[0_24px_60px_rgba(0,0,0,0.08)] ${group.featured ? 'w-[640px]' : 'w-[480px]'}`}>
                  <div class={group.featured ? 'grid grid-cols-5' : ''}>
                    <div class={`p-6 space-y-1 ${group.featured ? 'col-span-3' : ''}`}>
                      <p class="px-3 pb-2 text-[11px] font-medium uppercase tracking-[0.15em] text-warm-400">
                        {group.label}
                      </p>
                      {group.links.map((link) => (
                        <a
                          href={link.href}
                          class="group/item flex items-center gap-4 rounded-xl px-3 py-3 transition-colors duration-150 hover:bg-warm-50"
                        >
                          {link.logo && (
                            <img
                              src={link.logo}
                              alt=""
                              class="w-10 h-10 object-contain shrink-0"
                            />
                          )}
                          <div>
                            <span class="block text-[15px] font-medium text-warm-900 group-hover/item:text-gold-600">
                              {link.label}
                            </span>
                            <span class="block mt-0.5 text-[13px] leading-snug text-warm-400">
                              {link.description}
                            </span>
                          </div>
                        </a>
                      ))}
                    </div>
                    {group.featured && (
                      <div class="col-span-2 rounded-r-2xl bg-warm-50 p-6 flex flex-col justify-end">
                        <a href={group.featured.href} class="group/feat block">
                          <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-2">Featured</p>
                          <p class="text-[15px] font-medium text-warm-900 group-hover/feat:text-gold-600 transition-colors">
                            {group.featured.label}
                          </p>
                          <p class="mt-1 text-[13px] leading-snug text-warm-400">
                            {group.featured.description}
                          </p>
                          <span class="inline-block mt-3 text-[13px] font-medium text-gold-600">Learn more &rarr;</span>
                        </a>
                      </div>
                    )}
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}

        <a
          href="/get-started"
          id="nav-cta"
          class="ml-4 inline-flex items-center rounded-full px-6 py-3 text-[15px] font-medium transition-colors duration-300 bg-white text-warm-900 hover:bg-white/90"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-toggle"
        class="lg:hidden p-2 transition-colors duration-300 text-white"
        aria-label="Toggle menu"
      >
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width={1.5} stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke-width={1.5} stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden bg-white border-t border-warm-100 hidden">
    <div class="px-6 py-4">
      <a href="/about" class="block py-4 text-[17px] font-medium text-warm-700 border-b border-warm-100">
        About
      </a>

      {dropdowns.map((group, idx) => (
        <div class="border-b border-warm-100 last:border-b-0" data-mobile-accordion={idx}>
          <button
            class="flex w-full items-center justify-between py-4 text-[17px] font-medium text-warm-700"
            data-mobile-trigger={idx}
          >
            {group.label}
            <svg
              class="ml-1 h-3.5 w-3.5 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width={2}
              stroke="currentColor"
              data-mobile-chevron={idx}
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div class="pb-4 pl-2 space-y-1 hidden" data-mobile-content={idx}>
            {group.sections?.length ? (
              group.sections.map((section) => (
                <div>
                  {section.href ? (
                    <a
                      href={section.href}
                      class="block pt-2 pb-1 text-[12px] font-medium uppercase tracking-[0.12em] text-warm-400 hover:text-gold-600 transition-colors"
                    >
                      {section.heading} &rarr;
                    </a>
                  ) : (
                    <p class="pt-2 pb-1 text-[12px] font-medium uppercase tracking-[0.12em] text-warm-400">
                      {section.heading}
                    </p>
                  )}
                  {section.links.map((link) => (
                    <a
                      href={link.href}
                      class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              ))
            ) : (
              group.links.map((link) => (
                <a
                  href={link.href}
                  class="block py-2.5 text-[16px] text-warm-600 hover:text-warm-900"
                >
                  {link.label}
                </a>
              ))
            )}
            {group.featured && (
              <a
                href={group.featured.href}
                class="block py-2.5 text-[16px] text-gold-600"
              >
                {group.featured.label}
              </a>
            )}
          </div>
        </div>
      ))}

      <a
        href="/get-started"
        class="mt-6 block w-full text-center rounded-full bg-warm-900 px-6 py-3.5 text-[17px] font-medium text-white"
      >
        Get Started
      </a>
    </div>
  </div>
</nav>

<script>
  function initNavbar() {
    const nav = document.getElementById('main-nav')
    const logo = document.getElementById('nav-logo')
    const cta = document.getElementById('nav-cta')
    const mobileToggle = document.getElementById('mobile-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const hamburgerIcon = document.getElementById('hamburger-icon')
    const closeIcon = document.getElementById('close-icon')

    if (!nav) return

    let scrolled = false
    let mobileOpen = false
    let activeDropdown: string | null = null
    let closeTimeout: ReturnType<typeof setTimeout> | null = null

    function updateNavStyle() {
      const solid = scrolled || mobileOpen || activeDropdown !== null
      if (solid) {
        nav!.classList.remove('bg-warm-900/10', 'backdrop-blur-[2px]')
        nav!.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm')
      } else {
        nav!.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm')
        nav!.classList.add('bg-warm-900/10', 'backdrop-blur-[2px]')
      }

      // Logo brightness
      if (solid) {
        logo?.classList.add('brightness-0')
      } else {
        logo?.classList.remove('brightness-0')
      }

      // CTA button style
      if (cta) {
        if (solid) {
          cta.classList.remove('bg-white', 'text-warm-900', 'hover:bg-white/90')
          cta.classList.add('bg-warm-900', 'text-white', 'hover:bg-warm-800')
        } else {
          cta.classList.remove('bg-warm-900', 'text-white', 'hover:bg-warm-800')
          cta.classList.add('bg-white', 'text-warm-900', 'hover:bg-white/90')
        }
      }

      // Desktop nav link colors
      const textLinks = nav!.querySelectorAll<HTMLElement>('.nav-text-link')
      textLinks.forEach((link) => {
        if (solid) {
          link.classList.remove('text-white/80', 'hover:text-white')
          link.classList.add('text-warm-600', 'hover:text-warm-900')
        } else {
          link.classList.remove('text-warm-600', 'hover:text-warm-900')
          link.classList.add('text-white/80', 'hover:text-white')
        }
      })

      // Mobile toggle color
      if (mobileToggle) {
        if (solid) {
          mobileToggle.classList.remove('text-white')
          mobileToggle.classList.add('text-warm-600')
        } else {
          mobileToggle.classList.remove('text-warm-600')
          mobileToggle.classList.add('text-white')
        }
      }
    }

    // Scroll tracking
    window.addEventListener('scroll', () => {
      scrolled = window.scrollY > 50
      updateNavStyle()
    }, { passive: true })

    // Desktop dropdowns
    const dropdownContainers = nav!.querySelectorAll<HTMLElement>('[data-dropdown]')
    dropdownContainers.forEach((container) => {
      const idx = container.dataset.dropdown!
      const trigger = container.querySelector(`[data-dropdown-trigger="${idx}"]`) as HTMLButtonElement
      const panel = container.querySelector(`[data-dropdown-panel="${idx}"]`) as HTMLElement
      const chevron = container.querySelector(`[data-dropdown-chevron="${idx}"]`) as SVGElement

      function open() {
        if (closeTimeout) clearTimeout(closeTimeout)
        // Close other panels
        dropdownContainers.forEach((c) => {
          const cIdx = c.dataset.dropdown!
          if (cIdx !== idx) {
            const p = c.querySelector(`[data-dropdown-panel="${cIdx}"]`) as HTMLElement
            const ch = c.querySelector(`[data-dropdown-chevron="${cIdx}"]`) as SVGElement
            const t = c.querySelector(`[data-dropdown-trigger="${cIdx}"]`) as HTMLButtonElement
            p?.classList.add('hidden')
            ch?.classList.remove('rotate-180')
            t?.setAttribute('aria-expanded', 'false')
          }
        })
        panel.classList.remove('hidden')
        chevron?.classList.add('rotate-180')
        trigger.setAttribute('aria-expanded', 'true')
        activeDropdown = idx
        updateNavStyle()
      }

      function close() {
        closeTimeout = setTimeout(() => {
          panel.classList.add('hidden')
          chevron?.classList.remove('rotate-180')
          trigger.setAttribute('aria-expanded', 'false')
          activeDropdown = null
          updateNavStyle()
        }, 150)
      }

      container.addEventListener('mouseenter', open)
      container.addEventListener('mouseleave', close)
      trigger.addEventListener('click', () => {
        if (panel.classList.contains('hidden')) {
          open()
        } else {
          panel.classList.add('hidden')
          chevron?.classList.remove('rotate-180')
          trigger.setAttribute('aria-expanded', 'false')
          activeDropdown = null
          updateNavStyle()
        }
      })
    })

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (nav && !nav.contains(e.target as Node)) {
        dropdownContainers.forEach((c) => {
          const idx = c.dataset.dropdown!
          const p = c.querySelector(`[data-dropdown-panel="${idx}"]`) as HTMLElement
          const ch = c.querySelector(`[data-dropdown-chevron="${idx}"]`) as SVGElement
          const t = c.querySelector(`[data-dropdown-trigger="${idx}"]`) as HTMLButtonElement
          p?.classList.add('hidden')
          ch?.classList.remove('rotate-180')
          t?.setAttribute('aria-expanded', 'false')
        })
        activeDropdown = null
        updateNavStyle()
      }
    })

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownContainers.forEach((c) => {
          const idx = c.dataset.dropdown!
          const p = c.querySelector(`[data-dropdown-panel="${idx}"]`) as HTMLElement
          const ch = c.querySelector(`[data-dropdown-chevron="${idx}"]`) as SVGElement
          const t = c.querySelector(`[data-dropdown-trigger="${idx}"]`) as HTMLButtonElement
          p?.classList.add('hidden')
          ch?.classList.remove('rotate-180')
          t?.setAttribute('aria-expanded', 'false')
        })
        activeDropdown = null
        mobileOpen = false
        mobileMenu?.classList.add('hidden')
        hamburgerIcon?.classList.remove('hidden')
        closeIcon?.classList.add('hidden')
        updateNavStyle()
      }
    })

    // Mobile menu toggle
    mobileToggle?.addEventListener('click', () => {
      mobileOpen = !mobileOpen
      mobileMenu?.classList.toggle('hidden', !mobileOpen)
      hamburgerIcon?.classList.toggle('hidden', mobileOpen)
      closeIcon?.classList.toggle('hidden', !mobileOpen)
      updateNavStyle()
    })

    // Mobile accordions
    const mobileAccordions = nav!.querySelectorAll<HTMLElement>('[data-mobile-accordion]')
    mobileAccordions.forEach((accordion) => {
      const idx = accordion.dataset.mobileAccordion!
      const trigger = accordion.querySelector(`[data-mobile-trigger="${idx}"]`) as HTMLButtonElement
      const content = accordion.querySelector(`[data-mobile-content="${idx}"]`) as HTMLElement
      const chevron = accordion.querySelector(`[data-mobile-chevron="${idx}"]`) as SVGElement

      trigger?.addEventListener('click', () => {
        const isOpen = !content.classList.contains('hidden')
        content.classList.toggle('hidden', isOpen)
        chevron?.classList.toggle('rotate-180', !isOpen)
      })
    })

    updateNavStyle()
  }

  document.addEventListener('astro:page-load', initNavbar)
  if (document.readyState !== 'loading') {
    initNavbar()
  } else {
    document.addEventListener('DOMContentLoaded', initNavbar)
  }
</script>
