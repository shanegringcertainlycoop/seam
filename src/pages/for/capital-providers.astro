---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../../lib/seo-helpers'

/* --- Data --- */

const challenges = [
  {
    pain: 'Social risk with no measurement framework',
    solution: 'SEAM certification provides standardized, third-party-verified social performance data across four pillars. Not self-reported surveys — measured outcomes with independent verification.',
  },
  {
    pain: 'GRESB social indicators are hard to populate',
    solution: 'GRESB recognizes SEAM as a green building certification, earning your project that point. Certification also produces verified documentation across governance, workforce, community, and supply chain, giving ESG teams stronger evidence for social indicator responses.',
  },
  {
    pain: 'No financial language for social outcomes',
    solution: 'The ROSSI Calculator translates social equity performance into the financial language decision-makers use, giving teams the numbers they need to build the business case internally.',
  },
  {
    pain: 'International compliance frameworks are multiplying',
    solution: "SEAM is built on internationally recognized standards and gives organizations a structured, documented evidence base that supports reporting against requirements like the EU CSRD, the Australian and UK Modern Slavery Acts, and Canada\u2019s Fighting Against Forced Labour Act.",
  },
]

const products = [
  {
    label: 'ROSSI Calculator',
    title: 'Financial modeling for social equity',
    description: 'Translate social equity outcomes into the financial language decision-makers use. Model the return on social sustainability investment and build the internal business case in numbers your team can act on.',
    href: '/resources/rossi',
    fit: 'Best for sustainability leads, ESG officers, and making the case internally.',
    logo: '/logos/rossi-calculator.png',
  },
  {
    label: 'Certification',
    title: 'Portfolio-level diligence',
    description: "Use SEAM Certification as a diligence and governance signal across your holdings. Third-party verified evidence of social performance gives ESG and compliance teams a documented foundation for reporting and a clearer view of social risk that standard due diligence cannot produce.",
    href: '/certification',
    fit: 'Best for institutional owners and capital providers managing social risk across a portfolio.',
    logos: ['/logos/cert-bronze.png', '/logos/cert-silver.png', '/logos/cert-gold.png', '/logos/cert-platinum.png'],
  },
  {
    label: 'The Standard',
    title: 'Due diligence framework',
    description: "Evaluate social risk before you buy. Use the SEAM Standard as an evidence-based screen in acquisition diligence: assess a building\u2019s social performance against a public, internationally recognized framework with structured indicators and documented outcomes.",
    href: '/resources/standard',
    fit: 'Best for acquisition teams evaluating social risk in new investments.',
  },
]

const faqs = [
  {
    q: 'How does SEAM align with GRESB?',
    a: "SEAM certification data maps directly to GRESB social indicators. Certified projects generate standardized performance data that feeds into GRESB submissions. The ROSSI Calculator produces GRESB-aligned scoring at both project and portfolio levels.",
  },
  {
    q: 'Can SEAM data be used for SFDR reporting?',
    a: "SEAM's four pillars align with SFDR principal adverse impact indicators related to social and governance factors. The Standard's community engagement, employment, and accessibility metrics provide evidence for Article 8 and Article 9 fund disclosures.",
  },
  {
    q: 'How does ROSSI quantify social outcomes?',
    a: 'ROSSI models financial impact across four dimensions: tenant retention value (reduced vacancy and turnover costs), insurance risk reduction (claims reduction from community engagement), operating cost impact (efficiency gains from inclusive design), and ESG scoring improvement (GRESB and proprietary scoring models).',
  },
  {
    q: 'Can we require SEAM certification in our investment criteria?',
    a: 'Yes. Several institutional investors now include SEAM certification as a condition or incentive in acquisition criteria, fund mandates, and asset management agreements. Our team can help structure these requirements.',
  },
  {
    q: 'What is the verification methodology?',
    a: 'SEAM certification uses independent third-party review including documentation assessment, site verification, and community engagement surveys. Reviewers are credentialed and follow standardized protocols. All certifications require recertification every three years.',
  },
]

const faqItems = faqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Who We Serve', path: '/about' },
    { name: 'Capital Providers', path: '/for/capital-providers' },
  ]),
]
---

<SiteLayout
  title="Social Equity Data for Capital Providers & Compliance"
  description="GRESB-aligned social performance data, ROSSI financial modeling, and third-party-verified outcomes for investors and compliance teams."
  path="/for/capital-providers"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0">
      <img
        src="/images/hero-capital.jpg"
        alt="Capital providers and social diligence"
        class="h-full w-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>
    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-4xl mx-auto text-center">
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          For Capital Providers &amp; Compliance
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          A diligence signal for{' '}
          <em class="font-display italic font-normal text-seam-300">social risk</em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl mx-auto text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          SEAM provides GRESB-aligned social performance data and third-party-verified outcomes that institutional investors, insurers, and international compliance teams can act on.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4 justify-center">
          <a href="/resources/rossi" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
            Calculate your ROI
          </a>
          <a href="/get-started" class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">
            Talk to our team
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pain Points / Solutions ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">The challenge</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Social performance is the{' '}<em class="italic font-normal text-seam-600">next diligence frontier</em>
        </h2>
      </div>
      <div class="reveal-stagger space-y-6">
        {challenges.map((c) => (
          <div class="reveal-child grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 rounded-2xl border border-warm-100 p-5 sm:p-8 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            <div>
              <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-warm-600 mb-3 block">The problem</span>
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900">{c.pain}</h3>
            </div>
            <div>
              <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-gold-600 mb-3 block">How SEAM helps</span>
              <p class="text-[16px] leading-relaxed text-warm-600">{c.solution}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Products for You ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Your toolkit</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Products built for{' '}<em class="italic font-normal text-seam-600">capital decisions</em>
        </h2>
      </div>
      <div class="reveal-stagger grid grid-cols-1 lg:grid-cols-3 gap-6 pt-10">
        {products.map((p) => (
          <a href={p.href} class="reveal-child group relative overflow-visible rounded-2xl bg-white border border-warm-100 p-6 sm:p-8 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            {(p.logos || p.logo) && (
              <div class="absolute -top-5 right-3 sm:-top-8 sm:right-8">
                {p.logos ? (
                  <div class="flex items-end -space-x-2 sm:-space-x-4">
                    {p.logos.map((src) => (
                      <img src={src} alt="" class="w-7 h-7 sm:w-14 sm:h-14 object-contain drop-shadow-sm" loading="lazy" decoding="async" />
                    ))}
                  </div>
                ) : (
                  <img src={p.logo} alt="" class="w-12 h-12 sm:w-16 sm:h-16 object-contain drop-shadow-sm" loading="lazy" decoding="async" />
                )}
              </div>
            )}
            <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-gold-600 mb-2 block">{p.label}</span>
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-4">{p.title}</h3>
            <p class="text-[16px] leading-relaxed text-warm-600 mb-6">{p.description}</p>
            <p class="text-[14px] leading-relaxed text-warm-600 italic border-t border-warm-100 pt-5">{p.fit}</p>
            <span class="inline-block mt-4 text-[14px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Frequently asked</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Questions from{' '}<em class="italic font-normal text-seam-600">capital providers</em>
        </h2>
      </div>
      <div class="max-w-3xl">
        {faqs.map((faq) => (
          <details class="border-b border-warm-200 group">
            <summary class="flex w-full items-center justify-between py-6 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="text-[17px] lg:text-[18px] font-medium text-warm-900 pr-8">{faq.q}</span>
              <svg class="shrink-0 w-5 h-5 text-warm-600 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </summary>
            <div class="pb-6">
              <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-white max-w-3xl mx-auto">
        Social equity is{' '}<em class="italic font-normal text-seam-300">the next diligence layer</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-400 max-w-xl mx-auto">Model the financial case, set portfolio requirements, or talk to our team about institutional partnerships.</p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a href="/resources/rossi" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">Try ROSSI</a>
        <a href="/get-started" class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300">Contact our team</a>
      </div>
    </div>
  </section>

</SiteLayout>
