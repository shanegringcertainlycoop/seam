---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../../lib/seo-helpers'

/* --- Data --- */

const challenges = [
  {
    pain: 'Will this space be accessible to everyone I care about?',
    solution: 'The Standard evaluates whether a building can be used and accessed by the full range of people it serves. Certification is one signal that accessibility was treated as a real design and operations question, not an afterthought.',
  },
  {
    pain: 'Is this landlord investing in the community?',
    solution: 'SEAM tracks how a project hires locally, who it spends with, how it engages the community before and during the work, and whether it invests in long-term community well-being. Certification is a signal that a building\u2019s impact reaches beyond the property line.',
  },
  {
    pain: 'Are the workers who built and maintain this place treated fairly?',
    solution: 'SEAM verifies whether project owners, suppliers, and tenants pay living wages, provide decent work, and source materials through ethical supply chains. The people who build and care for a building are part of who the building affects, and certification holds the project accountable for them too.',
  },
  {
    pain: 'Will the people who live and work near this building have a voice in how it\u2019s used?',
    solution: 'SEAM requires meaningful engagement with the people a building affects, before and during the work. Certification means the project actively listened to community members, workers, and neighbors, and that the engagement is documented and verified.',
  },
]

const products = [
  {
    label: 'Certification',
    title: 'SEAM Certification',
    description: 'Choose spaces that put people first. SEAM-certified buildings meet verified standards for health, equity, and inclusion — so you know the commitment is real, not just a marketing claim.',
    href: '/certification',
    fit: "When you\u2019re evaluating a new apartment, office, or community space \u2014 check whether it\u2019s SEAM-certified.",
    logos: ['/logos/cert-bronze.png', '/logos/cert-silver.png', '/logos/cert-gold.png', '/logos/cert-platinum.png'],
  },
  {
    label: 'Directory',
    title: 'SEAM Directory',
    description: 'Find certified buildings and credentialed professionals near you. See exactly what each project has been verified for and who led the work.',
    href: '/directory',
    fit: "Find what\u2019s certified near you, and see exactly what each building has been verified for.",
  },
  {
    label: 'The Standard',
    title: 'The SEAM Standard',
    description: "Understand exactly what certified buildings are held to. Read the full Standard — it\u2019s free, open, and written so anyone can follow the criteria from air quality to labor practices.",
    href: '/resources/standard',
    fit: 'When you want to understand the specific criteria behind certification \u2014 from air quality to labor practices.',
  },
]

const outcomes = [
  { metric: 'Impact that reaches past the property line', detail: "A building affects more than the people who walk through its doors. SEAM looks at the workers who built it, the suppliers who stocked it, and the neighbors who live alongside it. Certification means all of them were part of the work." },
  { metric: 'Inclusive by design', detail: 'SEAM evaluates whether a building can be used and accessed by the full range of people it serves, across abilities, languages, and identities. Inclusion is built into how the project is reviewed, not bolted on at the end.' },
  { metric: 'Community investment', detail: "Local hiring, fair wages for workers, and supplier diversity are part of how a building earns SEAM Certification. The building\u2019s success is tied to the neighborhood\u2019s success." },
  { metric: 'Transparency you can trust', detail: 'SEAM Certification is verified by independent third-party reviewers, and certified projects are publicly listed. You can see which buildings have been held to the Standard and at what level.' },
]

const faqs = [
  {
    q: 'What does SEAM certification mean for me as a tenant?',
    a: 'It means your building has been independently verified against standards for health and safety, accessibility, community investment, and fair labor practices. Certification is earned through measurable performance, not self-reporting.',
  },
  {
    q: 'How can I find SEAM-certified buildings near me?',
    a: 'The SEAM Directory lets you browse certified projects by location, certification level, and rating system track. You can see exactly what each building has been verified for.',
  },
  {
    q: 'Does SEAM certification affect my rent?',
    a: "SEAM does not set or regulate rent. However, certified buildings often participate in anti-displacement and affordability commitments as part of the Social Justice pillar. Check a building\u2019s certification details in the Directory.",
  },
  {
    q: "What\u2019s the difference between SEAM and LEED?",
    a: "LEED measures environmental performance \u2014 energy efficiency, water use, materials. SEAM measures social equity \u2014 health, accessibility, community investment, fair labor, and cultural preservation. Many buildings pursue both.",
  },
  {
    q: 'How do I ask my landlord to pursue SEAM certification?',
    a: "Start by sharing the SEAM Standard or Directory with your property manager. The Operations + Maintenance track is designed for existing buildings and evaluates ongoing practices like local hiring, accessibility, and community engagement.",
  },
]

const faqItems = faqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Who We Serve', path: '/about' },
    { name: 'People & Communities', path: '/for/people' },
  ]),
]
---

<SiteLayout
  title="For People & Communities"
  description="SEAM-certified buildings meet verified standards for health, equity, accessibility, and community investment. Choose places that reflect your values."
  path="/for/people"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0">
      <img
        src="/images/hero-people.webp"
        alt="Diverse community members in a welcoming building lobby"
        class="h-full w-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-4xl mx-auto text-center">
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          For People &amp; Communities
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Buildings should work{' '}
          <em class="font-display italic font-normal text-seam-300">
            for you
          </em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl mx-auto text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          SEAM Certified spaces are held to measurable standards for health, accessibility, fair treatment, and community. When a building earns SEAM Certification, it's a sign the people who built and run it took the people inside and around it seriously.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4 justify-center">
          <a
            href="/directory?tab=projects"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Find certified buildings
          </a>
          <a
            href="/resources/standard"
            class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
          >
            Learn the Standard
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pain Points / Solutions ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Why it matters
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Your questions.{' '}
          <em class="italic font-normal text-seam-600">Real answers.</em>
        </h2>
      </div>

      <div class="reveal-stagger space-y-6">
        {challenges.map((c) => (
          <div
            class="reveal-child grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 rounded-2xl border border-warm-100 p-5 sm:p-8 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <div>
              <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-warm-600 mb-3 block">
                Your concern
              </span>
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900">
                {c.pain}
              </h3>
            </div>
            <div>
              <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-gold-600 mb-3 block">
                How SEAM helps
              </span>
              <p class="text-[16px] leading-relaxed text-warm-600">
                {c.solution}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Products for You ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Your toolkit
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Tools for{' '}
          <em class="italic font-normal text-seam-600">informed choices</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 lg:grid-cols-3 gap-6 pt-10">
        {products.map((p) => (
          <a
            href={p.href}
            class="reveal-child group relative overflow-visible rounded-2xl bg-white border border-warm-100 p-6 sm:p-8 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            {(p.logos || p.logo) && (
              <div class="absolute -top-5 right-3 sm:-top-8 sm:right-8">
                {p.logos ? (
                  <div class="flex items-end -space-x-2 sm:-space-x-4">
                    {p.logos.map((src) => (
                      <img src={src} alt="" class="w-7 h-7 sm:w-14 sm:h-14 object-contain drop-shadow-sm" loading="lazy" decoding="async" />
                    ))}
                  </div>
                ) : (
                  <img src={p.logo} alt="" class="w-12 h-12 sm:w-16 sm:h-16 object-contain drop-shadow-sm" loading="lazy" decoding="async" />
                )}
              </div>
            )}
            <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-gold-600 mb-2 block">
              {p.label}
            </span>
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-4">
              {p.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600 mb-6">
              {p.description}
            </p>
            <p class="text-[14px] leading-relaxed text-warm-600 italic border-t border-warm-100 pt-5">
              {p.fit}
            </p>
            <span class="inline-block mt-4 text-[14px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
              Learn more &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Outcomes ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          What you get
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Buildings that{' '}
          <em class="italic font-normal text-seam-600">earn your trust</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 gap-6">
        {outcomes.map((o) => (
          <div class="reveal-child rounded-2xl border border-warm-100 p-8 lg:p-10">
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3">
              {o.metric}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600">
              {o.detail}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Testimonial ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl mx-auto text-center">
        <svg class="mx-auto mb-8 w-12 h-12 text-warm-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
        </svg>
        <blockquote class="font-display text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.3] tracking-[-0.02em] text-white">
          When we moved into a SEAM-certified building, the difference was immediate. The air felt cleaner, the common spaces were designed for everyone, and for the first time I felt like the building was built with people like me in mind — not as an afterthought.
        </blockquote>
        <div class="mt-10">
          <p class="text-[16px] font-medium text-white">Maria Torres</p>
          <p class="text-[14px] text-warm-400 mt-1">
            Resident &middot; Alma Commons, Denver
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Frequently asked
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Questions from{' '}
          <em class="italic font-normal text-seam-600">people &amp; communities</em>
        </h2>
      </div>

      <div class="max-w-3xl">
        {faqs.map((faq) => (
          <details class="border-b border-warm-200 group">
            <summary class="flex w-full items-center justify-between py-6 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="text-[17px] lg:text-[18px] font-medium text-warm-900 pr-8">
                {faq.q}
              </span>
              <svg
                class="shrink-0 w-5 h-5 text-warm-600 transition-transform duration-300 group-open:rotate-45"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </summary>
            <div class="pb-6">
              <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">
                {faq.a}
              </p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-white max-w-3xl mx-auto">
        Choose spaces that{' '}
        <em class="italic font-normal text-seam-300">reflect your values</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-400 max-w-xl mx-auto">
        Browse certified buildings in your area, read the Standard, or share SEAM with your landlord or property manager.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/directory?tab=projects"
          class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
        >
          Find certified buildings
        </a>
        <a
          href="/resources/standard"
          class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300"
        >
          Read the Standard
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
