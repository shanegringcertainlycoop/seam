---
import SiteLayout from '../layouts/SiteLayout.astro'
import { faqSchema, breadcrumbSchema } from '../lib/seo-helpers'

/* ─── Data Arrays ─── */

const comparisons = [
  {
    title: 'Create recognized proof',
    description: 'Turn one activity into something credible and externally recognizable.',
    iconPath: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z',
  },
  {
    title: 'Give leadership something tangible',
    description: 'Show real progress with a concrete, verifiable achievement.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  },
  {
    title: 'Strengthen market positioning',
    description: 'Differentiate your building or organization with more than internal claims.',
    iconPath: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
  },
  {
    title: 'Start without overcommitting',
    description: 'Take a focused first step without pursuing full certification.',
    iconPath: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
  },
]

/* Mark-eligible activities are sourced from the digital standard.
 * Falls back to an empty list if the endpoint is unreachable at build time. */
const STANDARD_URL = (import.meta.env.STANDARD_URL as string | undefined) ?? 'https://standard.seamcertification.org'

type StandardMark = {
  activityId: string
  title: string
  url: string
  activityType: 'Driver' | 'Impact'
  ratingSystems: string[]
  pillar: { slug: string; title: string }
  concept: { slug: string; code: string; title: string }
  objective: { slug: string; code: string; title: string }
}

let approvedMarks: StandardMark[] = []
try {
  const res = await fetch(`${STANDARD_URL}/api/marks.json`)
  if (res.ok) {
    const data = (await res.json()) as { activities?: StandardMark[] }
    approvedMarks = data.activities ?? []
  }
} catch {
  // Endpoint unreachable at build time. Fall back to empty list.
}

const steps = [
  {
    number: '01',
    title: 'Select an activity',
    description: 'Select from the available SEAM Marks based on the work your organization is already doing or plans to implement.',
    cta: { label: 'Tell us what you\u2019re working on', href: '#interest-form' },
  },
  {
    number: '02',
    title: 'Submit documentation',
    description: "Provide the documentation that the activity specifies. We'll help you understand exactly what evidence we need to verify your achievement.",
  },
  {
    number: '03',
    title: 'Third-party review',
    description: 'An independent reviewer evaluates your submission against the Standard. Reviewers may request additional documentation or clarification before issuing a determination.',
  },
  {
    number: '04',
    title: 'Earn verified recognition',
    description: 'Receive the SEAM Mark for the verified activity. Your organization is listed in the SEAM directory. Repeat for additional Marks at any time.',
  },
]

const audiences = [
  {
    title: 'Property managers',
    description: 'Turn the equity programs you already run into a verified credential. Strengthen lease renewals and demonstrate value to ownership without a full certification commitment.',
  },
  {
    title: 'Anchor institutions',
    description: 'Hospitals, universities, and civic buildings can verify community benefit practices — local hiring, procurement policies, public access — one activity at a time.',
  },
  {
    title: 'Operators exploring certification',
    description: "Not sure if full certification is right for your building? Start with SEAM Marks. Every verified activity counts toward certification if you decide to pursue it later.",
  },
  {
    title: 'Portfolio managers',
    description: 'Roll out SEAM Marks across multiple properties as a portfolio-wide social equity baseline before committing individual buildings to full certification.',
  },
]

const faqs = [
  {
    q: 'How is a SEAM Mark different from full certification?',
    a: 'Full certification evaluates your entire building across all four pillars. A SEAM Mark verifies a single activity at a time (or 3–5 as Bulk Marks). Both are third-party verified and publicly listed, but Marks are faster, more focused, and lower commitment.',
  },
  {
    q: 'Does a SEAM Mark count toward full certification?',
    a: 'Yes. Every verified activity earns credit toward its pillar. If you later pursue full certification, your Marks carry forward — reducing the scope and timeline of the certification process.',
  },
  {
    q: 'How long does verification take?',
    a: 'Most activity verifications are completed within six to eight weeks from documentation submission. Timeline depends on the complexity of the activity and the completeness of your initial submission.',
  },
  {
    q: 'How much does it cost?',
    a: 'Pricing is per activity. <a href="/membership" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">Community members</a> receive discounted verification fees. Bulk Marks (3–5 related activities) save up to 60% vs. individual pricing. See <a href="/pricing" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">pricing details</a>.',
  },
  {
    q: 'Do we need a SEAM AP for activity verification?',
    a: 'No. A <a href="/ap-credential" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM AP</a> is not required for SEAM Mark submissions. However, working with an AP can strengthen your documentation and increase the likelihood of first-submission approval.',
  },
  {
    q: 'How long does the credential last?',
    a: 'SEAM Marks are valid for three years. Renewal requires updated documentation demonstrating that the verified activity remains in practice.',
  },
]

const barHeights = [14, 10, 16, 8, 18, 12]

const faqItems = faqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Solutions', path: '/certification' },
    { name: 'SEAM Marks', path: '/marks' },
  ]),
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="SEAM Marks — Activity-Level Equity Verification"
  description="Verify individual social equity practices without full certification. Single Mark or Bulk Marks (3–5 related activities). Each SEAM Mark counts toward full certification."
  path="/marks"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="/images/approved-hero.jpg"
        alt="Architectural detail — design with intention"
        class="w-full h-full object-cover object-center"
      />
    </div>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/50 to-warm-900/40"></div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="hero-enter">
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
            Activity-Level Verification
          </span>
          <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
            Verify the human impact work{' '}
            <em class="font-display italic font-normal text-seam-300">
              you already do
            </em>
          </h1>
          <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
            SEAM Marks verify individual activities from the <a href="/resources/standard" class="underline decoration-white/30 hover:decoration-white/60 transition-colors">SEAM Standard</a> without requiring full <a href="/certification" class="underline decoration-white/30 hover:decoration-white/60 transition-colors">project certification</a>. Each Mark stands on its own as a recognized achievement, and each one can count toward full certification if you choose to pursue it. Choose a Single Mark or save with Bulk Marks (3–5 related activities).
          </p>
          <div class="hero-cta mt-10 flex flex-wrap gap-4">
            <a
              href="#interest-form"
              class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
            >
              Get started
            </a>
            <a
              href="#marks"
              class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
            >
              Explore available marks
            </a>
          </div>
        </div>

        <!-- SEAM Marks logo -->
        <div class="hidden lg:flex justify-center">
          <div class="relative w-56 h-56 flex items-center justify-center">
            <!-- Burst ripple rings — fast outward pulse with gold tint -->
            <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/40" style="animation-delay: 0s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/30" style="animation-delay: 1s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/20" style="animation-delay: 2s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border border-seam-300/15" style="animation-delay: 0.5s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border border-seam-300/10" style="animation-delay: 1.5s;"></div>
            <!-- Warm glow behind mark -->
            <div class="absolute inset-[-20px] rounded-full bg-gold-400/[0.06] approved-glow"></div>
            <img src="/logos/approved-wordmark.png" alt="SEAM Marks" class="relative w-56 h-56 object-contain drop-shadow-2xl" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── How It's Different ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          How it works
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Why organizations use{' '}
          <em class="italic font-normal text-seam-600">SEAM Marks</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8">
        {comparisons.map((c) => (
          <div
            class="reveal-child group rounded-2xl border border-warm-100 p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <div class="text-gold-600 mb-6">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={c.iconPath} />
              </svg>
            </div>
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-4">
              {c.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600">
              {c.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Available Marks ─── -->
  <section id="marks" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Available SEAM Marks
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Turn your work into{' '}
          <em class="italic font-normal text-seam-600">recognized progress</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Pick from the following list of available SEAM Marks. Each is verified to earn credit toward full <a href="/certification" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM Certification</a> if you choose to pursue it.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {approvedMarks.length === 0 ? (
          <p class="col-span-full text-[15px] leading-relaxed text-warm-500">
            The list of available Marks is loading. <a href="https://standard.seamcertification.org/marks" target="_blank" rel="noopener" class="underline decoration-warm-300 hover:decoration-warm-600">Browse them on the SEAM Standard &rarr;</a>
          </p>
        ) : approvedMarks.map((mark) => (
          <a
            href={mark.url}
            target="_blank"
            rel="noopener"
            class="reveal-child rounded-2xl bg-white p-8 lg:p-10 text-left transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] hover:border-seam-300 border border-transparent group"
          >
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[12px] font-mono font-medium text-seam-700">
                {mark.activityId}
              </span>
              <span class="inline-flex items-center rounded-full bg-warm-100 px-2.5 py-0.5 text-[11px] font-medium text-warm-600">
                {mark.activityType}
              </span>
            </div>
            <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-warm-400 mb-2">
              {mark.objective.code} &middot; {mark.objective.title}
            </p>
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-3 group-hover:text-seam-700 transition-colors">
              {mark.title}
            </h3>
            {mark.ratingSystems.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-4">
                {mark.ratingSystems.map((rs) => (
                  <span class="rounded-full bg-warm-50 border border-warm-100 px-2.5 py-0.5 text-[11px] font-mono font-medium text-warm-500">
                    {rs}
                  </span>
                ))}
              </div>
            )}
            <span class="mt-4 inline-flex items-center text-[13px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
              View on the SEAM Standard &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── The Process ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          The process
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Four steps to{' '}
          <em class="italic font-normal text-seam-600">approval</em>
        </h2>
      </div>

      <div class="reveal-stagger relative">
        <!-- Vertical spine — hidden on mobile -->
        <div class="hidden lg:block absolute left-[39px] top-0 bottom-0 w-px bg-warm-200"></div>

        {steps.map((step) => (
          <div
            class="reveal-child group relative grid grid-cols-1 lg:grid-cols-[80px_1fr] gap-6 lg:gap-12 pb-16 last:pb-0"
          >
            <!-- Node -->
            <div class="hidden lg:flex flex-col items-center">
              <div class="relative z-10 flex h-[80px] w-[80px] items-center justify-center rounded-full border-2 border-warm-200 bg-white group-hover:border-seam-500 transition-colors duration-300">
                <span class="font-display text-[28px] tracking-[-0.02em] text-seam-600">
                  {step.number}
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="rounded-2xl border border-warm-100 p-8 lg:p-10 group-hover:border-warm-200 group-hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] transition-all duration-300">
              <span class="lg:hidden text-[14px] font-medium text-seam-500 mb-3 block">
                {step.number}
              </span>
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">
                {step.title}
              </h3>
              <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">
                {step.description}
              </p>
              {(step as any).cta && (
                <a
                  href={(step as any).cta.href}
                  class="inline-flex items-center mt-4 text-[14px] font-medium text-seam-600 hover:text-seam-700 transition-colors"
                >
                  {(step as any).cta.label}
                  <svg class="ml-1.5 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Who It's For ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Who it serves
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          For organizations{' '}
          <em class="italic font-normal text-seam-600">ready to lead</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {audiences.map((a) => (
          <div class="reveal-child rounded-2xl bg-white p-5 sm:p-8 lg:p-10">
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-3">
              {a.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600">
              {a.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Full-width Image Break ─── -->
  <section class="relative h-[50vh] lg:h-[60vh] overflow-hidden">
    <img
      src="/images/approved-break.jpg"
      alt="Behind the scenes — the people and processes behind social equity certification"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-warm-900/20"></div>
  </section>

  <!-- ─── Pricing ─── -->
  <section id="pricing" class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Pricing
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Simple, transparent{' '}
          <em class="italic font-normal text-seam-600">pricing</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Choose the option that fits your organization. Every verified activity earns credit toward full SEAM Certification.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
        <!-- Single Mark -->
        <div class="reveal-child rounded-2xl border border-warm-100 bg-white p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-4">
            Single Mark
          </p>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-display text-[clamp(2.5rem,4vw,3.5rem)] tracking-[-0.03em] text-warm-900">$750</span>
          </div>
          <p class="text-[15px] text-warm-500 mb-8">per activity verification</p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              One SEAM Mark
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              Third-party verification
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              Directory listing &amp; credential
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              Counts toward full certification
            </li>
          </ul>
          <a
            href="#interest-form"
            class="inline-flex items-center justify-center w-full rounded-full border-2 border-warm-900 px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-900 hover:text-white transition-colors duration-300"
          >
            Get started
          </a>
        </div>

        <!-- Bulk Marks -->
        <div class="reveal-child relative rounded-2xl border-2 border-seam-500 bg-white p-10 lg:p-12 transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)]">
          <span class="absolute -top-3.5 left-8 inline-block rounded-full bg-seam-600 px-4 py-1 text-[12px] font-medium text-white tracking-wide uppercase">
            Best value
          </span>
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-4">
            Bulk Marks
          </p>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-display text-[clamp(2.5rem,4vw,3.5rem)] tracking-[-0.03em] text-warm-900">$2,000</span>
          </div>
          <p class="text-[15px] text-warm-500 mb-8">3–5 related activities</p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              3–5 related SEAM Marks
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
