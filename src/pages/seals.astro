---
import SiteLayout from '../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../lib/seo-helpers'

const benefits = [
  {
    title: 'Proof, not promises',
    body: 'Independent SEAM review against the same Standard that powers full Certification — applied to one defined theme.',
  },
  {
    title: 'A faster, narrower path',
    body: 'Earn credible recognition without certifying the whole building. Show focused commitment now.',
  },
  {
    title: 'Recognized publicly',
    body: 'A shareable claim, listed in the SEAM directory. Buyers, regulators, and investors can see the work.',
  },
  {
    title: 'Counts toward Certification',
    body: 'Every Activity you complete for a Seal compounds into future SEAM Certification when scope aligns.',
  },
]

const pilots = [
  {
    seal: 'Community Development Seal',
    href: '/directory/project/t2s-cares-liberia',
    image: '/images/directory/project-t2s-cares-liberia.png',
    name: 'T2S C.A.R.E.S. Liberia Mental Health Infrastructure Initiative',
    location: 'Liberia',
    owner: 'T2S C.A.R.E.S.',
    blurb:
      'SEAM is applying its built-environment community development framework to a mental health infrastructure initiative — using the project as a pilot to inform the Community Development Seal.',
  },
  {
    seal: 'Ethical Procurement Seal',
    href: '/directory/project/private-client-modern-slavery-endorsement',
    image: '/images/directory/project-modern-slavery-endorsement.jpg',
    name: 'Private Client — Modern Slavery Assessment',
    location: 'Australian Modern Slavery Act 2018',
    owner: 'Global Investment Manager',
    blurb:
      "A confidential Modern Slavery Assessment for a real estate investment manager — testing how SEAM can verify a focused subset of modern slavery requirements, and informing the Ethical Procurement Seal.",
  },
]

const howItWorks = [
  {
    n: '01',
    title: 'Pick a theme',
    body: 'Choose the Seal that matches the work you\'re already doing — supply-chain due diligence, community development, and more on the way.',
  },
  {
    n: '02',
    title: 'Complete the Activities',
    body: 'Each Seal is a defined set of SEAM Standard activities, scoped to your context. Pull from work you\'re already doing where it counts.',
  },
  {
    n: '03',
    title: 'Get independently reviewed',
    body: 'SEAM verifies your evidence against the Standard. Earn the Seal — and where performance is exceptional, the Leading Practice distinction.',
  },
]

const faqs = [
  {
    question: 'What is a SEAM Seal?',
    answer:
      'A SEAM Seal is a thematic recognition awarded for completing a curated set of 12–26 related activities from the SEAM Standard. The Seal sits between Marks (single or bundled activity verification) and full Certification (whole-building, all pillars). It gives organizations a focused, theme-specific recognition without taking on a whole-building certification.',
  },
  {
    question: 'How is the Seal different from Marks?',
    answer:
      'Marks verify one activity (Single Mark) or a small bundle of 3 related activities (Bulk Marks). A Seal is broader — a curated theme of 12–26 activities that demonstrate sustained action across one focused area of social equity work.',
  },
  {
    question: 'How is the Seal different from Certification?',
    answer:
      'Full SEAM Certification evaluates a building across all four pillars and the full activity set. A Seal is narrower and themed — it lets an organization prove sustained action in a specific area (for example, the Ethical Procurement Seal or the Community Development Seal) without pursuing whole-building certification.',
  },
  {
    question: 'How is a Seal awarded?',
    answer:
      'Achievement is binary: you complete the applicable Activity subset for the reviewed scope, or you don\'t. Organizations that meet Gold- or Platinum-equivalent thresholds within the subset earn the additional distinction "[Seal Name] — Leading Practice." The Seal is designed so that organizations can only earn it when their evidence is clear. Credible evidence of active, unaddressed harm within the reviewed scope means the Seal cannot be granted until that issue is resolved or documented through an approved corrective action process.',
  },
  {
    question: 'What is the "Assessment Scope"?',
    answer:
      'Every Seal claim is bounded by an Assessment Scope: the explicit definition of what was reviewed, by whom, for what period, and under which conditions. That keeps the public claim transparent to buyers, regulators, investors, and impacted parties. A Seal only applies to what was reviewed, not to entities or activities outside that scope.',
  },
  {
    question: 'Which Seals are available?',
    answer:
      'Two Seals are open now in pilot cohorts: the Ethical Procurement Seal ($5,000) and the Community Development Seal ($2,500). Each is a flat fee per Assessment Scope. More themes are in development.',
  },
]

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'SEAM Seal', path: '/seals' },
  ]),
  faqSchema(faqs),
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="SEAM Seal — Thematic Social Equity Recognitions"
  description="A SEAM Seal proves sustained commitment to one social equity theme — independently reviewed, publicly listed, and built on the same Standard as full Certification."
  path="/seals"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-warm-900">
    <img
      src="/images/seals/seals-overview-hero.jpg"
      alt="People studying a community map together"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-warm-900/85 via-warm-900/65 to-warm-900/35"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900/70 via-transparent to-warm-900/20"></div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-16 items-center">
        <div class="hero-enter max-w-2xl">
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
            SEAM Seal
          </span>
          <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.25rem)] leading-[1.05] tracking-[-0.04em] text-white">
            Prove one thing <em class="font-display italic font-normal text-seam-300">deeply.</em>
          </h1>
          <p class="hero-subtitle mt-8 max-w-2xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
            Independently verified and built on the SEAM Standard, a SEAM Seal recognizes deep, focused commitment in one area of human impact without requiring full building certification. Each Seal is publicly listed, and the work behind it is reviewed against the same criteria that power full SEAM Certification.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/get-started" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[15px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
              Talk to an advisor
            </a>
          </div>
        </div>

        <!-- Shields -->
        <div class="hero-enter flex items-end justify-center mx-auto lg:mx-0 -space-x-10 sm:-space-x-14 lg:-space-x-16">
          <img
            src="/logos/seal-ethical-procurement.svg"
            alt="Ethical Procurement Seal"
            class="w-36 h-36 sm:w-44 sm:h-44 lg:w-52 lg:h-52 object-contain drop-shadow-2xl"
            loading="eager"
            decoding="async"
          />
          <img
            src="/logos/seal-community-development.svg"
            alt="Community Development Seal"
            class="w-36 h-36 sm:w-44 sm:h-44 lg:w-52 lg:h-52 object-contain drop-shadow-2xl"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Why a Seal ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Why a Seal</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Focused commitment, <em class="italic font-normal text-seam-600">verified</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {benefits.map((b) => (
          <div class="rounded-2xl bg-warm-50 border border-warm-200/60 p-6 lg:p-8">
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-3">{b.title}</h3>
            <p class="text-[15px] leading-relaxed text-warm-600">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── The first Seal ─── -->
  <section id="themes" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">The SEAM Seal</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Two themes <em class="italic font-normal text-seam-600">ready to earn</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          Each Seal is a curated group of SEAM Standard activities that represent deep, demonstrable commitment in a focused area. The first two are being shaped through live pilots with anchor organizations.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        <a href="/seals/ethical-procurement" class="group relative rounded-2xl bg-white border border-warm-200/60 p-8 lg:p-10 pt-20 lg:pt-24 flex flex-col transition-all duration-300 hover:border-seam-300 hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)]">
          <img src="/logos/seal-ethical-procurement.svg" alt="Ethical Procurement Seal" width="120" height="139" loading="lazy" decoding="async" class="absolute -top-6 right-5 lg:right-6 w-20 lg:w-24 h-auto drop-shadow-md" />
          <h3 class="font-display text-[28px] tracking-[-0.02em] text-warm-900 group-hover:text-seam-700 transition-colors">Ethical Procurement</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-warm-600 flex-1">
            Show your supply chain can stand up to modern-slavery and forced-labor scrutiny — without certifying the whole building. Aligns with the Australian and UK Modern Slavery Acts, UFLPA, EU Forced Labour Regulation, UNGPs, OECD, and ILO standards.
          </p>
          <span class="mt-6 inline-flex items-center text-[14px] font-medium text-seam-600 group-hover:text-seam-700 transition-colors">
            Explore the Ethical Procurement Seal &rarr;
          </span>
        </a>

        <a href="/seals/community-development" class="group relative rounded-2xl bg-white border border-warm-200/60 p-8 lg:p-10 pt-20 lg:pt-24 flex flex-col transition-all duration-300 hover:border-seam-300 hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)]">
          <img src="/logos/seal-community-development.svg" alt="Community Development Seal" width="120" height="139" loading="lazy" decoding="async" class="absolute -top-6 right-5 lg:right-6 w-20 lg:w-24 h-auto drop-shadow-md" />
          <h3 class="font-display text-[28px] tracking-[-0.02em] text-warm-900 group-hover:text-seam-700 transition-colors">Community Development</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-warm-600 flex-1">
            Prove a community initiative is real work — designed with impacted parties, tied to a material issue, delivered, and independently reviewed. The Seal that separates a serious initiative from a one-off volunteer event.
          </p>
          <span class="mt-6 inline-flex items-center text-[14px] font-medium text-seam-600 group-hover:text-seam-700 transition-colors">
            Explore the Community Development Seal &rarr;
          </span>
        </a>
      </div>

    </div>
  </section>

  <!-- ─── Pilots in action ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Pilots in action</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Real organizations, <em class="italic font-normal text-seam-600">real reviews</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          Each first-cohort Seal is being shaped against an active pilot project. These aren't hypothetical — they're the work that's defining what each Seal stands for.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {pilots.map((p) => (
          <a
            href={p.href}
            class="block group rounded-2xl overflow-hidden border border-warm-200/60 bg-white transition-all duration-300 hover:border-seam-300 hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)]"
          >
            <div class="relative bg-warm-900 aspect-[16/9] overflow-hidden">
              <img
                src={p.image}
                alt={p.name}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-7 lg:p-8 flex flex-col">
              <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-3">{p.seal} pilot</p>
              <h3 class="font-display text-[22px] tracking-[-0.02em] text-warm-900 leading-tight mb-3 group-hover:text-seam-700 transition-colors">
                {p.name}
              </h3>
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="inline-flex items-center rounded-full bg-warm-100 px-2.5 py-0.5 text-[11px] font-medium text-warm-600">
                  {p.owner}
                </span>
                <span class="inline-flex items-center rounded-full bg-warm-100 px-2.5 py-0.5 text-[11px] font-medium text-warm-600">
                  {p.location}
                </span>
              </div>
              <p class="text-[14px] leading-relaxed text-warm-600 mb-5 flex-1">
                {p.blurb}
              </p>
              <span class="inline-flex items-center text-[13px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
                View the project profile &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>

      <p class="mt-10 text-[17px] leading-relaxed text-warm-700 max-w-2xl">
        Both Seals are now accepting pilot participants. <a href="/get-started" class="font-medium text-seam-700 underline decoration-warm-300 hover:decoration-seam-500 transition-colors">Talk to an advisor</a> to get involved.
      </p>
    </div>
  </section>

  <!-- ─── How it works ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">How it works</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Three steps to a <em class="italic font-normal text-seam-600">verified Seal</em>
        </h2>
      </div>

      <div class="space-y-4">
        {howItWorks.map((step) => (
          <div class="grid grid-cols-[60px_1fr] lg:grid-cols-[120px_1fr] gap-6 lg:gap-10 rounded-2xl border border-warm-200/60 bg-white p-6 lg:p-8">
            <p class="font-display text-[36px] lg:text-[44px] tracking-[-0.04em] text-seam-600 leading-none">{step.n}</p>
            <div>
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">{step.title}</h3>
              <p class="text-[15px] leading-relaxed text-warm-600 max-w-2xl">{step.body}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-8 text-[14px] leading-relaxed text-warm-500 max-w-3xl">
        Every Seal claim is bounded by a clearly defined Assessment Scope — what was reviewed, by whom, for what period. That keeps the public claim transparent to buyers, investors, and regulators.
      </p>
    </div>
  </section>

  <!-- ─── Pricing ─── -->
  <section id="pricing" class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Pricing
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          A flat fee per <em class="italic font-normal text-seam-600">Seal</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Each Seal is priced per Assessment Scope. Every activity counts toward full SEAM Certification if you choose to pursue it later.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
        <!-- Community Development Seal -->
        <a
          href="/seals/community-development"
          class="reveal-child group rounded-2xl border border-warm-100 bg-white p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] flex flex-col"
        >
          <div class="flex items-start justify-between gap-4 mb-4">
            <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600">Community Development Seal</p>
            <img src="/logos/seal-community-development.svg" alt="" aria-hidden="true" class="w-12 h-auto -mt-1 shrink-0" loading="lazy" decoding="async" />
          </div>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-display text-[clamp(2.5rem,4vw,3.5rem)] tracking-[-0.03em] text-warm-900">$2,500</span>
          </div>
          <p class="text-[15px] text-warm-500 mb-8">per Seal · per Assessment Scope</p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              One reviewed community initiative
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Independent review against the Seal pathway
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Public listing with Assessment Scope
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Activities count toward full Certification
            </li>
          </ul>
          <span class="mt-auto inline-flex items-center justify-center w-full rounded-full border-2 border-warm-900 px-8 py-4 text-[16px] font-medium text-warm-900 group-hover:bg-warm-900 group-hover:text-white transition-colors duration-300">
            Explore the CD Seal &rarr;
          </span>
        </a>

        <!-- Ethical Procurement Seal -->
        <a
          href="/seals/ethical-procurement"
          class="reveal-child group rounded-2xl border border-warm-100 bg-white p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] flex flex-col"
        >
          <div class="flex items-start justify-between gap-4 mb-4">
            <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600">Ethical Procurement Seal</p>
            <img src="/logos/seal-ethical-procurement.svg" alt="" aria-hidden="true" class="w-12 h-auto -mt-1 shrink-0" loading="lazy" decoding="async" />
          </div>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-display text-[clamp(2.5rem,4vw,3.5rem)] tracking-[-0.03em] text-warm-900">$5,000</span>
          </div>
          <p class="text-[15px] text-warm-500 mb-8">per Seal · per Assessment Scope</p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              One reviewed entity, scope, and period
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Independent review against the Seal pathway
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Aligns with UK / AU Modern Slavery Acts, UFLPA, UNGPs
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Activities count toward full Certification
            </li>
          </ul>
          <span class="mt-auto inline-flex items-center justify-center w-full rounded-full border-2 border-warm-900 px-8 py-4 text-[16px] font-medium text-warm-900 group-hover:bg-warm-900 group-hover:text-white transition-colors duration-300">
            Explore the EP Seal &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Where Seal fits ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Where Seal fits</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Between a Mark and a <em class="italic font-normal text-seam-600">full Certification</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          SEAM offers three depths of recognition. Choose the one that matches your scope today — and build toward the next one as your practice matures.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
