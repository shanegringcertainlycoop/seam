        <aside class="hidden lg:block lg:sticky lg:top-24">
          <div class="rounded-2xl overflow-hidden aspect-[3/4] bg-warm-100">
            <img
              src="/images/seals/seals-overview-faq.jpg"
              alt="Two people in colorful jackets standing together against a yellow wall"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </aside>
      </div>
