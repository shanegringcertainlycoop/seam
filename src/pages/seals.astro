  </section>

  <!-- ─── Interest Form ─── -->
  <section id="interest-form" class="py-24 lg:py-32 bg-warm-900">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-start">
        <!-- Left: copy -->
        <div class="reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
            Get started
          </p>
          <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white">
            Join a Seal <em class="italic font-normal text-seam-300">pilot cohort.</em>
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-400 max-w-lg">
            Tell us about your work and which Seal fits. We'll walk you through the Assessment Scope, documentation, and review process — and confirm timing.
          </p>
          <div class="mt-8 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="shrink-0 w-5 h-5 text-seam-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <p class="text-[15px] text-warm-300">No commitment required — just a conversation</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="shrink-0 w-5 h-5 text-seam-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <p class="text-[15px] text-warm-300">We'll respond within 2 business days</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="shrink-0 w-5 h-5 text-seam-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <p class="text-[15px] text-warm-300">Every Seal activity counts toward full Certification</p>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div>
          <form id="seal-interest-form" class="rounded-2xl bg-white/[0.06] backdrop-blur-sm border border-white/[0.1] p-8 lg:p-10 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="seal-firstname" class="block text-[13px] font-medium text-warm-300 mb-2">First Name *</label>
                <input type="text" id="seal-firstname" name="firstname" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
              <div>
                <label for="seal-lastname" class="block text-[13px] font-medium text-warm-300 mb-2">Last Name *</label>
                <input type="text" id="seal-lastname" name="lastname" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
            </div>
            <div>
              <label for="seal-email" class="block text-[13px] font-medium text-warm-300 mb-2">Work Email *</label>
              <input type="email" id="seal-email" name="email" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="seal-company" class="block text-[13px] font-medium text-warm-300 mb-2">Company Name *</label>
                <input type="text" id="seal-company" name="company" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
              <div>
                <label for="seal-jobtitle" class="block text-[13px] font-medium text-warm-300 mb-2">Job Title *</label>
                <input type="text" id="seal-jobtitle" name="jobtitle" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
            </div>
            <div>
              <label for="seal-interest" class="block text-[13px] font-medium text-warm-300 mb-2">Which Seal are you interested in, and what's the scope? *</label>
              <textarea id="seal-interest" name="seam_activities_certified_list" rows="3" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
              Submit interest
            </button>
            <p id="seal-form-status" class="text-[13px] text-center text-warm-400 hidden"></p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    function initSealForm() {
      const form = document.getElementById('seal-interest-form') as HTMLFormElement | null
      if (!form) return

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
        const statusEl = document.getElementById('seal-form-status')!
        const original = btn.textContent

        btn.disabled = true
        btn.textContent = 'Submitting...'
        statusEl.classList.add('hidden')

        const data = new FormData(form)
        const fields = [
          { objectTypeId: '0-1', name: 'firstname', value: data.get('firstname') },
          { objectTypeId: '0-1', name: 'lastname', value: data.get('lastname') },
          { objectTypeId: '0-1', name: 'email', value: data.get('email') },
          { objectTypeId: '0-1', name: 'company', value: data.get('company') },
          { objectTypeId: '0-1', name: 'jobtitle', value: data.get('jobtitle') },
          { objectTypeId: '0-1', name: 'seam_activities_certified_list', value: data.get('seam_activities_certified_list') },
        ]

        try {
          const res = await fetch(
            'https://api.hsforms.com/submissions/v3/integration/submit/46821728/bc0c72ba-7cb7-49c1-8113-7e179a941086',
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                fields,
                context: {
                  pageUri: window.location.href,
                  pageName: 'SEAM Seal',
                },
              }),
            }
          )

          if (res.ok) {
            form.reset()
            statusEl.textContent = "Thank you! We'll be in touch within 2 business days."
            statusEl.classList.remove('hidden', 'text-red-400')
            statusEl.classList.add('text-seam-300')
          } else {
            throw new Error('Submission failed')
          }
        } catch (_err) {
          statusEl.textContent = 'Something went wrong. Please email admin@seamcertification.org directly.'
          statusEl.classList.remove('hidden', 'text-seam-300')
          statusEl.classList.add('text-red-400')
        } finally {
          btn.disabled = false
          btn.textContent = original
        }
      })
    }

    document.addEventListener('astro:page-load', initSealForm)
    if (document.readyState !== 'loading') {
      initSealForm()
    } else {
      document.addEventListener('DOMContentLoaded', initSealForm)
    }
  </script>
</SiteLayout>
