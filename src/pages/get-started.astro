---
import SiteLayout from '../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../lib/seo-helpers'
import { team } from '../data/team'

const rainey = team.find((m) => m.slug === 'rainey-shane')!

const topics = [
  {
    title: 'Certification',
    description: 'Full building certification across four rating systems and four achievement levels.',
    href: '/certification',
  },
  // HIDDEN: Approved program temporarily hidden
  // {
  //   title: 'SEAM Approved',
  //   description: 'Verify a single activity — a product, service, or program — without full certification.',
  //   href: '/approved',
  // },
  {
    title: 'AP Credential',
    description: 'Become a SEAM Accredited Professional and guide projects through the Standard.',
    href: '/ap-credential',
    sale: 'Bundle $389 (reg. $519) — code SITELAUNCH25 · ends May 31',
  },
  {
    title: 'Community Membership',
    description: 'Join the network of organizations and professionals advancing social equity.',
    href: '/membership',
  },
]

const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Talk to an Advisor', path: '/get-started' },
])
---

<SiteLayout
  title="Talk to an Advisor — SEAM"
  description="Book a call with Rainey Shane to explore SEAM Certification, the AP credential, or membership."
  path="/get-started"
  jsonLd={[jsonLd]}
>

  <!-- ─── Hero ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-3xl">
        <p class="hero-enter text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
          Talk to an advisor
        </p>
        <h1 class="hero-enter font-display text-[clamp(2.5rem,5vw,4rem)] leading-[1.08] tracking-[-0.03em] text-white" style="animation-delay:.05s">
          Let's talk about what's <em class="italic font-normal text-seam-300">possible</em>
        </h1>
        <p class="hero-enter mt-6 text-[18px] leading-relaxed text-warm-400 max-w-2xl" style="animation-delay:.1s">
          No pressure, no pitch. Just a conversation about where you are, where you want to go, and how SEAM can help you get there.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Rainey Showcase + Calendar ─── -->
  <section id="calendar" class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <!-- Left: Rainey's profile -->
        <div class="reveal-slide-left">
          <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
            <img
              src={rainey.image}
              alt={rainey.name}
              class="w-48 h-48 lg:w-56 lg:h-56 rounded-full object-cover object-top shadow-[0_16px_48px_rgba(0,0,0,0.12)]"
            />
            <h2 class="mt-8 font-display text-[28px] lg:text-[32px] tracking-[-0.02em] text-warm-900">
              {rainey.name}
            </h2>
            <p class="mt-1 text-[16px] font-medium text-seam-600">
              {rainey.role}
            </p>
            <div class="mt-5 space-y-4 text-[16px] leading-relaxed text-warm-600 max-w-md">
              {rainey.bio.split('\n\n').map((p) => <p>{p}</p>)}
            </div>
            {rainey.linkedIn && (
              <a
                href={rainey.linkedIn}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex items-center gap-2 text-[14px] font-medium text-warm-500 hover:text-seam-600 transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                Connect on LinkedIn
              </a>
            )}
          </div>
        </div>

        <!-- Right: HubSpot meetings embed -->
        <div class="reveal-fade-up">
          <div class="rounded-2xl border border-warm-100 bg-warm-50 p-8 lg:p-10 min-h-[500px] flex flex-col items-center justify-center">
            <!-- Replace this placeholder with your HubSpot meetings embed -->
            <!-- Example: <iframe src="https://meetings.hubspot.com/rainey-shane" width="100%" height="600" frameborder="0"></iframe> -->
            <div class="text-center">
              <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-seam-100">
                <svg class="h-8 w-8 text-seam-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
              </div>
              <p class="font-display text-[22px] tracking-[-0.02em] text-warm-900 mb-2">
                Book a time with Rainey
              </p>
              <p class="text-[15px] text-warm-500 max-w-sm">
                Calendar embed loading&hellip; If it doesn't appear, <a href="mailto:rainey@seamstandard.org" class="underline decoration-seam-300 hover:decoration-seam-600 transition-colors">email Rainey directly</a>.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── What You Can Discuss ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          What you can discuss
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Every path starts with a{' '}
          <em class="italic font-normal text-seam-600">conversation</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {topics.map((topic) => (
          <div class="reveal-child rounded-2xl border border-warm-100 bg-white p-8 flex flex-col">
            <h3 class="font-display text-[22px] tracking-[-0.02em] text-warm-900 mb-3">
              {topic.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600 mb-4 flex-1">
              {topic.description}
            </p>
            {topic.sale && (
              <div class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 border border-amber-200 px-2.5 py-1 mb-4">
                <svg class="w-3.5 h-3.5 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                <span class="text-[11px] font-semibold text-amber-800">{topic.sale}</span>
              </div>
            )}
            <a
              href={topic.href}
              class="inline-flex items-center text-[14px] font-medium text-seam-600 hover:text-seam-700 transition-colors self-start"
            >
              Learn more &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Bottom CTA ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-white mb-6">
        Ready to start the <em class="italic font-normal text-seam-300">conversation</em>?
      </h2>
      <p class="text-[17px] text-warm-400 max-w-xl mx-auto mb-10">
        Pick a time that works for you. No commitment, no forms &mdash; just a conversation about what's possible.
      </p>
      <a
        href="#calendar"
        class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
      >
        Book a time with Rainey &uarr;
      </a>
    </div>
  </section>

</SiteLayout>
