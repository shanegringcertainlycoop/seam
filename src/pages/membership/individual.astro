---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../../lib/seo-helpers'
import { seamAPs } from '../../data/directory'

const individualMembers = seamAPs.filter((ap) => (ap.membershipTier === 'Open' || ap.membershipTier === 'Changemaker') && ap.photo)

const included = [
  { title: 'Access to The Stitch', description: 'Our member community platform, with pre-built documentation templates for every activity in the Standard. Start from proven formats instead of blank pages.' },
  { title: 'Discounts on Certifications and Events', description: 'Member pricing on full certification fees, the AP exam, and in-person events throughout the year.' },
  { title: 'Recognition in the SEAM Directory', description: 'A public profile in the SEAM practitioner directory. Connect with APs, project teams, and peers. Receive inbound referrals from organizations seeking expertise.' },
  { title: 'Resources & Expert Insights', description: 'Self-paced courses covering the Standard, equity in commercial real estate, and access to the SEAM community.' },
  { title: 'Content Sharing in the SEAM Network', description: 'Publish case studies, project write-ups, and research to a network of practitioners. Model the financial impact of social equity outcomes with ROSSI.' },
  { title: 'A Community Built for Impact', description: 'Participate in advisory sessions, pilot new activities, and help shape future versions of the SEAM Standard. Your voice moves the field forward.' },
]

const tiers = [
  {
    name: 'Open',
    price: 'Free',
    period: '',
    description: 'For those exploring SEAM and seeking to get involved. No commitment required.',
    features: ['Join critical conversations', 'Attend public webcasts and events', 'Monthly newsletter with field updates', 'LEED Crosswalk access'],
    cta: 'Get started free',
    href: 'https://community.seamcertification.org/plans/1975148',
    highlighted: false,
    badge: '/logos/member-individual.png',
  },
  {
    name: 'Changemaker',
    price: '$99',
    period: '/year',
    description: 'For those who want more than basic access. Tangible benefits and opportunities to participate more meaningfully in SEAM\u2019s ongoing work.',
    features: ['Access to The Stitch: SEAM online community + resources', 'Recognition in the SEAM Member Directory', 'Eligible to join Technical Advisory Groups shaping industry standards', '5% discount on SEAM events', '5% discount on SEAM certifications, endorsements, and marks', 'LEED Crosswalk access'],
    cta: 'Join as a Changemaker',
    href: 'https://community.seamcertification.org/plans/1975151',
    highlighted: true,
    badge: '/logos/member-changemaker.png',
  },
]

const personas = [
  { title: 'Consultants building a SEAM practice', description: 'SEAM Templates and the practitioner network give you the tools to serve clients pursuing certification.' },
  { title: 'APs maintaining their credential', description: 'CEU-eligible courses, webcasts, and peer sessions keep you current.' },
  { title: 'Professionals preparing for the AP exam', description: 'Study for the AP exam with courses covering all four pillars and the certification process.' },
  { title: 'Advocates entering the built environment', description: 'The Standard, introductory courses, and access to a broad network of social equity experts.' },
]

const faqs = [
  { q: 'What is the difference between Open and Changemaker?', a: 'Open is free and gives you access to the SEAM global membership network, member meetups, public resources, informational webinars, newsletter, and feed. Changemaker ($99/yr) provides deeper participation in SEAM’s work. Paid membership includes 5% discount on SEAM events and project certifications, endorsements, and marks; eligibility to apply for SEAM Technical Advisory Groups; and access to select SEAM AP webinars and continuing education sessions for learning purposes. Continuing education credit applies only to credentialed SEAM APs, but Changemaker Members may attend these sessions to build knowledge and stay engaged with emerging SEAM guidance, tools, and implementation practices.' },
  { q: 'Can I upgrade or downgrade at any time?', a: 'Yes. Upgrade from Open to Changemaker or Special Access at any time — your billing starts immediately. Downgrade at the end of your annual billing cycle.' },
  { q: 'Is there special pricing for students or nonprofits?', a: 'Yes. Special Access pricing is available for students, emerging and developing country members, nonprofit staff, and early-career professionals. Income-qualified, honor system.' },
  { q: 'Do Changemaker benefits carry over if I let my membership lapse?', a: 'Course completions and CEU records are permanent. Template access, ROSSI, and network features require an active membership. Re-join anytime to restore access.' },
  { q: 'Can my employer reimburse individual membership?', a: 'Yes. We provide invoices and receipts suitable for professional development reimbursement. Many employers cover Changemaker membership as a continuing education benefit.' },
]

const faqItems = faqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Community', path: '/membership' },
    { name: 'Individual Membership', path: '/membership/individual' },
  ]),
]
---

<SiteLayout
  title="Individual SEAM Membership — Free & Changemaker Tiers"
  description="Join the SEAM practitioner community. Open (free) and Changemaker ($99/yr) tiers with templates, courses, ROSSI access, and certification discounts."
  path="/membership/individual"
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/hero-individual.jpg"
        alt="Individual membership for practitioners"
        class="h-full w-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>
    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-3xl">
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          Individual Membership
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Your commitment. <em class="font-display italic font-normal text-seam-300">Your pace.</em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          The built environment can shape who thrives and who doesn't. Membership connects you to the people advancing social equity and the tools to move you forward, wherever you are in the work.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a href="https://community.seamcertification.org/plans/1975148" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
            Join for free
          </a>
          <a href="#pricing" class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">
            Compare tiers
          </a>
        </div>
      </div>
    </div>
    <div class="hidden lg:flex absolute -bottom-24 right-12 items-end gap-0 z-10">
      <img src="/logos/member-individual.png" alt="Individual membership" class="w-64 h-64 object-contain drop-shadow-2xl -mr-12" loading="lazy" decoding="async" />
      <img src="/logos/member-changemaker.png" alt="Changemaker membership" class="w-64 h-64 object-contain drop-shadow-2xl" loading="lazy" decoding="async" />
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">What you get</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Tools to build <em class="italic font-normal text-seam-600">a real practice</em>
        </h2>
      </div>
      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {included.map((item) => (
          <div class="reveal-child rounded-2xl border border-warm-100 p-6 sm:p-8 lg:p-10 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3">{item.title}</h3>
            <p class="text-[15px] leading-relaxed text-warm-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Pricing</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Pick what <em class="italic font-normal text-seam-600">you need</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Start free with Open. Upgrade when you are ready. Downgrade or cancel anytime.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 pt-12 items-stretch">
        {tiers.map((tier) => (
          <div class={`relative overflow-visible rounded-2xl p-6 sm:p-8 lg:p-10 flex flex-col ${tier.highlighted ? 'bg-warm-900 text-white' : 'bg-white border border-warm-100'}`}>
            <img src={tier.badge} alt="" class="absolute -top-12 right-10 w-24 h-24 object-contain drop-shadow-lg" loading="lazy" decoding="async" />
            <h3 class={`font-display text-[28px] tracking-[-0.02em] ${tier.highlighted ? 'text-white' : 'text-warm-900'}`}>{tier.name}</h3>
            <div class="mt-3 flex items-baseline gap-1">
              <span class={`font-display text-[40px] tracking-[-0.04em] ${tier.highlighted ? 'text-white' : 'text-warm-900'}`}>{tier.price}</span>
              {tier.period && <span class={`text-[16px] ${tier.highlighted ? 'text-warm-400' : 'text-warm-600'}`}>{tier.period}</span>}
            </div>
            <p class={`mt-4 text-[15px] leading-relaxed ${tier.highlighted ? 'text-warm-300' : 'text-warm-600'}`}>{tier.description}</p>

            <ul class="mt-8 space-y-3 flex-1">
              {tier.features.map((f) => (
                <li class={`flex items-start gap-2.5 text-[14px] leading-snug ${tier.highlighted ? 'text-warm-200' : 'text-warm-600'}`}>
                  <svg class={`shrink-0 w-4 h-4 mt-0.5 ${tier.highlighted ? 'text-seam-400' : 'text-seam-500'}`} fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a href={tier.href} target={tier.href.startsWith('http') ? '_blank' : undefined} rel={tier.href.startsWith('http') ? 'noopener noreferrer' : undefined} class={`mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3.5 text-[15px] font-medium transition-colors duration-300 ${tier.highlighted ? 'bg-white text-warm-900 hover:bg-warm-100' : 'bg-warm-900 text-white hover:bg-warm-800'}`}>
              {tier.cta}
            </a>
          </div>
        ))}

        <!-- Right column: Educational Access info box -->
        <a href="https://community.seamcertification.org/plans/1975151" target="_blank" rel="noopener noreferrer" class="group rounded-2xl border border-warm-200 p-6 sm:p-8 lg:p-10 flex flex-col transition-all duration-300 hover:border-warm-300">
          <h3 class="font-display text-[22px] tracking-[-0.02em] text-warm-900 mb-3">Educational Access</h3>
          <p class="text-[15px] leading-relaxed text-warm-600 flex-1">
            For students, global members, nonprofit staff, and early-career professionals. Income-qualified, honor system.
          </p>
          <span class="mt-6 inline-flex items-center text-[15px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
            Apply for a discounted Changemaker rate &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Who it serves</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Wherever you are <em class="italic font-normal text-seam-600">in your journey</em>
        </h2>
      </div>
      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 gap-6">
        {personas.map((p) => (
          <div class="reveal-child rounded-2xl bg-warm-50 p-6 sm:p-8 lg:p-10">
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3">{p.title}</h3>
            <p class="text-[15px] leading-relaxed text-warm-600">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Members -->
  <section class="py-24 lg:py-32 bg-gradient-to-b from-warm-900 to-warm-800">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">From the directory</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white">
          Members making <em class="italic font-normal text-seam-300">an impact</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-400 max-w-xl">
          Individual and Changemaker members leading certification projects and advancing social equity across the built environment.
        </p>
      </div>
      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {individualMembers.map((member) => (
          <a href={`/directory/ap/${member.slug}`} class="reveal-child group rounded-2xl bg-white/5 border border-white/10 p-6 transition-all duration-300 hover:bg-white/10 hover:border-white/20">
            <div class="flex items-start gap-4 mb-4">
              <img
                src={member.photo}
                alt={member.name}
                class="w-14 h-14 rounded-full object-cover shrink-0 ring-2 ring-white/10"
                loading="lazy"
                decoding="async"
              />
              <div class="min-w-0">
                <p class="text-[16px] font-medium text-white truncate group-hover:text-seam-300 transition-colors">{member.name}</p>
                <p class="text-[13px] text-warm-400 truncate">{member.title}</p>
              </div>
            </div>
            <p class="text-[13px] text-warm-400 mb-4">{member.organization}</p>
            <div class="flex items-center gap-2">
              <img
                src={member.membershipTier === 'Changemaker' ? '/logos/member-changemaker.png' : '/logos/member-individual.png'}
                alt={`${member.membershipTier} member`}
                class="w-6 h-6 object-contain"
                loading="lazy"
                decoding="async"
              />
              <span class="text-[12px] font-medium text-warm-300">{member.membershipTier} Member</span>
              {member.credentials && (
                <span class="ml-auto text-[11px] font-medium text-gold-400 bg-gold-400/10 rounded-full px-2 py-0.5">{member.credentials}</span>
              )}
            </div>
          </a>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/directory" class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300">
          View full directory &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-start">
        <div>
          <div class="reveal-slide-left max-w-2xl mb-12 lg:mb-16">
            <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Frequently asked</p>
            <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
              Questions about <em class="italic font-normal text-seam-600">individual membership</em>
            </h2>
          </div>
          <div>
            {faqs.map((faq) => (
              <details class="border-b border-warm-200 group">
                <summary class="flex w-full items-center justify-between py-6 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span class="text-[17px] lg:text-[18px] font-medium text-warm-900 pr-8">{faq.q}</span>
                  <svg class="shrink-0 w-5 h-5 text-warm-600 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                </summary>
                <div class="pb-6">
                  <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
        <div class="reveal-scale hidden lg:block">
          <div class="aspect-square overflow-hidden rounded-2xl">
            <img src="/images/individual-faq.jpg" alt="SEAM Changemaker member" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-white max-w-3xl mx-auto">
        Start free. <em class="italic font-normal text-seam-300">Grow when you are ready.</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-400 max-w-xl mx-auto">Open costs nothing. Changemaker pays for itself with one client referral.</p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a href="https://community.seamcertification.org/plans/1975151" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">Join the community</a>
        <a href="/ap-credential" class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300">Earn the AP credential</a>
      </div>
    </div>
  </section>

</SiteLayout>
