  <!-- Ecosystem hotspot interactivity -->
  <script>
    function initEcosystemHotspots() {
      const container = document.getElementById('ecosystem-container')
      if (!container) return

      const hotspots = container.querySelectorAll<HTMLButtonElement>('.hotspot')
      const tooltips = container.querySelectorAll<HTMLElement>('[data-hotspot-tooltip]')

      let hovered: string | null = null
      let locked: string | null = '1'

      function getActive(): string | null {
        return locked ?? hovered
      }

      function applyState() {
        const active = getActive()

        // Hotspot dot/halo states
        hotspots.forEach((btn) => {
          const id = btn.dataset.hotspotId ?? ''
          const isActive = active === id
          btn.setAttribute('aria-expanded', String(isActive))
          btn.style.zIndex = isActive ? '30' : '10'

          const halo = btn.querySelector<HTMLElement>('.hotspot-halo')
          const dot = btn.querySelector<HTMLElement>('.hotspot-dot')

          if (halo) {
            if (isActive) {
              halo.classList.remove('h-8', 'w-8', 'md:h-11', 'md:w-11')
              halo.classList.add('h-10', 'w-10', 'md:h-14', 'md:w-14')
            } else {
              halo.classList.remove('h-10', 'w-10', 'md:h-14', 'md:w-14')
              halo.classList.add('h-8', 'w-8', 'md:h-11', 'md:w-11')
            }
          }

          if (dot) {
            if (isActive) {
              dot.classList.remove('h-3', 'w-3', 'md:h-4', 'md:w-4', 'ring-2', 'scale-100')
              dot.classList.add('h-3.5', 'w-3.5', 'md:h-5', 'md:w-5', 'ring-[3px]', 'md:ring-4', 'scale-110')
            } else {
              dot.classList.remove('h-3.5', 'w-3.5', 'md:h-5', 'md:w-5', 'ring-[3px]', 'md:ring-4', 'scale-110')
              dot.classList.add('h-3', 'w-3', 'md:h-4', 'md:w-4', 'ring-2', 'scale-100')
            }
          }
        })

        // Tooltip opacity (desktop)
        tooltips.forEach((tt) => {
          const id = tt.dataset.hotspotTooltip ?? ''
          const isActive = active === id
          tt.setAttribute('aria-hidden', String(!isActive))
          tt.style.opacity = isActive ? '1' : '0'
        })

      }

      hotspots.forEach((btn) => {
        const id = btn.dataset.hotspotId ?? ''

        btn.addEventListener('mouseenter', () => {
          hovered = id
          applyState()
        })
        btn.addEventListener('mouseleave', () => {
          hovered = null
          applyState()
        })
        btn.addEventListener('focus', () => {
          hovered = id
          applyState()
        })
        btn.addEventListener('blur', () => {
          hovered = null
          applyState()
        })
        btn.addEventListener('click', (e) => {
          e.stopPropagation()
          locked = locked === id ? null : id
          applyState()
        })
      })

      // Close locked tooltip on click anywhere outside a hotspot
      document.addEventListener('mousedown', (e) => {
        if (locked === null) return
        const target = e.target as Node
        const clickedHotspot = (target as Element).closest?.('.hotspot')
        if (!clickedHotspot) {
          locked = null
          applyState()
        }
      })

      applyState()
    }

    document.addEventListener('astro:page-load', initEcosystemHotspots)
    // Fallback: if astro:page-load doesn't fire (no view transitions), run on DOMContentLoaded
    if (document.readyState !== 'loading') {
      initEcosystemHotspots()
    } else {
      document.addEventListener('DOMContentLoaded', initEcosystemHotspots)
    }
  </script>

  <!-- Mobile ecosystem slider -->
  <script>
    function initEcosystemSlider() {
      const slider = document.getElementById('ecosystem-slider')
      if (!slider) return

      const dots = document.querySelectorAll<HTMLButtonElement>('[data-slide-dot]')
      const cards = slider.children

      // Update dots on scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return
            const idx = Array.from(cards).indexOf(entry.target as Element)
            if (idx < 0) return
            dots.forEach((dot, i) => {
              if (i === idx) {
                dot.classList.remove('w-2', 'bg-warm-300')
                dot.classList.add('w-6', 'bg-seam-600')
              } else {
                dot.classList.remove('w-6', 'bg-seam-600')
                dot.classList.add('w-2', 'bg-warm-300')
              }
            })
          })
        },
        { root: slider, threshold: 0.6 }
      )

      Array.from(cards).forEach((card) => observer.observe(card))

      // Tap dot to scroll
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const i = Number(dot.dataset.slideDot)
          const card = cards[i] as HTMLElement
          if (card) {
            slider.scrollTo({ left: card.offsetLeft - slider.offsetLeft - 24, behavior: 'smooth' })
          }
        })
      })
    }

    document.addEventListener('astro:page-load', initEcosystemSlider)
    if (document.readyState !== 'loading') {
      initEcosystemSlider()
    } else {
      document.addEventListener('DOMContentLoaded', initEcosystemSlider)
    }
  </script>

