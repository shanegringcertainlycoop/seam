---
import SiteLayout from '../layouts/SiteLayout.astro'
import BusinessCaseBanner from '../components/BusinessCaseBanner.astro'
import { faqSchema, breadcrumbSchema } from '../lib/seo-helpers'
import { certifiedProjects } from '../data/directory'
import { posts } from '../data/blog'

const recentPosts = posts.filter((p) => p.image).slice(0, 3)

/* ─── Section 2a: Ecosystem Visualization ─── */
const hotspots = [
  {
    id: 1,
    x: 48,
    y: 45,
    title: 'Tenants + occupants inside the building',
    body:
      'The people who live, work, and gather here every day. Indoor environment, access, affordability, and belonging shape their daily experience — and their long-term health.',
  },
  {
    id: 2,
    x: 62,
    y: 64,
    title: 'Facilities + management professionals who run it',
    body:
      'The teams keeping the building alive. Fair wages, training pathways, and safe working conditions determine whether operations sustain people or wear them down.',
  },
  {
    id: 3,
    x: 82,
    y: 54,
    title: 'Workers + contractors who built it',
    body:
      'The trades who put the building up. Prevailing wage, apprenticeship access, and site safety decide whether construction builds careers or just structures.',
  },
  {
    id: 4,
    x: 78,
    y: 80,
    title: 'Residents + community who neighbor it',
    body:
      "The blocks, schools, and small businesses shaped by the building's presence. Displacement, traffic, jobs, and public space all ripple outward from every project.",
  },
  {
    id: 5,
    x: 18,
    y: 50,
    title: 'Vendors + manufacturers who supply it',
    body:
      'Every product specified carries a supply chain. Local sourcing, minority- and women-owned businesses, and ethical manufacturing turn procurement into equity.',
  },
  {
    id: 6,
    x: 88,
    y: 12,
    title: 'Laborers who source, collect, and refine it',
    body:
      'Materials start in mines, forests, mills, and factories often far from sight. Fair labor and human rights at the raw-material level are where real accountability begins.',
  },
]

/* ─── Section 2b: Stats ─── */
/* ─── Section 3: Products ─── */
const products = [
  {
    label: 'SEAM Certification',
    title: 'Full building certification',
    description:
      'Prove your building makes life better for the people it touches — from the workers who built it to the community around it.',
    href: '/certification',
    audience: 'For developers, owners, and capital providers',
    logos: ['/logos/cert-bronze.png', '/logos/cert-silver.png', '/logos/cert-gold.png', '/logos/cert-platinum.png'],
  },
  {
    label: 'SEAM Approved',
    title: 'Activity-level verification',
    description:
      'Not ready for full certification? Start with one verified activity and build from there.',
    href: '/approved',
    audience: 'For operators, managers, and anchor institutions',
    logo: '/logos/approved-wordmark.png',
  },
  {
    label: 'SEAM AP Credential',
    title: 'Professional accreditation',
    description:
      'Become the person organizations call when they want to get social equity right. Lead projects, grow your practice.',
    href: '/ap-credential',
    audience: 'For consultants and sustainability professionals',
    logo: '/logos/ap-seal.png',
  },
  {
    label: 'COMMUNITY',
    title: 'SEAM Membership',
    description:
      'Connect with practitioners doing this work across the industry. Events, peer groups, and tools — at every career stage.',
    href: '/community',
    audience: 'For all professional audiences',
    logos: ['/logos/member-individual.png', '/logos/member-changemaker.png', '/logos/member-standing.png', '/logos/member-ladder.png', '/logos/member-arc.png'],
  },
]

/* ─── Section 5: Proof / Certified Projects ─── */
const projects = certifiedProjects.slice(0, 2).map((p) => ({
  name: p.name,
  location: `${p.location.city}, ${p.location.state}`,
  level: `${p.certificationLevel} Certified`,
  description: p.description,
  image: p.image,
  href: `/directory/project/${p.slug}`,
}))

/* ─── Section 6: Resources ─── */
const resources = [
  {
    title: 'Open Membership',
    description: 'Free to join. Show up, learn, and find your people in social equity.',
    cta: 'Enroll for free',
    href: '/community',
  },
  {
    title: 'The SEAM Standard',
    description: 'Four pillars, 50+ activities, zero cost. Read the framework everyone is talking about.',
    cta: 'Download',
    href: '/resources/standard',
  },
  {
    title: 'ROSSI Calculator',
    description: 'Put a dollar figure on doing the right thing. The business case, quantified.',
    cta: 'Try ROSSI',
    href: '/resources/rossi',
  },
  {
    title: 'Blog & Insights',
    description: 'What we are learning from the first wave of certified projects — and what comes next.',
    cta: 'Read',
    href: '/resources/blog',
  },
]

const jsonLd = [
  faqSchema([
    {
      question: 'What is SEAM certification?',
      answer:
        'SEAM is the first certification system built to measure social equity in the built environment. It evaluates buildings across four interdependent pillars: Social Impact, Social Responsibility, Social Justice, and Social Accountability, with levels from Bronze through Platinum.',
    },
    {
      question: 'How is SEAM different from LEED or WELL?',
      answer:
        'SEAM is complementary to LEED, WELL, and Fitwel. While those systems focus on environmental performance and physical wellness, SEAM measures social equity — the relationship between a building and the people it touches. SEAM requires ongoing verification, community voice in evaluation, and interdependent scoring across all four pillars.',
    },
    {
      question: 'What is SEAM Approved?',
      answer:
        'SEAM Approved is a standalone activity-level verification program. Organizations can verify individual social equity practices without committing to full certification. It serves as both a standalone credential and a natural on-ramp to full SEAM certification.',
    },
    {
      question: 'What is the ROSSI Calculator?',
      answer:
        'ROSSI (Return on Social Sustainability Investment) translates social equity outcomes into financial language. It models project-level and portfolio-level impact, GRESB alignment, and insurance risk reduction to help capital providers evaluate social sustainability investments.',
    },
  ]),
  breadcrumbSchema([{ name: 'Home', path: '/' }]),
]
---
<SiteLayout
  description="SEAM is the first certification for social equity in buildings. Bronze through Platinum levels. Download the free Standard or start your project."
  path="/"
  jsonLd={jsonLd}
>
  <!-- ─── Section 1: Hero ─── -->
  <section class="relative min-h-[90vh] flex items-end overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        data-parallax="0.25"
        src="/hero.png"
        alt="The Jack building in Seattle's Pioneer Square — the world's first SEAM Certified commercial real estate location"
        class="hero-image h-full w-full object-cover object-center scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/10"></div>
    </div>

    <div class="hero-enter relative mx-auto max-w-[1400px] px-6 lg:px-10 py-20 lg:py-28 w-full">
      <div class="max-w-3xl">
        <h1 class="hero-title font-display text-[clamp(2.5rem,6vw,5.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Buildings have a human impact.{' '}
          <em class="font-display italic font-normal text-seam-300">
            How far does yours reach?
          </em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-2xl text-[clamp(1.1rem,1.5vw,1.25rem)] leading-relaxed text-warm-200">
          From the labor you source to the manufacturers you choose and the communities you touch, your building leaves a lasting impression. SEAM was created to make it a positive one.
        </p>
        <div class="hero-cta mt-12 flex flex-wrap gap-4">
          <a
            href="/get-started"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Start a project
          </a>
          <a
            href="/about"
            class="inline-flex items-center rounded-full border border-white/30 px-8 py-4 text-[16px] font-medium text-white hover:border-white/60 transition-colors duration-300"
          >
            Learn more
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Section 2: Mission ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up max-w-3xl mx-auto text-center">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          Our purpose
        </p>
        <p class="font-display text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.3] tracking-[-0.02em] text-warm-900">
          When buildings are{' '}
          <em class="italic font-normal text-seam-600">
            designed and operated
          </em>{' '}
          with people as a focus, communities thrive and investments outperform.
          <br /><br />
          <img src="/logos/seam-wordmark.png" alt="SEAM" class="inline-block h-[1.1em] w-auto align-baseline brightness-0 -mb-[0.05em]" /> is the world's first standard built to advance social equity in commercial real estate.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Section 2a: Ecosystem Visualization ─── -->
  <section class="bg-warm-50 py-20 lg:py-28">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up max-w-2xl mx-auto text-center mb-10 lg:mb-14">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">
          Who your building touches
        </p>
        <h2 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.2] tracking-[-0.02em] text-warm-900">
          Every building reaches{' '}
          <em class="italic font-normal text-seam-600">six groups of people.</em>
        </h2>
        <p class="mt-4 text-[15px] text-warm-600">
          Hover or tap a dot to see who.
        </p>
      </div>

      <div
        id="ecosystem-container"
        class="relative mx-auto w-full max-w-[1100px] aspect-[7/5] overflow-hidden rounded-xl"
      >
        <img
          src="/images/ecosystem-building.png"
          alt="Isometric illustration of a building and its surrounding ecosystem"
          class="absolute inset-0 h-full w-full object-cover object-top select-none pointer-events-none"
          draggable="false"
        />

        {hotspots.map((spot) => {
          const translateX = spot.x < 20 ? '-20%' : spot.x > 80 ? '-80%' : '-50%'
          return (
            <button
              type="button"
              data-hotspot-id={spot.id}
              aria-label={spot.title}
              aria-expanded="false"
              class="hotspot absolute -translate-x-1/2 -translate-y-1/2 group flex items-center justify-center outline-none"
              style={`left: ${spot.x}%; top: ${spot.y}%;`}
            >
              {/* Halo — subtle, grows gently on active */}
              <span
                class="hotspot-halo absolute rounded-full bg-seam-600/15 transition-transform duration-[400ms] ease-out h-8 w-8 md:h-11 md:w-11"
              ></span>
              {/* Inner dot — subtle scale + ring change */}
              <span
                class="hotspot-dot relative block rounded-full bg-seam-600 ring-white shadow-[0_2px_8px_rgba(0,0,0,0.25)] transition-[transform,box-shadow] duration-[250ms] ease-out h-3 w-3 md:h-4 md:w-4 ring-2 scale-100"
              ></span>
              {/* Tooltip (desktop) — always mounted, fades in/out */}
              <div
                role="tooltip"
                aria-hidden="true"
                data-hotspot-tooltip={spot.id}
                class="hidden md:block pointer-events-none absolute left-1/2 top-full mt-4 w-[300px] rounded-2xl bg-white p-5 text-left shadow-[0_12px_40px_rgba(0,0,0,0.12)] border border-warm-100 z-10 transition-opacity duration-200 ease-out opacity-0"
                style={`transform: translateX(${translateX});`}
              >
                <p class="font-display text-[18px] leading-snug tracking-[-0.01em] text-warm-900 mb-2">
                  {spot.title}
                </p>
                <p class="text-[14px] leading-relaxed text-warm-600">
                  {spot.body}
                </p>
              </div>
            </button>
          )
        })}
      </div>

      <!-- Mobile info panel — shows the active hotspot below the image -->
      <div class="md:hidden mt-6 min-h-[160px]">
        <div id="ecosystem-mobile-empty" class="text-center text-[14px] text-warm-400 pt-6">
          Tap any dot above to learn more.
        </div>
        {hotspots.map((spot) => (
          <div
            data-hotspot-panel={spot.id}
            class="hotspot-mobile-panel hidden rounded-2xl bg-white p-5 border border-warm-100 shadow-[0_8px_24px_rgba(0,0,0,0.06)]"
          >
            <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-2">
              Tap a dot
            </p>
            <p class="font-display text-[18px] leading-snug tracking-[-0.01em] text-warm-900 mb-2">
              {spot.title}
            </p>
            <p class="text-[14px] leading-relaxed text-warm-600">
              {spot.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Section 2b: Business Case ─── -->
  <BusinessCaseBanner />

  <!-- ─── Section 3: Products ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          What we offer
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          SEAM is built for{' '}
          <em class="italic font-normal text-seam-600">where you are</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-6">
        {products.map((product) => (
          <a
            href={product.href}
            class="reveal-child group relative overflow-visible rounded-2xl border border-warm-100 p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <div class="absolute -top-5 sm:-top-10 right-4 sm:right-8 flex items-end pointer-events-none">
              {product.logos ? (
                <div class="flex items-end -space-x-2 sm:-space-x-6">
                  {product.logos.map((logo) => (
                    <img
                      src={logo}
                      alt=""
                      class="w-9 h-9 sm:w-24 sm:h-24 object-contain drop-shadow-md"
                    />
                  ))}
                </div>
              ) : (
                <img
                  src={product.logo}
                  alt=""
                  class="w-16 h-16 sm:w-24 sm:h-24 object-contain drop-shadow-md"
                />
              )}
            </div>
            <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-seam-600 mb-2 block">
              {product.label}
            </span>
            <h3 class="font-display text-[24px] lg:text-[28px] tracking-[-0.02em] text-warm-900 mb-4">
              {product.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600 mb-6">
              {product.description}
            </p>
            <div class="flex items-center justify-between">
              <span class="text-[14px] text-warm-400">{product.audience}</span>
              <span class="text-warm-400 group-hover:text-warm-900 group-hover:translate-x-1 transition-all duration-300">
                &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Section 5: Proof / Certified Projects ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          Proof
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Buildings already{' '}
          <em class="italic font-normal text-seam-600">leading the way</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects.map((project) => (
          <a
            href={project.href}
            class="reveal-child group relative rounded-2xl bg-warm-900 p-10 lg:p-12 min-h-[360px] flex flex-col justify-end overflow-hidden transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.3)]"
          >
            <img
              src={project.image}
              alt={project.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-warm-900/90 via-warm-900/40 to-transparent"></div>
            <div class="relative">
              <span class="inline-block rounded-full bg-seam-600 px-4 py-1.5 text-[12px] font-medium text-white mb-4">
                {project.level}
              </span>
              <h3 class="font-display text-[28px] lg:text-[32px] tracking-[-0.02em] text-white mb-2">
                {project.name}
              </h3>
              <p class="text-[15px] text-warm-300 mb-3">{project.location}</p>
              <p class="text-[16px] leading-relaxed text-warm-400">
                {project.description}
              </p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/about/projects"
          class="text-[15px] font-medium text-warm-900 underline underline-offset-4 decoration-warm-300 hover:decoration-warm-900 transition-colors duration-300"
        >
          View all certified projects
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Section 5b: Community Faces ─── -->
  <section class="py-24 lg:py-32 overflow-hidden">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          The people behind the Standard
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Practitioners, leaders, and{' '}
          <em class="italic font-normal text-seam-600">changemakers</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          SEAM APs, member organizations, and community members building the social equity ecosystem in the built environment.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-7 lg:grid-cols-11 gap-3 lg:gap-4 max-w-5xl mx-auto justify-items-center">
        {[
          { src: '/images/team/rainey-shane.png', name: 'Rainey Shane', role: 'Co-Founder' },
          { src: '/images/team/alex-demestihas.png', name: 'Alex Demestihas', role: 'Co-Founder' },
          { src: '/images/ap-alexandra-bull.jpg', name: 'Alexandra Bull', role: 'SEAM AP' },
          { src: '/images/ap-christian-mayer.jpg', name: 'Christian Mayer', role: 'SEAM AP' },
          { src: '/images/ap-melina-gorrebeeck.jpg', name: 'Melina Gorrebeeck', role: 'SEAM AP' },
          { src: '/images/directory/ap-jennifer-beyer.jpg', name: 'Jennifer Beyer', role: 'SEAM AP' },
          { src: '/images/directory/ap-patricia-raicht.jpg', name: 'Patricia Raicht', role: 'SEAM AP' },
          { src: '/images/directory/ap-lonna-babu.jpg', name: 'Lonna Babu', role: 'SEAM AP' },
          { src: '/images/directory/ap-karin-miller.jpg', name: 'Karin Miller', role: 'SEAM AP' },
          { src: '/images/directory/ap-lina-daniel.jpg', name: 'Lina Daniel', role: 'SEAM AP' },
          { src: '/images/directory/ap-max-kriegsfeld.jpg', name: 'Max Kriegsfeld', role: 'SEAM AP' },
          { src: '/images/directory/ap-jayne-lee.jpg', name: 'Jayne Lee', role: 'SEAM AP' },
          { src: '/images/directory/ap-hetvi-vora.jpg', name: 'Hetvi Vora', role: 'SEAM AP' },
          { src: '/images/directory/ap-anna-fredlander.jpg', name: 'Anna Fredlander', role: 'SEAM AP' },
          { src: '/images/directory/ap-monica-wentz.jpg', name: 'Monica Wentz', role: 'SEAM AP' },
          { src: '/images/directory/ap-valerie-oliver.jpg', name: 'Valerie Oliver', role: 'SEAM AP' },
          { src: '/images/directory/ap-jennifer-webb.jpg', name: 'Jennifer Webb', role: 'SEAM AP' },
          { src: '/images/directory/ap-edward-wan.jpg', name: 'Edward Wan', role: 'SEAM AP' },
          { src: '/images/directory/ap-eva-lo.png', name: 'Eva Lo', role: 'SEAM AP' },
          { src: '/images/team/chris-pirschel.jpg', name: 'Chris Pirschel', role: 'CMO' },
          { src: '/images/team/shane-gring.jpg', name: 'Shane Gring', role: 'COO' },
        ].map((person, i) => (
          <div class="reveal-child">
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full overflow-hidden ring-2 ring-white shadow-[0_4px_16px_rgba(0,0,0,0.1)]">
              <img
                src={person.src}
                alt={person.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>

      <div class="reveal-stagger mt-12 flex flex-wrap justify-center items-center gap-8 lg:gap-12 max-w-4xl mx-auto">
        {[
          { src: '/logos/jll.png', name: 'JLL' },
          { src: '/logos/interface.png', name: 'Interface' },
          { src: '/logos/hitt.png', name: 'HITT Contracting' },
          { src: '/logos/jamestown.png', name: 'Jamestown' },
          { src: '/logos/leapley.png', name: 'Leapley Construction' },
          { src: '/logos/thm-advisors.svg', name: 'THM Advisors' },
          { src: '/logos/brightworks.svg', name: 'Brightworks Sustainability' },
        ].sort(() => Math.random() - 0.5).map((org) => (
          <div class="reveal-child">
            <img
              src={org.src}
              alt={org.name}
              class="h-7 lg:h-9 object-contain opacity-40 grayscale"
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <div class="reveal-fade-up mt-12 text-center">
        <a
          href="/directory"
          class="inline-flex items-center rounded-full border border-warm-200 px-6 py-3 text-[15px] font-medium text-warm-700 hover:border-warm-400 hover:text-warm-900 transition-colors duration-300"
        >
          Browse the full directory
          <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Section 6: Resources ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          Open resources
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Start here,{' '}
          <em class="italic font-normal text-seam-600">no commitment required</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {resources.map((resource) => (
          <a
            href={resource.href}
