---
import SiteLayout from '../layouts/SiteLayout.astro'
import BusinessCaseBanner from '../components/BusinessCaseBanner.astro'
import { faqSchema, breadcrumbSchema, organizationSchema } from '../lib/seo-helpers'
import { certifiedProjects } from '../data/directory'
import { posts } from '../data/blog'

const recentPosts = posts.filter((p) => p.image).slice(0, 3)

/* ─── Section 2a: Ecosystem Visualization ─── */
const hotspots = [
  {
    id: 1,
    x: 48,
    y: 50,
    title: 'Occupants',
    image: '/images/home/occupants.webp',
    intro: 'The people who live, work, and gather here every day.',
    body:
      'Indoor air, access, affordability, and belonging shape their experience and long-term health. Most standards start here. SEAM starts here too, then keeps going.',
  },
  {
    id: 2,
    x: 57,
    y: 60,
    title: 'Operators',
    image: '/images/home/operators.webp',
    intro: 'The people who keep it running.',
    body:
      'Facility teams, custodial staff, security. They maintain the space, often invisibly. How they\u2019re trained, paid, and treated is part of the building\u2019s performance.',
  },
  {
    id: 3,
    x: 38,
    y: 36,
    title: 'Builders',
    image: '/images/home/builders.webp',
    intro: 'The people who built it.',
    body:
      'Construction is one of the most dangerous industries in the world. Safety, fair wages, and labor conditions on the jobsite are the building\u2019s first chapter.',
  },
  {
    id: 4,
    x: 72,
    y: 52,
    title: 'Neighbors',
    image: '/images/home/neighbors.webp',
    intro: 'The people who live alongside it.',
    body:
      'A building changes the block \u2014 traffic, shadows, rents, and who feels welcome. The surrounding community is an impacted party whether or not they were consulted.',
  },
  {
    id: 5,
    x: 78,
    y: 58,
    title: 'Suppliers',
    image: '/images/home/suppliers.webp',
    intro: 'The people who source and ship what goes into it.',
    body:
      'Manufacturers, fabricators, drivers. A building is assembled from thousands of decisions made in places the owner will never visit. Each carries a labor record.',
  },
  {
    id: 6,
    x: 22,
    y: 22,
    title: 'Laborers',
    image: '/images/home/laborers.webp',
    intro: 'The people at the very beginning of the chain.',
    body:
      'Mines, forests, mills, factories \u2014 often far from sight, beyond easy oversight. Fair labor at the raw-material level is where real accountability begins.',
  },
]

/* ─── Section 2b: Stats ─── */
/* ─── Section 3: Products ─── */
const products = [
  {
    label: 'SEAM Certification',
    title: 'Full building certification',
    description:
      'Prove your building makes life better for the people it touches — from the workers who built it to the community around it.',
    href: '/certification',
    audience: 'For developers, owners, and capital providers',
    logos: ['/logos/cert-bronze.png', '/logos/cert-silver.png', '/logos/cert-gold.png', '/logos/cert-platinum.png'],
  },
  {
    label: 'SEAM Marks',
    title: 'Activity-level verification',
    description:
      'Not ready for full certification? Start with one verified activity (Single Mark) or a bundle of 3–5 (Bulk Marks) and build from there.',
    href: '/marks',
    audience: 'For operators, managers, and anchor institutions',
    logo: '/logos/approved-wordmark.png',
  },
  {
    label: 'SEAM Seals',
    title: 'Thematic credential',
    description:
      'Coming soon — a thematic credential awarded for completing 18–25 related activities. Between Marks and full Certification.',
    href: '/seals',
    audience: 'For organizations ready to commit deeply in a focused area',
    logo: '/logos/seal-placeholder.svg',
  },
  {
    label: 'SEAM AP Credential',
    title: 'Professional accreditation',
    description:
      'Become the person organizations call when they want to get social equity right. Lead projects, grow your practice.',
    href: '/ap-credential',
    audience: 'For consultants and sustainability professionals',
    logo: '/logos/ap-seal.png',
    sale: '$389 (reg. $519) — code SITELAUNCH25 · ends May 31',
  },
  {
    label: 'COMMUNITY',
    title: 'SEAM Membership',
    description:
      'Connect with practitioners doing this work across the industry. Events, peer groups, and tools — at every career stage.',
    href: '/membership',
    audience: 'For all professional audiences',
    logos: ['/logos/member-individual.png', '/logos/member-changemaker.png', '/logos/member-standing.png', '/logos/member-ladder.png', '/logos/member-arc.png'],
  },
]

/* ─── Section 5: Proof / Certified Projects ─── */
const certBadge: Record<string, string> = {
  Pursuing: '/logos/cert-registered.png',
  Bronze: '/logos/cert-bronze.png',
  Silver: '/logos/cert-silver.png',
  Gold: '/logos/cert-gold.png',
  Platinum: '/logos/cert-platinum.png',
}

const featuredSlugs = ['the-jack', 'bertschi-school']
const projects = featuredSlugs.map((slug) => certifiedProjects.find((p) => p.slug === slug)!).map((p) => ({
  name: p.name,
  location: `${p.location.city}, ${p.location.state}`,
  level: p.certificationLevel,
  badge: certBadge[p.certificationLevel] || '',
  description: p.slug === 'bertschi-school'
    ? 'Bertschi School is pursuing SEAM Silver for its new 49,384 SF Schoolhouse — aiming to be the first school to achieve the credential. Students have been integral to the planning process from the very beginning.'
    : p.description,
  image: p.image,
  href: `/directory/project/${p.slug}`,
}))

/* ─── Section 6: Resources ─── */
const resources = [
  {
    title: 'Open Membership',
    description: 'Free to join. Show up, learn, and find your people in social equity.',
    cta: 'Enroll for free',
    href: '/membership',
    logo: '/logos/member-individual.png',
  },
  {
    title: 'The SEAM Standard',
    description: 'Four pillars, 50+ activities, zero cost. Read the framework everyone is talking about.',
    cta: 'Download',
    href: '/resources/standard',
  },
  {
    title: 'ROSSI Calculator',
    description: 'Put a dollar figure on doing the right thing. The business case, quantified.',
    cta: 'Try ROSSI',
    href: '/resources/rossi',
    logo: '/logos/rossi-calculator.png',
  },
  {
    title: 'Blog & Insights',
    description: 'What we are learning from the first wave of certified projects — and what comes next.',
    cta: 'Read',
    href: '/resources/blog',
  },
]

const jsonLd = [
  faqSchema([
    {
      question: 'What is SEAM certification?',
      answer:
        'SEAM is the first certification system built to measure social equity in the built environment. It evaluates buildings across four interdependent pillars: Social Impact, Social Responsibility, Social Justice, and Social Accountability, with levels from Bronze through Platinum.',
    },
    {
      question: 'How is SEAM different from LEED or WELL?',
      answer:
        'SEAM is complementary to LEED, WELL, and Fitwel. While those systems focus on environmental performance and physical wellness, SEAM measures social equity — the relationship between a building and the people it touches. SEAM requires community voice in evaluation and interdependent scoring across all four pillars. Certification validity varies by rating system: Buildings + Interiors projects have no expiration and require annual data submissions for select activities, while Operations + Maintenance certifications are valid for three years and require recertification.',
    },
    {
      question: 'What is a SEAM Mark?',
      answer:
        'SEAM Marks are standalone, activity-level verifications. Organizations can verify individual social equity practices without committing to full certification — as a Single Mark or a bundle of 3–5 related activities (Bulk Marks). Marks serve as both a standalone credential and a natural on-ramp to full SEAM Certification.',
    },
    {
      question: 'What is a SEAM Seal?',
      answer:
        'A SEAM Seal is a thematic credential awarded for completing a curated set of 18 to 25 related activities. Seals sit between Marks (single or bundled activity verification) and full Certification (whole-building, all pillars). Seals are in active development.',
    },
    {
      question: 'What is the ROSSI Calculator?',
      answer:
        'ROSSI (Return on Social Sustainability Investment) translates social equity outcomes into financial language. It models project-level and portfolio-level projections across profit, customer loyalty, customer acquisition, turnover, productivity, cost of capital, and social initiative gains to help organizations evaluate their social sustainability investments.',
    },
  ]),
  breadcrumbSchema([{ name: 'Home', path: '/' }]),
  organizationSchema(),
]
---
<SiteLayout
  description="SEAM is the first certification for social equity in buildings. Bronze through Platinum levels. Download the free Standard or start your project."
  path="/"
  jsonLd={jsonLd}
>
  <!-- ─── Section 1: Hero ─── -->
  <section class="relative min-h-[90vh] flex items-end overflow-hidden">
    <!-- Background video with static fallback -->
    <div class="absolute inset-0 bg-warm-900">
      <picture>
        <source media="(max-width: 767px)" srcset="/hero-mobile.webp" />
        <source media="(min-width: 768px)" srcset="/hero.webp" />
        <img
          src="/hero.webp"
          alt=""
          width="2400"
          height="1600"
          class="absolute inset-0 h-full w-full object-cover object-center scale-105"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
      <video
        autoplay
        muted
        loop
        playsinline
        preload="none"
        class="hidden md:block hero-image absolute inset-0 h-full w-full object-cover object-center scale-105 opacity-0 transition-opacity duration-700"
        oncanplaythrough="this.classList.remove('opacity-0')"
      >
        <source src="/home-hero.mp4" type="video/mp4" media="(min-width: 768px)" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/90 via-warm-900/55 to-warm-900/30"></div>
    </div>

    <div class="hero-enter relative mx-auto max-w-[1400px] px-6 lg:px-10 py-20 lg:py-28 w-full">
      <div class="max-w-3xl">
        <h1 class="hero-title font-display text-[clamp(2.5rem,6vw,5.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Buildings have a human impact.{' '}
          <em class="font-display italic font-normal text-seam-300">
            How far does yours reach?
          </em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-2xl text-[clamp(1.1rem,1.5vw,1.25rem)] leading-relaxed text-warm-200">
          From the labor you source to the manufacturers you choose and the communities you touch, your building leaves a lasting impression. SEAM was created to make it a positive one.
        </p>
        <div class="hero-cta mt-12 flex flex-wrap gap-4">
          <a
            href="/get-started"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Start a project
          </a>
          <a
            href="/about"
            class="inline-flex items-center rounded-full border border-white/30 px-8 py-4 text-[16px] font-medium text-white hover:border-white/60 transition-colors duration-300"
          >
            Learn more
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Section 2: Mission ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up max-w-3xl mx-auto text-center">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          Our purpose
        </p>
        <p class="font-display text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.3] tracking-[-0.02em] text-warm-900">
          When buildings are{' '}
          <em class="italic font-normal text-seam-600">
            designed and operated
          </em>{' '}
          with people as a focus, communities thrive and investments outperform.
          <br /><br />
          <img src="/logos/seam-wordmark.svg" alt="SEAM" class="inline-block h-[1.1em] w-auto align-baseline -mb-[0.05em]" decoding="async" /> is the world's first standard built to advance social equity in commercial real estate.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Section 2a: Ecosystem Visualization ─── -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up max-w-2xl mx-auto text-center mb-10 lg:mb-14">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">
          Who your building touches
        </p>
        <h2 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.2] tracking-[-0.02em] text-warm-900">
          A building is bigger than{' '}
          <em class="italic font-normal text-seam-600">its walls.</em>
        </h2>
        <p class="mt-4 text-[17px] leading-relaxed text-warm-600 max-w-xl mx-auto">
          Every project impacts people. SEAM is the only standard that accounts for all of them.
        </p>
      </div>
    </div>

    <!-- Desktop: graphic + hotspots -->
    <div class="hidden md:block mx-auto max-w-[1400px]">
      <div
        id="ecosystem-container"
        class="relative w-full aspect-[2/1]"
      >
        <img
          src="/images/home/6-dimensions.webp"
          alt="Isometric illustration of a building at the center of six concentric rings representing the people it touches — tenants, facilities staff, construction workers, community residents, supply chain vendors, and raw material laborers"
          class="absolute inset-0 h-full w-full object-contain select-none pointer-events-none"
          draggable="false"
          loading="lazy"
          decoding="async"
        />

        {hotspots.map((spot) => {
          const translateX = spot.x < 20 ? '-20%' : spot.x > 80 ? '-80%' : '-50%'
          return (
            <button
              type="button"
              data-hotspot-id={spot.id}
              aria-label={spot.title}
              aria-expanded="false"
              class="hotspot absolute -translate-x-1/2 -translate-y-1/2 group flex items-center justify-center outline-none z-10"
              style={`left: ${spot.x}%; top: ${spot.y}%;`}
            >
              {/* Halo — subtle, grows gently on active */}
              <span
                class="hotspot-halo absolute rounded-full bg-gold-500/20 transition-transform duration-[400ms] ease-out h-8 w-8 md:h-11 md:w-11"
              ></span>
              {/* Inner dot — subtle scale + ring change */}
              <span
                class="hotspot-dot relative block rounded-full bg-gold-500 ring-white shadow-[0_2px_8px_rgba(0,0,0,0.25)] transition-[transform,box-shadow] duration-[250ms] ease-out h-3 w-3 md:h-4 md:w-4 ring-2 scale-100"
              ></span>
              {/* Tooltip (desktop) — always mounted, fades in/out */}
              <div
                role="tooltip"
                aria-hidden="true"
                data-hotspot-tooltip={spot.id}
                class="hidden md:block pointer-events-none absolute left-1/2 top-full mt-4 w-[480px] max-w-[90vw] rounded-2xl bg-white text-left shadow-[0_12px_40px_rgba(0,0,0,0.12)] border border-warm-100 z-20 transition-opacity duration-200 ease-out opacity-0"
                style={`transform: translateX(${translateX});`}
              >
                <div class="flex p-4 gap-4">
                  <img src={spot.image} alt="" class="w-[180px] h-[210px] rounded-xl object-cover flex-shrink-0" loading="lazy" decoding="async" />
                  <div class="flex flex-col justify-center">
                    <p class="font-display text-[18px] leading-snug tracking-[-0.01em] text-warm-900 mb-2">
                      {spot.title}
                    </p>
                    <p class="text-[14px] leading-relaxed font-medium text-warm-800 mb-1">
                      {spot.intro}
                    </p>
                    <p class="text-[14px] leading-relaxed text-warm-500">
                      {spot.body}
                    </p>
                  </div>
                </div>
              </div>
            </button>
          )
        })}
      </div>

      <div class="reveal-fade-up mt-10 text-center hidden md:block">
        <a
          href="/social-equity-101"
          class="inline-flex items-center text-[15px] font-medium text-seam-600 hover:text-warm-900 transition-colors duration-300"
        >
          Learn how it works
          <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile: swipeable card slider -->
    <div class="md:hidden px-6">
      <div
        id="ecosystem-slider"
        class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth -mx-6 px-6 pb-4"
        style="-webkit-overflow-scrolling: touch; scrollbar-width: none;"
      >
        {hotspots.map((spot, i) => (
          <div class="snap-center shrink-0 w-[85vw] max-w-[340px] rounded-2xl bg-warm-50 border border-warm-100 overflow-hidden">
            {spot.image ? (
              <img src={spot.image} alt="" class="w-full aspect-[3/2] object-cover" loading="lazy" decoding="async" />
            ) : (
              <div class="w-full aspect-[3/2] bg-warm-100 flex items-center justify-center">
                <span class="text-[40px] font-display text-warm-300">{i + 1}</span>
              </div>
            )}
            <div class="p-5">
              <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-2">
                {i + 1} of 6
              </p>
              <p class="font-display text-[20px] leading-snug tracking-[-0.01em] text-warm-900 mb-2">
                {spot.title}
              </p>
              <p class="text-[15px] leading-relaxed font-medium text-warm-800 mb-1">
                {spot.intro}
              </p>
              <p class="text-[14px] leading-relaxed text-warm-500">
                {spot.body}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Dot indicators -->
      <div class="flex justify-center gap-2 mt-4" id="ecosystem-slider-dots">
        {hotspots.map((_, i) => (
          <button
            type="button"
            data-slide-dot={i}
            class:list={[
              'h-2 rounded-full transition-all duration-300',
              i === 0 ? 'w-6 bg-seam-600' : 'w-2 bg-warm-300',
            ]}
            aria-label={`Go to slide ${i + 1}`}
          />
        ))}
      </div>

      <div class="mt-8 text-center">
        <a
          href="/social-equity-101"
          class="inline-flex items-center text-[15px] font-medium text-seam-600 hover:text-warm-900 transition-colors duration-300"
        >
          Learn how it works
          <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Section 2b: Business Case ─── -->
  <BusinessCaseBanner />

  <!-- ─── Section 3: Products ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          What we offer
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          SEAM is built for{' '}
          <em class="italic font-normal text-seam-600">where you are</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-6">
        {products.map((product) => (
          <a
            href={product.href}
            class="reveal-child group relative overflow-visible rounded-2xl border border-warm-100 p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <div class="absolute -top-5 sm:-top-10 right-4 sm:right-8 flex items-end pointer-events-none">
              {product.logos ? (
                <div class="flex items-end -space-x-2 sm:-space-x-6">
                  {product.logos.map((logo) => (
                    <img
                      src={logo}
                      alt=""
                      class="w-9 h-9 sm:w-24 sm:h-24 object-contain drop-shadow-md"
                      loading="lazy"
                      decoding="async"
                    />
                  ))}
                </div>
              ) : (
                <img
                  src={product.logo}
                  alt=""
                  class="w-16 h-16 sm:w-24 sm:h-24 object-contain drop-shadow-md"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
            <span class="text-[13px] font-medium uppercase tracking-[0.1em] text-seam-600 mb-2 block">
              {product.label}
            </span>
            <h3 class="font-display text-[24px] lg:text-[28px] tracking-[-0.02em] text-warm-900 mb-4">
              {product.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600 mb-4">
              {product.description}
            </p>
            {product.sale && (
              <div class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 border border-amber-200 px-3 py-1.5 mb-4">
                <svg class="w-3.5 h-3.5 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                <span class="text-[12px] font-semibold text-amber-800">{product.sale}</span>
              </div>
            )}
            <div class="flex items-center justify-between">
              <span class="text-[14px] text-warm-400">{product.audience}</span>
              <span class="text-warm-400 group-hover:text-warm-900 group-hover:translate-x-1 transition-all duration-300">
                &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Section 5: Proof / Certified Projects ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-6">
          Proof
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Buildings already{' '}
          <em class="italic font-normal text-seam-600">leading the way</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects.map((project) => (
          <a
            href={project.href}
            class="reveal-child group relative rounded-2xl min-h-[360px] flex flex-col justify-end overflow-visible transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.3)]"
          >
            <div class="absolute inset-0 rounded-2xl overflow-hidden">
              <img
                src={project.image}
                alt={project.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-warm-900 via-warm-900/60 to-warm-900/10"></div>
            </div>
            {project.badge && (
              <img
                src={project.badge}
                alt={`${project.level} Certified`}
                class="absolute -top-5 sm:-top-8 right-4 sm:right-8 w-16 h-16 lg:w-20 lg:h-20 object-contain drop-shadow-[0_4px_12px_rgba(0,0,0,0.4)] pointer-events-none z-10"
                loading="lazy"
                decoding="async"
              />
            )}
            <div class="relative p-10 lg:p-12">
              <h3 class="font-display text-[28px] lg:text-[32px] tracking-[-0.02em] text-white mb-2">
                {project.name}
              </h3>
              <p class="text-[15px] text-warm-300 mb-3">{project.location}</p>
              <p class="text-[16px] leading-relaxed text-warm-400">
                {project.description}
              </p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
