  </section>

  <script>
    function initOrgForm() {
      const form = document.getElementById('org-membership-form') as HTMLFormElement | null
      if (!form) return

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
        const statusEl = document.getElementById('org-form-status')!
        const original = btn.textContent

        btn.disabled = true
        btn.textContent = 'Submitting...'
        statusEl.classList.add('hidden')

        const data = new FormData(form)
        const fields = [
          { objectTypeId: '0-1', name: 'firstname', value: data.get('firstname') },
          { objectTypeId: '0-1', name: 'lastname', value: data.get('lastname') },
          { objectTypeId: '0-1', name: 'email', value: data.get('email') },
          { objectTypeId: '0-1', name: 'company', value: data.get('company') },
          { objectTypeId: '0-1', name: 'numemployees', value: data.get('numemployees') || '' },
          { objectTypeId: '0-1', name: 'jobtitle', value: data.get('jobtitle') },
          { objectTypeId: '0-1', name: 'primary_job_function', value: data.get('primary_job_function') || '' },
          { objectTypeId: '0-1', name: 'getting_started_comments', value: data.get('getting_started_comments') || '' },
        ]

        try {
          const res = await fetch(
            'https://api.hsforms.com/submissions/v3/integration/submit/46821728/0f29a4a9-2ab7-4237-98b3-f4be59964370',
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                fields,
                context: {
                  pageUri: window.location.href,
                  pageName: 'Organization Membership',
                },
              }),
            }
          )

          if (res.ok) {
            form.reset()
            statusEl.textContent = "Thank you! We'll be in touch within 2 business days."
            statusEl.classList.remove('hidden', 'text-red-400')
            statusEl.classList.add('text-seam-300')
          } else {
            throw new Error('Submission failed')
          }
        } catch (_err) {
          statusEl.textContent = 'Something went wrong. Please email admin@seamcertification.org directly.'
          statusEl.classList.remove('hidden', 'text-seam-300')
          statusEl.classList.add('text-red-400')
        } finally {
          btn.disabled = false
          btn.textContent = original
        }
      })
    }

    document.addEventListener('astro:page-load', initOrgForm)
    if (document.readyState !== 'loading') {
      initOrgForm()
    } else {
      document.addEventListener('DOMContentLoaded', initOrgForm)
    }
  </script>

</SiteLayout>
