---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../../lib/seo-helpers'

const reasons = [
  { title: 'Access to The Stitch', description: 'Give your entire team — property managers, sustainability leads, community liaisons, executives — access to the same templates, courses, and tools in our members-only community platform.' },
  { title: 'Foundations Course and Exam Credits', description: 'Ladder and Arc tiers include complimentary Foundations: Social Equity in the Built Environment course and exam credits for team members. Build in-house expertise without per-seat costs.' },
  { title: 'Recognition on the SEAM Site & Directory', description: 'Showcase your commitment with a listing in the Member Directory and recognition on the SEAM website — text listing, logo, or featured placement depending on tier.' },
  { title: 'Discounts for Certifications & Events', description: 'Tiered discounts on SEAM Approved verification, full certification fees, and events throughout the year. Scale your investment alongside your portfolio.' },
  { title: 'Thought Leadership Opportunities', description: 'Submit blog posts, featured articles, and webinars. Arc members help shape future versions of the Standard and the direction of the movement.' },
  { title: 'Support the Movement, Build Your Reputation', description: 'Event sponsorships, use of membership logos, and co-branded content opportunities. Public leadership in the movement for social equity in the built environment.' },
]

const tiers = [
  {
    name: 'Standing',
    price: '$1,600',
    period: '/year',
    description: 'For organizations beginning their SEAM journey. Access to The Stitch and foundational benefits.',
    features: [
      'Access to The Stitch members-only hub',
      '5% discount on certifications and events',
      'Eligibility to sponsor events',
      'Recognition in the Member Directory',
      'Recognition on the SEAM website (text listing)',
      '3 included employee individual memberships',
    ],
    cta: 'Talk to our team',
    highlighted: false,
    badge: '/logos/member-standing.png',
  },
  {
    name: 'Ladder',
    price: '$6,000',
    period: '/year',
    description: 'For organizations actively pursuing certification or rolling out SEAM Approved across properties.',
    features: [
      'Access to The Stitch members-only hub',
      '10% discount on certifications and events',
      'Eligibility to sponsor events',
      'Recognition in the Member Directory',
      'Recognition on the SEAM website (logo)',
      'Ability to submit a blog post on SEAM\u2019s website',
      '10 included employee individual memberships',
      '1 complimentary AP training and exam',
    ],
    cta: 'Talk to our team',
    highlighted: true,
    badge: '/logos/member-ladder.png',
  },
  {
    name: 'Arc',
    price: '$18,000',
    period: '/year',
    description: 'For institutions leading the movement. Maximum influence and recognition.',
    features: [
      'Access to The Stitch members-only hub',
      '15% discount on certifications and events',
      'Eligibility to sponsor events',
      'Recognition on the SEAM website (logo, featured)',
      'Submit featured articles & webinars',
      'Use of the membership logo',
      '25 included employee individual memberships',
      '5 complimentary AP trainings and exams',
      '1 included event sponsorship',
    ],
    cta: 'Talk to our team',
    highlighted: false,
    badge: '/logos/member-arc.png',
  },
]

const memberLogos = [
  { src: '/logos/members/jamestown.png', alt: 'Jamestown', height: 'h-16', slug: 'jamestown' },
  { src: '/logos/members/hitt.png', alt: 'HITT', height: 'h-20', slug: 'hitt-contracting' },
  { src: '/logos/members/jll.png', alt: 'JLL', height: 'h-24', slug: 'jll' },
  { src: '/logos/members/interface.png', alt: 'Interface', height: 'h-20', slug: 'interface' },
  { src: '/logos/members/leapley.png', alt: 'Leapley Construction', height: 'h-24', slug: 'leapley-construction' },
  { src: '/logos/thm-advisors.svg', alt: 'THM Advisors', height: 'h-16', slug: 'thm-advisors' },
  { src: '/logos/brightworks.svg', alt: 'Brightworks Sustainability', height: 'h-16', slug: 'brightworks-sustainability' },
]

const memberNames = [
  { name: 'Val Interiors', slug: 'val-interiors' },
]

const faqs = [
  { q: 'How does team seat allocation work?', a: 'Each organization tier includes a set number of seats. Every seat holder gets full individual-level access — templates, courses, ROSSI, and network. Seat assignments can be changed quarterly through your admin dashboard.' },
  { q: 'Can we add seats or properties mid-cycle?', a: 'Yes. Additional seats and properties can be added at any time. Pricing is prorated for the remainder of your annual billing cycle.' },
  { q: 'Is organization pricing public?', a: 'Pricing is based on portfolio size, property count, and scope. Contact our team for a quote tailored to your organization. All tiers are billed annually.' },
  { q: 'What does dedicated onboarding include?', a: 'A SEAM team member reviews your existing social equity programs, maps them to Standard activities, identifies quick wins for SEAM Approved, and builds a certification roadmap. Ladder tier includes one session; Arc includes ongoing strategy check-ins.' },
  { q: 'Can our team members also hold individual memberships?', a: 'Organization seats provide full individual-level access. Separate individual memberships are not needed. Team members who are SEAM APs can track CEUs through their organization seat.' },
  { q: 'What is the advisory council?', a: 'Arc members sit on the advisory council that informs Standard development. The council meets quarterly, reviews proposed changes, pilots new activities, and provides strategic input on the direction of the SEAM ecosystem.' },
]

const faqItems = faqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Community', path: '/community' },
    { name: 'Organization Membership', path: '/community/organization' },
  ]),
]
---

<SiteLayout
  title="Organization Membership"
  description="Organization community membership for teams and institutions. Standing ($1,600/yr), Ladder ($6,000/yr), and Arc ($18,000/yr) tiers with team seats, AP training credits, discounted certifications, and recognition on the SEAM site and directory."
  path="/community/organization"
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/hero-organization.jpg"
        alt="Organization membership for teams and institutions"
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>
    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-3xl">
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          Organization Membership
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Equip your team. <em class="font-display italic font-normal text-seam-300">Scale the commitment.</em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          Standing, Ladder, and Arc tiers for teams and institutions. Portfolio tools, team seats, dedicated onboarding, and volume pricing designed for organizations ready to make social equity a defining part of how they operate.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a href="/get-started" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
            Talk to our team
          </a>
          <a href="#pricing" class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">
            Compare tiers
          </a>
        </div>
      </div>
    </div>
    <div class="hidden lg:flex absolute -bottom-24 right-12 items-end gap-0 z-10">
      <img src="/logos/member-standing.png" alt="Standing membership" class="w-56 h-56 object-contain drop-shadow-2xl -mr-10" />
      <img src="/logos/member-ladder.png" alt="Ladder membership" class="w-56 h-56 object-contain drop-shadow-2xl -mr-10" />
      <img src="/logos/member-arc.png" alt="Arc membership" class="w-56 h-56 object-contain drop-shadow-2xl" />
    </div>
  </section>

  <!-- Why Org Membership -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Why organizations join</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Impact is the destination. <em class="italic font-normal text-seam-600">Membership is the engine.</em>
        </h2>
      </div>
      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {reasons.map((r) => (
          <div class="reveal-child rounded-2xl border border-warm-100 p-8 lg:p-10 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3">{r.title}</h3>
            <p class="text-[15px] leading-relaxed text-warm-600">{r.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Organization tiers</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Scale your commitment <em class="italic font-normal text-seam-600">with your portfolio</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Organization pricing is based on portfolio size and scope. All tiers include annual billing with the option to add seats and properties mid-cycle.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 pt-12">
        {tiers.map((tier) => (
          <div class={`relative rounded-2xl p-8 lg:p-10 flex flex-col ${tier.highlighted ? 'bg-warm-900 text-white' : 'bg-white border border-warm-100'}`}>
            <img src={tier.badge} alt="" class="absolute -top-12 right-10 w-24 h-24 object-contain drop-shadow-lg" />
            <h3 class={`font-display text-[28px] tracking-[-0.02em] ${tier.highlighted ? 'text-white' : 'text-warm-900'}`}>{tier.name}</h3>
            <div class="mt-5 flex items-baseline gap-1">
              <span class={`font-display text-[40px] tracking-[-0.02em] ${tier.highlighted ? 'text-white' : 'text-warm-900'}`}>{tier.price}</span>
              <span class={`text-[15px] ${tier.highlighted ? 'text-warm-300' : 'text-warm-600'}`}>{tier.period}</span>
            </div>
            <p class={`mt-4 text-[15px] leading-relaxed ${tier.highlighted ? 'text-warm-300' : 'text-warm-600'}`}>{tier.description}</p>

            <ul class="mt-8 space-y-3 flex-1">
              {tier.features.map((f) => (
                <li class={`flex items-start gap-2.5 text-[14px] leading-snug ${tier.highlighted ? 'text-warm-200' : 'text-warm-600'}`}>
                  <svg class={`shrink-0 w-4 h-4 mt-0.5 ${tier.highlighted ? 'text-seam-400' : 'text-seam-500'}`} fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

          </div>
        ))}
      </div>

      <div class="reveal-fade-up mt-12 text-center">
        <a href="#contact" class="inline-flex items-center rounded-full bg-warm-900 px-10 py-4 text-[16px] font-medium text-white hover:bg-warm-800 transition-colors duration-300">
          Talk to our team
        </a>
      </div>
    </div>
  </section>

  <!-- Who Joins -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Who joins</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Organizations who <em class="italic font-normal text-seam-600">understand the future</em>
        </h2>
      </div>
      <div class="reveal-fade-up flex flex-wrap items-center justify-center lg:justify-between gap-x-12 gap-y-10 mb-16">
        {memberLogos.map((logo) => (
          <a href={`/directory/org/${logo.slug}`} class="transition-opacity duration-300 hover:opacity-70">
            <img src={logo.src} alt={logo.alt} class={`${logo.height} w-auto object-contain`} />
          </a>
        ))}
      </div>
      {memberNames.length > 0 && (
        <div class="reveal-fade-up flex flex-wrap items-center justify-center lg:justify-around gap-x-12 gap-y-6">
          {memberNames.map((m) => (
            <a href={`/directory/org/${m.slug}`} class="font-display text-[clamp(1.75rem,3vw,2.75rem)] tracking-[-0.02em] text-warm-900 hover:text-gold-600 transition-colors duration-300">{m.name}</a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl mx-auto text-center">
        <svg class="mx-auto mb-8 w-12 h-12 text-warm-400" fill="currentColor" viewBox="0 0 24 24"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" /></svg>
        <blockquote class="font-display text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.3] tracking-[-0.02em] text-white">
          Ladder membership let us roll out SEAM Approved across our portfolio in one quarter. Access to The Stitch mapped our existing programs to the Standard, and the AP training gave our team the credential to lead the work in-house. We stopped reinventing the wheel.
        </blockquote>
        <div class="mt-10">
          <p class="text-[16px] font-medium text-white">Tebogo &ldquo;Tebby&rdquo; Modisagape</p>
          <p class="text-[14px] text-warm-400 mt-1">President of Val Interiors &middot; Ladder Member</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-start">
        <div>
          <div class="reveal-slide-left max-w-2xl mb-12 lg:mb-16">
            <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Frequently asked</p>
            <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
              Questions about <em class="italic font-normal text-seam-600">organization membership</em>
            </h2>
          </div>
          <div>
            {faqs.map((faq) => (
              <details class="border-b border-warm-200 group">
                <summary class="flex w-full items-center justify-between py-6 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span class="text-[17px] lg:text-[18px] font-medium text-warm-900 pr-8">{faq.q}</span>
                  <svg class="shrink-0 w-5 h-5 text-warm-600 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                </summary>
                <div class="pb-6">
                  <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
        <div class="reveal-scale hidden lg:block">
          <div class="aspect-[603/699] overflow-hidden rounded-2xl">
            <img src="/images/organization-faq.jpg" alt="SEAM organization member at work" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Get in Touch ─── -->
  <section id="contact" class="py-24 lg:py-32 bg-warm-900">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <div class="reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
            Get in touch
          </p>
          <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white">
            Your portfolio deserves
            <em class="italic font-normal text-seam-300">a social equity strategy</em>
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-400 max-w-lg">
            Talk to our team about the right tier for your organization. Custom scoping, portfolio pricing, and dedicated onboarding.
          </p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3 text-[15px] text-warm-300">
              <svg class="shrink-0 w-5 h-5 mt-0.5 text-seam-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              Standing, Ladder, and Arc tiers
            </li>
            <li class="flex items-start gap-3 text-[15px] text-warm-300">
              <svg class="shrink-0 w-5 h-5 mt-0.5 text-seam-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              Portfolio and multi-year pricing available
            </li>
            <li class="flex items-start gap-3 text-[15px] text-warm-300">
              <svg class="shrink-0 w-5 h-5 mt-0.5 text-seam-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              Typical response within 2 business days
            </li>
          </ul>
        </div>

        <div class="reveal-fade-up">
          <form id="org-membership-form" class="rounded-2xl bg-white/[0.06] backdrop-blur-sm border border-white/[0.1] p-8 lg:p-10 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="org-firstname" class="block text-[13px] font-medium text-warm-300 mb-2">First Name *</label>
                <input type="text" id="org-firstname" name="firstname" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
              <div>
                <label for="org-lastname" class="block text-[13px] font-medium text-warm-300 mb-2">Last Name *</label>
                <input type="text" id="org-lastname" name="lastname" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
            </div>
            <div>
              <label for="org-email" class="block text-[13px] font-medium text-warm-300 mb-2">Work Email *</label>
              <input type="email" id="org-email" name="email" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="org-company" class="block text-[13px] font-medium text-warm-300 mb-2">Company Name *</label>
                <input type="text" id="org-company" name="company" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
              <div>
                <label for="org-jobtitle" class="block text-[13px] font-medium text-warm-300 mb-2">Job Title *</label>
                <input type="text" id="org-jobtitle" name="jobtitle" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="org-employees" class="block text-[13px] font-medium text-warm-300 mb-2">Number of Employees *</label>
                <select id="org-employees" name="numemployees" required class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20fill%3D%22none%22%20stroke%3D%22rgba(255%2C255%2C255%2C0.4)%22%20stroke-width%3D%222%22%3E%3Cpath%20d%3D%22m2%204%204%204%204-4%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat">
                  <option value="" class="bg-warm-900">Select...</option>
                  <option value="1-5" class="bg-warm-900">1-5</option>
                  <option value="5-25" class="bg-warm-900">5-25</option>
                  <option value="25-50" class="bg-warm-900">25-50</option>
                  <option value="50-100" class="bg-warm-900">50-100</option>
                  <option value="100-500" class="bg-warm-900">100-500</option>
                  <option value="500-1000" class="bg-warm-900">500-1,000</option>
                  <option value="1000+" class="bg-warm-900">1,000+</option>
                </select>
              </div>
              <div>
                <label for="org-job-function" class="block text-[13px] font-medium text-warm-300 mb-2">Primary Job Function</label>
