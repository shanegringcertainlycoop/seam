            </div>
            <div>
              <label for="org-comments" class="block text-[13px] font-medium text-warm-300 mb-2">Any additional details you'd like to share?</label>
              <textarea id="org-comments" name="getting_started_comments" rows="3" class="w-full rounded-xl bg-white/[0.08] border border-white/[0.12] px-4 py-3 text-[15px] text-white placeholder-white/30 focus:outline-none focus:border-seam-400/50 focus:bg-white/[0.1] transition-colors resize-none"></textarea>
