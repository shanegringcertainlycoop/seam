---
import SiteLayout from '../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../lib/seo-helpers'

/* ─── Data ─── */

const steps = [
  {
    number: '01',
    title: 'Read the Standard',
    price: 'Free',
    subtitle: 'Start here — no account needed.',
    audience: 'Everyone',
    body: 'The SEAM Standard\u2122 is open-access. Read the full framework covering Social Impact, Social Responsibility, Social Justice, and Social Accountability — and decide if the mission resonates.',
    href: '/resources/standard',
    cta: 'Read the Standard',
    logo: '/images/seam-standard-book.png',
  },
  {
    number: '02',
    title: 'Become an Open Member',
    price: 'Free',
    subtitle: 'Join the conversation at no cost.',
    audience: 'Individuals',
    body: 'Open Members get access to the SEAM community, newsletters, and event invitations. It\u2019s the simplest way to stay connected and informed.',
    href: '/membership/individual',
    cta: 'Join free',
    logo: '/logos/member-individual.png',
  },
  {
    number: '03',
    title: 'Become a Changemaker',
    price: '$99/yr',
    subtitle: 'Go deeper with full member benefits.',
    audience: 'Individuals',
    body: 'Changemakers receive voting rights, continuing education credits, early access to programs, and a seat at the table shaping the future of social equity in the built environment.',
    href: '/membership/individual',
    cta: 'Become a Changemaker',
    logo: '/logos/member-changemaker.png',
  },
  {
    number: '04',
    title: 'Earn the SEAM AP',
    price: 'From $519',
    subtitle: 'The professional credential for equity leaders.',
    audience: 'Professionals',
    body: 'The SEAM Accredited Professional credential signals deep expertise in social equity standards. Prep, sit for the exam, and join a growing network of credentialed practitioners.',
    href: '/ap-credential',
    cta: 'Learn about the AP',
    logo: '/logos/ap-seal.png',
  },
  {
    number: '05',
    title: 'Earn a SEAM Mark',
    price: 'From $750',
    subtitle: 'Verify a single activity or a bundle of 3–5.',
    audience: 'Organizations',
    body: 'SEAM Marks are lightweight, activity-level credentials for products, services, and programs that meet specific social equity criteria — without pursuing full building certification. Single Mark or Bulk Marks (3–5 related activities).',
    href: '/marks',
    cta: 'Explore Marks',
    logo: '/logos/mark-activity.svg',
  },
  {
    number: '06',
    title: 'Earn a SEAM SEAL',
    price: 'Coming soon',
    subtitle: 'A thematic recognition across 11–25 activities.',
    audience: 'Organizations',
    body: 'SEAM SEALs recognize sustained action in a focused theme — between single-activity Marks and full building Certification. Themes and pricing in development.',
    href: '/seals',
    cta: 'Learn about SEALs',
    logos: ['/logos/seal-ethical-procurement.svg', '/logos/seal-community-development.svg'],
  },
  {
    number: '07',
    title: 'Join as an Organization',
    price: 'From $1,600/yr',
    subtitle: 'Align your company with the mission.',
    audience: 'Organizations',
    body: 'Organizational membership gives your team access to toolkits, benchmarking data, co-marketing opportunities, and a voice in Standard development.',
    href: '/membership/organization',
    cta: 'View membership tiers',
    logos: ['/logos/member-standing.png', '/logos/member-ladder.png', '/logos/member-arc.png'],
  },
  {
    number: '08',
    title: 'Certify a Building',
    price: 'From $7,625',
    subtitle: 'The gold standard in social equity certification.',
    audience: 'Project teams',
    body: 'Pursue Bronze, Silver, Gold, or Platinum certification for new construction, renovations, or existing buildings. Third-party verified. Globally recognized.',
    href: '/certification',
    cta: 'Start certification',
    logos: ['/logos/cert-bronze.png', '/logos/cert-silver.png', '/logos/cert-gold.png', '/logos/cert-platinum.png'],
  },
  {
    number: '09',
    title: 'Lead at Scale',
    price: '$18K/yr+',
    subtitle: 'Enterprise partnerships for systemic change.',
    audience: 'Enterprise',
    body: 'Founding Members and strategic partners shape the SEAM Standard\u2122 itself, sponsor research, and lead the movement. This is how institutions drive equity at portfolio scale.',
    href: '/membership/organization',
    cta: 'Talk to our team',
  },
]

const shortcuts = [
  {
    label: 'I want to read the Standard',
    description: 'Open-access. No sign-up required.',
    href: '/resources/standard',
    cta: 'Read now →',
  },
  {
    label: 'I want to certify a building',
    description: 'Start the certification process for your project.',
    href: '/get-started',
    cta: 'Get started →',
  },
  {
    label: 'I want to earn the AP',
    description: 'Become a SEAM Accredited Professional.',
    href: '/ap-credential',
    cta: 'Learn more →',
  },
]

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Pathways', path: '/pathways' },
  ]),
]
---

<SiteLayout
  title="Your Path into SEAM — From Free to Full Certification"
  description="Explore seven ways to engage with SEAM — from reading the free Standard to full building certification. Find your starting point in the social equity ecosystem."
  path="/pathways"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900 py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="hero-enter max-w-4xl mx-auto text-center">
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          Your path into SEAM
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4rem)] leading-[1.08] tracking-[-0.03em] text-white">
          Seven ways in. <em class="font-display italic font-normal text-seam-300">One mission.</em>
        </h1>
        <p class="hero-subtitle mt-6 max-w-2xl mx-auto text-[clamp(1.05rem,1.4vw,1.15rem)] leading-relaxed text-warm-300">
          Whether you&rsquo;re an individual exploring social equity for the first time or an enterprise ready to certify at scale, there&rsquo;s a path designed for you.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4 justify-center">
          <a href="#pathways" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
            Find your starting point
          </a>
          <a href="/pricing" class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">
            See pricing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Engagement Ladder ─── -->
  <section id="pathways" class="py-24 lg:py-32 bg-[#f7f6f4]">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">

      <!-- Section header -->
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">The engagement ladder</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          From curious to <em class="italic font-normal text-seam-600">certified</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Each step builds on the last — but you can enter wherever it makes sense for you.
        </p>
      </div>

      <!-- Timeline -->
      <div class="reveal-stagger relative">
        <!-- Vertical spine (desktop only) -->
        <div class="hidden lg:block absolute left-[39px] top-0 bottom-0 w-px bg-warm-300/60"></div>

        {steps.map((step, i) => (
          <>
            {/* Divider between step 4 and 5 */}
            {i === 4 && (
              <div class="reveal-child relative grid grid-cols-1 lg:grid-cols-[80px_1fr] gap-6 lg:gap-12 pb-16">
                <div class="hidden lg:flex flex-col items-center">
                  <div class="relative z-10 h-px w-full"></div>
                </div>
                <div class="flex items-center gap-4">
                  <div class="h-px flex-1 bg-warm-300/60"></div>
                  <span class="text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 whitespace-nowrap">For organizations</span>
                  <div class="h-px flex-1 bg-warm-300/60"></div>
                </div>
              </div>
            )}
            <div class="reveal-child group relative grid grid-cols-1 lg:grid-cols-[80px_1fr] gap-6 lg:gap-12 pb-16 last:pb-0">
              {/* Step number node */}
              <div class="hidden lg:flex flex-col items-center">
                <div class="relative z-10 flex h-[80px] w-[80px] items-center justify-center rounded-full border-2 border-warm-200 bg-white group-hover:border-seam-500 transition-colors duration-300">
                  <span class="font-display text-[28px] tracking-[-0.02em] text-seam-600">{step.number}</span>
                </div>
              </div>

              {/* Card */}
              <div class="relative overflow-visible rounded-2xl border border-warm-100 bg-white p-8 lg:p-10 group-hover:border-warm-200 group-hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] transition-all duration-300">
                {/* Logo / marks */}
                {(step.logos || step.logo) && (
                  <div class="absolute -top-4 sm:-top-8 right-4 sm:right-8 flex items-end pointer-events-none">
                    {step.logos ? (
                      <div class="flex items-end -space-x-1 sm:-space-x-4">
                        {step.logos.map((logo: string) => (
                          <img src={logo} alt="" class="w-8 h-8 sm:w-16 sm:h-16 object-contain drop-shadow-md" loading="lazy" decoding="async" />
                        ))}
                      </div>
                    ) : (
                      <img src={step.logo} alt="" class="w-12 h-12 sm:w-16 sm:h-16 object-contain drop-shadow-md" loading="lazy" decoding="async" />
                    )}
                  </div>
                )}
                <div class="flex flex-wrap items-start gap-3 mb-4">
                  {/* Mobile step number */}
                  <span class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-full border-2 border-warm-200 font-display text-[18px] tracking-[-0.02em] text-seam-600 shrink-0">
                    {step.number}
                  </span>
                  <span class="inline-block rounded-full bg-seam-50 border border-seam-200/60 px-3 py-1 text-[13px] font-medium text-seam-700">
                    {step.price}
                  </span>
                  <span class="inline-block rounded-full bg-warm-50 border border-warm-200/60 px-3 py-1 text-[13px] font-medium text-warm-600">
                    {step.audience}
                  </span>
                </div>
                <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-2">{step.title}</h3>
                <p class="text-[15px] font-medium text-warm-500 mb-4">{step.subtitle}</p>
                <p class="text-[16px] leading-relaxed text-warm-600 mb-4 max-w-2xl">{step.body}</p>
                {step.sale && (
                  <div class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 border border-amber-200 px-3 py-1.5 mb-6">
                    <svg class="w-3.5 h-3.5 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    <span class="text-[12px] font-semibold text-amber-800">{step.sale}</span>
                  </div>
                )}
                <a
                  href={step.href}
                  class="inline-flex items-center rounded-full border border-warm-200 px-6 py-3 text-[14px] font-medium text-warm-700 hover:bg-warm-50 hover:border-warm-300 transition-colors duration-300"
                >
                  {step.cta} <span class="ml-2 text-gold-600 group-hover:text-gold-700 transition-colors duration-300">&rarr;</span>
                </a>
              </div>
            </div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Quick-Start Shortcuts ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">

      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Quick start</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Already know what you need?
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-3 gap-6">
        {shortcuts.map((sc) => (
          <a href={sc.href} class="reveal-child group rounded-2xl border border-warm-100 bg-white p-8 lg:p-10 flex flex-col hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] transition-all duration-300">
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">{sc.label}</h3>
            <p class="text-[16px] leading-relaxed text-warm-600 mb-8 flex-1">{sc.description}</p>
            <span class="inline-flex items-center text-[14px] font-medium text-warm-700 self-start">
              {sc.cta}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Not Sure? CTA ─── -->
  <section class="py-24 lg:py-32 bg-[#f7f6f4]">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up rounded-3xl bg-seam-800 p-12 lg:p-20 text-center">
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-white">
          Not sure where to start?
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-300 max-w-2xl mx-auto">
          That&rsquo;s okay. Most people begin by reading the Standard or reaching out to our team. We&rsquo;ll help you find the right path.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a href="/get-started" class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-seam-800 hover:bg-warm-100 transition-colors duration-300">
            Get started
          </a>
          <a href="/resources/standard" class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300">
            Read the Standard
          </a>
        </div>
      </div>
    </div>
  </section>

</SiteLayout>
