  <script>
    function initApprovedForm() {
      const form = document.getElementById('approved-interest-form') as HTMLFormElement | null
      if (!form) return

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
        const statusEl = document.getElementById('ap-form-status')!
        const original = btn.textContent

        btn.disabled = true
        btn.textContent = 'Submitting...'
        statusEl.classList.add('hidden')

        const data = new FormData(form)
        const fields = [
          { objectTypeId: '0-1', name: 'firstname', value: data.get('firstname') },
          { objectTypeId: '0-1', name: 'lastname', value: data.get('lastname') },
          { objectTypeId: '0-1', name: 'email', value: data.get('email') },
          { objectTypeId: '0-1', name: 'company', value: data.get('company') },
          { objectTypeId: '0-1', name: 'jobtitle', value: data.get('jobtitle') },
          { objectTypeId: '0-1', name: 'seam_activities_certified_list', value: data.get('seam_activities_certified_list') },
        ]

        try {
          const res = await fetch(
            'https://api.hsforms.com/submissions/v3/integration/submit/46821728/bc0c72ba-7cb7-49c1-8113-7e179a941086',
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                fields,
                context: {
                  pageUri: window.location.href,
                  pageName: 'SEAM Approved',
                },
              }),
            }
          )

          if (res.ok) {
            form.reset()
            statusEl.textContent = "Thank you! We'll be in touch within 2 business days."
            statusEl.classList.remove('hidden', 'text-red-400')
            statusEl.classList.add('text-seam-300')
          } else {
            throw new Error('Submission failed')
          }
        } catch (_err) {
          statusEl.textContent = 'Something went wrong. Please email admin@seamcertification.org directly.'
          statusEl.classList.remove('hidden', 'text-seam-300')
          statusEl.classList.add('text-red-400')
        } finally {
          btn.disabled = false
          btn.textContent = original
        }
      })
    }

    function initApprovedModals() {
      const cards = document.querySelectorAll('.approved-card')
      const modals = document.querySelectorAll('.approved-modal')

      function openModal(index: number) {
        const modal = document.querySelector(`[data-modal-index="${index}"]`) as HTMLElement
        if (!modal) return
        modal.classList.remove('hidden')
        modal.classList.add('flex')
        document.body.style.overflow = 'hidden'
      }

      function closeAll() {
        modals.forEach((m) => {
          m.classList.add('hidden')
          m.classList.remove('flex')
        })
        document.body.style.overflow = ''
      }

      cards.forEach((card) => {
        card.addEventListener('click', () => {
          const index = (card as HTMLElement).dataset.markIndex
          if (index !== undefined) openModal(parseInt(index, 10))
        })
      })

      // Close buttons
      document.querySelectorAll('.modal-close').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation()
          closeAll()
        })
      })

      // Click backdrop to close
      modals.forEach((modal) => {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) closeAll()
        })
      })

      // Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAll()
      })
    }

    function initAll() {
      initApprovedModals()
      initApprovedForm()
    }

    document.addEventListener('astro:page-load', initAll)
    if (document.readyState !== 'loading') {
      initAll()
    } else {
      document.addEventListener('DOMContentLoaded', initAll)
    }
  </script>

