    code: 'HRa2.3',
    concept: 'Human Rights',
    objective: 'Ethical Suppliers Procurement',
    title: 'Supplier Living Wage',
    description: 'Push the living wage floor down the supply chain. The Owner\u2019s contract terms require it, qualification screens for it, and ongoing monitoring verifies it. Same wage methodology as HRa2.1 \u2014 but applied to Tier 1 (and rewarded for reaching Tiers 2 and 3).',
    modal: {
      type: 'Driver',
      appliesTo: ['B+I:D', 'B+I:O', 'O+M:D', 'O+M:O'],
      outcomes: 'A wage floor that reaches beyond the Owner\u2019s own employees to every Supplier worker on the project. The Activity uses contract terms, pre-selection assessment, and recurring monitoring to make the living wage a procurement-level standard \u2014 and rewards Owners who push compliance further into the supply chain. Unlike HRa2.1 (the Owner side, which is binary pass/fail), this scales 1\u20135 points by % of Tier 1 workers earning a living wage, with bonus points available for Tier 2 and Tier 3.',
      whatItTakes: {
        intro: 'Core requirements:',
        items: [
          'Contractual requirement \u2014 a living wage clause embedded in the Owner\u2019s contract terms with all Suppliers and vendors',
          'Pre-selection assessment \u2014 evaluate each Supplier\u2019s ability to comply with the living wage requirement during qualification and proposal stages, before they\u2019re brought on',
          'Ongoing monitoring \u2014 Supplier self-assessments, verified through third-party evaluations during the period of review',
        ],
        sections: [
          {
            intro: 'Same living wage methodology as HRa2.1:',
            items: [
              'Global Living Wage Coalition (GLWC) is the preferred source, using the Anker methodology',
              'Other credible third-party sources where GLWC isn\u2019t available (Living Wage Foundation UK, MIT Living Wage Calculator, Living Wage for US)',
              'Manual calculation as a last resort, after exhaustive search',
              'Family wage is international best practice',
              'Manual calculation must cover food, water, clothing, transport, education, decent housing (UN-HABITAT), healthcare, unexpected-event reserve, and any region-specific basic needs',
              'Calculation must specify area, time period, and rationale if outside the reporting period',
              'Excludes overtime pay, and productivity bonuses/allowances unless guaranteed',
              'Wage measured as net (take-home) pay, with benefits supporting basic needs counted as supplements',
            ],
          },
        ],
      },
      indicators: {
        scenarios: [
          { label: 'Performance', text: '% of Tier 1 Supplier workers earning at or above a living wage. Formula: P = (sum of workers earning \u2265 living wage across all Suppliers \u00f7 total Supplier workers on project) \u00d7 100.' },
          { label: 'Context', text: 'Context 1: total number of Supplier workers on the project. Context 2: the gap between actual wages and the living wage, reported in aggregate (satisfies UNRISD SDPI Tier 2.B.II.B.4 \u2014 Living wage gap).' },
        ],
        scoring: 'Outcome threshold: the do-no-harm bar requires all workers to earn a living wage.\n20% Tier 1 workers earning a living wage \u2192 1 pt \u00b7 40% \u2192 2 pts \u00b7 60% \u2192 3 pts \u00b7 80% \u2192 4 pts \u00b7 100% \u2192 5 pts\n+2 pts \u2014 60% of Tier 2 workers earning a living wage\n+3 pts \u2014 60% of Tier 3 workers earning a living wage',
      },
      documentation: [
        'Resources used (financial, human, material)',
        'Third-party living wage audit report confirming compliance without disclosing employee data \u2014 must detail data collection methods and calculate any living wage gaps',
        'Methodology for determining and categorizing the number of project workers',
        'Methodology for identifying sites that need unique living cost assessments',
        'Data sources used for living wage thresholds, with reasoning for the final choice',
        'Analysis if the living wage or cost data is outdated, addressing relevancy',
        'If applicable \u2014 documentation of the approach for incorporating any region-specific basic needs into the assessment, including the parameters for deciding what qualifies',
      ],
    },
  },
]

const steps = [
  {
    number: '01',
    title: 'Select an activity',
    description: 'Select from the available SEAM Approved Marks based on the work your organization is already doing or plans to implement.',
    cta: { label: 'Tell us what you\u2019re working on', href: '#interest-form' },
  },
  {
    number: '02',
    title: 'Submit documentation',
    description: "Provide the documentation that the activity specifies. We'll help you understand exactly what evidence we need to verify your achievement.",
  },
  {
    number: '03',
    title: 'Third-party review',
    description: 'An independent reviewer evaluates your submission against the Standard. Reviewers may request additional documentation or clarification before issuing a determination.',
  },
  {
    number: '04',
    title: 'Earn verified recognition',
    description: 'Receive the SEAM Approved Mark for the verified activity. Your organization is listed in the SEAM directory. Repeat for additional Marks at any time.',
  },
]

const audiences = [
  {
    title: 'Property managers',
    description: 'Turn the equity programs you already run into a verified credential. Strengthen lease renewals and demonstrate value to ownership without a full certification commitment.',
  },
  {
    title: 'Anchor institutions',
    description: 'Hospitals, universities, and civic buildings can verify community benefit practices — local hiring, procurement policies, public access — one activity at a time.',
  },
  {
    title: 'Operators exploring certification',
    description: "Not sure if full certification is right for your building? Start with SEAM Approved. Every verified activity counts toward certification if you decide to pursue it later.",
  },
  {
    title: 'Portfolio managers',
    description: 'Roll out SEAM Approved across multiple properties as a portfolio-wide social equity baseline before committing individual buildings to full certification.',
  },
]

const faqs = [
  {
    q: 'How is SEAM Approved different from full certification?',
    a: 'Full certification evaluates your entire building across all four pillars. SEAM Approved verifies a single activity at a time. Both are third-party verified and publicly listed, but Approved is faster, more focused, and lower commitment.',
  },
  {
    q: 'Does SEAM Approved count toward full certification?',
    a: 'Yes. Every verified activity earns credit toward its pillar. If you later pursue full certification, your SEAM Approved activities carry forward — reducing the scope and timeline of the certification process.',
  },
  {
    q: 'How long does verification take?',
    a: 'Most activity verifications are completed within four to six weeks from documentation submission. Timeline depends on the complexity of the activity and the completeness of your initial submission.',
  },
  {
    q: 'How much does it cost?',
    a: 'Pricing is per activity. <a href="/community" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">Community members</a> receive discounted verification fees. Volume pricing is available for organizations verifying multiple activities or rolling out Approved across a portfolio. See <a href="/pricing" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">pricing details</a>.',
  },
  {
    q: 'Do we need a SEAM AP for activity verification?',
    a: 'No. A <a href="/ap-credential" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM AP</a> is not required for SEAM Approved submissions. However, working with an AP can strengthen your documentation and increase the likelihood of first-submission approval.',
  },
  {
    q: 'How long does the credential last?',
    a: 'SEAM Approved credentials are valid for three years. Renewal requires updated documentation demonstrating that the verified activity remains in practice.',
  },
]

const barHeights = [14, 10, 16, 8, 18, 12]

const faqItems = faqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Solutions', path: '/certification' },
    { name: 'SEAM Approved', path: '/approved' },
  ]),
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="SEAM Approved — Activity-Level Equity Verification"
  description="Verify individual social equity practices without full certification. Each SEAM Approved Mark counts toward full certification."
  path="/approved"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="hero-enter">
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
            Activity-Level Verification
          </span>
          <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
            Verify the human impact work{' '}
            <em class="font-display italic font-normal text-seam-300">
              you already do
            </em>
          </h1>
          <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
            SEAM Approved Marks verify individual activities from the <a href="/resources/standard" class="underline decoration-white/30 hover:decoration-white/60 transition-colors">SEAM Standard</a> without requiring full <a href="/certification" class="underline decoration-white/30 hover:decoration-white/60 transition-colors">project certification</a>. Each Approved Mark stands on its own as a recognized achievement, and each one can count toward full certification if you choose to pursue it.
          </p>
          <div class="hero-cta mt-10 flex flex-wrap gap-4">
            <a
              href="#interest-form"
              class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
            >
              Get started
            </a>
            <a
              href="#marks"
              class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
            >
              Explore available marks
            </a>
          </div>
        </div>

        <!-- SEAM Approved logo -->
        <div class="hidden lg:flex justify-center">
          <div class="relative w-56 h-56 flex items-center justify-center">
            <!-- Burst ripple rings — fast outward pulse with gold tint -->
            <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/40" style="animation-delay: 0s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/30" style="animation-delay: 1s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border-2 border-gold-400/20" style="animation-delay: 2s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border border-seam-300/15" style="animation-delay: 0.5s;"></div>
            <div class="approved-ripple absolute inset-[-8px] rounded-full border border-seam-300/10" style="animation-delay: 1.5s;"></div>
            <!-- Warm glow behind mark -->
            <div class="absolute inset-[-20px] rounded-full bg-gold-400/[0.06] approved-glow"></div>
            <img src="/logos/approved-wordmark.png" alt="SEAM Approved" class="relative w-56 h-56 object-contain drop-shadow-2xl" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── How It's Different ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          How it works
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Why organizations use{' '}
          <em class="italic font-normal text-seam-600">Approved Marks</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8">
        {comparisons.map((c) => (
          <div
            class="reveal-child group rounded-2xl border border-warm-100 p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <div class="text-gold-600 mb-6">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={c.iconPath} />
              </svg>
            </div>
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-4">
              {c.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600">
              {c.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Approved Marks ─── -->
  <section id="marks" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Available Approved Marks
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Turn your work into{' '}
          <em class="italic font-normal text-seam-600">recognized progress</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Pick from the following list of SEAM Approved Marks. Each is verified to earn credit toward full <a href="/certification" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM Certification</a> if you choose to pursue it.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {approvedMarks.map((mark, i) => (
          <button
            type="button"
            data-mark-index={i}
            class="approved-card reveal-child rounded-2xl bg-white p-8 lg:p-10 text-left transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] hover:border-seam-300 border border-transparent cursor-pointer group"
          >
            <div class="flex flex-wrap items-center gap-2 mb-4">
              {mark.code.includes('+') ? (
                mark.code.split('+').map((c: string) => (
                  <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[12px] font-mono font-medium text-seam-700">
                    {c.trim()}
                  </span>
                ))
              ) : (
                <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[12px] font-mono font-medium text-seam-700">
                  {mark.code}
                </span>
              )}
            </div>
            <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-warm-400 mb-2">
              {mark.objective}
            </p>
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-3 group-hover:text-seam-700 transition-colors">
              {mark.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600">
              {mark.description}
            </p>
            <span class="mt-4 inline-flex items-center text-[13px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
              View details &rarr;
            </span>
          </button>
        ))}
      </div>

      <!-- Modals -->
      {approvedMarks.map((mark, i) => (
        <div
          data-modal-index={i}
          class="approved-modal fixed inset-0 z-50 hidden items-start justify-center overflow-y-auto bg-warm-900/60 backdrop-blur-sm p-4 sm:p-8"
        >
          <div class="approved-modal-card relative w-full max-w-3xl rounded-2xl bg-white shadow-2xl my-8 sm:my-16">
            <!-- Header -->
            <div class="sticky top-0 z-10 bg-white rounded-t-2xl border-b border-warm-100 px-8 py-6 flex items-start justify-between gap-4">
              <div>
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  {mark.code.includes('+') ? (
                    mark.code.split('+').map((c: string) => (
                      <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[12px] font-mono font-medium text-seam-700">
                        {c.trim()}
                      </span>
                    ))
                  ) : (
                    <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[12px] font-mono font-medium text-seam-700">
                      {mark.code}
                    </span>
                  )}
                  <span class="text-[13px] font-medium text-warm-900">{mark.title}</span>
                </div>
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[12px] text-warm-500">
                  <span>Concept: <strong class="text-warm-700">{mark.concept}</strong></span>
                  <span class="text-warm-300">&middot;</span>
                  <span>Objective: <strong class="text-warm-700">{mark.objective}</strong></span>
                  <span class="text-warm-300">&middot;</span>
                  <span>Type: <strong class="text-warm-700">{mark.modal.type}</strong></span>
                </div>
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {mark.modal.appliesTo.map((tag: string) => (
                    <span class="rounded-full bg-warm-100 px-2.5 py-0.5 text-[11px] font-medium text-warm-600">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <button
                type="button"
                class="modal-close shrink-0 rounded-full p-2 text-warm-400 hover:text-warm-600 hover:bg-warm-100 transition-colors"
                aria-label="Close"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <!-- Body -->
            <div class="px-8 py-8 space-y-8">
              <!-- Outcomes -->
              <section>
                <h4 class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-3">Outcomes</h4>
                <p class="text-[15px] leading-relaxed text-warm-600">{mark.modal.outcomes}</p>
              </section>

              <!-- What it takes -->
              <section>
                <h4 class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-3">What it takes</h4>
                <p class="text-[15px] font-medium text-warm-800 mb-3">{mark.modal.whatItTakes.intro}</p>
                <ul class="space-y-2.5">
                  {mark.modal.whatItTakes.items.map((item: string) => (
                    <li class="flex items-start gap-2.5 text-[14px] leading-relaxed text-warm-600">
                      <svg class="shrink-0 w-4 h-4 mt-0.5 text-seam-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
                {mark.modal.whatItTakes.sections && (mark.modal.whatItTakes as any).sections.map((sec: { intro: string; items: string[] }) => (
                  <div class="mt-6">
                    <p class="text-[15px] font-medium text-warm-800 mb-3">{sec.intro}</p>
                    <ul class="space-y-2.5">
                      {sec.items.map((item: string) => (
                        <li class="flex items-start gap-2.5 text-[14px] leading-relaxed text-warm-600">
                          <svg class="shrink-0 w-4 h-4 mt-0.5 text-seam-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                          </svg>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </section>

              <!-- Indicators -->
              <section>
                <h4 class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-3">Indicators</h4>
                <div class="space-y-3 mb-3">
                  {mark.modal.indicators.scenarios.map((s: { label: string; text: string }) => (
                    <div class="rounded-xl bg-warm-50 border border-warm-100 px-5 py-4">
                      <p class="text-[13px] font-medium text-warm-900 mb-1">{s.label}</p>
                      <p class="text-[14px] leading-relaxed text-warm-600">{s.text}</p>
                    </div>
                  ))}
                </div>
                {mark.modal.indicators.scoring.split('\n').map((line: string) => (
                  <p class="text-[13px] text-warm-500 italic">{line}</p>
                ))}
              </section>

              <!-- Documentation required -->
              <section>
                <h4 class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-3">Documentation required</h4>
                <ul class="space-y-2">
                  {mark.modal.documentation.map((item: string) => (
                    <li class="flex items-start gap-2.5 text-[14px] leading-relaxed text-warm-600">
                      <svg class="shrink-0 w-3.5 h-3.5 mt-1 text-warm-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </section>

              {mark.modal.note && (
                <div class="rounded-xl bg-amber-100 border border-amber-700/20 px-5 py-4">
                  <p class="text-[13px] leading-relaxed text-amber-800"><strong>Note:</strong> {mark.modal.note}</p>
                </div>
              )}
            </div>

            <!-- Footer -->
            <div class="px-8 py-6 border-t border-warm-100 flex flex-wrap gap-3">
              <a href="#interest-form" class="inline-flex items-center rounded-full bg-warm-900 px-6 py-3 text-[14px] font-medium text-white hover:bg-warm-800 transition-colors duration-300">
                Get started with this activity
              </a>
              <button type="button" class="modal-close inline-flex items-center rounded-full border border-warm-300 px-6 py-3 text-[14px] font-medium text-warm-700 hover:border-warm-400 transition-colors duration-300">
                Close
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── The Process ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          The process
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Four steps to{' '}
          <em class="italic font-normal text-seam-600">approval</em>
        </h2>
      </div>

      <div class="reveal-stagger relative">
        <!-- Vertical spine — hidden on mobile -->
        <div class="hidden lg:block absolute left-[39px] top-0 bottom-0 w-px bg-warm-200"></div>

        {steps.map((step) => (
          <div
            class="reveal-child group relative grid grid-cols-1 lg:grid-cols-[80px_1fr] gap-6 lg:gap-12 pb-16 last:pb-0"
          >
            <!-- Node -->
            <div class="hidden lg:flex flex-col items-center">
              <div class="relative z-10 flex h-[80px] w-[80px] items-center justify-center rounded-full border-2 border-warm-200 bg-white group-hover:border-seam-500 transition-colors duration-300">
                <span class="font-display text-[28px] tracking-[-0.02em] text-seam-600">
                  {step.number}
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="rounded-2xl border border-warm-100 p-8 lg:p-10 group-hover:border-warm-200 group-hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] transition-all duration-300">
              <span class="lg:hidden text-[14px] font-medium text-seam-500 mb-3 block">
                {step.number}
              </span>
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">
                {step.title}
              </h3>
              <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">
