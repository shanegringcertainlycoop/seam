  {
    code: 'SJa2.4',
    concept: 'Social Equity + Justice',
    objective: 'Equity + Inclusion in the Workplace',
    title: 'Gender Pay Equity for Equal Work',
    description: 'Run a gender wage gap analysis across all work types on the project, close the gap through pay, benefits, or promotion adjustments, and put a recurring audit in place to keep it closed.',
    modal: {
      type: 'Driver',
      appliesTo: ['B+I:D', 'B+I:O', 'O+M:D', 'O+M:O'],
