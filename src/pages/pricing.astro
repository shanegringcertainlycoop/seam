                Changemaker membership is included for 1 year to support your professional journey.
              </p>
              <span class="mt-6 inline-flex items-center text-[15px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
                Learn more &rarr;
              </span>
            </a>
            <a href="/get-started" class="group reveal-child rounded-2xl border border-warm-200/60 p-8 lg:p-10 flex flex-col flex-1 transition-all duration-300 hover:border-warm-300">
              <h3 class="font-display text-[22px] tracking-[-0.02em] text-warm-900 mb-3">Special Access</h3>
              <p class="text-[15px] leading-relaxed text-warm-600 flex-1">
                For students, global members, nonprofit staff, and early-career professionals. Income-qualified, honor system.
              </p>
              <span class="mt-6 inline-flex items-center text-[15px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
                Apply now &rarr;
              </span>
            </a>
          </div>
        </div>

        <!-- Divider -->
        <div class="my-20 lg:my-28 border-t border-warm-200"></div>

        <!-- Organization membership -->
        <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Organization Membership</p>
          <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
            Scale your commitment <em class="italic font-normal text-seam-600">with your portfolio</em>
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
            Organization pricing includes annual billing with the option to add seats and properties mid-cycle.
          </p>
        </div>

        <div class="reveal-stagger grid grid-cols-1 lg:grid-cols-3 gap-6">
          {organizationTiers.map((tier) => (
            <div class={`reveal-child rounded-2xl p-8 lg:p-10 flex flex-col ${tier.highlighted ? 'bg-seam-800 text-white ring-2 ring-seam-400/40' : 'bg-white border border-warm-200/60'}`}>
              <h3 class={`font-display text-[28px] tracking-[-0.02em] ${tier.highlighted ? 'text-white' : 'text-warm-900'}`}>{tier.name}</h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class={`font-display text-[42px] tracking-[-0.04em] ${tier.highlighted ? 'text-gold-300' : 'text-warm-900'}`}>{tier.price}</span>
                {tier.period && <span class={`text-[16px] ${tier.highlighted ? 'text-warm-400' : 'text-warm-600'}`}>{tier.period}</span>}
              </div>
              <p class={`mt-4 text-[15px] leading-relaxed ${tier.highlighted ? 'text-seam-200' : 'text-warm-600'}`}>{tier.description}</p>

              <ul class="mt-8 space-y-3 flex-1">
                {tier.features.map((f) => (
                  <li class={`flex items-start gap-2.5 text-[14px] leading-snug ${tier.highlighted ? 'text-seam-100' : 'text-warm-600'}`}>
                    <svg class={`shrink-0 w-4 h-4 mt-0.5 ${tier.highlighted ? 'text-gold-400' : 'text-seam-500'}`} fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>

              <a href="/get-started" class={`mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3.5 text-[15px] font-medium transition-colors duration-300 ${tier.highlighted ? 'bg-white text-seam-800 hover:bg-warm-100' : 'bg-warm-900 text-white hover:bg-warm-800'}`}>
                {tier.cta}
              </a>
            </div>
          ))}
        </div>

        <div class="mt-20 max-w-3xl">
          <h3 class="font-display text-[clamp(1.5rem,3vw,2rem)] tracking-[-0.02em] text-warm-900 mb-8">Membership pricing FAQ</h3>
          {membershipFaqs.map((faq) => (
            <details class="border-b border-warm-200 group">
              <summary class="w-full flex items-center justify-between py-5 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span class="text-[15px] lg:text-[16px] font-medium text-warm-900 pr-6 group-hover:text-seam-600 transition-colors">{faq.q}</span>
                <svg class="shrink-0 w-4 h-4 text-warm-600 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </summary>
              <div class="pb-5">
                <p class="text-[14px] leading-relaxed text-warm-600 pr-10">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up rounded-3xl bg-seam-800 p-12 lg:p-20 text-center">
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-white">
          Not sure which path is right?
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-300 max-w-2xl mx-auto">
          Whether you are a practitioner, a building owner, or an organization with a portfolio, our team can help you find the right entry point. No commitment required.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a
            href="/get-started"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-seam-800 hover:bg-warm-100 transition-colors duration-300"
          >
            Get started
          </a>
          <a
            href="/community"
            class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
          >
            Explore the Community
          </a>
        </div>
      </div>
    </div>
  </section>

</SiteLayout>
