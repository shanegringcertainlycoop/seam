---
import SiteLayout from '../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../lib/seo-helpers'

/* ─── Tab state from URL ─── */
type TabKey = 'certification' | 'approved' | 'credential' | 'membership'
const validTabs: TabKey[] = ['certification', 'approved', 'credential', 'membership']
const tabParam = Astro.url.searchParams.get('tab') as TabKey | null
const activeTab: TabKey = tabParam && validTabs.includes(tabParam) ? tabParam : 'certification'

const tabs: { key: TabKey; label: string }[] = [
  { key: 'certification', label: 'Certification' },
  { key: 'approved', label: 'SEAM Approved' },
  { key: 'credential', label: 'AP Credential' },
  { key: 'membership', label: 'Membership' },
]

/* ─── Certification data (used by client-side calculator) ─── */

/* ─── SEAM Approved data ─── */
const approvedTiers = [
  {
    name: 'Single Activity',
    price: '$750',
    period: '/activity',
    description: 'Verify one activity against the SEAM Standard. Ideal for testing a single practice before committing to full certification.',
    features: [
      'One SEAM Approved Mark',
      'Third-party verification',
      'Directory listing & credential',
      'Counts toward full certification',
    ],
    cta: 'Get started',
    highlighted: false,
  },
  {
    name: 'Bundle',
    price: '$2,000',
    period: '/bundle',
    description: 'Verify 3–5 thematic activities at a significant discount. The most popular option for organizations building toward certification.',
    features: [
      '3–5 related Approved Marks',
      'Grouped by theme for deeper impact',
      'Up to 60% savings vs. individual',
      'Accelerated path to certification',
    ],
    cta: 'Start a bundle',
    highlighted: true,
  },
]

/* ─── AP Credential data ─── */
const credentialTiers = [
  {
    name: 'AP Credential Bundle',
    price: '$389',
    period: '',
    strikethrough: '$587',
    description: 'Everything you need to earn your SEAM AP. The recommended path for most professionals.',
    features: [
      'Foundations course ($129 value)',
      'Proctored online examination',
      'Digital credential & seal',
      'SEAM directory listing',
      'Changemaker membership — 1 year ($99 value)',
    ],
    cta: 'Get started',
    highlighted: true,
  },
  {
    name: 'Training Only',
    price: '$129',
    period: '',
    strikethrough: '',
    description: 'Foundations: Social Equity in the Built Environment course. Build knowledge without committing to the exam.',
    features: [
      '10 modules · 55 lessons',
      '8+ hours of course material',
      '9 knowledge checks',
      '2-hour practice exam',
      'Income-qualified rate available',
    ],
    cta: 'Enroll in course',
    highlighted: false,
  },
]

/* ─── Membership data ─── */
const individualTiers = [
  {
    name: 'Open',
    price: 'Free',
    period: '',
    description: 'For those exploring SEAM and seeking to get involved. No commitment required.',
    features: [
      'Download the full SEAM Standard',
      'Join critical conversations',
      'Attend public webcasts and events',
      'Monthly newsletter with field updates',
    ],
    cta: 'Get started free',
    highlighted: false,
    note: '',
  },
  {
    name: 'Changemaker',
    price: '$99',
    period: '/year',
    description: 'Includes tools, access, and discounts to support deeper SEAM engagement.',
    features: [
      'Everything in Open',
      'Activity documentation templates',
      'SEAM AP exam fee covered',
      'Full course library with CEU credit',
      'Practitioner network and referrals',
      'Basic ROSSI Calculator access',
      'CEU tracking dashboard',
      'Access to SEAM project referrals',
      'Discounted SEAM Approved verification',
    ],
    cta: 'Join as Changemaker',
    highlighted: true,
    note: '',
  },
]

const organizationTiers = [
  {
    name: 'Standing',
    price: '$1,600',
    period: '/year',
    description: 'For organizations beginning their SEAM journey. Access to The Stitch and foundational benefits.',
    features: [
      'Access to The Stitch members-only hub',
      '5% discount on certifications and events',
      'Eligibility to sponsor events',
      'Recognition in the Member Directory',
      'Recognition on the SEAM website (text listing)',
      '3 included employee individual memberships',
    ],
    cta: 'Talk to our team',
    highlighted: false,
  },
  {
    name: 'Ladder',
    price: '$6,000',
    period: '/year',
    description: 'For organizations actively pursuing certification or rolling out SEAM Approved across properties.',
    features: [
      'Access to The Stitch members-only hub',
      '10% discount on certifications and events',
      'Eligibility to sponsor events',
      'Recognition on the SEAM website (logo)',
      'Ability to submit a blog post on SEAM\u2019s website',
      '10 included employee individual memberships',
      '1 complimentary AP training and exam',
    ],
    cta: 'Start as Ladder',
    highlighted: true,
  },
  {
    name: 'Arc',
    price: '$18,000',
    period: '/year',
    description: 'For institutions leading the movement. Maximum influence and recognition.',
    features: [
      'Access to The Stitch members-only hub',
      '15% discount on certifications and events',
      'Eligibility to sponsor events',
      'Recognition on the SEAM website (logo, featured)',
      'Submit featured articles & webinars',
      'Use of the membership logo',
      '25 included employee individual memberships',
      '5 complimentary AP trainings and exams',
      '1 included event sponsorship',
    ],
    cta: 'Talk to our team',
    highlighted: false,
  },
]

/* ─── FAQ data (per tab) ─── */
const certFaqs = [
  {
    q: 'What is included in the registration fee?',
    a: 'Registration gives you access to the online project portal, documentation templates, a preliminary review of your project scope, and locks in your fee schedule for 24 months. It is a separate fee from the verification review.',
  },
  {
    q: 'How is the per-SF verification fee calculated?',
    a: 'The rate is based on your project\'s gross square footage and uses a tiered structure: $0.035/SF for the first 250K SF, $0.025/SF for 250K\u2013500K, and $0.015/SF above 500K. A minimum fee applies based on the certification level you\u2019re pursuing.',
  },
  {
    q: 'How long does a certification remain valid?',
    a: 'SEAM Certification is valid for 3 years. After that, projects must recertify to maintain their certification level. Recertification fees are approximately 60% of the original verification fee.',
  },
  {
    q: 'Do organization members get discounts on certification fees?',
    a: 'Yes. Standing members receive 5% off, Ladder members 10% off, and Arc members 15% off certification and event fees.',
  },
  {
    q: 'Is there volume pricing for portfolios?',
    a: 'Yes. Organizations certifying 5 or more projects can access portfolio pricing through an Organization membership at the Ladder or Arc tier. Contact our team for a custom quote.',
  },
]

const approvedFaqs = [
  {
    q: 'How much does a single activity verification cost?',
    a: 'A single SEAM Approved Mark costs $750. For organizations verifying 3\u20135 related activities, the Bundle option is $2,000 \u2014 up to 60% savings vs. individual pricing.',
  },
  {
    q: 'Can I start with Approved and upgrade to full Certification later?',
    a: 'Yes. Every verified activity earns pathway credit toward full certification. Many organizations start by verifying 3\u20135 activities and then transition to a full certification track when ready.',
  },
  {
    q: 'Do community members get a discount?',
    a: 'Yes. Changemaker individual members receive discounted verification fees. Organization members at Ladder and above receive volume pricing automatically.',
  },
  {
    q: 'How long does the Approved credential last?',
    a: 'SEAM Approved credentials are valid for 3 years. Renewal requires updated documentation demonstrating that the verified activity remains in practice.',
  },
]

const credentialFaqs = [
  {
    q: 'What does the AP Credential Bundle include?',
    a: 'The Bundle ($389) includes the Foundations: Social Equity in the Built Environment course ($129 value), the AP exam, your digital credential and seal, a directory listing, and 1 year of Changemaker membership ($99 value).',
  },
  {
    q: 'Can my AP exam fee be covered by my organization?',
    a: 'Yes. Organization members at Ladder and Arc tiers include complimentary AP trainings and exams, and exam fees can be invoiced to the organization.',
  },
  {
    q: 'Is the exam fee covered for Changemaker members?',
    a: 'Yes. The AP exam fee is included as part of your Changemaker membership ($99/yr). No additional exam cost.',
  },
  {
    q: 'Can I take the training without the exam?',
    a: 'Yes. The Training Only option is $129 and includes the full Foundations course \u2014 10 modules, 55 lessons, 8+ hours of content, and 9 knowledge checks.',
  },
  {
    q: 'Is there a refund policy for the exam?',
    a: 'Exam fees can be transferred to a later date but are non-refundable. Training access remains available after purchase.',
  },
]

const membershipFaqs = [
  {
    q: 'What is the difference between Open and Changemaker?',
    a: 'Open is free and gives you access to public resources. Changemaker ($99/yr) adds access to The Stitch community hub, course library, templates, AP exam coverage, CEU tracking, and project referral eligibility.',
  },
  {
    q: 'What discounts do organization members receive?',
    a: 'Standing members get 5% off certifications and events. Ladder gets 10% off plus 1 complimentary AP training. Arc gets 15% off plus 5 AP trainings and 1 event sponsorship.',
  },
  {
    q: 'Can I upgrade or downgrade my membership?',
    a: 'Yes. Individual memberships can be changed anytime. Organization membership changes take effect at the next billing cycle. Contact our team for mid-cycle adjustments.',
  },
  {
    q: 'Is there special pricing for students or nonprofits?',
    a: 'Yes. Special Access pricing is available for students, global members, nonprofit staff, and early-career professionals. Income-qualified, honor system.',
  },
  {
    q: 'What payment methods do you accept?',
    a: 'We accept credit cards, ACH transfers, and wire transfers. Organization memberships and fees above $5,000 can be invoiced with Net 30 terms.',
  },
]

const allFaqs = [...certFaqs, ...approvedFaqs, ...credentialFaqs, ...membershipFaqs]
const faqItems = allFaqs.map((f) => ({ question: f.q, answer: f.a }))

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Pricing', path: '/pricing' },
  ]),
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="Pricing — Certification, Approved & AP Credential"
  description="Transparent pricing for SEAM Certification, SEAM Approved verification, AP Credential, and membership. See fees for every path."
  path="/pricing"
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0">
      <img
        src="/images/hero-pricing.jpg"
        alt="People moving forward together"
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-4xl mx-auto text-center">
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          Pricing
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4rem)] leading-[1.1] tracking-[-0.04em] text-white">
          Transparent pricing for <em class="font-display italic font-normal text-seam-300">every path</em>
        </h1>
        <p class="hero-subtitle mt-6 max-w-2xl mx-auto text-[clamp(1.05rem,1.4vw,1.15rem)] leading-relaxed text-warm-300">
          Whether you are certifying a building, verifying a single activity, earning your credential, or joining a community of practice — you should know exactly what it costs before you start.
        </p>
      </div>
    </div>
  </section>

  <!-- Tab Navigation -->
  <div class="sticky top-[72px] z-30 bg-white border-b border-warm-100 shadow-sm">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <nav class="flex gap-1 overflow-x-auto scrollbar-hide py-2" aria-label="Pricing categories">
        {tabs.map((tab) => (
          <a
            href={`/pricing?tab=${tab.key}`}
            class={`whitespace-nowrap rounded-full px-5 py-2.5 text-[14px] font-medium transition-colors duration-200 ${
              activeTab === tab.key
                ? 'bg-warm-900 text-white'
                : 'text-warm-600 hover:bg-warm-100 hover:text-warm-700'
            }`}
          >
            {tab.label}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Certification Tab -->
  {/* All tabs rendered; hidden via CSS for indexability */}
  <div class={activeTab === 'certification' ? '' : 'hidden'}>
    <div class="py-20 lg:py-28">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
        <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Full Certification</p>
          <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
            Estimate your <em class="italic font-normal text-seam-600">certification investment</em>
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
            Use the calculator below to estimate fees based on your project type, size, and any applicable discounts. Registration locks in your fee schedule for 24 months.
          </p>
        </div>

        <!-- Calculator — two-column layout -->
        <div id="cert-calculator" class="rounded-3xl border border-warm-200 bg-white shadow-[0_8px_30px_rgba(0,0,0,0.04)] overflow-hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <!-- Left: Controls -->
            <div class="p-8 lg:p-10 space-y-8">
              <!-- Project Type -->
              <div>
                <label class="block text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 mb-4">Rating System</label>
                <div class="flex flex-col sm:flex-row gap-3">
                  <button data-type="bi" class="cert-type-btn flex-1 rounded-xl border-2 border-seam-500 bg-seam-50 px-4 py-3 text-left transition-all duration-200">
                    <span class="block text-[15px] font-medium text-warm-900">Buildings + Interiors</span>
                    <span class="block text-[12px] text-warm-500 mt-0.5">New construction &amp; renovations</span>
                  </button>
                  <button data-type="om" class="cert-type-btn flex-1 rounded-xl border-2 border-warm-200 bg-white px-4 py-3 text-left transition-all duration-200 hover:border-warm-300">
                    <span class="block text-[15px] font-medium text-warm-900">Operations + Maintenance</span>
                    <span class="block text-[12px] text-warm-500 mt-0.5">Existing buildings &amp; operations</span>
                  </button>
                </div>
              </div>

              <!-- Project Size -->
              <div>
                <label for="size-input" class="block text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 mb-4">Project Size</label>
                <div class="relative">
                  <input
                    type="text"
                    id="size-input"
                    value="100,000"
                    inputmode="numeric"
                    class="w-full rounded-xl border-2 border-warm-200 bg-white px-5 py-3.5 font-display text-[20px] tracking-[-0.02em] text-warm-900 focus:outline-none focus:border-seam-500 transition-colors"
                  />
                  <span class="absolute right-5 top-1/2 -translate-y-1/2 text-[13px] text-warm-400">sq ft</span>
                </div>
                <div class="mt-3">
                  <input
                    type="range"
                    id="size-slider"
                    min="0"
                    max="100"
                    value="14"
                    class="w-full h-2 bg-warm-200 rounded-full appearance-none cursor-pointer [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-5 [&::-webkit-slider-thumb]:h-5 [&::-webkit-slider-thumb]:bg-seam-600 [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:shadow-md [&::-moz-range-thumb]:w-5 [&::-moz-range-thumb]:h-5 [&::-moz-range-thumb]:bg-seam-600 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:cursor-pointer"
                  />
                  <div class="flex justify-between mt-1 text-[11px] text-warm-400">
                    <span>1K</span>
                    <span>100K</span>
                    <span>1M</span>
                    <span>10M</span>
                    <span>20M</span>
                  </div>
                </div>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  <button data-sqft="25000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">25K</button>
                  <button data-sqft="50000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">50K</button>
                  <button data-sqft="100000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">100K</button>
                  <button data-sqft="250000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">250K</button>
                  <button data-sqft="500000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">500K</button>
                  <button data-sqft="1000000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">1M</button>
                  <button data-sqft="5000000" class="size-preset rounded-full border border-warm-200 px-2.5 py-1 text-[11px] font-medium text-warm-500 hover:border-warm-300 hover:text-warm-700 transition-colors">5M</button>
                </div>
              </div>

              <!-- Discounts -->
              <div>
                <label class="block text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 mb-4">Discounts</label>
                <div class="space-y-3">
                  <!-- Membership -->
                  <div class="rounded-xl border border-warm-200 px-4 py-3.5 transition-all duration-200 has-[select:not([value=''])]:border-seam-500 has-[select:not([value=''])]:bg-seam-50">
                    <span class="block text-[13px] font-medium text-warm-900 mb-2">Community Membership</span>
                    <select id="discount-member" class="w-full rounded-lg border border-warm-200 bg-white px-3 py-2 text-[13px] text-warm-700 focus:outline-none focus:border-seam-500 transition-colors cursor-pointer">
                      <option value="">No membership</option>
                      <option value="75">Standing — $75 off</option>
                      <option value="150">Ladder — $150 off</option>
                      <option value="225">Arc / Silver Founding — $225 off</option>
                      <option value="450">Gold Founding — $450 off</option>
                      <option value="750">Platinum Founding — $750 off</option>
                    </select>
                  </div>

                  <!-- Project Type -->
                  <div class="rounded-xl border border-warm-200 px-4 py-3.5 transition-all duration-200 has-[select:not([value=''])]:border-seam-500 has-[select:not([value=''])]:bg-seam-50">
                    <span class="block text-[13px] font-medium text-warm-900 mb-2">
                      Qualifying Project — $500 off
                      <span class="relative inline-block ml-1 group/tip2">
                        <svg class="inline w-3.5 h-3.5 text-warm-400 group-hover/tip2:text-warm-600 transition-colors cursor-help" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827m0 3h.01M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
                        </svg>
                        <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 rounded-lg bg-warm-900 px-4 py-3 text-[12px] leading-relaxed text-warm-200 opacity-0 group-hover/tip2:opacity-100 transition-opacity duration-200 shadow-lg z-10">
                          Includes projects in Emerging Market economies as classified by the World Bank. This covers upper-middle-income countries with developing financial markets and infrastructure. <a href="https://datahelpdesk.worldbank.org/knowledgebase/articles/906519-world-bank-country-and-lending-groups" target="_blank" rel="noopener noreferrer" class="underline text-seam-300 hover:text-seam-200 pointer-events-auto">See eligible countries &rarr;</a>
                          <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-px border-4 border-transparent border-t-warm-900"></span>
                        </span>
                      </span>
                    </span>
                    <select id="discount-project" class="w-full rounded-lg border border-warm-200 bg-white px-3 py-2 text-[13px] text-warm-700 focus:outline-none focus:border-seam-500 transition-colors cursor-pointer">
                      <option value="">Not applicable</option>
                      <option value="500">Government / Municipal</option>
                      <option value="500">Social</option>
                      <option value="500">Non-profit or Charity</option>
                      <option value="500">Low Income / Affordable Housing</option>
                      <option value="500">Senior / Assisted Living</option>
                      <option value="500">Healthcare</option>
                      <option value="500">Emerging Market</option>
                      <option value="500">Small Business</option>
                    </select>
                  </div>

                  <!-- Developing Country -->
                  <label class="flex items-center gap-3 rounded-xl border border-warm-200 px-4 py-3.5 cursor-pointer transition-all duration-200 hover:border-warm-300 has-[input:checked]:border-seam-500 has-[input:checked]:bg-seam-50">
                    <input type="checkbox" id="discount-developing" class="w-4 h-4 rounded border-warm-300 text-seam-600 focus:ring-seam-500" />
                    <div>
                      <span class="text-[13px] font-medium text-warm-900">
                        Developing Country — $1,000 off
                        <span class="relative inline-block ml-1 group/tip">
                          <svg class="inline w-3.5 h-3.5 text-warm-400 group-hover/tip:text-warm-600 transition-colors cursor-help" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827m0 3h.01M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
                          </svg>
                          <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 rounded-lg bg-warm-900 px-4 py-3 text-[12px] leading-relaxed text-warm-200 opacity-0 group-hover/tip:opacity-100 transition-opacity duration-200 shadow-lg z-10">
                            Based on the World Bank country classification by income level. Low-income and lower-middle-income economies qualify. <a href="https://datahelpdesk.worldbank.org/knowledgebase/articles/906519-world-bank-country-and-lending-groups" target="_blank" rel="noopener noreferrer" class="underline text-seam-300 hover:text-seam-200 pointer-events-auto">See eligible countries &rarr;</a>
                            <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-px border-4 border-transparent border-t-warm-900"></span>
                          </span>
                        </span>
                      </span>
                      <span class="block text-[11px] text-warm-500">World Bank classification</span>
                    </div>
                  </label>
                </div>
              </div>
            </div>

            <!-- Right: Results -->
            <div class="bg-warm-900 p-8 lg:p-10 flex flex-col">
              <div class="flex items-baseline justify-between mb-6">
                <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400">Your Estimate</p>
                <p id="per-sf-rate" class="text-[12px] text-warm-500">$0.044/sq ft</p>
              </div>

              <!-- Registration -->
              <div class="mb-6 pb-6 border-b border-warm-700/50">
                <p class="text-[12px] text-warm-400 mb-1">Registration Fee</p>
                <div class="flex items-baseline justify-between">
                  <p class="text-[12px] text-warm-500">One-time — locks fees for 24 mo</p>
                  <p class="font-display text-[24px] tracking-[-0.03em] text-white">$2,000</p>
                </div>
              </div>

              <!-- Verification by cert level -->
              <p class="text-[12px] text-warm-400 mb-3">Verification by Certification Level</p>
              <div class="grid grid-cols-2 gap-3 mb-6">
