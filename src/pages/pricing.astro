  <script>
    function initCertCalculator() {
      const slider = document.getElementById('size-slider') as HTMLInputElement
      const sizeInput = document.getElementById('size-input') as HTMLInputElement
      const typeButtons = document.querySelectorAll('.cert-type-btn')
      const presetButtons = document.querySelectorAll('.size-preset')
      const discountMember = document.getElementById('discount-member') as HTMLSelectElement
      const discountProject = document.getElementById('discount-project') as HTMLSelectElement
      const discountDeveloping = document.getElementById('discount-developing') as HTMLInputElement
      const perSfRate = document.getElementById('per-sf-rate')!
      const priceBronze = document.getElementById('price-bronze')!
      const priceSilver = document.getElementById('price-silver')!
      const priceGold = document.getElementById('price-gold')!
      const pricePlatinum = document.getElementById('price-platinum')!
      const priceTotal = document.getElementById('price-total')!
      const priceSavings = document.getElementById('price-savings')!
      const savingsAmount = document.getElementById('savings-amount')!

      if (!slider || !sizeInput) return

      const REGISTRATION = 2000

      // Per-SF rate tiers from the SEAM fee table
      const rateTiers = [
        { min: 1, max: 99999, rate: 0.047 },
        { min: 100000, max: 249999, rate: 0.044 },
        { min: 250000, max: 499999, rate: 0.041 },
        { min: 500000, max: 749999, rate: 0.039 },
        { min: 750000, max: 999999, rate: 0.036 },
        { min: 1000000, max: 1249999, rate: 0.033 },
        { min: 1250000, max: 1499999, rate: 0.030 },
        { min: 1500000, max: 1749999, rate: 0.027 },
        { min: 1750000, max: 1999999, rate: 0.025 },
        { min: 2000000, max: 2499999, rate: 0.022 },
        { min: 2500000, max: 2999999, rate: 0.019 },
        { min: 3000000, max: 5000000, rate: 0.016 },
        { min: 5000001, max: 9999999, rate: 0.013 },
        { min: 10000000, max: 20000000, rate: 0.011 },
      ]

      // Cert-level minimum fees (floor regardless of sqft)
      const certMinimums = {
        bronze: 5625,
        silver: 6875,
        gold: 8125,
        platinum: 9375,
      }

      let currentSqft = 100000

      // Log scale slider: maps 0-100 → 1,000-20,000,000
      const LOG_MIN = Math.log(1000)
      const LOG_MAX = Math.log(20000000)

      function sliderToSqft(val: number): number {
        const logVal = LOG_MIN + (val / 100) * (LOG_MAX - LOG_MIN)
        return Math.round(Math.exp(logVal) / 1000) * 1000
      }

      function sqftToSlider(sqft: number): number {
        const clamped = Math.max(1000, Math.min(20000000, sqft))
        return Math.round(((Math.log(clamped) - LOG_MIN) / (LOG_MAX - LOG_MIN)) * 100)
      }

      function getRate(sqft: number): number {
        for (const tier of rateTiers) {
          if (sqft >= tier.min && sqft <= tier.max) return tier.rate
        }
        return rateTiers[rateTiers.length - 1].rate
      }

      function calcVerification(sqft: number, level: keyof typeof certMinimums): number {
        const raw = sqft * getRate(sqft)
        return Math.max(raw, certMinimums[level])
      }

      function fmt(n: number): string {
        return '$' + Math.round(n).toLocaleString('en-US')
      }

      function getTotalDiscount(): number {
        let total = 0
        const memberVal = parseInt(discountMember.value, 10)
        if (!isNaN(memberVal)) total += memberVal
        const projectVal = parseInt(discountProject.value, 10)
        if (!isNaN(projectVal)) total += projectVal
        if (discountDeveloping.checked) total += 1000
        return total
      }

      function update() {
        const sqft = currentSqft
        const rate = getRate(sqft)
        const discountDollars = getTotalDiscount()

        perSfRate.textContent = `Rate: $${rate.toFixed(3)}/sq ft`

        const levels: (keyof typeof certMinimums)[] = ['bronze', 'silver', 'gold', 'platinum']
        const els = [priceBronze, priceSilver, priceGold, pricePlatinum]
        const verifValues: number[] = []

        levels.forEach((level, i) => {
          const base = calcVerification(sqft, level)
          const final = Math.max(0, Math.round(base - discountDollars))
          verifValues.push(final)
          els[i].textContent = fmt(final)
        })

        const totalLow = REGISTRATION + verifValues[0]
        const totalHigh = REGISTRATION + verifValues[3]
        priceTotal.textContent = `${fmt(totalLow)} – ${fmt(totalHigh)}`

        if (discountDollars > 0) {
          priceSavings.classList.remove('hidden')
          savingsAmount.textContent = fmt(discountDollars)
        } else {
          priceSavings.classList.add('hidden')
        }
      }

      function setSqft(val: number) {
        currentSqft = Math.max(1000, Math.min(20000000, val))
        sizeInput.value = currentSqft.toLocaleString('en-US')
        slider.value = String(sqftToSlider(currentSqft))
        update()
      }

      // Slider input
      slider.addEventListener('input', () => {
        currentSqft = sliderToSqft(parseInt(slider.value, 10))
        sizeInput.value = currentSqft.toLocaleString('en-US')
        update()
      })

      // Text input
      sizeInput.addEventListener('input', () => {
        const raw = sizeInput.value.replace(/[^0-9]/g, '')
        const val = parseInt(raw, 10)
        if (!isNaN(val) && val > 0) {
          currentSqft = val
          slider.value = String(sqftToSlider(val))
          update()
        }
      })

      sizeInput.addEventListener('blur', () => {
        sizeInput.value = currentSqft.toLocaleString('en-US')
      })

      // Preset buttons
      presetButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const sqft = parseInt((btn as HTMLElement).dataset.sqft!, 10)
          setSqft(sqft)
        })
      })

      // Type toggle (visual for now — same rates)
      typeButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const type = (btn as HTMLElement).dataset.type!
          typeButtons.forEach((b) => {
            if ((b as HTMLElement).dataset.type === type) {
              b.classList.remove('border-warm-200', 'bg-white')
              b.classList.add('border-seam-500', 'bg-seam-50')
            } else {
              b.classList.remove('border-seam-500', 'bg-seam-50')
              b.classList.add('border-warm-200', 'bg-white')
            }
          })
          update()
        })
      })

      discountMember.addEventListener('change', update)
      discountProject.addEventListener('change', update)
      discountDeveloping.addEventListener('change', update)

      // Init
      slider.value = String(sqftToSlider(currentSqft))
      update()
    }

    document.addEventListener('astro:page-load', initCertCalculator)
    if (document.readyState !== 'loading') {
      initCertCalculator()
    } else {
      document.addEventListener('DOMContentLoaded', initCertCalculator)
    }
  </script>

