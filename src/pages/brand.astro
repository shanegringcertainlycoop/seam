  <script>
    document.querySelectorAll('.copy-swatch').forEach((el) => {
      el.addEventListener('click', async () => {
        const hex = el.getAttribute('data-copy')
        if (!hex) return
        try {
          await navigator.clipboard.writeText(hex)
          const feedback = el.querySelector('.copy-feedback') as HTMLElement | null
          if (feedback) {
            feedback.style.opacity = '1'
            setTimeout(() => { feedback.style.opacity = '0' }, 900)
          }
        } catch {}
      })
    })
  </script>
