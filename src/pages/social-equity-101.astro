---
import SiteLayout from '../layouts/SiteLayout.astro'
import { SITE_URL, breadcrumbSchema, faqSchema } from '../lib/seo-helpers'

const faqs = [
  {
    question: 'What is social equity in the built environment?',
    answer:
      'Social equity in the built environment means that the benefits and burdens of a building are distributed fairly among everyone it touches — from the people who use the space daily to the communities that supply its raw materials. It examines wages, working conditions, health impacts, community displacement, and supply chain labor practices as measurable outcomes of how a building is designed, built, and operated.',
  },
  {
    question: 'Who is affected by a building\'s social impact?',
    answer:
      'Every building touches at least six groups of people: occupants who use the space daily, operators who maintain and service it, builders who construct it, neighbors who live and work around it, suppliers who manufacture its materials, and the laborers in extraction communities where raw materials originate. Most building standards only address one or two of these groups.',
  },
  {
    question: 'What is SEAM certification?',
    answer:
      'SEAM is the first certification system built to measure social equity in the built environment. It evaluates buildings across four interdependent pillars — Social Impact, Social Responsibility, Social Justice, and Social Accountability — through scored activities and third-party verification, resulting in recognition at one of four levels of achievement.',
  },
  {
    question: 'How is SEAM different from LEED and WELL?',
    answer:
      'LEED measures environmental performance. WELL measures occupant health and wellness. SEAM measures social equity — the fairness of a building\'s relationship with all the people it touches, including workers, neighbors, supply chains, and extraction communities. SEAM is complementary to both systems and designed to work alongside them.',
  },
  {
    question: 'How is social equity different from ESG?',
    answer:
      'ESG (Environmental, Social, and Governance) is a reporting framework — it tells investors what a company discloses about its impacts. Social equity certification through SEAM is an operating standard — it defines specific practices, sets measurable thresholds, and requires third-party verification. ESG asks "did you report it?" SEAM asks "did you do it?"',
  },
  {
    question: 'Can social equity be measured?',
    answer:
      'Yes, though it requires different metrics than environmental performance. SEAM measures scored activities like living wage commitments, benefits coverage rates, supplier audit completion, community impact assessments, and grievance resolution timelines. These are verified through documentation review, worker surveys, and third-party audits — similar to how LEED verifies energy performance.',
  },
  {
    question: 'What are the four pillars of social equity in the SEAM Standard?',
    answer:
      'The SEAM Standard organizes social equity into four measurable pillars: Social Impact (understanding who your project affects), Social Responsibility (governance, community engagement, and reinvestment), Social Justice (equity across procurement, the workplace, and capital access), and Social Accountability (human rights, ethical sourcing, and worker well-being). All four pillars are interdependent — a building must demonstrate performance across each one.',
  },
  {
    question: 'Does social equity certification add cost?',
    answer:
      'Buildings already carry social costs — they are just externalized onto workers, neighbors, and supply chain communities. SEAM certification internalizes some of these costs while generating measurable returns: certified buildings see 51% less tenant turnover, 4–8% rent premiums, and reduced litigation exposure. The certification fee itself is comparable to LEED or WELL.',
  },
  {
    question: 'What is the ROI of social equity in real estate?',
    answer:
      'Certified green and socially responsible buildings consistently command 4–8% rent premiums, demonstrate lower vacancy rates, and see 51% less tenant turnover. Corporate tenants increasingly require social impact data for ESG reporting, making social equity credentials a competitive advantage in leasing. The ROSSI Calculator from SEAM quantifies these returns at the project and portfolio level.',
  },
]

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Social Equity 101', path: '/social-equity-101' },
  ]),
  faqSchema(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'Social Equity 101 — What Buildings Owe the People They Touch',
    description: 'A comprehensive guide to social equity in the built environment: what it means, who it affects, how it is measured, and why it matters for buildings and real estate.',
    author: { '@type': 'Organization', name: 'SEAM, Inc.', url: SITE_URL },
    publisher: { '@type': 'Organization', name: 'SEAM', url: SITE_URL, logo: { '@type': 'ImageObject', url: `${SITE_URL}/logos/seam-wordmark.png` } },
    datePublished: '2025-03-01',
    dateModified: '2026-05-04',
    mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE_URL}/social-equity-101` },
    url: `${SITE_URL}/social-equity-101`,
    about: [
      { '@type': 'Thing', name: 'Social equity in the built environment' },
      { '@type': 'Thing', name: 'Building certification' },
      { '@type': 'Thing', name: 'ESG real estate' },
    ],
  },
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="Social Equity 101 — What Buildings Owe the People They Touch"
  description="What social equity means for buildings and the six groups of people every project touches. Learn what it is, who it affects, and how SEAM measures it."
  path="/social-equity-101"
  type="article"
  article={{ author: 'SEAM, Inc.', publishedTime: '2025-03-01', section: 'Education' }}
  jsonLd={jsonLd}
>

  <!-- ═══════════════════════════════════════════════════════════════════
       1. HERO — Full-width 6-dimensions background
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[85vh] flex items-end overflow-hidden bg-warm-900">
    <img
      src="/images/home/6-dimensions.png"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-center select-none pointer-events-none opacity-30"
      draggable="false"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900 via-warm-900/60 to-warm-900/30"></div>
    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 pb-16 lg:pb-24 pt-40 w-full">
      <div class="max-w-3xl hero-enter">
        <!-- Breadcrumbs -->
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 text-[14px] text-warm-400">
            <li><a href="/" class="hover:text-warm-300 transition-colors">Home</a></li>
            <li aria-hidden="true" class="select-none">/</li>
            <li aria-current="page" class="text-white font-medium">Social Equity 101</li>
          </ol>
        </nav>

        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          How does a building impact the people it touches?
        </h1>

        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300" data-speakable>
          It's a fair question, and not one we always ask. Every building is a series of
          decisions about people, made long before the site is selected and felt far beyond
          the property line. Social equity asks whether those decisions were intentional and fair.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       2. THE SETUP — Two-column: prose + 6-dimensions illustration
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-fade-up max-w-3xl mx-auto">
        <!-- Prose -->
        <div>
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
            The concept
          </p>
          <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-8">
            Every building is a set of decisions about people
          </h2>
          <div class="space-y-5 text-[17px] leading-relaxed text-warm-600" data-speakable>
            <p>
              Who gets paid a living wage to clean the floors? Who breathes the dust during
              construction? Whose neighborhood absorbs the traffic and noise? Which communities
              mine the raw materials?
            </p>
            <p>
              These aren't abstract questions. They have dollar amounts, health outcomes,
              and real people attached to them.
            </p>
            <p>
              LEED measures environmental performance. WELL measures occupant wellness. SEAM measures
              the equity of every relationship a building creates. That is what social equity in the
              built environment means, and what
              <a href="/resources/standard" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">the SEAM Standard</a> was built to make measurable.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       PULL QUOTE
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-24">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <blockquote class="reveal-fade max-w-3xl mx-auto text-center">
        <p class="font-display italic text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.2] tracking-[-0.02em] text-warm-400">
          "A building is more than a structure. It's a supply chain, a labor market,
          a neighborhood force, and a set of choices about who matters."
        </p>
      </blockquote>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       3. THE SIX GROUPS — Alternating editorial blocks
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- ─── 3a. Occupants (image left) ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="reveal-slide-left">
          <img
            src="/images/home/occupants.png"
            alt="Illustration of building occupants"
            class="w-full max-w-[520px] h-auto rounded-2xl"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="reveal-slide-right">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">01 — Occupants</p>
          <h3 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-3">
            Who thrives inside?
          </h3>
          <p class="text-[17px] leading-relaxed text-warm-600 mb-8">
            Every building creates micro-environments. The question is whether the people inside
            have what they need to do their work, regardless of role, body, or background.
          </p>
          <ul class="space-y-4" data-speakable>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              The Americans with Disabilities Act has been federal law since 1990. Yet ADA Title III lawsuits hit <strong>8,800 in 2024</strong>, a 7% increase over the prior year. Compliance with the minimum is not the same as access.<sup class="text-seam-600"><a href="#sources">1</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Standard thermostat settings of 72°F are based on a 1960s metabolic model calibrated to the average male, overestimating female metabolic rates by <strong>up to 35%</strong>. Women report thermal dissatisfaction roughly <strong>50% more often</strong> than men. The standard wasn't built for them.<sup class="text-seam-600"><a href="#sources">2, 3</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Federal law has required workplace lactation accommodation since 2010, expanded by the PUMP Act of 2022. Yet roughly <strong>half of U.S. workplaces</strong> still lack a dedicated lactation room, leaving employees to make do with conference rooms, supply closets, and converted storage space.<sup class="text-seam-600"><a href="#sources">4</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              In a study of 40,000+ occupants across 304 buildings, <strong>over 59% of open-plan workers</strong> reported dissatisfaction with sound privacy. It was the top complaint. Enclosed offices remain reserved for senior staff, while the people most affected have the least power to fix it.<sup class="text-seam-600"><a href="#sources">5</a></sup>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 3b. Operators (image right) ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="order-2 lg:order-1 reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">02 — Operators</p>
          <h3 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-3">
            Who keeps the lights on?
          </h3>
          <p class="text-[17px] leading-relaxed text-warm-600 mb-8">
            Custodians, security guards, and maintenance crews keep buildings running every day.
            They are often the least visible workers in the building, and the worst compensated.
          </p>
          <ul class="space-y-4" data-speakable>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              The median janitor in a U.S. office building earns <strong>$17.27 an hour</strong>. National average Class A office rent exceeds <strong>$39 per square foot</strong>. A single square foot of leased space costs more per year than two hours of the cleaner's labor.<sup class="text-seam-600"><a href="#sources">6, 7</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Only about <strong>half of workers in service occupations</strong> have access to employer-provided health insurance. Coverage rates are lower still among part-time and contracted building maintenance staff, the workers most likely to need it.<sup class="text-seam-600"><a href="#sources">8</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Cleaning crews work 10pm–6am, invisible to the tenants they serve. Private-sector night-shift premiums vary widely. Many fall well below the <strong>10% differential</strong> the federal government pays its own night-shift workers.<sup class="text-seam-600"><a href="#sources">9</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Security guards in U.S. commercial buildings earn a median of <strong>$18.45 an hour</strong>. They are often the first responders to a medical emergency, a fire, or a violent incident in the building. The pay does not reflect the responsibility.<sup class="text-seam-600"><a href="#sources">10</a></sup>
            </li>
          </ul>
        </div>
        <div class="order-1 lg:order-2 reveal-slide-right">
          <img
            src="/images/home/operators.png"
            alt="Illustration of building operators"
            class="w-full max-w-[520px] h-auto rounded-2xl"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 3c. Builders (image left) ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="reveal-slide-left">
          <img
            src="/images/home/builders.png"
            alt="Illustration of construction builders"
            class="w-full max-w-[520px] h-auto rounded-2xl"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="reveal-slide-right">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">03 — Builders</p>
          <h3 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-3">
            Who pours the concrete?
          </h3>
          <p class="text-[17px] leading-relaxed text-warm-600 mb-8">
            Construction is one of the most dangerous industries in the world. The people who
            physically create our buildings bear risks that rarely appear in project budgets.
          </p>
          <ul class="space-y-4" data-speakable>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Construction workers face a fatal injury rate of <strong>9.2 per 100,000</strong> — nearly three times the all-industry average of 3.3 per 100,000.<sup class="text-seam-600"><a href="#sources">11</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              An estimated <strong>1 in 5 construction workers</strong> is misclassified as an independent contractor, losing access to benefits, overtime, and workers' compensation.<sup class="text-seam-600"><a href="#sources">12</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Heat-related illness kills an average of <strong>40+ U.S. workers per year</strong> across all industries, with construction workers accounting for roughly one-third of these deaths despite comprising only 7% of the workforce. Experts consider these figures significant underestimates.<sup class="text-seam-600"><a href="#sources">13</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Women hold <strong>fewer than 5% of active construction apprenticeships</strong>. Black workers remain significantly underrepresented. The construction industry generates <strong>$1.8 trillion a year</strong>.<sup class="text-seam-600"><a href="#sources">14</a></sup>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull quote -->
  <section class="py-20 lg:py-24 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <blockquote class="reveal-fade max-w-3xl mx-auto text-center">
        <p class="font-display italic text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.2] tracking-[-0.02em] text-warm-400">
          "The further from the lobby, the less we ask about fairness."
        </p>
      </blockquote>
    </div>
  </section>

  <!-- ─── 3d. Neighbors (image right) ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="order-2 lg:order-1 reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">04 — Neighbors</p>
          <h3 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-3">
            Who lives with the consequences?
          </h3>
          <p class="text-[17px] leading-relaxed text-warm-600 mb-8">
            A building doesn't stop at its property line. Its impacts ripple outward through
            traffic, noise, shadow, displacement, and economic change.
          </p>
          <ul class="space-y-4" data-speakable>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Heavy construction equipment generates <strong>80–101 dB at 50 feet</strong>. Even at 1,500 feet, noise from pile driving can exceed the EPA's residential outdoor guideline of <strong>55 dB</strong>.<sup class="text-seam-600"><a href="#sources">15, 16</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              New market-rate apartment construction can raise rents in nearby lower-priced buildings by <strong>4–7% within five years</strong>, even as it moderates rents in higher-priced surrounding buildings.<sup class="text-seam-600"><a href="#sources">17</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              A 500,000 SF office building generates an estimated <strong>5,500 daily vehicle trips</strong> under standard ITE assumptions, though actual counts vary by transit access and location.<sup class="text-seam-600"><a href="#sources">18</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Only a handful of U.S. cities require shadow studies for new development. There is no federal solar access standard. New construction routinely shadows neighboring properties anyway.<sup class="text-seam-600"><a href="#sources">19</a></sup>
            </li>
          </ul>
        </div>
        <div class="order-1 lg:order-2 reveal-slide-right">
          <img
            src="/images/home/neighbors.png"
            alt="Illustration of building neighbors"
            class="w-full max-w-[520px] h-auto rounded-2xl"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 3e. Suppliers (styled placeholder) ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="reveal-slide-left">
          <img
            src="/images/home/suppliers.png"
            alt="Suppliers — the people who source and ship what goes into a building"
            class="w-full rounded-2xl"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="reveal-slide-right">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">05 — Suppliers</p>
          <h3 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-3">
            Who makes the materials?
          </h3>
          <p class="text-[17px] leading-relaxed text-warm-600 mb-8">
            Every carpet tile, light fixture, and steel beam has a manufacturing story. Most of
            those stories are invisible to the people who specify, install, and use them.
          </p>
          <ul class="space-y-4" data-speakable>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              The majority of commercial furniture supply chains <strong>lack independent third-party labor audits</strong>, with certification programs like BIFMA LEVEL covering only a fraction of the market.<sup class="text-seam-600"><a href="#sources">20</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              A typical office fit-out relies on globally sourced materials. Wood, metals, textiles, and building systems components are drawn from supply chains that <strong>span dozens of countries</strong>.<sup class="text-seam-600"><a href="#sources">21</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Building product transparency programs focus overwhelmingly on material health and environmental impact; <strong>labor practice disclosure across supply chains remains rare</strong> and largely voluntary.<sup class="text-seam-600"><a href="#sources">22</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Third-party certification for labor and environmental practices covers only a <strong>small fraction of the building materials market</strong>. Programs like FSC exist for wood. Most non-wood materials lack comparable frameworks.<sup class="text-seam-600"><a href="#sources">23</a></sup>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Transition line ─── -->
  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <p class="reveal-fade max-w-3xl mx-auto text-center text-[19px] lg:text-[21px] leading-relaxed text-warm-500 italic">
        At the deepest end of the supply chain, the human cost gets harder to see, and harder to dismiss.
      </p>
    </div>
  </section>

  <!-- ─── 3f. Laborers ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="order-2 lg:order-1 reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-600 mb-4">06 — Origin</p>
          <h3 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-3">
            Who extracts the raw materials?
          </h3>
          <p class="text-[17px] leading-relaxed text-warm-600 mb-8">
            At the far end of every supply chain are the extraction communities. They are the
            places where sand, copper, steel, and rare earth minerals begin their journey into buildings.
          </p>
          <ul class="space-y-4" data-speakable>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Workers exposed to respirable crystalline silica at the current OSHA permissible limit for a 45-year career face a lifetime silicosis risk of roughly <strong>1 in 20</strong>.<sup class="text-seam-600"><a href="#sources">24</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Copper mining for electrical systems <strong>displaces indigenous communities</strong> in Peru, Chile, and the DRC. A 2025 investigation found 77% of critical mineral mining incidents infringe on Indigenous Peoples' rights.<sup class="text-seam-600"><a href="#sources">25</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Steel production accounts for <strong>8% of global CO₂ emissions</strong> and concentrates health impacts in communities near blast furnaces.<sup class="text-seam-600"><a href="#sources">26</a></sup>
            </li>
            <li class="text-[16px] leading-relaxed text-warm-700 pl-5 border-l-2 border-seam-500">
              Rare earth minerals in smart building systems are <strong>linked to forced labor</strong> in documented cases, with 77 companies identified in China's Xinjiang region operating in critical minerals industries.<sup class="text-seam-600"><a href="#sources">27</a></sup>
            </li>
          </ul>
        </div>
        <div class="order-1 lg:order-2 reveal-slide-right">
          <img
            src="/images/home/laborers.png"
            alt="Laborers — the people at the very beginning of the supply chain"
            class="w-full rounded-2xl"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       4. THE SKEPTIC'S SECTION — Dark background
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-36 bg-warm-900">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-3xl">
        <div class="reveal-fade-up">
          <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white mb-4">
            Common questions, honest answers
          </h2>
          <p class="text-[17px] lg:text-[19px] leading-relaxed text-warm-400 mb-16">
            Here are the four we hear most often.
          </p>
        </div>

        <div class="reveal-stagger space-y-10" data-speakable>
          <!-- Objection 1 -->
          <div class="reveal-child pl-6 border-l-[3px] border-seam-500">
            <p class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-white mb-3">"This sounds expensive."</p>
            <p class="text-[16px] leading-relaxed text-warm-300">
              Buildings already carry social costs. They're just externalized. When a janitor
              relies on Medicaid because the building's service contract doesn't include health
              insurance, taxpayers cover the difference. When construction workers are misclassified
              as contractors, the cost of injuries shifts to public systems. SEAM doesn't add cost.
              It makes existing costs visible and gives you a framework to manage them.
            </p>
          </div>

          <!-- Objection 2 -->
          <div class="reveal-child pl-6 border-l-[3px] border-seam-500">
            <p class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-white mb-3">"Isn't this what ESG covers?"</p>
            <p class="text-[16px] leading-relaxed text-warm-300">
              ESG is a reporting framework. It tells investors what a company discloses about its
              impacts. SEAM is an operating standard. It defines specific practices, sets
              measurable thresholds, and requires third-party verification. ESG measures disclosure.
              SEAM measures practice. They're complementary, but they answer different questions.
            </p>
          </div>

          <!-- Objection 3 -->
          <div class="reveal-child pl-6 border-l-[3px] border-seam-500">
            <p class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-white mb-3">"My tenants don't care about this."</p>
            <p class="text-[16px] leading-relaxed text-warm-300">
              The market is already pricing social performance into real estate decisions. Certified
              green buildings consistently demonstrate lower vacancy and stronger tenant retention, and command
              <strong class="text-white">4–8% rent premiums</strong>.<sup class="text-seam-400"><a href="#sources" class="text-seam-400">28</a></sup> Corporate tenants increasingly require social
              impact data for their own ESG reporting. The question is no longer whether tenants
              care. It's how soon your building will be expected to prove it.
            </p>
          </div>

          <!-- Objection 4 -->
          <div class="reveal-child pl-6 border-l-[3px] border-seam-500">
            <p class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-white mb-3">"You can't measure this."</p>
            <p class="text-[16px] leading-relaxed text-warm-300">
              Hard, but not impossible. SEAM uses scored activities. Each activity is a documented
              practice with a defined threshold, verified through documentation review, worker
              surveys, and third-party audits. It's the same model that made LEED and WELL
              credible: define what "good" looks like, require evidence, and let an independent
              reviewer confirm it.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

