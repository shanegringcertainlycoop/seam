---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../lib/seo-helpers'
import Breadcrumbs from '../../components/Breadcrumbs.astro'

const approaches = [
  {
    label: 'B+I:',
    title: 'Developers',
    description:
      'For construction projects where you assume full developer responsibilities: project ownership, vision establishment, financing procurement, construction supervision, landlord duties, and tenant leasing management. This includes ground-up construction, tear-downs, major renovations, and projects on previously developed sites.',
    href: '/get-started',
  },
  {
    label: 'B+I:',
    title: 'Occupiers',
    description:
      "For construction projects where you are a tenant or property owner with no landlord duties or control over tenant leasing. This covers interior fit-outs, tenant improvements, and situations where you're improving a space but don't control the broader building operations.",
    href: '/get-started',
  },
]

const categories = [
  {
    title: 'Planning & Assessment',
    description:
      "Understand your project's social context before construction begins. Document who your project affects, establish community baselines, map your value chain, and design engagement plans that reflect the specific needs of your location.",
    iconPath: 'M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z',
  },
  {
    title: 'Governance & Team Training',
    description:
      'Embed social responsibility into project management through team education, site-specific policies, alignment with recognized frameworks, and transparent public communication about your commitments and progress.',
    iconPath: 'M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  },
  {
    title: 'Inclusive Design & Materials',
    description:
      'Create spaces that work for everyone through accessible design, ethical material sourcing, biophilic elements, and design decisions that center the voices of historically excluded communities.',
    iconPath: 'M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z',
  },
  {
    title: 'Construction & Labor Practices',
    description:
      'Set clear standards for how people are treated during construction. This covers fair wages, worker safety protocols, inclusive hiring practices, and decent working conditions for everyone on site.',
    iconPath: 'M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z',
  },
  {
    title: 'Community & Economic Benefits',
    description:
      'Generate economic opportunity that reaches beyond your immediate project team. Address displacement prevention, promote local employment, structure inclusive tenant agreements, and ensure your project creates broader community benefit.',
    iconPath: 'M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z',
  },
  {
    title: 'Health & Environmental Quality',
    description:
      'Protect and promote the physical and mental wellbeing of future occupants through indoor air quality standards, thermal comfort, natural lighting, and environmental features that support long-term health.',
    iconPath: 'M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 0 1-1.161.886l-.143.048a1.107 1.107 0 0 0-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 0 1-1.652.928l-.679-.906a1.125 1.125 0 0 0-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 0 0-8.862 12.872M12.75 3.031a9 9 0 0 1 6.69 14.036m0 0-.177-.529A2.25 2.25 0 0 0 17.128 15H16.5l-.324-.324a1.453 1.453 0 0 0-2.328.377l-.036.073a1.586 1.586 0 0 1-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438a2.253 2.253 0 0 1-1.699 2.583l-.349.087a9 9 0 0 1-5.191-1.49',
  },
]

const audienceCards = [
  {
    title: 'Developers + Owners',
    description: 'Set project requirements that embed equity into every phase of design and construction.',
    image: '/images/buildings-interiors/audience-developers.jpg',
  },
  {
    title: 'Architects',
    description: 'Use a rigorous framework to translate equity goals into spatial design decisions and material selections.',
    image: '/images/buildings-interiors/audience-architects.jpg',
  },
  {
    title: 'Interior Designers',
    description: 'Design fit-outs that serve the health, comfort, and dignity of every occupant who uses the space.',
    image: '/images/buildings-interiors/audience-interior-designers.jpg',
  },
  {
    title: 'Capital Providers',
    description: 'Align investment decisions with a structured social equity framework and support projects that can demonstrate measurable outcomes for people and communities.',
    image: '/images/buildings-interiors/audience-capital.jpg',
  },
]

const levels = [
  {
    number: '01',
    title: 'Bronze',
    description:
      'Foundational commitment. The project meets baseline requirements across all four pillars, with a primary focus on identifying and avoiding harm to the people it affects.',
    image: '/logos/cert-bronze.png',
  },
  {
    number: '02',
    title: 'Silver',
    description:
      'Meaningful progress. The project goes beyond baseline in multiple areas and demonstrates documented outcomes that measurably benefit the people and communities it serves.',
    image: '/logos/cert-silver.png',
  },
  {
    number: '03',
    title: 'Gold',
    description:
      'Active leadership. The project achieves high performance across all pillars, with innovative approaches that actively contribute to more equitable outcomes in procurement, the workplace, the community, and the supply chain.',
    image: '/logos/cert-gold.png',
  },
  {
    number: '04',
    title: 'Platinum',
    description:
      'Industry benchmark. The project sets a standard for what social equity in the built environment can look like, with transformative, documented contributions to solutions that extend beyond the project itself.',
    image: '/logos/cert-platinum.png',
  },
]
---

<SiteLayout
  title="Buildings + Interiors Rating System — SEAM"
  description="The SEAM Buildings + Interiors rating system evaluates how new construction, renovations, and interior fit-outs are designed to advance social equity. Air quality, lighting, thermal comfort, acoustics, accessibility, and biophilic design."
  path="/rating-system/buildings-interiors"
  jsonLd={breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Rating Systems', path: '/rating-system' },
    { name: 'Buildings + Interiors', path: '/rating-system/buildings-interiors' },
  ])}
>

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center bg-warm-900">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/buildings-interiors/hero-studio.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-warm-900/85 via-warm-900/60 to-seam-900/70"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>
    </div>

    <!-- B+I product logo, straddles hero/overview boundary -->
    <img
      src="/logos/rating-bi.png"
      alt="SEAM Buildings + Interiors"
      class="hidden lg:block absolute right-[5%] xl:right-[8%] bottom-0 translate-y-1/2 w-[240px] xl:w-[280px] pointer-events-none select-none z-10"
    />

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="max-w-3xl hero-enter">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'The Standard', href: '/resources/standard' },
            { label: 'Buildings + Interiors' },
          ]}
        />
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          Rating System
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Buildings +{' '}
          <em class="font-display italic font-normal text-seam-300">
            Interiors
          </em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          The rating system for new construction, renovations, and interior fit-outs. Measure social equity across every dimension of how a project is designed, built, and brought to life, from the initial design decisions to the people involved in construction and the communities affected by both.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a
            href="/get-started"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Start your project
          </a>
          <a
            href="/resources/standard"
            class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
          >
            Access the Standard
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Overview
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Design and construction that centers{' '}
          <em class="italic font-normal text-seam-300">people</em>
        </h2>
        <div class="mt-8 space-y-6 text-[17px] leading-relaxed text-warm-600">
          <p>
            Buildings + Interiors is SEAM&rsquo;s rating system for projects at the design and construction stage.
          </p>
          <p>
            It applies all four pillars of the SEAM Standard to the decisions that happen before a building opens: who you engage during planning, how you govern the project, who you hire and on what terms, what your materials are made of and where they come from, and how the finished space serves everyone it touches.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Two Approaches -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-12 lg:mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Two approaches
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Choose your application.
        </h2>
        <p class="mt-8 text-[17px] leading-relaxed text-warm-600">
          SEAM&rsquo;s Buildings + Interiors rating system has two applications based on your level of control and responsibility in the project.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 lg:grid-cols-2 gap-6">
        {approaches.map((approach) => (
          <a
            href={approach.href}
            class="reveal-child group block rounded-2xl border border-warm-100 p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <span class="text-[14px] font-medium text-seam-600 mb-3 block">
              {approach.label}
            </span>
            <h3 class="font-display text-[26px] lg:text-[28px] tracking-[-0.02em] text-warm-900 mb-6">
              {approach.title}
            </h3>
            <p class="text-[17px] leading-relaxed text-warm-600 mb-10">
              {approach.description}
            </p>
            <span class="inline-flex items-center text-[14px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
              Start project <span class="ml-1 transition-transform duration-300 group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>

      <p class="mt-12 text-center text-[17px] leading-relaxed text-warm-600 max-w-3xl mx-auto">
        Not sure which applies to your project?{' '}
        <a href="/contact" class="text-warm-900 underline underline-offset-4 decoration-warm-300 hover:decoration-warm-900 transition-colors">Contact our team</a>{' '}
        to determine the right application for your specific situation.
      </p>
    </div>
  </section>

  <!-- Activity Categories -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Activity categories
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          What gets measured{' '}
          <em class="italic font-normal text-seam-300">gets built</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          SEAM activities address different dimensions of how buildings shape the daily experience and long-term outcomes of the people inside them.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((c) => (
          <div class="reveal-child group rounded-2xl border border-warm-100 bg-white p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            <div class="text-gold-600 mb-6">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={c.iconPath} />
              </svg>
            </div>
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-4">
              {c.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600">
              {c.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
          Who it&rsquo;s for
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white">
          Built for the teams that{' '}
          <em class="italic font-normal text-seam-300">shape our spaces</em>
        </h2>
        <p class="mt-6 text-[17px] text-warm-400 max-w-2xl mx-auto leading-relaxed">
          The Buildings + Interiors track is designed for everyone who has a hand in how a new project comes to life, from the developers who set the vision to the architects and designers who execute it, and the capital providers who make it possible.
        </p>
      </div>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {audienceCards.map((a) => (
          <div class="flex flex-col rounded-2xl border border-warm-700 overflow-hidden text-left">
            <div class="p-8 lg:p-10 flex-1">
              <h3 class="font-display text-[20px] lg:text-[24px] tracking-[-0.02em] text-white mb-3">
                {a.title}
              </h3>
              <p class="text-[15px] lg:text-[16px] leading-relaxed text-warm-400">
                {a.description}
              </p>
            </div>
            {a.image && (
              <div class="mt-auto h-40 lg:h-48 w-full overflow-hidden">
                <img
                  src={a.image}
                  alt=""
                  class="h-full w-full object-cover"
                />
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certification Levels -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Certification levels
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Bronze through{' '}
          <em class="italic font-normal text-seam-600">Platinum</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Each certification level reflects demonstrated progress across all four pillars. The path to Platinum is built on consistent, documented commitment at every level of the Standard.
        </p>
      </div>

      <div class="reveal-stagger">
        {levels.map((level, i) => (
          <div
            class={`reveal-child grid grid-cols-1 lg:grid-cols-12 items-center gap-6 lg:gap-12 py-10 lg:py-12 ${
              i < levels.length - 1 ? 'border-b border-warm-200' : ''
            }`}
          >
            <div class="lg:col-span-1">
              <span class="font-display text-[clamp(1.5rem,2vw,2rem)] tracking-[-0.02em] text-seam-500">
                {level.number}
              </span>
            </div>
            <div class="lg:col-span-2">
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900">
                {level.title}
              </h3>
            </div>
            <div class="lg:col-span-3 flex justify-center lg:justify-start">
              <img
                src={level.image}
                alt={`SEAM ${level.title} certification badge`}
                class="h-28 w-28 object-contain drop-shadow-[0_4px_8px_rgba(0,0,0,0.15)]"
              />
            </div>
            <div class="lg:col-span-6">
              <p class="text-[16px] lg:text-[17px] leading-relaxed text-warm-600">
                {level.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-white max-w-3xl mx-auto">
        Ready to build something that works for{' '}
        <em class="italic font-normal text-seam-300">everyone it touches?</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-400 max-w-xl mx-auto">
        Register your project today or download the Standard to explore the Buildings + Interiors framework.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/get-started"
          class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
        >
          Register your project
        </a>
        <a
          href="/resources/standard"
          class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300"
        >
          Access the Standard
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
