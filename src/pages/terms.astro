---
import SiteLayout from '../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../lib/seo-helpers'

const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Terms of Use', path: '/terms' },
]) as unknown as Record<string, unknown>
---

<SiteLayout
  title="Terms of Use — SEAM"
  description="Terms of Use governing access to and use of the SEAM website, including disclaimers, limitations of liability, and governing law."
  path="/terms"
  jsonLd={jsonLd}
  solidNav={true}
