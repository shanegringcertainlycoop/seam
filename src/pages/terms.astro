<style is:global>
  #terms-prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
    color: var(--color-warm-900);
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
  }
  #terms-prose h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--color-warm-900);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  #terms-prose p {
    margin-bottom: 1.25rem;
  }
  #terms-prose ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    list-style-type: disc;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  #terms-prose ul li::marker {
    color: var(--color-warm-300);
  }
  #terms-prose a {
    text-decoration: underline;
    text-decoration-color: var(--color-warm-300);
    transition: text-decoration-color 0.2s;
  }
  #terms-prose a:hover {
    text-decoration-color: var(--color-warm-600);
  }
</style>
