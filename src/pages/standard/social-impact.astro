---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../lib/seo-helpers'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import ConceptBadge from '../../components/ConceptBadge.astro'

const STANDARD_URL = (import.meta.env.STANDARD_URL as string | undefined) ?? 'https://standard.seamcertification.org'

type StandardActivity = {
  activityId: string
  displayTitle: string
  title: string
  marketingTitle?: string
  url: string
  activityType: 'Driver' | 'Impact'
  concept: { slug: string; code: string; title: string }
  objective: { slug: string; code: string; title: string }
}

let pillarActivities: StandardActivity[] = []
try {
  const res = await fetch(`${STANDARD_URL}/api/activities.json`)
  if (res.ok) {
    const data = (await res.json()) as { pillars?: Array<{ slug: string; activities: StandardActivity[] }> }
    const match = data.pillars?.find((p) => p.slug === 'social-impact')
    pillarActivities = match?.activities ?? []
  }
} catch {
  // Endpoint unreachable at build time. Fall back to empty list.
}

const CONCEPT_CODES: Record<string, string> = {
  'Impact Assessment': 'IA',
}

const focusAreas = [
  {
    concept: 'Impact Assessment',
    title: 'Contextual Analysis',
    description:
      "Understand your project's social impact before you build by identifying who it affects, mapping your value chain, and establishing a social baseline.",
    href: `${STANDARD_URL}/social-impact/impact-assessment/contextual-analysis`,
  },
  {
    concept: 'Impact Assessment',
    title: 'Impacted Party Engagement',
    description:
      'Build processes to collect, analyze, and respond to feedback from the people most affected by your project throughout development.',
    href: `${STANDARD_URL}/social-impact/impact-assessment/impacted-party-engagement`,
  },
  {
    concept: 'Impact Assessment',
    title: 'Monitoring + Evaluation',
    description:
      "Track whether your project's social impact is moving in the right direction using established indicators and regular assessment cycles.",
    href: `${STANDARD_URL}/social-impact/impact-assessment/monitoring-evaluation`,
  },
]
---

<SiteLayout
  title="Social Impact — SEAM Standard Pillar"
  description="The Social Impact pillar of the SEAM Standard measures tangible outcomes for people and communities through contextual analysis, impacted party engagement, and monitoring and evaluation."
  path="/standard/social-impact"
  jsonLd={breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Standard', path: '/resources/standard' },
    { name: 'Social Impact', path: '/standard/social-impact' },
  ])}
>

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden bg-warm-900">
    <img
      src="/images/social-impact/hero-friends.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-warm-900/85 via-warm-900/60 to-seam-900/70"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="max-w-3xl hero-enter">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'The Standard', href: '/resources/standard' },
            { label: 'Social Impact' },
          ]}
        />
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          SEAM Standard Pillar
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Social{' '}
          <em class="font-display italic font-normal text-seam-300">
            Impact
          </em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          Measurable outcomes for people and communities. Social Impact in SEAM builds the evidence behind your project&rsquo;s wide-ranging effect on the people and communities it reaches.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a
            href="/get-started"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Get started
          </a>
          <a
            href="/resources/standard"
            class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
          >
            Access the Standard
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          What is Social Impact
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Outcomes that can be{' '}
          <em class="italic font-normal text-seam-300">measured and verified</em>
        </h2>
        <div class="mt-8 space-y-6 text-[17px] leading-relaxed text-warm-600">
          <p>
            Most projects make assumptions about who they affect and how.
          </p>
          <p>
            Social Impact in SEAM replaces those assumptions with a structured process: understand the social context of your project before you build, engage the people most likely to be affected, and put monitoring systems in place to track whether your efforts are actually working.
          </p>
          <p>
            The result is a project that can demonstrate its social value with real evidence, not just good intentions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Focus Areas -->
  <section class="relative py-24 lg:py-32 bg-warm-50 overflow-hidden">
    <img
      src="/images/social-impact/bridge.png"
      alt=""
      class="hidden lg:block absolute right-[-40px] top-10 w-[380px] xl:w-[460px] pointer-events-none select-none"
      loading="lazy"
      decoding="async"
    />

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Concepts and Objectives
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Three ways to{' '}
          <em class="italic font-normal text-seam-300">demonstrate impact.</em>
        </h2>
        <p class="mt-4 text-[17px] leading-relaxed text-warm-600">
          Social Impact in SEAM is built around the Impact Assessment concept, spanning 3 actionable objectives.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {focusAreas.map((area) => (
          <a
            href={area.href}
            target="_blank"
            rel="noopener"
            class="reveal-child block rounded-2xl bg-white border border-warm-100 p-10 transition-all duration-300 hover:border-seam-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] group"
          >
            <div class="flex items-center gap-2 mb-4">
              <ConceptBadge code={CONCEPT_CODES[area.concept] ?? ''} size="xs" />
              <span class="text-[12px] font-normal uppercase tracking-[0.1em] text-[#6B8F9C]">
                {area.concept}
              </span>
            </div>
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3 group-hover:text-seam-700 transition-colors">
              {area.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600">
              {area.description}
            </p>
            <span class="mt-5 inline-flex items-center text-[13px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
              View on the SEAM Standard &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Activities -->
  {pillarActivities.length > 0 && (
    <section class="py-24 lg:py-32 bg-white">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
        <div class="reveal-slide-left max-w-2xl mb-12 lg:mb-16">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
            Activities
          </p>
          <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
            Every activity in <em class="italic font-normal text-seam-600">Social Impact.</em>
          </h2>
          <p class="mt-4 text-[17px] leading-relaxed text-warm-600">
            All {pillarActivities.length} activities that contribute to Social Impact across the concepts above.
          </p>
        </div>

        <div class="reveal-stagger overflow-hidden rounded-2xl border border-warm-100 bg-white">
          <ul class="divide-y divide-warm-100">
            {pillarActivities.map((a) => (
              <li>
                <a href={a.url} target="_blank" rel="noopener" class="group flex items-baseline gap-3 px-5 py-3 hover:bg-warm-50 transition-colors"><ConceptBadge code={a.concept.code} size="xs" class="shrink-0 self-center" /><span class="font-mono text-[11px] text-warm-500 group-hover:text-seam-600 w-16 shrink-0">{a.activityId}</span><span class="flex-1 text-[15px] text-warm-800 group-hover:text-seam-700 transition-colors">{a.title}</span><span class="hidden sm:inline shrink-0 font-mono text-[11px] text-warm-500 w-14 text-right">{a.objective.code}</span><span class="shrink-0 text-[10px] uppercase tracking-wider text-warm-500 w-14 text-right">{a.activityType}</span></a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <!-- Why It Matters -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
          Why it matters
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white">
          Buildings shape lives.{' '}
          <em class="italic font-normal text-seam-300">Impact proves it.</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-400 max-w-2xl mx-auto">
          Without a structured way to measure what&rsquo;s happening, social equity commitments are just that: commitments. Social Impact gives your project the process and the proof to show that your work is making a real difference for the people it reaches.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 max-w-3xl mx-auto">
        Ready to measure the{' '}
        <em class="italic font-normal text-seam-600">impact that matters?</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-600 max-w-xl mx-auto">
        Explore the full SEAM Standard or start your project today to begin tracking real outcomes for people and communities.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/get-started"
          class="inline-flex items-center rounded-full bg-warm-900 px-8 py-4 text-[16px] font-medium text-white hover:bg-warm-800 transition-colors duration-300"
        >
          Start your project
        </a>
        <a
          href="/resources/standard"
          class="inline-flex items-center rounded-full border border-warm-300 px-8 py-4 text-[16px] font-medium text-warm-700 hover:border-warm-400 transition-colors duration-300"
        >
          Access the Standard
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
