---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../lib/seo-helpers'
import Breadcrumbs from '../../components/Breadcrumbs.astro'

const focusAreas = [
  {
    title: 'Education + Awareness',
    description:
      'Build working knowledge of social responsibility principles across your project team and communicate your commitments publicly through transparent reporting.',
  },
  {
    title: 'Voluntary Initiatives',
    description:
      'Align your project with recognized external frameworks that address social responsibility in commercial real estate.',
  },
  {
    title: 'Responsible Policies',
    description:
      'Establish site-specific governance policies that set clear expectations for how your organization and project teams operate.',
  },
  {
    title: 'Impacted Party Materiality',
    description:
      "Identify and prioritize the issues that matter most to the people your project affects, directing your efforts where they'll have the greatest relevance.",
  },
  {
    title: 'Community Development',
    description:
      'Design and execute community programs that address real, community-identified goals through direct engagement that goes beyond financial support.',
  },
  {
    title: 'Community Resilience',
    description:
      'Make financial investments that build long-term community capacity rather than creating ongoing dependency.',
  },
]
---

<SiteLayout
  title="Social Responsibility — SEAM Standard Pillar"
  description="The Social Responsibility pillar of the SEAM Standard evaluates how organizations turn equity commitments into action: education and awareness, voluntary initiatives, responsible policies, impacted party materiality, community development, and community resilience."
  path="/standard/social-responsibility"
  jsonLd={breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Standard', path: '/resources/standard' },
    { name: 'Social Responsibility', path: '/standard/social-responsibility' },
  ])}
>

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden bg-warm-900">
    <img
      src="/images/social-responsibility/hero-rocks.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover scale-x-[-1]"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-warm-900/85 via-warm-900/60 to-seam-900/70"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/20"></div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="max-w-3xl hero-enter">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'The Standard', href: '/resources/standard' },
            { label: 'Social Responsibility' },
          ]}
        />
        <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
          SEAM Standard Pillar
        </span>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Social{' '}
          <em class="font-display italic font-normal text-seam-300">
            Responsibility
          </em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          How an organization operates says as much as what it builds. Social Responsibility in SEAM focuses on governance practices, community engagement, and social investments that turn values into documented action.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a
            href="/get-started"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Get started
          </a>
          <a
            href="/resources/standard"
            class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
          >
            Access the Standard
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          What is Social Responsibility
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Building equity from the inside out
        </h2>
        <div class="mt-8 space-y-6 text-[17px] leading-relaxed text-warm-600">
          <p>
            Any organization can say they have responsible business practices.
          </p>
          <p>
            But SEAM asks how that commitment shows up in practice: in the governance structures that hold your organization accountable, in the community programs that go beyond a donation, and in the social investments that create positive impact.
          </p>
          <p>
            This pillar is about matching your organization&rsquo;s actions to its values.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Focus Areas -->
  <section class="relative py-24 lg:py-32 bg-warm-50 overflow-hidden">
    <img
      src="/images/social-responsibility/compass.png"
      alt=""
      class="hidden lg:block absolute right-[-60px] top-10 w-[340px] xl:w-[407px] pointer-events-none select-none"
    />

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Focus areas
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Six ways to take{' '}
          <em class="italic font-normal text-seam-600">responsible action</em>.
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {focusAreas.map((area, i) => (
          <div class="reveal-child rounded-2xl bg-white border border-warm-100 p-10 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            <span class="text-[14px] font-medium text-seam-500 mb-4 block">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3">
              {area.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600">
              {area.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why It Matters -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
          Why it matters
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-white">
          Process is product.{' '}
          <em class="italic font-normal text-seam-300">How you build matters.</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-400 max-w-2xl mx-auto">
          A certified building reflects the organization that built it. Social Responsibility gives you the tools to hold your organization accountable to the full picture of what responsible development requires, turning commitments into documented practice.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 max-w-3xl mx-auto">
        Ready to build{' '}
        <em class="italic font-normal text-seam-600">responsibly?</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-600 max-w-xl mx-auto">
        Explore the full SEAM Standard or start your project today to build the governance, relationships, and investments that make your equity commitments real.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/get-started"
          class="inline-flex items-center rounded-full bg-warm-900 px-8 py-4 text-[16px] font-medium text-white hover:bg-warm-800 transition-colors duration-300"
        >
          Start your project
        </a>
        <a
          href="/resources/standard"
          class="inline-flex items-center rounded-full border border-warm-300 px-8 py-4 text-[16px] font-medium text-warm-700 hover:border-warm-400 transition-colors duration-300"
        >
          Access the Standard
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
