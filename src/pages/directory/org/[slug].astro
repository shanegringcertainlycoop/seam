---
import SiteLayout from '../../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../../lib/seo-helpers'
import { memberOrgs, seamAPs } from '../../../data/directory'

const { slug } = Astro.params
const org = memberOrgs.find((o) => o.slug === slug)
if (!org) return Astro.redirect('/directory?tab=organizations', 404)

// Find APs who work at this organization
const orgAPs = seamAPs.filter((ap) => {
  const apOrg = ap.organization.toLowerCase()
  const orgName = org.name.toLowerCase()
  return apOrg === orgName || apOrg.includes(orgName) || orgName.includes(apOrg)
})

const description = `${org.name} is a ${org.tier} of SEAM, advancing social equity in the built environment.`

const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Directory', path: '/directory?tab=organizations' },
  { name: org.name, path: `/directory/org/${org.slug}` },
])
---
<SiteLayout
  title={`${org.name} — SEAM ${org.tier}`}
  description={description}
  path={`/directory/org/${org.slug}`}
  jsonLd={jsonLd}
>
  <article class="pt-28 sm:pt-30 lg:pt-32 pb-20 lg:pb-28">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      {/* Back link */}
      <a
        href="/directory?tab=organizations"
        class="inline-flex items-center gap-2 text-[14px] text-warm-600 hover:text-warm-700 transition-colors mb-10"
      >
        &larr; All Organizations
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] gap-12 lg:gap-16 items-start">
        {/* Sidebar */}
        <div class="reveal-fade-up lg:sticky lg:top-32">
          <div class="w-32 h-32 rounded-2xl bg-warm-50 overflow-hidden mb-6 flex items-center justify-center">
            {org.logo ? (
              <img
                src={org.logo}
                alt={org.name}
                class="w-full h-full object-contain p-4"
              />
            ) : (
              <span class="font-display text-[32px] text-warm-300">
                {org.name.split(' ').map((n) => n[0]).slice(0, 2).join('')}
              </span>
            )}
          </div>

          <h1 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-4">
            {org.name}
          </h1>

          <div class="space-y-3 text-[15px] text-warm-600">
            {[org.location.city, org.location.state].filter(Boolean).length > 0 && (
              <p>{[org.location.city, org.location.state].filter(Boolean).join(', ')}</p>
            )}
            <p>
              <span class={`inline-block rounded-full px-3 py-1 text-[13px] font-medium ${
                org.tier === 'Founding Sponsor' ? 'bg-gold-400/10 text-gold-600' : 'bg-seam-50 text-seam-700'
              }`}>
                {org.tier}
              </span>
            </p>
          </div>

          {org.website && (
            <div class="mt-6">
              <a
                href={org.website}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[14px] font-medium text-gold-600 hover:text-gold-700 transition-colors"
              >
                Website &rarr;
              </a>
            </div>
          )}
        </div>

        {/* Main Content */}
        <div class="reveal-fade-up">
          <section class="mb-12">
            <h2 class="font-display text-[24px] lg:text-[28px] tracking-[-0.02em] text-warm-900 mb-6">
              About
            </h2>
            <p class="text-[17px] leading-[1.8] text-warm-600">{org.description}</p>
          </section>

          <section class="mb-12">
            <h2 class="font-display text-[24px] lg:text-[28px] tracking-[-0.02em] text-warm-900 mb-6">
              Sectors
            </h2>
            <div class="flex flex-wrap gap-2">
              {org.sectors.map((s) => (
                <span class="rounded-full bg-warm-50 border border-warm-100 px-4 py-2 text-[14px] text-warm-600">
                  {s}
                </span>
              ))}
            </div>
          </section>

          {orgAPs.length > 0 && (
            <section>
              <h2 class="font-display text-[24px] lg:text-[28px] tracking-[-0.02em] text-warm-900 mb-6">
                SEAM APs at {org.name}
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {orgAPs.map((ap) => (
                  <a
                    href={`/directory/ap/${ap.slug}`}
                    class="group flex items-start gap-4 rounded-2xl border border-warm-100 p-5 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
                  >
                    <div class="w-14 h-14 rounded-full bg-warm-100 shrink-0 overflow-hidden">
                      <img
                        src={ap.photo}
                        alt={ap.name}
                        class="w-full h-full object-cover"
                        onerror="this.style.display='none'"
                      />
                    </div>
                    <div class="min-w-0">
                      <h3 class="font-display text-[18px] tracking-[-0.02em] text-warm-900 group-hover:text-gold-600 transition-colors duration-300 truncate">
                        {ap.name}
                      </h3>
                      <p class="text-[14px] text-warm-600 truncate">{ap.title}</p>
                      <span class={`inline-block mt-2 rounded-full px-3 py-1 text-[12px] font-medium ${
                        ap.credentials === 'SEAM AP+' ? 'bg-gold-400/10 text-gold-600' : 'bg-seam-50 text-seam-700'
                      }`}>
                        {ap.credentials}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </div>
    </div>
  </article>

  {/* CTA */}
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-6">
        Become a member organization
      </h2>
      <p class="text-[17px] leading-relaxed text-warm-600 max-w-2xl mx-auto mb-10">
        Join the network of organizations advancing social equity in the built environment.
      </p>
      <a
        href="/community/organization"
        class="inline-flex items-center rounded-full bg-warm-900 px-8 py-4 text-[15px] font-medium text-white hover:bg-warm-800 transition-colors"
      >
        Explore membership
        <svg
          class="ml-2 w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
          />
        </svg>
      </a>
    </div>
  </section>
</SiteLayout>
