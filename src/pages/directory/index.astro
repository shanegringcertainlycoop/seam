---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../lib/seo-helpers'
import {
  seamAPs,
  certifiedProjects,
  memberOrgs,
  certificationLevels,
  ratingSystems,
} from '../../data/directory'
import { team } from '../../data/team'

type Tab = 'professionals' | 'organizations' | 'projects'

const tabs: { key: Tab; label: string }[] = [
  { key: 'professionals', label: 'Professionals' },
  { key: 'organizations', label: 'Organizations' },
  { key: 'projects', label: 'Projects' },
]

const tabParam = new URL(Astro.request.url).searchParams.get('tab')
const activeTab: Tab =
  tabParam === 'organizations' || tabParam === 'projects' ? tabParam : 'professionals'

// Compute unique specialties from data (sorted, with 'All' first)
const specialtySet = new Set<string>()
seamAPs.forEach((ap) => ap.specialties.forEach((s) => specialtySet.add(s)))
const uniqueSpecialties = Array.from(specialtySet).sort()

// Role filters for Professionals tab
const roleFilters = ['All', 'Leadership', 'TAG', ...uniqueSpecialties]

const levelColors: Record<string, string> = {
  Bronze: 'bg-amber-100 text-amber-800',
  Silver: 'bg-gray-100 text-gray-700',
  Gold: 'bg-gold-400/10 text-gold-600',
  Platinum: 'bg-seam-50 text-seam-700',
}

const ctaConfig: Record<Tab, { heading: string; body: string; label: string; href: string }> = {
  professionals: {
    heading: 'Become a SEAM AP',
    body: 'Join the growing network of practitioners leading social equity certification in the built environment.',
    label: 'Learn about the AP Credential',
    href: '/ap-credential',
  },
  organizations: {
    heading: 'Become a member organization',
    body: 'Join the network of organizations advancing social equity in the built environment. Access courses, tools, and recognition for your team.',
    label: 'Explore membership',
    href: '/community/organization',
  },
  projects: {
    heading: 'Certify your building',
    body: 'Whether new construction or existing operations, SEAM certification measures what matters for the people in and around your building.',
    label: 'Explore certification',
    href: '/certification',
  },
}

const cta = ctaConfig[activeTab]

const searchPlaceholder =
  activeTab === 'professionals'
    ? 'Search by name, organization, or specialty...'
    : activeTab === 'organizations'
      ? 'Search by organization name or tier...'
      : 'Search by name, owner, or location...'

const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Directory', path: '/directory' },
])

// Pill style helpers for active/inactive state
const activePillClass = 'bg-seam-700 text-white active'
const inactivePillClass =
  'bg-warm-50 text-warm-600 hover:bg-warm-100 hover:text-warm-700'
---
<SiteLayout
  title="Directory"
  description="Browse SEAM Accredited Professionals, certified projects, and approved activities. The social equity ecosystem in the built environment."
  path="/directory"
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="relative min-h-[50vh] flex items-end bg-warm-900 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-warm-900 via-warm-900/95 to-warm-900"></div>
    <div class="reveal-fade-up relative mx-auto max-w-[1400px] px-6 lg:px-10 pb-16 lg:pb-20 pt-40">
      <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-400 mb-6">
        Directory
      </p>
      <h1 class="font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white mb-6 max-w-4xl">
        The SEAM ecosystem
      </h1>
      <p class="text-[17px] lg:text-[19px] leading-relaxed text-warm-400 max-w-2xl">
        Accredited professionals, certified buildings, and verified activities — the
        growing network advancing social equity in the built environment.
      </p>
    </div>
  </section>

  {/* Sticky Tab Bar — server-rendered links so each tab is a real URL */}
  <section class="sticky top-[88px] z-30 bg-white/95 backdrop-blur-md border-b border-warm-100">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="flex gap-2 overflow-x-auto py-4 scrollbar-hide">
        {tabs.map((tab) => (
          <a
            href={`/directory?tab=${tab.key}`}
            class={`shrink-0 rounded-full px-5 py-2.5 text-[14px] font-medium transition-all duration-200 ${
              activeTab === tab.key
                ? 'bg-warm-900 text-white'
                : 'bg-warm-50 text-warm-600 hover:bg-warm-100 hover:text-warm-700'
            }`}
          >
            {tab.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Search + Filters + Grid */}
  <section class="py-12 lg:py-16" data-directory-root>
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      {/* Search bar */}
      <div class="relative mb-6">
        <label for="directory-search" class="sr-only">
          Search the directory
        </label>
        <div class="absolute left-4 top-1/2 -translate-y-1/2">
          <svg
            class="w-5 h-5 text-warm-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
            />
          </svg>
        </div>
        <input
          id="directory-search"
          data-directory-search
          type="text"
          placeholder={searchPlaceholder}
          class="w-full rounded-full border border-warm-200 bg-white pl-12 pr-6 py-3.5 text-[15px] placeholder:text-warm-400 outline-none focus:border-warm-400 transition-colors"
        />
      </div>

      {/* Sub-filter pills */}
      <div class="flex flex-wrap gap-2 mb-8">
        {activeTab === 'professionals' &&
          roleFilters.map((s, i) => (
            <>
              {i === 3 && <span class="w-px h-8 bg-warm-200 self-center mx-1"></span>}
              <button
                type="button"
                data-directory-filter
                data-filter-type="specialty"
                data-filter-value={s}
                class={`shrink-0 rounded-full px-4 py-2 text-[13px] font-medium transition-all duration-200 ${
                  s === 'All' ? activePillClass : inactivePillClass
                }`}
              >
                {s}
              </button>
            </>
          ))}

        {activeTab === 'projects' && (
          <>
            {certificationLevels.map((l) => (
              <button
                type="button"
                data-directory-filter
                data-filter-type="level"
                data-filter-value={l}
                class={`shrink-0 rounded-full px-4 py-2 text-[13px] font-medium transition-all duration-200 ${
                  l === 'All' ? activePillClass : inactivePillClass
                }`}
              >
                {l === 'All' ? 'All Levels' : l}
              </button>
            ))}
            <span class="w-px h-8 bg-warm-200 self-center mx-1"></span>
            {ratingSystems.map((r) => (
              <button
                type="button"
                data-directory-filter
                data-filter-type="rating"
                data-filter-value={r}
                class={`shrink-0 rounded-full px-4 py-2 text-[13px] font-medium transition-all duration-200 ${
                  r === 'All' ? activePillClass : inactivePillClass
                }`}
              >
                {r === 'All' ? 'All Systems' : r}
              </button>
            ))}
          </>
        )}
      </div>

      {/* Results Grid — all items rendered server-side, filtered client-side */}
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        data-directory-grid
      >
        {/* ── Professionals tab: Leadership + APs unified ── */}
        {activeTab === 'professionals' && (
          <>
            {/* Leadership team members */}
            {team.map((member) => {
              const searchText = [member.name, member.role, member.bio, 'Leadership'].join(' ').toLowerCase()
              const tags = 'Leadership'
              return (
                <div
                  data-directory-item
                  data-search-text={searchText}
                  data-tags={tags}
                  class="group block rounded-2xl border border-warm-100 p-6 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
                >
                  <div class="flex items-start gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full bg-warm-100 shrink-0 overflow-hidden">
                      <img
                        src={member.image}
                        alt={member.name}
                        class="w-full h-full object-cover"
                        onerror="this.style.display='none'"
                      />
                    </div>
                    <div class="min-w-0">
                      <h3 class="font-display text-[18px] tracking-[-0.02em] text-warm-900 truncate">
                        {member.name}
                      </h3>
                      <p class="text-[14px] text-warm-600 truncate">{member.role}</p>
                    </div>
                  </div>
                  <p class="text-[14px] leading-relaxed text-warm-600 mb-4 line-clamp-3">
                    {member.bio}
                  </p>
                  <span class="inline-block rounded-full bg-gold-400/10 px-3 py-1 text-[12px] font-medium text-gold-600">
                    Leadership
                  </span>
                </div>
              )
            })}

            {/* SEAM APs */}
            {seamAPs.map((ap) => {
              const roleTags = ap.roles || []
              const allTags = [...roleTags, ...ap.specialties]
              const searchText = [
                ap.name,
                ap.organization,
                ap.location.city,
                ap.location.state,
                ...allTags,
              ]
                .join(' ')
                .toLowerCase()
              const tags = allTags.join('|')
              return (
                <a
                  href={`/directory/ap/${ap.slug}`}
                  data-directory-item
                  data-search-text={searchText}
                  data-tags={tags}
                  class="group block rounded-2xl border border-warm-100 p-6 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
                >
                  <div class="flex items-start gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full bg-warm-100 shrink-0 overflow-hidden">
                      <img
                        src={ap.photo}
                        alt={ap.name}
                        class="w-full h-full object-cover"
                        onerror="this.style.display='none'"
                      />
                    </div>
                    <div class="min-w-0">
                      <h3 class="font-display text-[18px] tracking-[-0.02em] text-warm-900 group-hover:text-gold-600 transition-colors duration-300 truncate">
                        {ap.name}
                      </h3>
                      <p class="text-[14px] text-warm-600 truncate">{ap.organization}</p>
                    </div>
                  </div>
                  <p class="text-[14px] text-warm-600 mb-4">
                    {[ap.location.city, ap.location.state].filter(Boolean).join(', ')}
                  </p>
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {roleTags.map((r) => (
                      <span class={`rounded-full px-3 py-1 text-[12px] font-medium ${
                        r === 'Leadership' ? 'bg-gold-400/10 text-gold-600' : 'bg-warm-900/10 text-warm-700'
                      }`}>
                        {r}
                      </span>
                    ))}
                    {ap.specialties.slice(0, 3).map((s) => (
                      <span class="rounded-full bg-warm-50 px-3 py-1 text-[12px] text-warm-600">
                        {s}
                      </span>
                    ))}
                  </div>
                  <span
                    class={`inline-block rounded-full px-3 py-1 text-[12px] font-medium ${
                      ap.credentials === 'SEAM AP+'
                        ? 'bg-gold-400/10 text-gold-600'
                        : 'bg-seam-50 text-seam-700'
                    }`}
                  >
                    {ap.credentials}
                  </span>
                </a>
              )
            })}
          </>
        )}

        {/* ── Organizations tab ── */}
        {activeTab === 'organizations' &&
          memberOrgs.map((org) => {
            const searchText = [org.name, org.tier, org.description, ...org.sectors, org.location.city, org.location.state].join(' ').toLowerCase()
            const tags = [org.tier, ...org.sectors].join('|')
            return (
              <div
                data-directory-item
                data-search-text={searchText}
                data-tags={tags}
                class="group block rounded-2xl border border-warm-100 p-6 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
              >
                <div class="flex items-start gap-4 mb-4">
                  <div class="w-14 h-14 rounded-xl bg-warm-50 shrink-0 overflow-hidden flex items-center justify-center">
                    {org.logo ? (
                      <img
                        src={org.logo}
                        alt={org.name}
                        class="w-full h-full object-contain p-2"
                      />
                    ) : (
                      <span class="font-display text-[16px] text-warm-400">
                        {org.name.split(' ').map((n) => n[0]).slice(0, 2).join('')}
                      </span>
                    )}
                  </div>
                  <div class="min-w-0">
                    <h3 class="font-display text-[18px] tracking-[-0.02em] text-warm-900 truncate">
                      {org.name}
                    </h3>
                    <p class="text-[14px] text-warm-600 truncate">
                      {[org.location.city, org.location.state].filter(Boolean).join(', ')}
                    </p>
                  </div>
                </div>
                <p class="text-[14px] leading-relaxed text-warm-600 mb-4 line-clamp-3">
                  {org.description}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class={`rounded-full px-3 py-1 text-[12px] font-medium ${
                    org.tier === 'Founding Sponsor' ? 'bg-gold-400/10 text-gold-600' : 'bg-seam-50 text-seam-700'
                  }`}>
                    {org.tier}
                  </span>
                  {org.sectors.slice(0, 2).map((s) => (
                    <span class="rounded-full bg-warm-50 px-3 py-1 text-[12px] text-warm-600">
                      {s}
                    </span>
                  ))}
                </div>
              </div>
            )
          })}

        {/* ── Projects tab ── */}
        {activeTab === 'projects' &&
          certifiedProjects.map((p) => {
            const searchText = [
              p.name,
              p.owner,
              p.location.city,
              p.location.state,
              p.description,
              ...p.highlights,
            ]
              .join(' ')
              .toLowerCase()
            const tags = [p.certificationLevel, p.ratingSystem].join('|')
            return (
              <a
                href={`/directory/project/${p.slug}`}
                data-directory-item
                data-search-text={searchText}
                data-tags={tags}
                class="group block rounded-2xl border border-warm-100 overflow-hidden transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
              >
                <div class="h-48 bg-warm-100 overflow-hidden">
                  <img
                    src={p.image}
                    alt={p.name}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    onerror="this.style.display='none'"
                  />
                </div>
                <div class="p-6">
                  <span
                    class={`inline-block rounded-full px-3 py-1 text-[12px] font-medium mb-3 ${
                      levelColors[p.certificationLevel] || 'bg-warm-50 text-warm-600'
                    }`}
                  >
                    {p.certificationLevel}
                  </span>
                  <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 group-hover:text-gold-600 transition-colors duration-300 mb-2">
                    {p.name}
                  </h3>
                  <p class="text-[14px] text-warm-600 mb-2">
                    {p.location.city}, {p.location.state}
                  </p>
                  <p class="text-[13px] text-warm-400">{p.ratingSystem}</p>
                </div>
              </a>
            )
          })}

      </div>

      {/* Empty State (toggled by script) */}
      <div class="text-center py-20 hidden" data-directory-empty>
        <p class="text-[17px] text-warm-600 mb-4">
          No results match your current filters.
        </p>
        <button
          type="button"
          data-directory-clear
          class="rounded-full bg-warm-900 px-6 py-3 text-[15px] font-medium text-white hover:bg-warm-800 transition-colors"
        >
          Clear all filters
        </button>
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-6">
        {cta.heading}
      </h2>
      <p class="text-[17px] leading-relaxed text-warm-600 max-w-2xl mx-auto mb-10">
        {cta.body}
      </p>
      <a
        href={cta.href}
        class="inline-flex items-center rounded-full bg-warm-900 px-8 py-4 text-[15px] font-medium text-white hover:bg-warm-800 transition-colors"
      >
        {cta.label}
        <svg
          class="ml-2 w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
          />
        </svg>
      </a>
    </div>
  </section>
</SiteLayout>

<script>
  import '../../scripts/directory-filter'
</script>
