---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../../lib/seo-helpers'

/* Activities for this Seal are sourced from the digital standard.
 * Falls back to an empty list if the endpoint is unreachable at build time. */
const STANDARD_URL = (import.meta.env.STANDARD_URL as string | undefined) ?? 'https://standard.seamcertification.org'

type StandardSealActivity = {
  activityId: string
  title: string
  marketingTitle?: string
  displayTitle?: string
  url: string
  activityType: 'Driver' | 'Impact'
  pillar: { slug: string; title: string }
  concept: { slug: string; code: string; title: string }
  objective: { slug: string; code: string; title: string }
}

let sealActivities: StandardSealActivity[] = []
try {
  const res = await fetch(`${STANDARD_URL}/api/seals.json`)
  if (res.ok) {
    const data = (await res.json()) as { seals?: Array<{ slug: string; activities: StandardSealActivity[] }> }
    const match = data.seals?.find((s) => s.slug === 'community-development')
    sealActivities = match?.activities ?? []
  }
} catch {
  // Endpoint unreachable at build time. Fall back to empty list.
}

/* Pathway steps follow Section 7 of the Community Development Seal Program
 * Guidance v1.0. Activity roles come from Section 6 of the same doc. The
 * groupings are seal-specific program design and aren't exposed by the
 * standard's data — they belong on marketing. */
const pathwaySteps: Array<{ heading: string; lead: string; activityIds: string[]; note?: string }> = [
  {
    heading: 'Build a credible foundation',
    lead: 'Document local context, affected groups, engagement approach, and baseline conditions for the reviewed initiative.',
    activityIds: ['IAa1.2', 'IAa1.5', 'IAa1.6', 'IAa1.7'],
  },
  {
    heading: 'Create transparent, reciprocal engagement',
    lead: 'Communicate relevant information about the project and likely impacts. Capture input from impacted parties under the engagement plan.',
    activityIds: ['IAa2.1', 'IAa2.2'],
  },
  {
    heading: 'Turn input into a reasoned basis for action',
    lead: 'Use the SEAM materiality Activity that matches your context to prioritize the issue that should guide the initiative.',
    activityIds: ['TGa5.1', 'TGa5.2'],
    note: 'Only one materiality Activity applies per initiative: TGa5.1 for construction-phase work (Buildings + Interiors), TGa5.2 for operating-asset work (Operations + Maintenance).',
  },
  {
    heading: 'Design for relevance and sustained value',
    lead: 'Link the selected issue to a defined initiative design grounded in impact, equity, ethics, participation, collaboration, and accountability.',
    activityIds: ['CIa1.1'],
  },
  {
    heading: 'Demonstrate completed action',
    lead: 'Deliver the volunteer event through the project or property team, in line with the reviewed initiative design.',
    activityIds: ['CIa1.2'],
  },
]

const activityRoles: Record<string, string> = {
  'IAa1.2': 'Establishes the demographic, social, economic, cultural, and historical context for the reviewed initiative.',
  'IAa1.5': 'Defines the people connected to the initiative.',
  'IAa1.6': 'Sets the engagement approach for identified impacted parties.',
  'IAa1.7': 'Establishes starting conditions for the initiative issue.',
  'IAa2.1': "Accessible communication about the project's relevant impacts.",
  'IAa2.2': 'Captures input from impacted parties under the engagement approach.',
  'TGa5.1': 'Connects a construction-phase initiative to a material issue.',
  'TGa5.2': 'Connects an operating-asset initiative to a material issue.',
  'CIa1.1': 'Connects the design to the community development objective.',
  'CIa1.2': 'Confirms the initiative completed the volunteer action.',
}

const activityById = new Map(sealActivities.map((a) => [a.activityId, a]))

const faqs = [
  {
    question: 'How is this different from full SEAM Certification?',
    answer:
      'Full Certification evaluates a whole building across all four pillars. The Community Development Seal is a limited-scope Seal for one defined community development initiative tied to a project or asset. It does not certify the full project, owner, or community-development portfolio.',
  },
  {
    question: 'Can a project earn more than one Community Development Seal?',
    answer:
      'Yes. A project may pursue more than one Community Development Seal when each initiative independently satisfies the Seal pathway and review requirements. Each Seal applies only to the initiative reviewed.',
  },
  {
    question: 'What is the "Assessment Scope"?',
    answer:
      'The Assessment Scope defines the boundary of the Seal claim. It identifies the reviewed initiative, project or asset context, applicant, SEAM phase (B+I or O+M), materiality Activity, target population, material issue, partners, review period, and any exclusions.',
  },
  {
    question: 'Does it work for both new construction and existing buildings?',
    answer:
      'Yes. The Seal applies across Buildings + Interiors (construction-phase) and Operations + Maintenance (operating-asset) contexts. The reviewed initiative uses the materiality Activity that matches its context — TGa5.1 for construction-phase, TGa5.2 for operating-asset.',
  },
  {
    question: 'What disqualifies an initiative from earning the Seal?',
    answer:
      'The Seal is not awarded when the issue was selected before engagement with impacted parties, when the initiative cannot be tied to a material issue identified through the SEAM pathway, when the volunteer event is disconnected from the reviewed initiative design, when the reviewed pathway is incomplete, or when the claim exceeds the reviewed Assessment Scope.',
  },
  {
    question: 'Does it count toward full Certification later?',
    answer:
      'Yes. Activities completed for this Seal may carry forward toward future SEAM Certification when the project, phase, reporting period, evidence, and applicable rating system remain aligned with SEAM requirements.',
  },
]

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'SEAM Seal', path: '/seals' },
    { name: 'Community Development', path: '/seals/community-development' },
  ]),
  faqSchema(faqs),
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="Community Development Seal — Reviewed Community Initiative Credential"
  description="A limited-scope SEAM recognition for a defined community development initiative reviewed against a SEAM Activity pathway grounded in impacted-party engagement and material issues."
  path="/seals/community-development"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center bg-warm-900">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/seals/community-development-hero.jpg"
        alt="Community members collaborating on a shared painting"
        class="absolute inset-0 w-full h-full object-cover opacity-60"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-warm-900/85 via-warm-900/65 to-warm-900/35"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/70 via-transparent to-warm-900/20"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-3xl">
        <div class="flex items-center gap-3 mb-8">
          <a href="/seals" class="text-[13px] font-medium text-warm-400 hover:text-warm-200 transition-colors">SEAM Seal</a>
          <span class="text-warm-500">/</span>
          <span class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-300">Community Development</span>
        </div>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.25rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Show that community work is <em class="font-display italic font-normal text-seam-300">grounded</em> — not performative
        </h1>
        <p class="hero-subtitle mt-8 max-w-2xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          A limited-scope SEAM recognition for a defined community development initiative — reviewed against a pathway grounded in impacted-party engagement, materiality, design, and completed delivery.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="/get-started" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[15px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
            Talk to an advisor
          </a>
          <a href="#pathway" class="inline-flex items-center justify-center rounded-full border border-warm-600 px-8 py-4 text-[15px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300">
            See the pathway
          </a>
        </div>
      </div>
    </div>

    <!-- Seal shield straddling the hero/white boundary -->
    <img
      src="/logos/seal-community-development.svg"
      alt="Community Development Seal"
      width="220"
      height="257"
      class="hidden lg:block absolute right-10 xl:right-20 bottom-0 translate-y-1/2 w-[220px] xl:w-[260px] h-auto drop-shadow-2xl z-10 pointer-events-none"
      decoding="async"
    />
  </section>

  <!-- ─── What this Seal recognizes ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-3xl mb-12">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">What it recognizes</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          A defined initiative, traceable from context to <em class="italic font-normal text-seam-600">completed action</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          The Community Development Seal recognizes a defined community development initiative grounded in impacted-party engagement, informed communication, materiality, initiative design, volunteer delivery, and independent review — within a defined Assessment Scope. The reviewed initiative must show a traceable pathway from community context and impacted-party input to a material issue, a designed initiative, and completed volunteer action. The Seal applies across Buildings + Interiors (construction-phase) and Operations + Maintenance (operating-asset) contexts.
        </p>
        <p class="mt-5 text-[17px] leading-relaxed text-warm-600">
          A qualifying initiative should be able to answer five public-facing questions: <strong class="font-medium text-warm-800">who may be affected</strong>, <strong class="font-medium text-warm-800">what they need and value</strong>, <strong class="font-medium text-warm-800">what issue is material</strong> enough to prioritize, <strong class="font-medium text-warm-800">what change</strong> the initiative intends to create, and <strong class="font-medium text-warm-800">what reviewed SEAM pathway</strong> supports the Seal claim.
        </p>
      </div>

      <p class="text-[14px] leading-relaxed text-warm-500 max-w-3xl">
        For the generic Seal model — what every Seal is and isn't, how the award works, and how claims are bounded — see <a href="/seals" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM Seal overview</a>.
      </p>
    </div>
  </section>

  <!-- ─── Activity pathway ─── -->
  <section id="pathway" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">The Activity pathway</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Five steps from context to <em class="italic font-normal text-seam-600">completed action</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          A defined SEAM Activity pathway moves an initiative from local context and impacted-party input through materiality, design, and a delivered volunteer event. Each step uses Activities pulled directly from the SEAM Standard.
        </p>
        <a
          href={`${STANDARD_URL}/standard?filter=seal%3Acommunity-development`}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center gap-2 rounded-full border border-warm-300 bg-white px-5 py-2.5 text-[14px] font-medium text-warm-900 hover:border-seam-400 hover:text-seam-700 transition-colors duration-200"
        >
          See all activities on the SEAM Standard
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17 17 7M9 7h8v8" />
          </svg>
        </a>
      </div>

      {sealActivities.length === 0 ? (
        <p class="text-[15px] leading-relaxed text-warm-500">
          Activity list is loading. <a href={`${STANDARD_URL}/seals/community-development`} target="_blank" rel="noopener" class="underline decoration-warm-300 hover:decoration-warm-600">Browse on the SEAM Standard &rarr;</a>
        </p>
      ) : (
        <div class="space-y-12">
          {pathwaySteps.map((step, i) => (
            <div>
              <div class="grid grid-cols-1 lg:grid-cols-[120px_1fr] gap-6 lg:gap-10 mb-6">
                <p class="font-display text-[44px] tracking-[-0.04em] text-seam-600 leading-none">
                  {String(i + 1).padStart(2, '0')}
                </p>
                <div>
                  <h3 class="font-display text-[24px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">
                    {step.heading}
                  </h3>
                  <p class="text-[15px] leading-relaxed text-warm-600 max-w-2xl">
                    {step.lead}
                  </p>
                  {step.note && (
                    <p class="mt-3 text-[13px] leading-relaxed text-warm-500 italic max-w-2xl">
                      {step.note}
                    </p>
                  )}
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:ml-[156px]">
                {step.activityIds.map((id) => {
                  const a = activityById.get(id)
                  if (!a) return null
                  return (
                    <a
                      href={a.url}
                      target="_blank"
                      rel="noopener"
                      class="block rounded-2xl bg-white border border-warm-200/60 p-6 lg:p-7 transition-all duration-300 hover:border-seam-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] group"
                    >
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[11px] font-mono font-medium text-seam-700">
                          {a.activityId}
                        </span>
                        <span class="inline-flex items-center rounded-full bg-warm-100 px-2.5 py-0.5 text-[10px] font-medium text-warm-600">
                          {a.activityType}
                        </span>
                      </div>
                      <h4 class="font-display text-[16px] tracking-[-0.02em] text-warm-900 leading-snug mb-2 group-hover:text-seam-700 transition-colors">
                        {a.displayTitle ?? a.title}
                      </h4>
                      {activityRoles[id] && (
                        <p class="text-[13px] leading-relaxed text-warm-600 mb-3">
                          {activityRoles[id]}
                        </p>
                      )}
                      <span class="inline-flex items-center text-[12px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
                        View on the SEAM Standard &rarr;
                      </span>
                    </a>
                  )
                })}
              </div>
            </div>
          ))}
        </div>
      )}

      <p class="mt-12 text-[14px] leading-relaxed text-warm-500 max-w-3xl">
        Activity-level requirements, indicators, scoring, and documentation are governed by the SEAM Standard. <a href="/resources/standard" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">Read the Standard</a>. Generic determination and public-claim limits for every Seal are on the <a href="/seals" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">Seal overview</a>.
      </p>
    </div>
  </section>

  <!-- ─── Pilot project showcase ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Pilot in action</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          The first initiative <em class="italic font-normal text-seam-600">under review</em>
        </h2>
      </div>

      <a
        href="/directory/project/t2s-cares-liberia"
        class="block group rounded-2xl overflow-hidden border border-warm-200/60 transition-all duration-300 hover:border-warm-300 hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)]"
      >
        <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr]">
          <div class="relative bg-warm-900 min-h-[280px] lg:min-h-[420px] overflow-hidden">
            <img
              src="/images/directory/project-t2s-cares-liberia.png"
              alt="T2S C.A.R.E.S. Liberia Mental Health Infrastructure Initiative"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="bg-white p-8 lg:p-12 flex flex-col">
            <div class="flex flex-wrap items-center gap-2 mb-5">
              <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[12px] font-medium text-seam-700">
                Seal pilot
              </span>
              <span class="inline-flex items-center rounded-full bg-warm-100 px-2.5 py-0.5 text-[11px] font-medium text-warm-600">
                Liberia
              </span>
            </div>
            <h3 class="font-display text-[24px] lg:text-[28px] tracking-[-0.02em] text-warm-900 leading-tight mb-4 group-hover:text-seam-700 transition-colors">
              T2S C.A.R.E.S. Liberia Mental Health Infrastructure Initiative, Phase 1
            </h3>
            <p class="text-[14px] font-medium uppercase tracking-[0.12em] text-warm-500 mb-5">
              Owner: T2S C.A.R.E.S.
            </p>
            <p class="text-[15px] leading-relaxed text-warm-600 mb-6 flex-1">
              SEAM is applying its built-environment community development framework to a mental health infrastructure initiative in Liberia — using the project as a pilot to inform the Community Development Seal. The pilot translates SEAM's Activity-based approach into practical guidance for identifying impacted parties, defining the area of influence, documenting baseline conditions, and connecting community input to volunteer action.
            </p>
            <span class="inline-flex items-center text-[14px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
              View the project profile &rarr;
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ─── Pricing ─── -->
  <section id="pricing" class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Pricing
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          A flat fee per <em class="italic font-normal text-seam-600">Assessment Scope</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          One reviewed Community Development initiative. Every activity counts toward full SEAM Certification if you choose to pursue it later.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 max-w-2xl">
        <div class="reveal-child relative rounded-2xl border border-warm-100 bg-white p-10 lg:p-12 transition-all duration-300">
          <img src="/logos/seal-community-development.svg" alt="" aria-hidden="true" class="absolute -top-10 right-6 lg:-top-12 lg:right-10 w-24 lg:w-28 h-auto drop-shadow-md" loading="lazy" decoding="async" />
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-4 pr-28 lg:pr-32">Community Development Seal</p>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-display text-[clamp(2.5rem,4vw,3.5rem)] tracking-[-0.03em] text-warm-900">$2,500</span>
          </div>
          <p class="text-[15px] text-warm-500 mb-8">per Seal · per Assessment Scope</p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Scoped to one defined initiative
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Independent review against the Seal pathway
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Activities count toward full Certification
            </li>
            <li class="flex items-start gap-3 text-[15px] leading-relaxed text-warm-600">
              <svg class="shrink-0 w-5 h-5 text-seam-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Member discount applies
            </li>
          </ul>
          <a
            href="/get-started"
            class="inline-flex items-center justify-center w-full rounded-full bg-seam-600 px-8 py-4 text-[16px] font-medium text-white hover:bg-seam-700 transition-colors duration-300"
          >
            Talk to an advisor
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Program statement ─── -->
  <section class="py-24 lg:py-32 bg-seam-900">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-300 mb-8">What this Seal stands for</p>
        <p class="font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.25] tracking-[-0.02em] text-white">
          A SEAM Community Development Seal should signify <em class="italic font-normal text-seam-300">more than participation.</em>
        </p>
        <p class="mt-8 text-[17px] lg:text-[19px] leading-relaxed text-warm-300 max-w-3xl">
          It should signify that a community development initiative was informed by context, shaped by impacted-party input, tied to a material issue, intentionally designed, delivered through volunteer action, and independently reviewed within a defined scope.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-12 lg:gap-16 items-start">
        <div>
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Frequently asked</p>
          <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900 mb-12">
            Questions about the <em class="italic font-normal text-seam-600">Community Development Seal</em>
          </h2>

          {faqs.map((faq) => (
            <details class="border-b border-warm-200 group">
              <summary class="w-full flex items-center justify-between py-5 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span class="text-[16px] lg:text-[17px] font-medium text-warm-900 pr-6 group-hover:text-seam-600 transition-colors">{faq.question}</span>
                <svg class="shrink-0 w-4 h-4 text-warm-600 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </summary>
              <div class="pb-6">
                <p class="text-[15px] leading-relaxed text-warm-600 pr-10">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="hidden lg:block lg:sticky lg:top-24">
