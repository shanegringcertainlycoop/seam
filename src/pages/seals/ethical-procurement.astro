---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { breadcrumbSchema, faqSchema } from '../../lib/seo-helpers'

/* Activities for this SEAL are sourced from the digital standard.
 * Falls back to an empty list if the endpoint is unreachable at build time. */
const STANDARD_URL = (import.meta.env.STANDARD_URL as string | undefined) ?? 'https://standard.seamcertification.org'

type StandardSealActivity = {
  activityId: string
  title: string
  url: string
  activityType: 'Driver' | 'Impact'
  pillar: { slug: string; title: string }
  concept: { slug: string; code: string; title: string }
  objective: { slug: string; code: string; title: string }
}

let sealActivities: StandardSealActivity[] = []
try {
  const res = await fetch(`${STANDARD_URL}/api/seals.json`)
  if (res.ok) {
    const data = (await res.json()) as { seals?: Array<{ slug: string; activities: StandardSealActivity[] }> }
    const match = data.seals?.find((s) => s.slug === 'ethical-procurement')
    sealActivities = match?.activities ?? []
  }
} catch {
  // Endpoint unreachable at build time. Fall back to empty list.
}

/* Pathway structure follows Sections 5 and 6 of the Ethical Procurement SEAL
 * Program Guidance v1.0. Required Activities apply to every assessed party.
 * Scope-Triggered Activities apply only when the Assessment Scope includes
 * the relevant condition. The groupings are seal-specific program design and
 * aren't exposed by the standard's data — they belong on marketing. */
const requiredPathwaySteps: Array<{ heading: string; lead: string; activityIds: string[]; note?: string }> = [
  {
    heading: 'Governance, scope, and value-chain mapping',
    lead: 'Establish project understanding and governance, and map the value chain the assessed party operates within.',
    activityIds: ['IAa1.1', 'IAa1.3'],
  },
  {
    heading: 'Risk identification and exposure analysis',
    lead: 'Identify and scope likely social and human-rights impacts, determine the social area of influence, and assemble baseline data.',
    activityIds: ['IAa1.4', 'IAa1.5', 'IAa1.7'],
  },
  {
    heading: 'Policy and procurement controls',
    lead: 'Set ethical materials procurement governance and policy, ethical sourcing of products and materials, and site-specific social responsibility policies.',
    activityIds: ['HRa1.1', 'HRa1.3', 'TGa3.1', 'TGa3.2'],
    note: 'Only one site-specific policy Activity applies per assessed party: TGa3.1 for the construction-project phase (Buildings + Interiors), TGa3.2 for the operating asset (Operations + Maintenance).',
  },
  {
    heading: "Labor conditions in the assessed organization's own operations",
    lead: 'Living wage and decent work conditions for the assessed party\'s own workforce.',
    activityIds: ['HRa2.1', 'HRa2.2'],
  },
  {
    heading: 'Corrective action and remediation',
    lead: 'Address identified impacts and remediate materials-procurement-related human-rights impacts.',
    activityIds: ['IAa2.3', 'HRa1.4'],
  },
  {
    heading: 'Grievance, reporting, and transparency',
    lead: 'Communicate externally about human-rights impacts, and operate a grievance mechanism for direct reporting of violations.',
    activityIds: ['HRa3.1', 'HRa3.2'],
  },
  {
    heading: 'Training and capability',
    lead: 'Educate and train relevant procurement employees on human-rights standards.',
    activityIds: ['HRa4.1'],
  },
  {
    heading: 'Monitoring, effectiveness, and review',
    lead: 'Implement ongoing social performance monitoring, plus periodic evaluation and review.',
    activityIds: ['IAa3.1', 'IAa3.2'],
  },
]

const scopeTriggeredActivities: Array<{ activityId: string; trigger: string }> = [
  { activityId: 'HRa1.2', trigger: 'Applies when the assessed party has Tier 1 Suppliers of goods or materials in scope.' },
  { activityId: 'HRa2.3', trigger: 'Applies when supplier living-wage expectations are in scope for Tier 1 Suppliers.' },
  { activityId: 'HRa2.4', trigger: 'Applies when supplier decent-work conditions are in scope for Tier 1 Suppliers.' },
  { activityId: 'HRa2.7', trigger: 'Applies when supplier procurement-related human-rights impacts have been identified or require review.' },
  { activityId: 'HRa2.5', trigger: 'Applies when tenant labor practices fall within the Assessment Scope.' },
  { activityId: 'HRa2.6', trigger: 'Applies when tenant decent-work conditions fall within the Assessment Scope.' },
  { activityId: 'IAa2.4', trigger: 'Applies when community members, occupants, residents, or other non-worker impacted parties need a project-level or asset-level grievance channel within the reviewed scope.' },
  { activityId: 'HRa4.2', trigger: 'Applies when the Assessment Scope includes external education, supplier capacity-building, or sector-level engagement.' },
]

const activityRoles: Record<string, string> = {
  'IAa1.1': 'Establishes project understanding and the governance framework for the reviewed scope.',
  'IAa1.3': 'Maps the proposed project value chain.',
  'IAa1.4': 'Identifies and scopes likely social and human-rights impacts.',
  'IAa1.5': 'Defines the social area of influence by identifying likely impacted parties.',
  'IAa1.7': 'Assembles baseline data for key social issues.',
  'HRa1.1': 'Ethical materials procurement governance and policy.',
  'HRa1.3': 'Ethical sourcing of products and materials.',
  'TGa3.1': 'Site-specific social responsibility policies for the construction-project phase.',
  'TGa3.2': 'Site-specific social responsibility policies for the operating asset.',
  'HRa2.1': "Living wage for the assessed organization's own operations.",
  'HRa2.2': "Decent work conditions for the assessed organization's own operations.",
  'IAa2.3': 'Develop and implement ways of addressing identified impacts.',
  'HRa1.4': 'Remediate materials-procurement-related human-rights impacts.',
  'HRa3.1': 'Communicate externally about human-rights impacts and how the project addresses them.',
  'HRa3.2': 'Operate a grievance mechanism for direct reporting of human-rights violations to the enterprise.',
  'HRa4.1': 'Education and training on human-rights standards for relevant procurement employees.',
  'IAa3.1': 'Ongoing social performance monitoring plan.',
  'IAa3.2': 'Periodic evaluation and review (audit).',
  // Scope-Triggered
  'HRa1.2': 'Supply-chain risk assessment and action plan for Tier 1 Suppliers.',
  'HRa2.3': 'Living wage expectations for Tier 1 Suppliers.',
  'HRa2.4': 'Decent work conditions for Tier 1 Suppliers.',
  'HRa2.7': 'Remediation of Supplier procurement-related human-rights impacts.',
  'HRa2.5': 'Living wage applied to tenant labor in scope.',
  'HRa2.6': 'Decent work conditions applied to tenant labor in scope.',
  'IAa2.4': 'Community grievance mechanism for non-worker impacted parties.',
  'HRa4.2': 'External capability-building — supplier education, sector-level engagement, or market leadership.',
}

const activityById = new Map(sealActivities.map((a) => [a.activityId, a]))

const audiences = [
  { label: 'Reporting entities', description: 'Organizations with modern slavery, forced-labor, or supply-chain disclosure obligations.' },
  { label: 'Vendors and suppliers', description: 'Tier 1 vendors and suppliers to commercial real estate value chains.' },
  { label: 'Property owners and managers', description: 'Building owners and operators with tenant relationships or procurement responsibilities.' },
  { label: 'Investment managers', description: 'Funds and asset managers reviewing portfolio-level due diligence.' },
]

const frameworks = [
  'Australian Modern Slavery Act 2018',
  'UK Modern Slavery Act 2015',
  'Canada Fighting Against Forced Labour and Child Labour in Supply Chains Act',
  'California Transparency in Supply Chains Act',
  'German Supply Chain Due Diligence Act',
  'French Duty of Vigilance Law',
  'Norwegian Transparency Act',
  'EU Forced Labour Regulation',
  'US Tariff Act Section 307 / UFLPA',
  'UNGPs · OECD · ILO forced-labor standards',
]

const faqs = [
  {
    question: 'How is this different from full SEAM Certification?',
    answer:
      'Full SEAM Certification evaluates a whole building across all four pillars. The Ethical Procurement SEAL is a limited-scope SEAL focused on one theme — modern slavery, forced labor, and supply-chain due diligence — and only within a defined Assessment Scope. It does not certify the full owner, portfolio, fund, or asset.',
  },
  {
    question: 'What is the "Assessment Scope"?',
    answer:
      'The Assessment Scope is the explicit boundary of the SEAL review and the public claim. It identifies the assessed party, their role, the frameworks covered, the supply-chain profile, tenant relationships, the reporting period, exclusions, and any owned or controlled entities included.',
  },
  {
    question: 'What does proportionate due diligence mean here?',
    answer:
      'Required Activities apply to every assessed party. Scope-Triggered Activities apply only when the Assessment Scope includes the relevant condition — for example, Tier 1 Suppliers in scope, tenant labor practices in scope, or U.S. import responsibilities. This adapts the same Standard-based method to the assessed party’s actual profile.',
  },
  {
    question: 'What is "Leading Practice" recognition?',
    answer:
      'Achievement is binary — you either earn the SEAL or you don’t. Above that, organizations meeting the Gold-equivalent or Platinum-equivalent thresholds across the applicable Activity subset may receive the distinction "SEAM Ethical Procurement SEAL — Leading Practice."',
  },
  {
    question: 'Does this satisfy modern slavery reporting obligations?',
    answer:
      'No. The SEAL can support evidence organization for selected frameworks, but it does not complete legal reporting, regulator filings, customs responses, or import admissibility determinations. The assessed party and its counsel remain responsible for legal interpretation and filings.',
  },
  {
    question: 'What disqualifies an assessed party from earning the SEAL?',
    answer:
      'The SEAL may not be awarded where credible evidence shows active, unremediated modern slavery, forced labor, child labor, trafficking, or refusal to provide required evidence within the Assessment Scope. Any such finding must be resolved, remediated, or documented through an approved corrective action process before the SEAL can be granted.',
  },
  {
    question: 'Does it count toward full Certification later?',
    answer:
      'Yes. Activities completed for this SEAL may carry forward toward a future SEAM Human Rights SEAL or full SEAM Certification when the assessed scope, entity, reporting period, evidence, and applicable rating system remain aligned with SEAM requirements.',
  },
]

const jsonLd = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'SEAM SEAL', path: '/seals' },
    { name: 'Ethical Procurement', path: '/seals/ethical-procurement' },
  ]),
  faqSchema(faqs),
] as unknown as Record<string, unknown>
---

<SiteLayout
  title="Ethical Procurement SEAL — Supply-Chain Human Rights Due Diligence"
  description="A limited-scope SEAM recognition for modern slavery, forced labor, and supply-chain human-rights due diligence in commercial real estate operations and procurement."
  path="/seals/ethical-procurement"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-warm-900">
    <img
      src="/images/seals/ethical-procurement-hero.jpg"
      alt="Workers on a commercial construction site"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-warm-900/85 via-warm-900/65 to-warm-900/35"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-warm-900/70 via-transparent to-warm-900/20"></div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-16 items-center">
        <div class="hero-enter max-w-3xl">
          <div class="flex items-center gap-3 mb-8">
            <a href="/seals" class="text-[13px] font-medium text-warm-400 hover:text-warm-200 transition-colors">SEAM SEAL</a>
            <span class="text-warm-500">/</span>
            <span class="text-[13px] font-medium uppercase tracking-[0.15em] text-seam-300">Ethical Procurement</span>
          </div>
          <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.25rem)] leading-[1.05] tracking-[-0.04em] text-white">
            Prove your <em class="font-display italic font-normal text-seam-300">supply chain</em> meets human-rights expectations
          </h1>
          <p class="hero-subtitle mt-8 max-w-2xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
            A limited-scope SEAM recognition for modern slavery, forced labor, and supply-chain human-rights due diligence — in commercial real estate operations and procurement.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/get-started" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[15px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300">
              Talk to an advisor
            </a>
            <a href="#pathway" class="inline-flex items-center justify-center rounded-full border border-warm-600 px-8 py-4 text-[15px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300">
              See the Activity pathway
            </a>
          </div>
        </div>
        <div class="hidden lg:flex justify-center shrink-0">
          <img src="/logos/seal-ethical-procurement.svg" alt="Ethical Procurement SEAL placeholder" width="220" height="257" class="w-[220px] h-auto drop-shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── What this SEAL recognizes ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-3xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">What it recognizes</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          A defined scope of ethical procurement, <em class="italic font-normal text-seam-600">independently reviewed</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          The Ethical Procurement SEAL recognizes documented and implemented ethical procurement practices for modern slavery, forced labor, and supply-chain human-rights due diligence — within a defined Assessment Scope. The same Standard-based method applies whether the assessed party is a reporting entity, vendor, supplier, owner, manager, or investment manager. The Assessment Scope makes the boundary of the claim transparent to buyers, regulators, investors, and impacted parties.
        </p>
      </div>

      <p class="text-[14px] leading-relaxed text-warm-500 max-w-3xl">
        For the generic SEAL model — what every SEAL is and isn't, how the award works, and how claims are bounded — see <a href="/seals" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM SEAL overview</a>.
      </p>
    </div>
  </section>

  <!-- ─── Who it's for ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Who it's for</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Built for commercial real estate <em class="italic font-normal text-seam-600">value chains</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {audiences.map((a) => (
          <div class="rounded-2xl bg-white border border-warm-200/60 p-6">
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-3">{a.label}</h3>
            <p class="text-[14px] leading-relaxed text-warm-600">{a.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Frameworks supported ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-12 lg:gap-16">
        <div>
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Framework alignment</p>
          <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
            Organize evidence for the <em class="italic font-normal text-seam-600">frameworks</em> you already report against
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
            The SEAL can support evidence organization for selected modern slavery, forced-labor, and supply-chain due-diligence frameworks identified in the Assessment Scope. It does not complete legal reporting obligations — your counsel does.
          </p>
        </div>

        <div class="rounded-2xl bg-warm-50 border border-warm-200/60 p-8">
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {frameworks.map((f) => (
              <li class="flex items-start gap-3 text-[14px] leading-snug text-warm-700">
                <span class="shrink-0 w-1.5 h-1.5 mt-2 rounded-full bg-seam-500"></span>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Activity pathway ─── -->
  <section id="pathway" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Required Activity pathway</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Eight grouped steps, <em class="italic font-normal text-seam-600">apply to every assessed party</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          These Required Activities apply to every Ethical Procurement SEAL review, regardless of profile. Activities are pulled directly from the SEAM Standard; pathway groupings follow the EP Program Guidance.
        </p>
      </div>

      {sealActivities.length === 0 ? (
        <p class="text-[15px] leading-relaxed text-warm-500">
          Activity list is loading. <a href={`${STANDARD_URL}/seals/ethical-procurement`} target="_blank" rel="noopener" class="underline decoration-warm-300 hover:decoration-warm-600">Browse on the SEAM Standard &rarr;</a>
        </p>
      ) : (
        <div class="space-y-12">
          {requiredPathwaySteps.map((step, i) => (
            <div>
              <div class="grid grid-cols-1 lg:grid-cols-[120px_1fr] gap-6 lg:gap-10 mb-6">
                <p class="font-display text-[44px] tracking-[-0.04em] text-seam-600 leading-none">
                  {String(i + 1).padStart(2, '0')}
                </p>
                <div>
                  <h3 class="font-display text-[24px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">
                    {step.heading}
                  </h3>
                  <p class="text-[15px] leading-relaxed text-warm-600 max-w-2xl">
                    {step.lead}
                  </p>
                  {step.note && (
                    <p class="mt-3 text-[13px] leading-relaxed text-warm-500 italic max-w-2xl">
                      {step.note}
                    </p>
                  )}
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:ml-[156px]">
                {step.activityIds.map((id) => {
                  const a = activityById.get(id)
                  if (!a) return null
                  return (
                    <a
                      href={a.url}
                      target="_blank"
                      rel="noopener"
                      class="block rounded-2xl bg-white border border-warm-200/60 p-6 lg:p-7 transition-all duration-300 hover:border-seam-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] group"
                    >
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        <span class="inline-flex items-center rounded-full bg-seam-50 border border-seam-200 px-3 py-1 text-[11px] font-mono font-medium text-seam-700">
                          {a.activityId}
                        </span>
                        <span class="inline-flex items-center rounded-full bg-warm-100 px-2.5 py-0.5 text-[10px] font-medium text-warm-600">
                          {a.activityType}
                        </span>
                      </div>
                      <h4 class="font-display text-[16px] tracking-[-0.02em] text-warm-900 leading-snug mb-2 group-hover:text-seam-700 transition-colors">
                        {a.title}
                      </h4>
                      {activityRoles[id] && (
                        <p class="text-[13px] leading-relaxed text-warm-600 mb-3">
                          {activityRoles[id]}
                        </p>
                      )}
                      <span class="inline-flex items-center text-[12px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
                        View on the SEAM Standard &rarr;
                      </span>
                    </a>
                  )
                })}
              </div>
            </div>
          ))}
        </div>
      )}

      <p class="mt-12 text-[14px] leading-relaxed text-warm-500 max-w-3xl">
        Activity-level requirements, indicators, scoring, and documentation are governed by the SEAM Standard. <a href="/resources/standard" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">Read the Standard</a>. Generic determination and public-claim limits for every SEAL are on the <a href="/seals" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAL overview</a>.
      </p>
    </div>
  </section>

  <!-- ─── Scope-Triggered Activities ─── -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-3xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Scope-Triggered Activities</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Proportionate due diligence, <em class="italic font-normal text-seam-600">adapted to your scope</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600">
          The Required Activities apply to every assessed party. These additional Activities apply only when your Assessment Scope includes the relevant supplier, tenant, impacted-party, or capacity-building condition.
        </p>
      </div>

      {sealActivities.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {scopeTriggeredActivities.map((st) => {
            const a = activityById.get(st.activityId)
            if (!a) return null
            return (
              <a
                href={a.url}
                target="_blank"
                rel="noopener"
                class="block rounded-2xl bg-warm-50 border border-warm-200/60 p-6 lg:p-7 transition-all duration-300 hover:border-seam-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] group"
              >
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex items-center rounded-full bg-white border border-seam-200 px-3 py-1 text-[11px] font-mono font-medium text-seam-700">
                    {a.activityId}
                  </span>
                  <span class="inline-flex items-center rounded-full bg-white border border-warm-200 px-2.5 py-0.5 text-[10px] font-medium text-warm-600">
                    Conditional
                  </span>
                </div>
                <h4 class="font-display text-[16px] tracking-[-0.02em] text-warm-900 leading-snug mb-2 group-hover:text-seam-700 transition-colors">
                  {a.title}
                </h4>
                <p class="text-[13px] leading-relaxed text-warm-600 mb-3">
                  <strong class="font-semibold text-warm-700">When it applies:</strong> {st.trigger}
                </p>
                <span class="inline-flex items-center text-[12px] font-medium text-gold-600 group-hover:text-gold-700 transition-colors">
                  View on the SEAM Standard &rarr;
                </span>
              </a>
            )
          })}
        </div>
      )}
    </div>
  </section>

  <!-- ─── Pilot project showcase ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Pilot in action</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          The first assessment <em class="italic font-normal text-seam-600">under review</em>
        </h2>
      </div>

      <a
        href="/directory/project/private-client-modern-slavery-endorsement"
        class="block group rounded-2xl overflow-hidden border border-warm-200/60 bg-white transition-all duration-300 hover:border-warm-300 hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)]"
      >
        <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr]">
          <div class="relative bg-warm-900 min-h-[280px] lg:min-h-[420px] overflow-hidden">
            <img
              src="/images/directory/project-modern-slavery-endorsement.jpg"
              alt="Private Client — Modern Slavery Assessment SEAL"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
          </div>
