---
import SiteLayout from '../layouts/SiteLayout.astro'
import BusinessCaseBanner from '../components/BusinessCaseBanner.astro'
import { breadcrumbSchema } from '../lib/seo-helpers'

/* ─── Data Arrays ─── */

const ratingSystems = [
  {
    title: 'Buildings + Interiors',
    description:
      'For new construction, major renovations, and tenant fit-outs. Evaluates social equity across design, procurement, supply chain, and community impact.',
    href: '/rating-system/buildings-interiors',
    logo: '/logos/rating-bi.png',
  },
  {
    title: 'Operations + Maintenance',
    description:
      'For ongoing building management — whether you own or occupy. Evaluates governance, community engagement, labor standards, and human rights in day-to-day operations.',
    href: '/rating-system/operations-maintenance',
    logo: '/logos/rating-om.png',
  },
]

const pillars = [
  {
    number: '01',
    title: 'Social Impact',
    href: '/standard/social-impact',
    icon: '/icons/pillar-social-impact.png',
    description:
      'Identify who your project affects, engage them meaningfully, and measure whether your efforts are actually working.',
  },
  {
    number: '02',
    title: 'Social Responsibility',
    href: '/standard/social-responsibility',
    icon: '/icons/pillar-social-responsibility.png',
    description:
      'Build equity into how your organization operates through governance practices, community engagement, and social investments that reflect your values.',
  },
  {
    number: '03',
    title: 'Social Justice',
    href: '/standard/social-justice',
    icon: '/icons/pillar-social-justice.png',
    description:
      'Advance equity and inclusion across procurement, the workplace, the community, and access to capital, while pushing the field forward.',
  },
  {
    number: '04',
    title: 'Social Accountability',
    href: '/standard/social-accountability',
    icon: '/icons/pillar-social-accountability.png',
    description:
      'Uphold human rights across your supply chain, support safe working conditions, and protect the health of the people your project touches.',
  },
]

const steps = [
  {
    title: 'Register your project',
    description: 'Submit your project details and select your certification track. Our team will confirm eligibility and assign an initial assessment scope.',
  },
  {
    title: 'Complete the assessment',
    description: 'Work with a <a href="/ap-credential" class="underline decoration-warm-300 hover:decoration-warm-600 transition-colors">SEAM AP</a> to evaluate your building across all four pillars. Document existing practices, identify gaps, and build an implementation plan.',
  },
  {
    title: 'Implement and verify',
    description: 'Execute your plan. A third-party reviewer verifies performance through documentation review and community engagement surveys.',
  },
  {
    title: 'Earn your certification',
    description: 'Receive your Bronze, Silver, Gold, or Platinum certification. O+M certification recertifies every three years to maintain the achievement and demonstrate ongoing commitment.',
  },
]

const differentiators = [
  {
    title: 'Social equity, not just sustainability',
    description: 'Environmental certifications measure how a building performs for the planet. Wellness certifications measure how it performs for physical health. SEAM complements both by measuring how it performs for people, communities, and those in the supply chain the building touches.',
  },
  {
    title: 'A holistic approach',
    description: "Each certification level reflects demonstrated progress across all four pillars. The path to Platinum is built on transformative, long-term solutions across the Standard's pillars.",
  },
  {
    title: 'Community voice in evaluation',
    description: "Certification isn't just a paperwork exercise. SEAM includes activities that incorporate direct surveys and interviews with occupants, workers, and neighbors.",
  },
  {
    title: 'Ongoing verification',
    description: 'SEAM Operation + Maintenance Certification requires recertification every three years. Buildings must demonstrate sustained commitment to social equity.',
  },
]

const levels = [
  { name: 'Bronze', tagline: 'Acting to avoid harm', description: 'The project is making measurable progress toward international social targets. Foundational activities are in place. Harm is being identified and addressed.', imp: 'Act to Avoid Harm', logo: '/logos/cert-bronze.png' },
  { name: 'Silver', tagline: 'Preventing harm', description: 'The project has moved from awareness to active prevention — with a demonstrated commitment to growing into positive social impact over time.', imp: 'Act to Avoid Harm (advanced)', logo: '/logos/cert-silver.png' },
  { name: 'Gold', tagline: 'Achieving positive impact', description: 'The project is actively improving the well-being of impacted parties. Social outcomes fall within a sustainable range — real benefit, not just reduced harm.', imp: 'Benefit Impacted Parties', logo: '/logos/cert-gold.png' },
  { name: 'Platinum', tagline: 'Contributing to solutions', description: 'The project is setting the standard for the industry — achieving lasting positive impact at scale, with benefits that extend beyond the project itself.', imp: 'Contribute to Solutions', logo: '/logos/cert-platinum.png' },
]

const levelIntensities = ['bg-seam-700/10', 'bg-seam-700/20', 'bg-seam-800/70', 'bg-seam-900/85']
const levelTextColors = ['text-seam-800', 'text-seam-800', 'text-white', 'text-white']
const levelSubColors = ['text-gold-600', 'text-gold-600', 'text-seam-200', 'text-seam-200']
const levelBodyColors = ['text-warm-600', 'text-warm-600', 'text-seam-100/80', 'text-seam-100/80']
const levelBorderColors = ['border-seam-600/20', 'border-seam-600/20', 'border-seam-400/20', 'border-seam-400/20']



const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Certification', path: '/certification' },
])
---

<SiteLayout
  title="Social Equity Certification for Buildings"
  description="SEAM is the first certification for social equity in buildings. Bronze through Platinum levels across four rating systems. Start your project today."
  path="/certification"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="/hero.png"
        alt="The Jack building in Seattle's Pioneer Square — the world's first SEAM Certified location"
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/80 via-warm-900/40 to-warm-900/10"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="hero-enter">
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300 mb-8">
            Building Certification
          </span>
          <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
            Certify that your building{' '}
            <em class="font-display italic font-normal text-seam-300">
              improves human impact
            </em>
          </h1>
          <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
            SEAM Certification is a first-of-its-kind operating system for managing human impact in real estate, from design, construction, and procurement through day-to-day operations.
          </p>
          <div class="hero-cta mt-10 flex flex-wrap gap-4">
            <a
              href="/get-started"
              class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
            >
              Start certification
            </a>
            <a
              href="/resources/standard"
              class="inline-flex items-center rounded-full border border-white/25 px-8 py-4 text-[16px] font-medium text-white hover:border-white/50 transition-colors duration-300"
            >
              Access the Standard
            </a>
          </div>
        </div>

        <!-- Featured project glass card -->
        <div class="hidden lg:flex justify-end items-center">
          <a href="/directory/project/the-jack" class="group block w-[320px] rounded-2xl bg-white/[0.07] backdrop-blur-xl border border-white/[0.12] shadow-[0_8px_32px_rgba(0,0,0,0.15)] overflow-hidden transition-all duration-300 hover:bg-white/[0.1] hover:border-white/[0.2]">
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src="/images/directory/the-jack.avif"
                alt="The Jack — world's first SEAM Certified building"
                class="w-full h-full object-cover opacity-80 group-hover:opacity-90 transition-opacity duration-300"
              />
            </div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-[15px] font-medium text-white/90">The Jack</p>
                  <p class="text-[12px] text-white/40 mt-0.5">Seattle, WA &middot; 175,000 SF</p>
                </div>
                <img
                  src="/logos/cert-bronze.png"
                  alt="SEAM Bronze Certified"
                  class="w-10 h-10 object-contain shrink-0 drop-shadow-md"
                />
              </div>
              <p class="mt-3 text-[12px] leading-relaxed text-white/35">
                First SEAM-certified building in the world. 1,000+ community voices documented.
              </p>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-[11px] font-medium text-white/25">Urban Visions &middot; O+M</span>
                <span class="text-[11px] font-medium text-white/30 group-hover:text-white/50 transition-colors">View &rarr;</span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Business Case ─── -->
  <BusinessCaseBanner
    title="Equity impacts your bottom line."
    summary="A decade of research confirms it — equitable organizations and certified buildings outperform their peers across every metric that matters."
  />

  <!-- ─── The Four Pillars ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          The framework
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Four{' '}
          <em class="italic font-normal text-seam-600">pillars of the SEAM Standard</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Much like your building, social equity is an ecosystem of interdependent efforts. With progress in each SEAM pillar, you move closer to certification.
        </p>
      </div>

      <div class="reveal-stagger">
        {pillars.map((pillar, i) => (
          <div
            class={`reveal-child relative grid grid-cols-1 lg:grid-cols-[80px_auto_1fr] gap-6 lg:gap-12 items-center py-10 lg:py-12 ${
              i < pillars.length - 1 ? 'border-b border-warm-200' : ''
            }`}
          >
            <div>
              <span class="font-display text-[clamp(1.5rem,2vw,2rem)] tracking-[-0.02em] text-seam-500">
                {pillar.number}
              </span>
            </div>
            <div class="flex items-center gap-6">
              <img
                src={pillar.icon}
                alt=""
                class="hidden lg:block h-[128px] w-auto object-contain pointer-events-none"
              />
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900">
                <a href={pillar.href} class="hover:text-seam-600 transition-colors">{pillar.title}</a>
              </h3>
            </div>
            <div>
              <p class="text-[16px] lg:text-[17px] leading-relaxed text-warm-600">
                {pillar.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── How It Works ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          The process
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          From registration to{' '}
          <em class="italic font-normal text-seam-600">certification</em>
        </h2>
      </div>

      <div class="reveal-stagger relative">
        <!-- Vertical spine — hidden on mobile -->
        <div class="hidden lg:block absolute left-[39px] top-0 bottom-0 w-px bg-warm-200"></div>

        {steps.map((step, i) => (
          <div
            class="reveal-child group relative grid grid-cols-1 lg:grid-cols-[80px_1fr] gap-6 lg:gap-12 pb-16 last:pb-0"
          >
            <!-- Node -->
            <div class="hidden lg:flex flex-col items-center">
              <div class="relative z-10 flex h-[80px] w-[80px] items-center justify-center rounded-full border-2 border-warm-200 bg-white group-hover:border-seam-500 transition-colors duration-300">
                <span class="font-display text-[28px] tracking-[-0.02em] text-seam-600">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="rounded-2xl border border-warm-100 p-8 lg:p-10 group-hover:border-warm-200 group-hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] transition-all duration-300">
              <span class="lg:hidden text-[14px] font-medium text-seam-500 mb-3 block">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 mb-3">
                {step.title}
              </h3>
              <p class="text-[16px] leading-relaxed text-warm-600 max-w-2xl">
                {step.description}
              </p>
              {i === 0 && (
                <a
                  href="/get-started"
                  class="inline-flex items-center mt-5 rounded-full bg-warm-900 px-6 py-3 text-[14px] font-medium text-white hover:bg-warm-800 transition-colors duration-300"
                >
                  Register now &rarr;
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Certification Levels ─── -->
  <section id="levels" class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">Certification levels</p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Recognition that reflects{' '}<em class="italic font-normal text-seam-600">real progress</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Four levels of SEAM Certification align to the Impact Management Project&apos;s ABCs: avoiding harm, benefiting people, and contributing to solutions.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 pt-12">
        {levels.map((level, i) => (
          <div class={`reveal-child relative rounded-2xl ${levelIntensities[i]} pt-14 pb-8 px-8 lg:pt-14 lg:pb-10 lg:px-10`}>
            <img src={level.logo} alt={`${level.name} certification`} class="absolute -top-10 right-4 w-24 h-24 object-contain drop-shadow-[0_4px_12px_rgba(0,0,0,0.15)]" />
            <h3 class={`relative font-display text-[28px] tracking-[-0.02em] ${levelTextColors[i]}`}>{level.name}</h3>
            <p class={`mt-1 text-[14px] font-medium ${levelSubColors[i]}`}>{level.tagline}</p>
            <p class={`mt-4 text-[15px] leading-relaxed ${levelBodyColors[i]}`}>{level.description}</p>
            <p class={`mt-5 text-[12px] uppercase tracking-[0.1em] ${levelSubColors[i]} border-t ${levelBorderColors[i]} pt-4`}>
              IMP: {level.imp}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── What Makes SEAM Different ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          What makes us different
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          <em class="italic font-normal text-seam-600">The only social equity standard for real estate</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 gap-6">
        {differentiators.map((d) => (
          <div class="reveal-child rounded-2xl bg-white p-5 sm:p-8 lg:p-10">
            <h3 class="font-display text-[20px] lg:text-[22px] tracking-[-0.02em] text-warm-900 mb-3">
              {d.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600">
              {d.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Rating Systems (Tracks) ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Two rating systems
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Choose the rating system that fits{' '}
          <em class="italic font-normal text-seam-600">your project</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
        {ratingSystems.map((t) => (
          <a
            href={t.href}
            class="reveal-child group rounded-2xl border border-warm-100 p-10 lg:p-12 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]"
          >
            <img src={t.logo} alt="" class="w-14 h-14 object-contain mb-6" />
            <h3 class="font-display text-[22px] lg:text-[26px] tracking-[-0.02em] text-warm-900 group-hover:text-seam-600 transition-colors mb-4">
              {t.title}
            </h3>
            <p class="text-[16px] leading-relaxed text-warm-600 mb-6">
              {t.description}
            </p>
            <span class="text-[14px] font-medium text-seam-600 group-hover:text-seam-700 transition-colors">
              Learn more &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Testimonial ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="max-w-4xl mx-auto text-center">
        <svg class="mx-auto mb-8 w-12 h-12 text-warm-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
        </svg>
        <blockquote class="font-display text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.3] tracking-[-0.02em] text-white">
          [SEAM Certification] reflects our belief that real estate carries a responsibility for strengthening neighborhoods, advancing fair business practices, and creating spaces designed to support the people who rely on them.
        </blockquote>
        <div class="mt-10">
          <p class="text-[16px] font-medium text-white">Greg Smith</p>
          <p class="text-[14px] text-warm-400 mt-1">
            CEO, Urban Visions &middot; The Jack
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pricing Calculator ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Investment
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Estimate your <em class="italic font-normal text-seam-600">certification investment</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          Use the calculator below to estimate fees based on your project type, size, and any applicable discounts. Registration locks in your fee schedule for 24 months.
        </p>
      </div>

      <!-- Calculator — two-column layout -->
      <div id="cert-calc-2" class="rounded-3xl border border-warm-200 bg-white shadow-[0_8px_30px_rgba(0,0,0,0.04)] overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <!-- Left: Controls -->
          <div class="p-8 lg:p-10 space-y-8">
            <!-- Project Type -->
            <div>
              <label class="block text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 mb-4">Rating System</label>
              <div class="flex flex-col sm:flex-row gap-3">
                <button data-type="bi" class="c2-type-btn flex-1 rounded-xl border-2 border-seam-500 bg-seam-50 px-4 py-3 text-left transition-all duration-200">
                  <span class="block text-[15px] font-medium text-warm-900">Buildings + Interiors</span>
                  <span class="block text-[12px] text-warm-500 mt-0.5">New construction &amp; renovations</span>
                </button>
                <button data-type="om" class="c2-type-btn flex-1 rounded-xl border-2 border-warm-200 bg-white px-4 py-3 text-left transition-all duration-200 hover:border-warm-300">
                  <span class="block text-[15px] font-medium text-warm-900">Operations + Maintenance</span>
                  <span class="block text-[12px] text-warm-500 mt-0.5">Existing buildings &amp; operations</span>
                </button>
              </div>
            </div>

            <!-- Project Size -->
            <div>
              <label for="c2-size-input" class="block text-[13px] font-medium uppercase tracking-[0.15em] text-warm-500 mb-4">Project Size</label>
              <div class="relative">
                <input
                  type="text"
                  id="c2-size-input"
                  value="100,000"
                  inputmode="numeric"
                  class="w-full rounded-xl border-2 border-warm-200 bg-white px-5 py-3.5 font-display text-[20px] tracking-[-0.02em] text-warm-900 focus:outline-none focus:border-seam-500 transition-colors"
                />
                <span class="absolute right-5 top-1/2 -translate-y-1/2 text-[13px] text-warm-400">sq ft</span>
              </div>
              <div class="mt-3">
                <input
                  type="range"
                  id="c2-size-slider"
                  min="0"
                  max="100"
                  value="14"
