  <script>
    function initCertCalc2() {
      const slider = document.getElementById('c2-size-slider') as HTMLInputElement
      const sizeInput = document.getElementById('c2-size-input') as HTMLInputElement
      const typeButtons = document.querySelectorAll('.c2-type-btn')
      const presetButtons = document.querySelectorAll('.c2-size-preset')
      const discountMember = document.getElementById('c2-discount-member') as HTMLSelectElement
      const discountProject = document.getElementById('c2-discount-project') as HTMLSelectElement
      const discountDeveloping = document.getElementById('c2-discount-developing') as HTMLInputElement
      const perSfRate = document.getElementById('c2-per-sf-rate')!
      const priceBronze = document.getElementById('c2-price-bronze')!
      const priceSilver = document.getElementById('c2-price-silver')!
      const priceGold = document.getElementById('c2-price-gold')!
      const pricePlatinum = document.getElementById('c2-price-platinum')!
      const priceTotal = document.getElementById('c2-price-total')!
      const priceSavings = document.getElementById('c2-price-savings')!
      const savingsAmount = document.getElementById('c2-savings-amount')!

      if (!slider || !sizeInput) return

      const REGISTRATION = 2000
      const rateTiers = [
        { min: 1, max: 99999, rate: 0.047 },
        { min: 100000, max: 249999, rate: 0.044 },
        { min: 250000, max: 499999, rate: 0.041 },
        { min: 500000, max: 749999, rate: 0.039 },
        { min: 750000, max: 999999, rate: 0.036 },
        { min: 1000000, max: 1249999, rate: 0.033 },
        { min: 1250000, max: 1499999, rate: 0.030 },
        { min: 1500000, max: 1749999, rate: 0.027 },
        { min: 1750000, max: 1999999, rate: 0.025 },
        { min: 2000000, max: 2499999, rate: 0.022 },
        { min: 2500000, max: 2999999, rate: 0.019 },
        { min: 3000000, max: 5000000, rate: 0.016 },
        { min: 5000001, max: 9999999, rate: 0.013 },
        { min: 10000000, max: 20000000, rate: 0.011 },
      ]
      const certMinimums = { bronze: 5625, silver: 6875, gold: 8125, platinum: 9375 }
      let currentSqft = 100000
      const LOG_MIN = Math.log(1000)
      const LOG_MAX = Math.log(20000000)

      function sliderToSqft(val: number): number {
        return Math.round(Math.exp(LOG_MIN + (val / 100) * (LOG_MAX - LOG_MIN)) / 1000) * 1000
      }
      function sqftToSlider(sqft: number): number {
        return Math.round(((Math.log(Math.max(1000, Math.min(20000000, sqft))) - LOG_MIN) / (LOG_MAX - LOG_MIN)) * 100)
      }
      function getRate(sqft: number): number {
        for (const tier of rateTiers) { if (sqft >= tier.min && sqft <= tier.max) return tier.rate }
        return rateTiers[rateTiers.length - 1].rate
      }
      function calcVerification(sqft: number, level: keyof typeof certMinimums): number {
        return Math.max(sqft * getRate(sqft), certMinimums[level])
      }
      function fmt(n: number): string { return '$' + Math.round(n).toLocaleString('en-US') }
      function getTotalDiscount(): number {
        let total = 0
        const mv = parseInt(discountMember.value, 10); if (!isNaN(mv)) total += mv
        const pv = parseInt(discountProject.value, 10); if (!isNaN(pv)) total += pv
        if (discountDeveloping.checked) total += 1000
        return total
      }

      function update() {
        const sqft = currentSqft
        const rate = getRate(sqft)
        const disc = getTotalDiscount()
        perSfRate.textContent = `$${rate.toFixed(3)}/sq ft`
        const levels: (keyof typeof certMinimums)[] = ['bronze', 'silver', 'gold', 'platinum']
        const els = [priceBronze, priceSilver, priceGold, pricePlatinum]
        const vals: number[] = []
        levels.forEach((l, i) => { const f = Math.max(0, Math.round(calcVerification(sqft, l) - disc)); vals.push(f); els[i].textContent = fmt(f) })
        priceTotal.textContent = `${fmt(REGISTRATION + vals[0])} – ${fmt(REGISTRATION + vals[3])}`
        if (disc > 0) { priceSavings.classList.remove('hidden'); savingsAmount.textContent = fmt(disc) }
        else { priceSavings.classList.add('hidden') }
      }

      function setSqft(val: number) {
        currentSqft = Math.max(1000, Math.min(20000000, val))
        sizeInput.value = currentSqft.toLocaleString('en-US')
        slider.value = String(sqftToSlider(currentSqft))
        update()
      }

      slider.addEventListener('input', () => { currentSqft = sliderToSqft(parseInt(slider.value, 10)); sizeInput.value = currentSqft.toLocaleString('en-US'); update() })
      sizeInput.addEventListener('input', () => { const v = parseInt(sizeInput.value.replace(/[^0-9]/g, ''), 10); if (!isNaN(v) && v > 0) { currentSqft = v; slider.value = String(sqftToSlider(v)); update() } })
      sizeInput.addEventListener('blur', () => { sizeInput.value = currentSqft.toLocaleString('en-US') })
      presetButtons.forEach((btn) => { btn.addEventListener('click', () => { setSqft(parseInt((btn as HTMLElement).dataset.sqft!, 10)) }) })
      typeButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const type = (btn as HTMLElement).dataset.type!
          typeButtons.forEach((b) => {
            if ((b as HTMLElement).dataset.type === type) { b.classList.remove('border-warm-200', 'bg-white'); b.classList.add('border-seam-500', 'bg-seam-50') }
            else { b.classList.remove('border-seam-500', 'bg-seam-50'); b.classList.add('border-warm-200', 'bg-white') }
          })
          update()
        })
      })
      discountMember.addEventListener('change', update)
      discountProject.addEventListener('change', update)
      discountDeveloping.addEventListener('change', update)
      slider.value = String(sqftToSlider(currentSqft))
      update()
    }

    document.addEventListener('astro:page-load', initCertCalc2)
    if (document.readyState !== 'loading') { initCertCalc2() }
    else { document.addEventListener('DOMContentLoaded', initCertCalc2) }
  </script>

