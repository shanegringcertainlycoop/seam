---
import SiteLayout from '../../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../../lib/seo-helpers'

const modules = [
  { module: 'Introduction to the SEAM Program', duration: '15 min', lessons: 5 },
  { module: 'Module 1: SEAM Framework + Design', duration: '45 min', lessons: 7, check: true },
  { module: 'Module 2: Concept 1. Impact Assessment', duration: '1 hr', lessons: 6, check: true },
  { module: 'Module 3: Concept 2. Transformational Governance', duration: '55 min', lessons: 7, check: true },
  { module: 'Module 4: Concept 3. Community Involvement', duration: '25 min', lessons: 3, check: true },
  { module: 'Module 5: Concept 4. Social Investment', duration: '25 min', lessons: 3, check: true },
  { module: 'Module 6: Concept 5. Social Equity + Justice', duration: '1 hr 25 min', lessons: 6, check: true },
  { module: 'Module 7: Concept 6. Social Justice Innovation', duration: '28 min', lessons: 4, check: true },
  { module: 'Module 8: Concept 7. Human Rights', duration: '1 hr 28 min', lessons: 7, check: true },
  { module: 'Module 9: Concept 8. Health + Safety', duration: '31 min', lessons: 3, check: true },
  { module: 'Practice Exam', duration: '2 hrs', lessons: 3 },
]

const whoItsFor = [
  'Sustainability professionals expanding into social equity',
  'Real estate developers and asset managers pursuing SEAM Certification',
  'DEI and ESG professionals seeking a rigorous, built-environment framework',
  'Community development practitioners entering commercial real estate',
  'Architects, engineers, and consultants adding social equity services',
]

const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Resources', path: '/resources/blog' },
  { name: 'Courses & Webinars', path: '/resources/courses' },
  { name: 'Foundations Course', path: '/resources/courses/foundations' },
]) as unknown as Record<string, unknown>
---

<SiteLayout
  title="Foundations: Social Equity in the Built Environment — SEAM Course"
  description="A self-paced course covering the SEAM Standard across 10 modules, 55 lessons, and 9 knowledge checks. Required preparation for the SEAM AP credential exam."
  path="/resources/courses/foundations"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0">
      <img
        src="/images/hero-foundations.jpg"
        alt="Foundations: Social Equity in the Built Environment course"
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/90 via-warm-900/60 to-warm-900/40"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-3xl">
        <a href="/resources/courses" class="inline-flex items-center gap-2 text-[13px] font-medium text-warm-400 hover:text-warm-200 transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
          All courses
        </a>
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300">
            Self-paced
          </span>
          <span class="inline-block rounded-full bg-gold-500/20 border border-gold-400/30 px-4 py-1.5 text-[13px] font-medium text-gold-300">
            $129
          </span>
        </div>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          Foundations: Social Equity<br />
          <em class="font-display italic font-normal text-seam-300">in the Built Environment</em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          55 lessons and 9 knowledge checks across 10 modules. Self-paced and available entirely online. Completion is required before sitting for the AP credential exam.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a
            href="/ap-credential#pricing"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Enroll now
          </a>
          <a
            href="#outline"
            class="inline-flex items-center rounded-full border border-white/30 px-8 py-4 text-[16px] font-medium text-white hover:border-white/60 hover:bg-white/[0.04] transition-colors duration-300"
          >
            View course outline
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Overview ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <div class="reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
            About this course
          </p>
          <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
            Learn the SEAM Standard{' '}
            <em class="italic font-normal text-seam-600">inside and out</em>
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
            This training is designed to provide the knowledge and tools you need to apply social equity principles to real-world projects. It covers all four pillars of the SEAM Standard — Social Impact, Social Responsibility, Social Justice, and Social Accountability — along with the certification process and how to apply SEAM activities in commercial real estate.
          </p>
          <p class="mt-4 text-[17px] leading-relaxed text-warm-600 max-w-xl">
            Whether you're preparing for the SEAM AP credential exam or deepening your understanding of social equity in the built environment, this course provides the structured foundation you need.
          </p>
        </div>

        <div class="reveal-fade-up">
          <div class="rounded-2xl bg-warm-50 p-8 lg:p-10">
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-6">
              At a glance
            </h3>
            <dl class="space-y-5">
              <div class="flex justify-between items-baseline border-b border-warm-100 pb-4">
                <dt class="text-[15px] text-warm-500">Format</dt>
                <dd class="text-[15px] font-medium text-warm-900">Self-paced, online</dd>
              </div>
              <div class="flex justify-between items-baseline border-b border-warm-100 pb-4">
                <dt class="text-[15px] text-warm-500">Modules</dt>
                <dd class="text-[15px] font-medium text-warm-900">10 modules + practice exam</dd>
              </div>
              <div class="flex justify-between items-baseline border-b border-warm-100 pb-4">
                <dt class="text-[15px] text-warm-500">Lessons</dt>
                <dd class="text-[15px] font-medium text-warm-900">55 lessons</dd>
              </div>
              <div class="flex justify-between items-baseline border-b border-warm-100 pb-4">
                <dt class="text-[15px] text-warm-500">Knowledge checks</dt>
                <dd class="text-[15px] font-medium text-warm-900">9 checks + practice exam</dd>
              </div>
              <div class="flex justify-between items-baseline border-b border-warm-100 pb-4">
                <dt class="text-[15px] text-warm-500">Estimated time</dt>
                <dd class="text-[15px] font-medium text-warm-900">30 – 40 hours</dd>
              </div>
              <div class="flex justify-between items-baseline border-b border-warm-100 pb-4">
                <dt class="text-[15px] text-warm-500">Typical completion</dt>
                <dd class="text-[15px] font-medium text-warm-900">6 – 8 weeks</dd>
              </div>
              <div class="flex justify-between items-baseline">
                <dt class="text-[15px] text-warm-500">Price</dt>
                <dd class="text-[15px] font-medium text-warm-900">$129 (included in AP Bundle at $389)</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Who It's For ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Who it's for
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Designed for{' '}
          <em class="italic font-normal text-seam-600">practitioners</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          No prior SEAM experience required. The course is built for professionals from any background — sustainability, real estate, DEI, community development, public health, or related fields.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {whoItsFor.map((item) => (
          <div class="reveal-child flex items-start gap-4 rounded-2xl bg-white p-6 lg:p-8">
            <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span class="text-[15px] leading-relaxed text-warm-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Course Outline ─── -->
  <section id="outline" class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Course outline
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          10 modules,{' '}
          <em class="italic font-normal text-seam-600">one framework</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-3">
        {modules.map((item) => (
          <div class="reveal-child rounded-xl border border-warm-100 px-6 py-5 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.04)]">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-5 h-5 text-seam-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
              </svg>
              <span class="text-[15px] font-medium text-warm-900">{item.module}</span>
            </div>
            <div class="flex items-center gap-3 pl-8">
              <span class="text-[13px] text-warm-400">{item.lessons} Lessons</span>
              {item.check && (
                <span class="text-[12px] text-seam-600 font-medium">+ Knowledge Check</span>
              )}
              <span class="text-[13px] font-medium text-warm-500">{item.duration}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-white max-w-3xl mx-auto">
        Ready to{' '}
        <em class="italic font-normal text-seam-300">get started?</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-400 max-w-xl mx-auto">
        Enroll in the Foundations course on its own for $129, or save with the AP Credential Bundle at $389 — which includes the course, exam, credential, and one year of Changemaker membership.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/ap-credential#pricing"
          class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
        >
          View pricing
        </a>
        <a
          href="/get-started"
          class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300"
        >
          Talk to an Advisor
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
