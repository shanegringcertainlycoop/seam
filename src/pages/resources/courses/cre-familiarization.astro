---
import SiteLayout from '../../../layouts/SiteLayout.astro'
import { breadcrumbSchema } from '../../../lib/seo-helpers'

const targetAudience = [
  'Professionals transitioning into real estate',
  'Social impact practitioners',
  'Community development workers',
  'Equity and inclusion specialists',
  'Impact investors',
  'Policy makers',
]

const learningOutcomes = [
  'Navigate CRE development stages',
  'Understand property types and markets',
  'Grasp financial and operational fundamentals',
  'Identify opportunities for social equity integration',
]

const benefits = [
  'Build commercial real estate fluency with no prior CRE background required',
  'Understand key CRE terms, roles, property types, and project stages',
  'Learn how development, financing, operations, and leasing decisions shape outcomes',
  'Identify where social equity can be integrated into real estate processes',
  'Prepare for SEAM AP or Foundations Training with stronger industry context',
  'Gain confidence when working with developers, owners, consultants, and project teams',
  'Translate social impact expertise into built environment applications',
  'Reduce the learning curve before pursuing advanced SEAM training',
]

const jsonLd = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Resources', path: '/resources/blog' },
  { name: 'Courses & Webinars', path: '/resources/courses' },
  { name: 'CRE Familiarization Course', path: '/resources/courses/cre-familiarization' },
]) as unknown as Record<string, unknown>
---

<SiteLayout
  title="CRE Familiarization Course — Commercial Real Estate Fundamentals"
  description="An introductory course on commercial real estate fundamentals for professionals preparing for SEAM training or social equity work in the built environment. No prior CRE experience required."
  path="/resources/courses/cre-familiarization"
  jsonLd={jsonLd}
>

  <!-- ─── Hero ─── -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-warm-900 via-warm-800 to-seam-900">
    <div class="absolute inset-0">
      <img
        src="/images/hero-cre-course.avif"
        alt="CRE Familiarization Course"
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-warm-900/90 via-warm-900/60 to-warm-900/40"></div>
    </div>

    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10 py-24 lg:py-32 w-full">
      <div class="hero-enter max-w-3xl">
        <a href="/resources/courses" class="inline-flex items-center gap-2 text-[13px] font-medium text-warm-400 hover:text-warm-200 transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
          All courses
        </a>
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-block rounded-full bg-seam-600/20 border border-seam-500/30 px-4 py-1.5 text-[13px] font-medium text-seam-300">
            Self-paced
          </span>
          <span class="inline-block rounded-full bg-gold-500/20 border border-gold-400/30 px-4 py-1.5 text-[13px] font-medium text-gold-300">
            $29
          </span>
        </div>
        <h1 class="hero-title font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05] tracking-[-0.04em] text-white">
          CRE Familiarization{' '}
          <em class="font-display italic font-normal text-seam-300">Course</em>
        </h1>
        <p class="hero-subtitle mt-8 max-w-xl text-[clamp(1.05rem,1.4vw,1.2rem)] leading-relaxed text-warm-300">
          An introductory training course designed for professionals who want to understand commercial real estate before moving into advanced SEAM training or social equity work in the built environment.
        </p>
        <div class="hero-cta mt-10 flex flex-wrap gap-4">
          <a
            href="https://community.seamcertification.org/plans/1980789?bundle_token=2a27dc29805d865e626af45be06c33e1&utm_source=manual"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
          >
            Enroll now
          </a>
          <a
            href="#outcomes"
            class="inline-flex items-center rounded-full border border-white/30 px-8 py-4 text-[16px] font-medium text-white hover:border-white/60 hover:bg-white/[0.04] transition-colors duration-300"
          >
            What you'll learn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Overview ─── -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <div class="reveal-slide-left">
          <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
            About this course
          </p>
          <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
            Build your CRE foundation{' '}
            <em class="italic font-normal text-seam-600">before going deeper</em>
          </h2>
          <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
            The course requires no prior CRE experience and gives participants a clear foundation in how commercial real estate projects are planned, financed, developed, operated, and evaluated.
          </p>
          <p class="mt-4 text-[17px] leading-relaxed text-warm-600 max-w-xl">
            Designed as an entry point for professionals committed to transforming real estate through equitable development practices, this course demystifies commercial real estate processes, builds technical literacy, and provides context for social equity interventions.
          </p>
        </div>

        <div class="reveal-fade-up">
          <div class="rounded-2xl bg-warm-50 p-8 lg:p-10">
            <h3 class="font-display text-[20px] tracking-[-0.02em] text-warm-900 mb-6">
              Course purpose
            </h3>
            <p class="text-[15px] leading-relaxed text-warm-600 mb-6">
              Provide foundational knowledge of commercial real estate development, enabling participants to:
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-[15px] leading-relaxed text-warm-700">Understand CRE project lifecycles</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-[15px] leading-relaxed text-warm-700">Recognize industry terminology</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-[15px] leading-relaxed text-warm-700">Comprehend technical and operational aspects</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-[15px] leading-relaxed text-warm-700">Prepare for advanced social equity integration</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Who It's For ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Who it's for
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Built for{' '}
          <em class="italic font-normal text-seam-600">changemakers</em>
        </h2>
        <p class="mt-6 text-[17px] leading-relaxed text-warm-600 max-w-xl">
          No prior CRE experience required. This course is designed for professionals from any background who want to understand how commercial real estate works — and where social equity fits in.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {targetAudience.map((item) => (
          <div class="reveal-child flex items-start gap-4 rounded-2xl bg-white p-6 lg:p-8">
            <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span class="text-[15px] leading-relaxed text-warm-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Key Learning Outcomes ─── -->
  <section id="outcomes" class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Key learning outcomes
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          What you'll{' '}
          <em class="italic font-normal text-seam-600">walk away with</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-6">
        {learningOutcomes.map((item) => (
          <div class="reveal-child rounded-xl border border-warm-100 px-6 py-5 transition-all duration-300 hover:border-warm-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.04)]">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-seam-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
              </svg>
              <span class="text-[15px] font-medium text-warm-900">{item}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Benefits ─── -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
      <div class="reveal-slide-left max-w-2xl mb-16 lg:mb-20">
        <p class="text-[13px] font-medium uppercase tracking-[0.15em] text-gold-600 mb-6">
          Benefits
        </p>
        <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[1.1] tracking-[-0.03em] text-warm-900">
          Why take{' '}
          <em class="italic font-normal text-seam-600">this course</em>
        </h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-6">
        {benefits.map((item) => (
          <div class="reveal-child flex items-start gap-4 rounded-2xl bg-white p-6 lg:p-8">
            <svg class="w-5 h-5 text-seam-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span class="text-[15px] leading-relaxed text-warm-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="py-24 lg:py-32 bg-warm-900">
    <div class="reveal-scale mx-auto max-w-[1400px] px-6 lg:px-10 text-center">
      <h2 class="font-display text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] tracking-[-0.03em] text-white max-w-3xl mx-auto">
        Ready to{' '}
        <em class="italic font-normal text-seam-300">get started?</em>
      </h2>
      <p class="mt-6 text-[17px] text-warm-400 max-w-xl mx-auto">
        Enroll in the CRE Familiarization Course and build the commercial real estate foundation you need before advancing into SEAM training.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="https://community.seamcertification.org/plans/1980789?bundle_token=2a27dc29805d865e626af45be06c33e1&utm_source=manual"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full bg-white px-8 py-4 text-[16px] font-medium text-warm-900 hover:bg-warm-100 transition-colors duration-300"
        >
          Enroll now
        </a>
        <a
          href="/resources/courses"
          class="inline-flex items-center rounded-full border border-warm-600 px-8 py-4 text-[16px] font-medium text-warm-300 hover:border-warm-400 hover:text-white transition-colors duration-300"
        >
          View all courses
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
