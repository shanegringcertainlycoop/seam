        </p>
      </div>

      <div class="reveal-fade-up rounded-2xl border border-warm-100 overflow-hidden">
        <div class="hidden lg:grid grid-cols-12 gap-4 px-8 py-5 bg-warm-50 border-b border-warm-100 text-[12px] font-medium uppercase tracking-[0.1em] text-warm-500">
