            <div class="lg:col-span-6">
              <p class="lg:hidden text-[11px] uppercase tracking-[0.1em] text-warm-400 mb-1">SEAM pillars</p>
              <div class="flex flex-wrap gap-2">
                {row.pillars.map((pillar) => (
                  <span class="inline-block rounded-full bg-warm-50 border border-warm-100 px-3 py-1 text-[13px] text-warm-700">
                    {pillar}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-8 text-[14px] leading-relaxed text-warm-500 max-w-3xl border-l-2 border-warm-200 pl-5">
        SDG mappings follow SEAM Standard v1.1 and the UN Guiding Principles on Business and Human Rights. These mappings can be referenced directly in ESG reporting and investor disclosures.
      </p>
    </div>
  </section>

  <!-- ─── CTA ─── -->
