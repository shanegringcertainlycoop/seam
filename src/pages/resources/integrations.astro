          <div class="col-span-4">Goal</div>
          <div class="col-span-6">SEAM pillars</div>
        </div>
        {sdgRows.map((row, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-12 gap-4 px-6 lg:px-8 py-5 lg:py-6 ${i !== 0 ? 'border-t border-warm-100' : ''}`}>
            <div class="lg:col-span-2">
              <p class="lg:hidden text-[11px] uppercase tracking-[0.1em] text-warm-400 mb-1">SDG</p>
              <p class="font-display text-[18px] tracking-[-0.02em] text-warm-900">{row.sdg}</p>
