---
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import ScrollProgress from '../components/ScrollProgress.astro'
import BundleOfferPopup from '../components/BundleOfferPopup.astro'
import '../styles/global.css'
import {
  SITE_URL,
  SITE_NAME,
  DEFAULT_IMAGE,
  DEFAULT_DESCRIPTION,
} from '../lib/seo-helpers'

interface Props {
  title?: string
  description?: string
  path?: string
  image?: string
  type?: 'website' | 'article'
  article?: {
    author: string
    publishedTime: string
    section: string
  }
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  citationDate?: string
  solidNav?: boolean
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  path = '',
  image = DEFAULT_IMAGE,
  type = 'website',
  article,
  jsonLd,
  citationDate,
  solidNav = false,
} = Astro.props

const citationAuthor = article?.author || 'SEAM, Inc.'
const resolvedCitationDate = citationDate || article?.publishedTime || '2026'

const fullTitle = title
  ? `${title} | ${SITE_NAME}`
  : 'SEAM — Social Equity Certification for the Built Environment'
const url = `${SITE_URL}${path}`
---
<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager (deferred until after LCP) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      function loadGTM() {
        if (window.__gtmLoaded) return;
        window.__gtmLoaded = true;
        var f = document.getElementsByTagName('script')[0];
        var j = document.createElement('script');
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-PFFKXQPW';
        f.parentNode.insertBefore(j, f);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGTM, { timeout: 4000 });
      } else {
        setTimeout(loadGTM, 3500);
      }
      ['pointerdown', 'keydown', 'touchstart', 'scroll'].forEach(function (ev) {
        window.addEventListener(ev, loadGTM, { once: true, passive: true });
      });
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Preload hero image (LCP element) on homepage only */}
    {path === '/' && (
      <>
        <link rel="preload" as="image" type="image/webp" href="/hero-mobile.webp" media="(max-width: 767px)" />
        <link rel="preload" as="image" type="image/webp" href="/hero.webp" media="(min-width: 768px)" />
      </>
    )}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Static meta -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="SEAM, Inc." />

    <!-- GEO: Generative Engine Optimization -->
    <meta name="citation_title" content={fullTitle} />
    <meta name="citation_author" content={citationAuthor} />
    <meta name="citation_date" content={resolvedCitationDate} />
    <meta name="speakable" content="true" />
    <meta name="geo.region" content="US" />
    <meta name="geo.placename" content="United States" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="SEAM — Social Equity Certification for the Built Environment" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content="SEAM — Social Equity Certification for the Built Environment" />

    <!-- Article-specific -->
    {article && <meta property="article:author" content={article.author} />}
    {article && <meta property="article:published_time" content={article.publishedTime} />}
    {article && <meta property="article:section" content={article.section} />}

    <!-- Fonts (non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SEAM",
      "legalName": "SEAM, Inc.",
      "url": SITE_URL,
      "description": "SEAM is the first certification system built to measure social equity in the built environment. The SEAM Standard evaluates buildings across four pillars: Social Impact, Social Responsibility, Social Justice, and Social Accountability.",
      "foundingDate": "2024",
      "sameAs": [
        "https://www.linkedin.com/company/seaminc"
      ],
      "knowsAbout": [
        "Social equity certification", "Built environment", "ESG real estate",
        "GRESB alignment", "Social sustainability", "DEI in real estate",
        "Building certification systems", "Community development", "Equitable housing"
      ],
      "offers": [
        { "@type": "Service", "name": "SEAM Certification", "description": "Full building certification from Bronze through Platinum across three tracks." },
        { "@type": "Service", "name": "SEAM Marks", "description": "Activity-level verification for organizations to validate individual social equity practices without pursuing full certification." },
        { "@type": "Service", "name": "SEAM SEALs", "description": "Thematic recognition awarded for completing a curated set of 11–25 related activities — between Marks and full Certification." },
        { "@type": "Service", "name": "SEAM AP Credential", "description": "Professional accreditation for practitioners who lead SEAM certification engagements." }
      ]
    })} />

    <!-- WebSite Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "SEAM",
      "url": SITE_URL,
      "description": "SEAM is the first certification system built to measure social equity in the built environment.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${SITE_URL}/resources/blog?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".hero-subtitle", "[data-speakable]"]
      }
    })} />

    <!-- Page-specific JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PFFKXQPW" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div class="min-h-screen bg-white font-sans text-warm-700 antialiased" data-solid-nav={solidNav ? 'true' : undefined}>
      <a href="#main-content" class="skip-to-content">Skip to main content</a>
      <!-- ─── Sitewide Promo Banner ─── -->
      <div id="promo-banner" class="fixed top-0 left-0 right-0 z-[60] bg-seam-600 text-white text-center py-3 px-6 min-h-[68px] md:min-h-[44px]">
        <p class="text-[14px] font-medium">
          AP Credential Bundle: <span class="line-through opacity-75">$519</span> <strong>$389</strong> — code <strong>SITELAUNCH25</strong>.
          <span class="inline-flex items-center gap-1 mx-1 rounded-full bg-white/20 px-2.5 py-0.5 text-[12px] font-semibold">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            Ends May 31
          </span>
          <a href="https://community.seamcertification.org/plans/1539142?bundle_token=a4239c7d9757838e8b3d7153035846d4&utm_source=manual" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 ml-1 hover:opacity-80 transition-opacity">Get started &rarr;</a>
        </p>
      </div>
      <ScrollProgress />
      <Navbar />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Global scripts -->
    <script src="../scripts/reveal.ts"></script>
    <script src="../scripts/count-up.ts"></script>
    <script>
      function adjustNavForBanner() {
        const banner = document.getElementById('promo-banner')
        const nav = document.getElementById('main-nav')
        if (banner && nav) {
          const h = banner.offsetHeight
          nav.style.top = h + 'px'
          document.body.style.paddingTop = h + 'px'
        }
      }
      document.addEventListener('astro:page-load', adjustNavForBanner)
      if (document.readyState !== 'loading') adjustNavForBanner()
      else document.addEventListener('DOMContentLoaded', adjustNavForBanner)
      window.addEventListener('resize', adjustNavForBanner)
    </script>
    <BundleOfferPopup />
  </body>
</html>
